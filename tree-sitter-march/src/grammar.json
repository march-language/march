{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "march",
  "word": "identifier",
  "rules": {
    "source_file": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "module_def"
        },
        {
          "type": "REPEAT1",
          "content": {
            "type": "SYMBOL",
            "name": "_declaration"
          }
        }
      ]
    },
    "module_def": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "mod"
        },
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "type_identifier"
          }
        },
        {
          "type": "STRING",
          "value": "do"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "_declaration"
          }
        },
        {
          "type": "STRING",
          "value": "end"
        }
      ]
    },
    "_declaration": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "function_def"
        },
        {
          "type": "SYMBOL",
          "name": "let_declaration"
        },
        {
          "type": "SYMBOL",
          "name": "type_def"
        }
      ]
    },
    "function_def": {
      "type": "SEQ",
      "members": [
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "STRING",
              "value": "pub"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "STRING",
          "value": "fn"
        },
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "identifier"
          }
        },
        {
          "type": "STRING",
          "value": "("
        },
        {
          "type": "STRING",
          "value": ")"
        },
        {
          "type": "STRING",
          "value": "do"
        },
        {
          "type": "STRING",
          "value": "end"
        }
      ]
    },
    "let_declaration": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "let"
        },
        {
          "type": "SYMBOL",
          "name": "identifier"
        },
        {
          "type": "STRING",
          "value": "="
        },
        {
          "type": "SYMBOL",
          "name": "_expr"
        }
      ]
    },
    "type_def": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "type"
        },
        {
          "type": "SYMBOL",
          "name": "type_identifier"
        },
        {
          "type": "STRING",
          "value": "="
        },
        {
          "type": "SYMBOL",
          "name": "type_identifier"
        }
      ]
    },
    "_expr": {
      "type": "SYMBOL",
      "name": "integer"
    },
    "comment": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "--"
          },
          {
            "type": "PATTERN",
            "value": ".*"
          }
        ]
      }
    },
    "integer": {
      "type": "PATTERN",
      "value": "[0-9]+"
    },
    "identifier": {
      "type": "PATTERN",
      "value": "[a-z_][a-zA-Z0-9_']*"
    },
    "type_identifier": {
      "type": "PATTERN",
      "value": "[A-Z][a-zA-Z0-9_']*"
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "\\s"
    },
    {
      "type": "SYMBOL",
      "name": "comment"
    },
    {
      "type": "SYMBOL",
      "name": "block_comment"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [
    {
      "type": "SYMBOL",
      "name": "block_comment"
    }
  ],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}