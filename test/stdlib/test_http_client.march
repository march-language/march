-- test/stdlib/test_http_client.march
-- Tests for the HttpClient stdlib module.
-- Covers client construction, step registration, pipeline config,
-- and built-in step helpers (no actual network calls).
-- Run with: dune exec march -- test test/stdlib/test_http_client.march

mod TestHttpClient do

-- Local mirror of HttpClient.ErrorRecovery (private type).
ptype ErrorRecovery = Recover(a) | Fail(b)

pfn make_bare_req() do
  Request(Get, SchemeHttp, "example.com", None, "/", None, Nil, "")
end

describe "HttpClient client construction" do
  test "new_client has no steps" do
    let client = HttpClient.new_client()
    assert (is_nil(HttpClient.list_steps(client)))
  end
end

describe "HttpClient step registration" do
  test "add_request_step registers with prefix" do
    let client = HttpClient.new_client()
    let client2 = HttpClient.add_request_step(client, "my-step", fn req -> Ok(req))
    let steps = HttpClient.list_steps(client2)
    assert (not (is_nil(steps)))
    assert (head(steps) == "request:my-step")
  end

  test "add_response_step registers with prefix" do
    let client = HttpClient.new_client()
    let client2 = HttpClient.add_response_step(client, "log-resp", fn (req, resp) -> Ok((req, resp)))
    let steps = HttpClient.list_steps(client2)
    assert (not (is_nil(steps)))
    assert (head(steps) == "response:log-resp")
  end

  test "add_error_step registers with prefix" do
    let client = HttpClient.new_client()
    let client2 = HttpClient.add_error_step(client, "on-error", fn (req, err) -> Fail(err))
    let steps = HttpClient.list_steps(client2)
    assert (not (is_nil(steps)))
    assert (head(steps) == "error:on-error")
  end

  test "multiple request steps are ordered" do
    let client = HttpClient.new_client()
      |> HttpClient.add_request_step("first",  fn req -> Ok(req))
      |> HttpClient.add_request_step("second", fn req -> Ok(req))
    let steps = HttpClient.list_steps(client)
    assert (List.length(steps) == 2)
    assert (head(steps) == "request:first")
    assert (head(tail(steps)) == "request:second")
  end

  test "mixed step types are all counted" do
    let client = HttpClient.new_client()
      |> HttpClient.add_request_step("auth",  fn req -> Ok(req))
      |> HttpClient.add_response_step("log",  fn (req, resp) -> Ok((req, resp)))
      |> HttpClient.add_error_step("retry",   fn (req, err) -> Fail(err))
    let steps = HttpClient.list_steps(client)
    assert (List.length(steps) == 3)
  end
end

describe "HttpClient pipeline config" do
  test "with_redirects does not add steps" do
    let client = HttpClient.new_client() |> HttpClient.with_redirects(5)
    assert (is_nil(HttpClient.list_steps(client)))
  end

  test "with_retry does not add steps" do
    let client = HttpClient.new_client() |> HttpClient.with_retry(3, 1000)
    assert (is_nil(HttpClient.list_steps(client)))
  end
end

describe "HttpClient built-in step helpers" do
  test "step_default_headers adds User-Agent and Accept" do
    let req = make_bare_req()
    let req2 = match HttpClient.step_default_headers(req) do
      Ok(r)  -> r
      Err(_) -> panic("step_default_headers: expected Ok")
    end
    assert (Http.get_request_header(req2, "user-agent") == Some("march/0.1"))
    assert (Http.get_request_header(req2, "accept") == Some("*/*"))
  end

  test "step_bearer_auth adds Authorization header" do
    let req = make_bare_req()
    let step = HttpClient.step_bearer_auth("my-secret-token")
    let req2 = match step(req) do
      Ok(r)  -> r
      Err(_) -> panic("step_bearer_auth: expected Ok")
    end
    assert (Http.get_request_header(req2, "authorization") == Some("Bearer my-secret-token"))
  end

  test "step_basic_auth adds Authorization header" do
    let req = make_bare_req()
    let step = HttpClient.step_basic_auth("user", "pass")
    let req2 = match step(req) do
      Ok(r)  -> r
      Err(_) -> panic("step_basic_auth: expected Ok")
    end
    assert (Http.get_request_header(req2, "authorization") == Some("Basic user:pass"))
  end

  test "step_content_type adds Content-Type header" do
    let req = make_bare_req()
    let step = HttpClient.step_content_type("application/json")
    let req2 = match step(req) do
      Ok(r)  -> r
      Err(_) -> panic("step_content_type: expected Ok")
    end
    assert (Http.get_request_header(req2, "content-type") == Some("application/json"))
  end

  test "step_raise_on_error returns Ok for 200" do
    let req = make_bare_req()
    let resp = Response(Status(200), Nil, "ok")
    match HttpClient.step_raise_on_error(req, resp) do
    Ok(_)  -> ()
    Err(_) -> assert false
    end
  end

  test "step_raise_on_error returns Err for 404" do
    let req = make_bare_req()
    let resp = Response(Status(404), Nil, "not found")
    match HttpClient.step_raise_on_error(req, resp) do
    Err(_) -> ()
    Ok(_)  -> assert false
    end
  end

  test "step_raise_on_error returns Err for 500" do
    let req = make_bare_req()
    let resp = Response(Status(500), Nil, "server error")
    match HttpClient.step_raise_on_error(req, resp) do
    Err(_) -> ()
    Ok(_)  -> assert false
    end
  end
end

describe "HttpClient redirect cross-origin auth stripping" do
  test "same origin preserves Authorization" do
    let req_a = Request(Get, SchemeHttps, "api.example.com", None, "/", None, Nil, "")
    let req_b = Request(Get, SchemeHttps, "api.example.com", None, "/v2", None, Nil, "")
    assert (HttpClient.hc_same_origin(req_a, req_b))
  end

  test "same origin: explicit default port matches omitted port" do
    let req_a = Request(Get, SchemeHttps, "api.example.com", None, "/", None, Nil, "")
    let req_b = Request(Get, SchemeHttps, "api.example.com", Some(443), "/", None, Nil, "")
    assert (HttpClient.hc_same_origin(req_a, req_b))
  end

  test "same origin: http default port matches omitted" do
    let req_a = Request(Get, SchemeHttp, "api.example.com", None, "/", None, Nil, "")
    let req_b = Request(Get, SchemeHttp, "api.example.com", Some(80), "/", None, Nil, "")
    assert (HttpClient.hc_same_origin(req_a, req_b))
  end

  test "different scheme is cross-origin" do
    let req_a = Request(Get, SchemeHttps, "api.example.com", None, "/", None, Nil, "")
    let req_b = Request(Get, SchemeHttp, "api.example.com", None, "/", None, Nil, "")
    assert (not (HttpClient.hc_same_origin(req_a, req_b)))
  end

  test "different host is cross-origin" do
    let req_a = Request(Get, SchemeHttps, "api.example.com", None, "/", None, Nil, "")
    let req_b = Request(Get, SchemeHttps, "evil.example.com", None, "/", None, Nil, "")
    assert (not (HttpClient.hc_same_origin(req_a, req_b)))
  end

  test "different port is cross-origin" do
    let req_a = Request(Get, SchemeHttps, "api.example.com", Some(443), "/", None, Nil, "")
    let req_b = Request(Get, SchemeHttps, "api.example.com", Some(8443), "/", None, Nil, "")
    assert (not (HttpClient.hc_same_origin(req_a, req_b)))
  end

  test "host comparison is case-insensitive" do
    let req_a = Request(Get, SchemeHttps, "API.Example.Com", None, "/", None, Nil, "")
    let req_b = Request(Get, SchemeHttps, "api.example.com", None, "/", None, Nil, "")
    assert (HttpClient.hc_same_origin(req_a, req_b))
  end

  test "strip removes Authorization" do
    let headers = Cons(Header("Authorization", "Bearer secret"),
                  Cons(Header("X-Custom", "ok"), Nil))
    let stripped = HttpClient.hc_strip_sensitive_headers(headers)
    -- X-Custom survives; Authorization is gone.
    match stripped do
    Cons(Header(n, _), Nil) -> assert (n == "X-Custom")
    _ -> assert false
    end
  end

  test "strip removes Cookie" do
    let headers = Cons(Header("Cookie", "session=abc"),
                  Cons(Header("Accept", "*/*"), Nil))
    let stripped = HttpClient.hc_strip_sensitive_headers(headers)
    match stripped do
    Cons(Header(n, _), Nil) -> assert (n == "Accept")
    _ -> assert false
    end
  end

  test "strip removes Proxy-Authorization" do
    let headers = Cons(Header("proxy-authorization", "Basic xyz"),
                  Cons(Header("User-Agent", "test"), Nil))
    let stripped = HttpClient.hc_strip_sensitive_headers(headers)
    match stripped do
    Cons(Header(n, _), Nil) -> assert (n == "User-Agent")
    _ -> assert false
    end
  end

  test "strip is case-insensitive on header name" do
    let headers = Cons(Header("AUTHORIZATION", "Bearer x"),
                  Cons(Header("Cookie", "s=1"),
                  Cons(Header("X-Safe", "ok"), Nil)))
    let stripped = HttpClient.hc_strip_sensitive_headers(headers)
    match stripped do
    Cons(Header(n, _), Nil) -> assert (n == "X-Safe")
    _ -> assert false
    end
  end

  test "strip preserves non-sensitive headers untouched" do
    let headers = Cons(Header("User-Agent", "march/0.1"),
                  Cons(Header("Accept", "*/*"),
                  Cons(Header("Content-Type", "application/json"), Nil)))
    let stripped = HttpClient.hc_strip_sensitive_headers(headers)
    -- All three remain.
    match stripped do
    Cons(_, Cons(_, Cons(_, Nil))) -> ()
    _ -> assert false
    end
  end
end

end
