-- Tests for the Set stdlib module (HAMT-based persistent set)
-- Run with: dune exec march -- test test/stdlib/test_set.march

mod TestSet do

fn int_cmp(a : Int) : Int -> Bool do
  fn b -> a < b
end

fn str_cmp(a : String) : String -> Bool do
  fn b -> a < b
end

fn set_of(xs : List(Int)) do
  Set.from_list(xs, int_cmp)
end

describe "empty and is_empty" do
  test "empty set is empty with size zero" do
    let s = Set.empty()
    assert Set.is_empty(s)
    assert (Set.size(s) == 0)
  end
end

describe "singleton" do
  test "singleton is non-empty and contains the element" do
    let s = Set.singleton(42)
    assert !Set.is_empty(s)
    assert (Set.size(s) == 1)
    assert Set.contains(s, 42, int_cmp)
  end

  test "singleton does not contain other elements" do
    assert !Set.contains(Set.singleton(42), 1, int_cmp)
  end
end

describe "insert" do
  test "insert adds new element" do
    let s = Set.insert(Set.empty(), 1, int_cmp)
    assert Set.contains(s, 1, int_cmp)
    assert (Set.size(s) == 1)
  end

  test "insert of duplicate does not increase size" do
    let s = Set.insert(Set.insert(Set.empty(), 5, int_cmp), 5, int_cmp)
    assert (Set.size(s) == 1)
  end

  test "insert multiple elements" do
    let s = set_of(Cons(1, Cons(2, Cons(3, Nil))))
    assert (Set.size(s) == 3)
    assert Set.contains(s, 1, int_cmp)
    assert Set.contains(s, 2, int_cmp)
    assert Set.contains(s, 3, int_cmp)
  end

  test "insert is persistent" do
    let s0 = Set.empty()
    let s1 = Set.insert(s0, 1, int_cmp)
    let s2 = Set.insert(s1, 2, int_cmp)
    assert (Set.size(s1) == 1)
    assert !Set.contains(s1, 2, int_cmp)
  end
end

describe "contains" do
  test "empty set contains nothing" do
    assert !Set.contains(Set.empty(), 99, int_cmp)
  end

  test "contains works for large sets" do
    let s = set_of(List.range(1, 21))
    assert Set.contains(s, 10, int_cmp)
    assert Set.contains(s, 1, int_cmp)
    assert Set.contains(s, 20, int_cmp)
    assert !Set.contains(s, 21, int_cmp)
    assert !Set.contains(s, 0, int_cmp)
  end
end

describe "remove" do
  test "remove eliminates the element" do
    let s = set_of(Cons(1, Cons(2, Cons(3, Nil))))
    let s2 = Set.remove(s, 2, int_cmp)
    assert !Set.contains(s2, 2, int_cmp)
    assert Set.contains(s2, 1, int_cmp)
    assert Set.contains(s2, 3, int_cmp)
    assert (Set.size(s2) == 2)
  end

  test "remove of absent element leaves set unchanged" do
    let s2 = Set.remove(Set.singleton(5), 99, int_cmp)
    assert (Set.size(s2) == 1)
  end

  test "remove of only element gives empty set" do
    assert Set.is_empty(Set.remove(Set.singleton(7), 7, int_cmp))
  end
end

describe "size" do
  test "size of empty set is zero" do
    assert (Set.size(Set.empty()) == 0)
  end

  test "size of 10-element set is ten" do
    assert (Set.size(set_of(List.range(1, 11))) == 10)
  end
end

describe "union" do
  test "union of disjoint sets has all elements" do
    let a = set_of(Cons(1, Cons(2, Nil)))
    let b = set_of(Cons(3, Cons(4, Nil)))
    let c = Set.union(a, b, int_cmp)
    assert (Set.size(c) == 4)
    assert Set.contains(c, 1, int_cmp)
    assert Set.contains(c, 4, int_cmp)
  end

  test "union with overlap deduplicates" do
    let a = set_of(Cons(1, Cons(2, Cons(3, Nil))))
    let b = set_of(Cons(2, Cons(3, Cons(4, Nil))))
    assert (Set.size(Set.union(a, b, int_cmp)) == 4)
  end

  test "union with empty preserves original" do
    let a = set_of(Cons(1, Cons(2, Nil)))
    assert (Set.size(Set.union(a, Set.empty(), int_cmp)) == 2)
  end
end

describe "intersection" do
  test "intersection keeps only shared elements" do
    let a = set_of(Cons(1, Cons(2, Cons(3, Nil))))
    let b = set_of(Cons(2, Cons(3, Cons(4, Nil))))
    let c = Set.intersection(a, b, int_cmp)
    assert (Set.size(c) == 2)
    assert Set.contains(c, 2, int_cmp)
    assert Set.contains(c, 3, int_cmp)
    assert !Set.contains(c, 1, int_cmp)
    assert !Set.contains(c, 4, int_cmp)
  end

  test "intersection of disjoint sets is empty" do
    let a = set_of(Cons(1, Cons(2, Nil)))
    let b = set_of(Cons(3, Cons(4, Nil)))
    assert Set.is_empty(Set.intersection(a, b, int_cmp))
  end

  test "intersection with empty is empty" do
    let a = set_of(Cons(1, Cons(2, Nil)))
    assert Set.is_empty(Set.intersection(a, Set.empty(), int_cmp))
  end
end

describe "difference" do
  test "difference removes elements in b from a" do
    let a = set_of(Cons(1, Cons(2, Cons(3, Cons(4, Nil)))))
    let b = set_of(Cons(2, Cons(4, Nil)))
    let c = Set.difference(a, b, int_cmp)
    assert (Set.size(c) == 2)
    assert Set.contains(c, 1, int_cmp)
    assert Set.contains(c, 3, int_cmp)
    assert !Set.contains(c, 2, int_cmp)
    assert !Set.contains(c, 4, int_cmp)
  end

  test "difference with empty b gives whole a" do
    let a = set_of(Cons(1, Cons(2, Nil)))
    assert (Set.size(Set.difference(a, Set.empty(), int_cmp)) == 2)
  end

  test "difference with self gives empty" do
    let a = set_of(Cons(1, Cons(2, Nil)))
    assert Set.is_empty(Set.difference(a, a, int_cmp))
  end
end

describe "is_subset" do
  test "subset relation holds when all elements present" do
    let a = set_of(Cons(1, Cons(2, Nil)))
    let b = set_of(Cons(1, Cons(2, Cons(3, Nil))))
    assert Set.is_subset(a, b, int_cmp)
  end

  test "superset is not a subset" do
    let a = set_of(Cons(1, Cons(2, Cons(3, Nil))))
    let b = set_of(Cons(1, Cons(2, Nil)))
    assert !Set.is_subset(a, b, int_cmp)
  end

  test "set is subset of itself" do
    let a = set_of(Cons(1, Cons(2, Nil)))
    assert Set.is_subset(a, a, int_cmp)
  end

  test "empty set is subset of any set" do
    let a = set_of(Cons(1, Cons(2, Nil)))
    assert Set.is_subset(Set.empty(), a, int_cmp)
  end
end

describe "to_list and from_list" do
  test "to_list returns all elements" do
    let s = set_of(Cons(1, Cons(2, Cons(3, Nil))))
    assert (length(Set.to_list(s)) == 3)
  end

  test "from_list deduplicates" do
    let lst = Cons(1, Cons(2, Cons(1, Cons(3, Nil))))
    let s = Set.from_list(lst, int_cmp)
    assert (Set.size(s) == 3)
  end

  test "from_list of empty gives empty set" do
    let empty : List(Int) = Nil
    assert Set.is_empty(Set.from_list(empty, int_cmp))
  end
end

describe "fold" do
  test "fold sums all elements" do
    let s = set_of(Cons(1, Cons(2, Cons(3, Cons(4, Cons(5, Nil))))))
    let sum = Set.fold(0, s, fn (acc, x) -> acc + x)
    assert (sum == 15)
  end

  test "fold counts elements" do
    let s = set_of(Cons(10, Cons(20, Cons(30, Nil))))
    let c = Set.fold(0, s, fn (acc, _x) -> acc + 1)
    assert (c == 3)
  end
end

describe "eq" do
  test "sets with same elements are equal" do
    let a = set_of(Cons(1, Cons(2, Cons(3, Nil))))
    let b = set_of(Cons(3, Cons(1, Cons(2, Nil))))
    assert Set.eq(a, b, int_cmp)
  end

  test "sets with different elements are not equal" do
    let a = set_of(Cons(1, Cons(2, Nil)))
    let b = set_of(Cons(1, Cons(3, Nil)))
    assert !Set.eq(a, b, int_cmp)
  end

  test "sets of different sizes are not equal" do
    let a = set_of(Cons(1, Cons(2, Nil)))
    let b = set_of(Cons(1, Cons(2, Cons(3, Nil))))
    assert !Set.eq(a, b, int_cmp)
  end

  test "two empty sets are equal" do
    assert Set.eq(Set.empty(), Set.empty(), int_cmp)
  end
end

describe "string sets" do
  test "set works with string elements" do
    let s = Set.from_list(Cons("apple", Cons("banana", Cons("cherry", Nil))), str_cmp)
    assert (Set.size(s) == 3)
    assert Set.contains(s, "banana", str_cmp)
    assert !Set.contains(s, "mango", str_cmp)
  end
end

end
