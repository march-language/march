-- Tests for the Prelude stdlib module
-- Run with: dune exec march -- test test/stdlib/test_prelude.march

mod TestPrelude do

describe "unwrap" do
  test "unwrap extracts value from Some" do
    assert (unwrap(Some(42)) == 42)
  end

  test "unwrap of Some(0) is 0" do
    assert (unwrap(Some(0)) == 0)
  end
end

describe "unwrap_or" do
  test "unwrap_or returns value when Some" do
    assert (unwrap_or(Some(5), 99) == 5)
  end

  test "unwrap_or returns default when None" do
    assert (unwrap_or(None, 7) == 7)
  end
end

describe "head" do
  test "head returns first element" do
    assert (head(Cons(10, Cons(20, Nil))) == 10)
  end

  test "head of singleton returns the element" do
    assert (head(Cons(99, Nil)) == 99)
  end
end

describe "tail" do
  test "tail returns rest of list" do
    let t = tail(Cons(1, Cons(2, Cons(3, Nil))))
    assert (head(t) == 2)
  end

  test "tail of singleton is Nil" do
    assert is_nil(tail(Cons(1, Nil)))
  end
end

describe "is_nil" do
  test "is_nil returns true for Nil" do
    assert is_nil(Nil)
  end

  test "is_nil returns false for Cons" do
    assert !is_nil(Cons(1, Nil))
  end
end

describe "length" do
  test "length of empty list is zero" do
    assert (length(Nil) == 0)
  end

  test "length of one-element list is one" do
    assert (length(Cons(1, Nil)) == 1)
  end

  test "length of three-element list is three" do
    assert (length(Cons(1, Cons(2, Cons(3, Nil)))) == 3)
  end
end

describe "reverse" do
  test "reverse of empty list is empty" do
    assert is_nil(reverse(Nil))
  end

  test "reverse of singleton is itself" do
    assert (head(reverse(Cons(42, Nil))) == 42)
  end

  test "reverse flips list order" do
    let r = reverse(Cons(1, Cons(2, Cons(3, Nil))))
    assert (head(r) == 3)
    assert (head(tail(r)) == 2)
  end
end

describe "fold_left" do
  test "fold_left sums a list" do
    let xs = Cons(1, Cons(2, Cons(3, Cons(4, Nil))))
    assert (fold_left(xs, 0, fn (acc, x) -> acc + x) == 10)
  end

  test "fold_left on empty list returns accumulator" do
    let empty_ints : List(Int) = Nil
    assert (fold_left(empty_ints, 0, fn (acc, x) -> acc + x) == 0)
  end

  test "fold_left computes product" do
    let xs = Cons(1, Cons(2, Cons(3, Nil)))
    assert (fold_left(xs, 1, fn (acc, x) -> acc * x) == 6)
  end
end

describe "filter" do
  test "filter keeps even numbers" do
    let xs = Cons(1, Cons(2, Cons(3, Cons(4, Cons(5, Nil)))))
    let evens = filter(xs, fn x -> x % 2 == 0)
    assert (length(evens) == 2)
    assert (head(evens) == 2)
  end

  test "filter with no passing elements gives empty list" do
    let xs = Cons(1, Cons(3, Cons(5, Nil)))
    assert is_nil(filter(xs, fn x -> x % 2 == 0))
  end

  test "filter where all pass keeps all elements" do
    let xs = Cons(2, Cons(4, Cons(6, Nil)))
    assert (length(filter(xs, fn x -> x % 2 == 0)) == 3)
  end
end

describe "map" do
  test "map doubles each element" do
    let xs = Cons(1, Cons(2, Cons(3, Nil)))
    let doubled = map(xs, fn x -> x * 2)
    assert (head(doubled) == 2)
    assert (head(tail(doubled)) == 4)
  end

  test "map over empty list gives empty list" do
    let empty_ints : List(Int) = Nil
    assert is_nil(map(empty_ints, fn x -> x * 2))
  end
end

describe "identity" do
  test "identity returns its argument unchanged" do
    assert (identity(42) == 42)
  end

  test "identity of zero is zero" do
    assert (identity(0) == 0)
  end

  test "identity of negative number" do
    assert (identity(-1) == -1)
  end
end

describe "compose" do
  test "compose applies second function then first" do
    let double = fn x -> x * 2
    let inc = fn x -> x + 1
    let double_then_inc = compose(inc, double)
    assert (double_then_inc(3) == 7)
  end

  test "compose respects function order" do
    let add_one = fn x -> x + 1
    let times_three = fn x -> x * 3
    let f = compose(times_three, add_one)
    assert (f(4) == 15)
  end
end

describe "const" do
  test "const returns fixed value regardless of argument" do
    let always5 = const(5)
    assert (always5(99) == 5)
  end

  test "const of zero always returns zero" do
    let always0 = const(0)
    assert (always0(42) == 0)
  end
end

describe "inspect" do
  test "inspect converts int to string" do
    assert (inspect(42) == "42")
  end

  test "inspect converts bool true to string" do
    assert (inspect(true) == "true")
  end
end

end
