-- Property-based tests for March stdlib modules.
-- Run with: march test test/stdlib/test_properties.march
-- Skip with: march test --skip-properties test/stdlib/test_properties.march

mod TestProperties do

  -- ---- Helpers ----

  pfn list_eq_int(xs : List(Int), ys : List(Int)) : Bool do
    if List.length(xs) != List.length(ys) do false
    else List.all(List.zip(xs, ys), fn p -> match p do (a, b) -> a == b end)
    end
  end

  pfn list_eq_str(xs : List(String), ys : List(String)) : Bool do
    if List.length(xs) != List.length(ys) do false
    else List.all(List.zip(xs, ys), fn p -> match p do (a, b) -> a == b end)
    end
  end

  pfn is_sorted_int(xs : List(Int)) : Bool do
    match xs do
    Nil -> true
    Cons(_, Nil) -> true
    Cons(a, Cons(b, rest)) ->
      if a <= b do is_sorted_int(Cons(b, rest))
      else false
      end
    end
  end

  pfn int_lt(a : Int, b : Int) : Bool do a < b end

  pfn opt_eq_int(a : Option(Int), b : Option(Int)) : Bool do
    match (a, b) do
    (Some(x), Some(y)) -> x == y
    (None, None)       -> true
    _                  -> false
    end
  end

  -- ================================================================
  -- List properties
  -- ================================================================

  describe "List" do

    test "reverse is involutive" do
      Check.all(Gen.list(Gen.int(-1000, 1000)), fn xs ->
        list_eq_int(List.reverse(List.reverse(xs)), xs)
      )
    end

    test "reverse preserves length" do
      Check.all(Gen.list(Gen.int(0, 100)), fn xs ->
        List.length(List.reverse(xs)) == List.length(xs)
      )
    end

    test "append is associative" do
      Check.all(
        Gen.tuple3(Gen.list(Gen.int(0, 10)), Gen.list(Gen.int(0, 10)), Gen.list(Gen.int(0, 10))),
        fn triple -> match triple do
          (a, b, c) ->
            list_eq_int(
              List.append(List.append(a, b), c),
              List.append(a, List.append(b, c))
            )
        end
      )
    end

    test "append length is additive" do
      Check.all(Gen.tuple2(Gen.list(Gen.int(0, 10)), Gen.list(Gen.int(0, 10))), fn pair ->
        match pair do
        (a, b) ->
          List.length(List.append(a, b)) == List.length(a) + List.length(b)
        end
      )
    end

    test "map preserves length" do
      Check.all(Gen.list(Gen.int(0, 100)), fn xs ->
        List.length(List.map(xs, fn x -> x * 2)) == List.length(xs)
      )
    end

    test "filter never increases length" do
      Check.all(Gen.list(Gen.int(-100, 100)), fn xs ->
        List.length(List.filter(xs, fn x -> x > 0)) <= List.length(xs)
      )
    end

    test "sort_by preserves length" do
      Check.all(Gen.list(Gen.int(-100, 100)), fn xs ->
        let sorted = List.sort_by(xs, int_lt)
        List.length(sorted) == List.length(xs)
      )
    end

    test "sort_by produces sorted output" do
      Check.all(Gen.list(Gen.int(-100, 100)), fn xs ->
        let sorted = List.sort_by(xs, int_lt)
        is_sorted_int(sorted)
      )
    end

    test "fold_left sum matches List.sum_int" do
      Check.all(Gen.list(Gen.int(-100, 100)), fn xs ->
        let folded = List.fold_left(xs, 0, fn (acc, x) -> acc + x)
        folded == List.sum_int(xs)
      )
    end

    test "take(n) ++ drop(n) == original" do
      Check.all(Gen.tuple2(Gen.list(Gen.int(0, 50)), Gen.int(0, 20)), fn pair ->
        match pair do
        (xs, n) ->
          let taken = List.take(xs, n)
          let dropped = List.drop(xs, n)
          list_eq_int(List.append(taken, dropped), xs)
        end
      )
    end

  end

  -- ================================================================
  -- String properties
  -- ================================================================

  describe "String" do

    test "reverse is involutive (ASCII)" do
      Check.all(Gen.lowercase_string(), fn s ->
        String.reverse(String.reverse(s)) == s
      )
    end

    test "split/join round-trip (pipe separator, non-empty)" do
      Check.all(
        Gen.bind(Gen.lowercase_string(), fn first ->
          Gen.map(Gen.list(Gen.lowercase_string()), fn rest ->
            Cons(first, rest)
          )
        ),
        fn parts ->
          let sep = "|"
          let joined = String.join(parts, sep)
          let split_back = String.split(joined, sep)
          list_eq_str(split_back, parts)
      )
    end

    test "trim is idempotent" do
      Check.all(Gen.string(), fn s ->
        String.trim(String.trim(s)) == String.trim(s)
      )
    end

    test "to_uppercase is idempotent" do
      Check.all(Gen.lowercase_string(), fn s ->
        String.to_uppercase(String.to_uppercase(s)) == String.to_uppercase(s)
      )
    end

    test "to_lowercase is idempotent" do
      Check.all(Gen.string(), fn s ->
        String.to_lowercase(String.to_lowercase(s)) == String.to_lowercase(s)
      )
    end

    test "length after repeat is n * original" do
      Check.all(Gen.tuple2(Gen.lowercase_string(), Gen.int(0, 5)), fn pair ->
        match pair do
        (s, n) ->
          string_length(String.repeat(s, n)) == string_length(s) * n
        end
      )
    end

  end

  -- ================================================================
  -- BigInt properties (model: compare with Int for small values)
  -- ================================================================

  describe "BigInt" do

    test "add matches Int for all values" do
      Check.all(Gen.tuple2(Gen.int(-500, 500), Gen.int(-500, 500)), fn pair ->
        match pair do (a, b) ->
          BigInt.to_string(BigInt.add(BigInt.from_int(a), BigInt.from_int(b)))
            == int_to_string(a + b)
        end
      )
    end

    test "add is commutative" do
      Check.all(Gen.tuple2(Gen.int(-500, 500), Gen.int(-500, 500)), fn pair ->
        match pair do (a, b) ->
          BigInt.add(BigInt.from_int(a), BigInt.from_int(b))
            == BigInt.add(BigInt.from_int(b), BigInt.from_int(a))
        end
      )
    end

    test "eq matches Int equality" do
      Check.all(Gen.tuple2(Gen.int(-200, 200), Gen.int(-200, 200)), fn pair ->
        match pair do (a, b) ->
          BigInt.eq(BigInt.from_int(a), BigInt.from_int(b)) == (a == b)
        end
      )
    end

    test "compare matches Int compare" do
      Check.all(Gen.tuple2(Gen.int(-200, 200), Gen.int(-200, 200)), fn pair ->
        match pair do (a, b) ->
          let r = BigInt.compare(BigInt.from_int(a), BigInt.from_int(b))
          if a < b do r < 0
          else if a > b do r > 0
          else r == 0 end end
        end
      )
    end

    test "mul matches Int for small values" do
      Check.all(Gen.tuple2(Gen.int(-100, 100), Gen.int(-100, 100)), fn pair ->
        match pair do (a, b) ->
          BigInt.to_string(BigInt.mul(BigInt.from_int(a), BigInt.from_int(b)))
            == int_to_string(a * b)
        end
      )
    end

    test "negate is self-inverse" do
      Check.all(Gen.int(-1000, 1000), fn n ->
        let bn = BigInt.from_int(n)
        BigInt.negate(BigInt.negate(bn)) == bn
      )
    end

    test "sub is inverse of add" do
      Check.all(Gen.tuple2(Gen.int(-200, 200), Gen.int(-200, 200)), fn pair ->
        match pair do (a, b) ->
          let ba = BigInt.from_int(a)
          let bb = BigInt.from_int(b)
          BigInt.eq(BigInt.sub(BigInt.add(ba, bb), bb), ba)
        end
      )
    end

    test "add is associative" do
      Check.all(
        Gen.tuple3(Gen.int(-50, 50), Gen.int(-50, 50), Gen.int(-50, 50)),
        fn triple -> match triple do (a, b, c) ->
          let ba = BigInt.from_int(a)
          let bb = BigInt.from_int(b)
          let bc = BigInt.from_int(c)
          BigInt.eq(
            BigInt.add(BigInt.add(ba, bb), bc),
            BigInt.add(ba, BigInt.add(bb, bc))
          )
        end
      )
    end

    test "mul is commutative" do
      Check.all(Gen.tuple2(Gen.int(-100, 100), Gen.int(-100, 100)), fn pair ->
        match pair do (a, b) ->
          BigInt.eq(
            BigInt.mul(BigInt.from_int(a), BigInt.from_int(b)),
            BigInt.mul(BigInt.from_int(b), BigInt.from_int(a))
          )
        end
      )
    end

    test "div/mod relationship: a == (a/b)*b + a%b" do
      Check.all(Gen.tuple2(Gen.int(-200, 200), Gen.int(1, 50)), fn pair ->
        match pair do (a, b) ->
          let ba = BigInt.from_int(a)
          let bb = BigInt.from_int(b)
          let q = BigInt.div(ba, bb)
          let r = BigInt.mod_(ba, bb)
          BigInt.eq(BigInt.add(BigInt.mul(q, bb), r), ba)
        end
      )
    end

  end

  -- ================================================================
  -- Decimal properties
  -- ================================================================

  describe "Decimal" do

    test "add is commutative" do
      Check.all(Gen.tuple2(Gen.int(-1000, 1000), Gen.int(-1000, 1000)), fn pair ->
        match pair do (a, b) ->
          Decimal.eq(
            Decimal.add(Decimal.from_int(a), Decimal.from_int(b)),
            Decimal.add(Decimal.from_int(b), Decimal.from_int(a))
          )
        end
      )
    end

    test "add zero is identity" do
      Check.all(Gen.int(-1000, 1000), fn n ->
        Decimal.eq(Decimal.add(Decimal.from_int(n), Decimal.from_int(0)), Decimal.from_int(n))
      )
    end

    test "sub is inverse of add" do
      Check.all(Gen.tuple2(Gen.int(-500, 500), Gen.int(-500, 500)), fn pair ->
        match pair do (a, b) ->
          let da = Decimal.from_int(a)
          let db = Decimal.from_int(b)
          Decimal.eq(Decimal.sub(Decimal.add(da, db), db), da)
        end
      )
    end

    test "mul one is identity" do
      Check.all(Gen.int(-1000, 1000), fn n ->
        Decimal.eq(Decimal.mul(Decimal.from_int(n), Decimal.from_int(1)), Decimal.from_int(n))
      )
    end

    test "from_int to_string matches int_to_string" do
      Check.all(Gen.int(-10000, 10000), fn n ->
        Decimal.to_string(Decimal.from_int(n)) == int_to_string(n)
      )
    end

    test "compare matches Int compare" do
      Check.all(Gen.tuple2(Gen.int(-200, 200), Gen.int(-200, 200)), fn pair ->
        match pair do (a, b) ->
          let r = Decimal.compare(Decimal.from_int(a), Decimal.from_int(b))
          if a < b do r < 0
          else if a > b do r > 0
          else r == 0 end end
        end
      )
    end

  end

  -- ================================================================
  -- Option functor/monad laws
  -- ================================================================

  describe "Option" do

    test "map identity law" do
      Check.all(Gen.option(Gen.int(-1000, 1000)), fn opt ->
        opt_eq_int(Option.map(opt, fn x -> x), opt)
      )
    end

    test "map composition law" do
      Check.all(Gen.option(Gen.int(0, 100)), fn opt ->
        let f = fn x -> x + 1
        let g = fn x -> x * 2
        let lhs = Option.map(Option.map(opt, f), g)
        let rhs = Option.map(opt, fn x -> g(f(x)))
        opt_eq_int(lhs, rhs)
      )
    end

    test "flat_map associativity" do
      Check.all(Gen.option(Gen.int(0, 100)), fn opt ->
        let f = fn n -> if n > 50 do Some(n * 2) else None end
        let g = fn n -> if n > 80 do Some(n + 10) else None end
        let lhs = Option.flat_map(Option.flat_map(opt, f), g)
        let rhs = Option.flat_map(opt, fn x -> Option.flat_map(f(x), g))
        opt_eq_int(lhs, rhs)
      )
    end

  end

  -- ================================================================
  -- Result monad laws
  -- ================================================================

  describe "Result" do

    test "flat_map left identity" do
      Check.all(Gen.int(-1000, 1000), fn n ->
        let f = fn x -> Ok(x * 2)
        let lhs = Result.flat_map(Ok(n), f)
        let rhs = f(n)
        match (lhs, rhs) do
        (Ok(a), Ok(b)) -> a == b
        _              -> false
        end
      )
    end

    test "map identity law" do
      Check.all(Gen.int(-1000, 1000), fn n ->
        match Result.map(Ok(n), fn x -> x) do
        Ok(v) -> v == n
        _     -> false
        end
      )
    end

    test "map_err identity on Ok" do
      Check.all(Gen.int(-1000, 1000), fn n ->
        match Result.map_err(Ok(n), fn e -> e) do
        Ok(v) -> v == n
        _     -> false
        end
      )
    end

  end

  -- ================================================================
  -- Base64 round-trip
  -- ================================================================

  describe "Base64" do

    test "encode/decode round-trip" do
      Check.all(Gen.lowercase_string(), fn s ->
        let b = Bytes.from_string(s)
        let encoded = Base64.encode(b)
        match Base64.decode(encoded) do
        Ok(decoded) -> Bytes.to_string(decoded) == s
        Err(_)      -> false
        end
      )
    end

    test "url_encode/url_decode round-trip" do
      Check.all(Gen.lowercase_string(), fn s ->
        let b = Bytes.from_string(s)
        let encoded = Base64.url_encode(b)
        match Base64.url_decode(encoded) do
        Ok(decoded) -> Bytes.to_string(decoded) == s
        Err(_)      -> false
        end
      )
    end

  end

  -- ================================================================
  -- JSON round-trip
  -- ================================================================

  describe "JSON" do

    test "int round-trip through JSON" do
      Check.all(Gen.int(-100000, 100000), fn n ->
        let json = Json.encode_int(n)
        let s = Json.to_string(json)
        match Json.parse(s) do
        Ok(parsed) ->
          match parsed do
          Number(f) -> float_to_int(f) == n
          _         -> false
          end
        Err(_) -> false
        end
      )
    end

    test "string round-trip through JSON" do
      Check.all(Gen.lowercase_string(), fn s ->
        let json = Json.encode_string(s)
        let rendered = Json.to_string(json)
        match Json.parse(rendered) do
        Ok(parsed) ->
          match parsed do
          Str(s2) -> s2 == s
          _       -> false
          end
        Err(_) -> false
        end
      )
    end

    test "bool round-trip through JSON" do
      Check.all(Gen.bool(), fn b ->
        let json = Json.encode_bool(b)
        let rendered = Json.to_string(json)
        match Json.parse(rendered) do
        Ok(parsed) ->
          match parsed do
          Bool(b2) -> b2 == b
          _        -> false
          end
        Err(_) -> false
        end
      )
    end

  end

  -- ================================================================
  -- Sort invariants
  -- ================================================================

  describe "Sort" do

    test "sort is idempotent" do
      Check.all(Gen.list(Gen.int(-100, 100)), fn xs ->
        let cmp = int_lt
        let sorted = List.sort_by(xs, cmp)
        let double_sorted = List.sort_by(sorted, cmp)
        list_eq_int(sorted, double_sorted)
      )
    end

  end

  -- ================================================================
  -- Arithmetic identities
  -- ================================================================

  describe "Arithmetic" do

    test "addition is commutative" do
      Check.all(Gen.tuple2(Gen.int(-10000, 10000), Gen.int(-10000, 10000)), fn pair ->
        match pair do (a, b) -> a + b == b + a end
      )
    end

    test "multiplication is commutative" do
      Check.all(Gen.tuple2(Gen.int(-1000, 1000), Gen.int(-1000, 1000)), fn pair ->
        match pair do (a, b) -> a * b == b * a end
      )
    end

    test "multiplication distributes over addition" do
      Check.all(
        Gen.tuple3(Gen.int(-50, 50), Gen.int(-50, 50), Gen.int(-50, 50)),
        fn triple -> match triple do
          (a, b, c) -> a * (b + c) == a * b + a * c
        end
      )
    end

  end

  -- ================================================================
  -- List: additional structural properties
  -- ================================================================

  describe "List (extended)" do

    test "zip/unzip round-trip" do
      Check.all(Gen.tuple2(Gen.list(Gen.int(0, 50)), Gen.list(Gen.int(0, 50))), fn pair ->
        match pair do (xs, ys) ->
          let len = if List.length(xs) < List.length(ys) do List.length(xs) else List.length(ys) end
          let xt = List.take(xs, len)
          let yt = List.take(ys, len)
          match List.unzip(List.zip(xt, yt)) do
          (xs_out, ys_out) ->
            list_eq_int(xs_out, xt) && list_eq_int(ys_out, yt)
          end
        end
      )
    end

    test "flat_map with repeat doubles length" do
      Check.all(Gen.list(Gen.int(0, 10)), fn xs ->
        let flat = List.flat_map(xs, fn x -> Cons(x, Cons(x, Nil)))
        List.length(flat) == List.length(xs) * 2
      )
    end

    test "enumerate preserves elements" do
      Check.all(Gen.list(Gen.int(0, 100)), fn xs ->
        let extracted = List.map(List.enumerate(xs), fn p ->
          match p do (_, x) -> x end)
        list_eq_int(extracted, xs)
      )
    end

    test "enumerate indices are sequential from 0" do
      Check.all(Gen.list(Gen.int(0, 50)), fn xs ->
        let indices = List.map(List.enumerate(xs), fn p ->
          match p do (i, _) -> i end)
        list_eq_int(indices, List.range(0, List.length(xs)))
      )
    end

    test "dedup is idempotent" do
      Check.all(Gen.list(Gen.int(-10, 10)), fn xs ->
        let once = List.dedup(xs)
        let twice = List.dedup(once)
        list_eq_int(once, twice)
      )
    end

    test "partition preserves total count" do
      Check.all(Gen.list(Gen.int(-100, 100)), fn xs ->
        match List.partition(xs, fn x -> x > 0) do
        (yes, no) ->
          List.length(yes) + List.length(no) == List.length(xs)
        end
      )
    end

    test "partition elements satisfy predicate" do
      Check.all(Gen.list(Gen.int(-100, 100)), fn xs ->
        match List.partition(xs, fn x -> x > 0) do
        (yes, no) ->
          List.all(yes, fn x -> x > 0) && List.all(no, fn x -> not(x > 0))
        end
      )
    end

  end

  -- ================================================================
  -- String: additional properties
  -- ================================================================

  describe "String (extended)" do

    test "contains self" do
      Check.all(Gen.lowercase_string(), fn s ->
        String.contains(s, s)
      )
    end

    test "starts_with/ends_with after concat" do
      Check.all(Gen.tuple2(Gen.lowercase_string(), Gen.lowercase_string()), fn pair ->
        match pair do (a, b) ->
          let combined = a ++ b
          String.starts_with(combined, a) && String.ends_with(combined, b)
        end
      )
    end

    test "pad_left reaches target width" do
      Check.all(Gen.tuple2(Gen.lowercase_string(), Gen.int(1, 50)), fn pair ->
        match pair do (s, width) ->
          let padded = String.pad_left(s, width, "0")
          string_length(padded) >= width
        end
      )
    end

    test "pad_right reaches target width" do
      Check.all(Gen.tuple2(Gen.lowercase_string(), Gen.int(1, 50)), fn pair ->
        match pair do (s, width) ->
          let padded = String.pad_right(s, width, "0")
          string_length(padded) >= width
        end
      )
    end

  end

  -- ================================================================
  -- Bytes properties
  -- ================================================================

  describe "Bytes" do

    test "from_string/to_string round-trip" do
      Check.all(Gen.lowercase_string(), fn s ->
        Bytes.to_string(Bytes.from_string(s)) == s
      )
    end

    test "concat length is additive" do
      Check.all(Gen.tuple2(Gen.lowercase_string(), Gen.lowercase_string()), fn pair ->
        match pair do (a, b) ->
          let ba = Bytes.from_string(a)
          let bb = Bytes.from_string(b)
          Bytes.length(Bytes.concat(ba, bb)) == Bytes.length(ba) + Bytes.length(bb)
        end
      )
    end

    test "to_hex/from_hex round-trip" do
      Check.all(Gen.lowercase_string(), fn s ->
        let b = Bytes.from_string(s)
        let hex = Bytes.to_hex(b)
        match Bytes.from_hex(hex) do
        Ok(b2) -> Bytes.to_string(b2) == s
        Err(_) -> false
        end
      )
    end

  end

  -- ================================================================
  -- Queue FIFO properties
  -- ================================================================

  describe "Queue" do

    test "to_list after from_list is identity" do
      Check.all(Gen.list(Gen.int(0, 100)), fn xs ->
        list_eq_int(Queue.to_list(Queue.from_list(xs)), xs)
      )
    end

    test "push_back then to_list appends" do
      Check.all(Gen.tuple2(Gen.list(Gen.int(0, 50)), Gen.int(0, 100)), fn pair ->
        match pair do (xs, x) ->
          let q = Queue.from_list(xs)
          let q2 = Queue.push_back(q, x)
          list_eq_int(Queue.to_list(q2), List.append(xs, Cons(x, Nil)))
        end
      )
    end

    test "size matches list length" do
      Check.all(Gen.list(Gen.int(0, 100)), fn xs ->
        Queue.size(Queue.from_list(xs)) == List.length(xs)
      )
    end

    test "pop_front returns first element" do
      Check.all(
        Gen.bind(Gen.int(0, 100), fn first ->
          Gen.map(Gen.list(Gen.int(0, 100)), fn rest ->
            Cons(first, rest)
          )
        ),
        fn xs ->
          let q = Queue.from_list(xs)
          match Queue.pop_front(q) do
          Some(pair) ->
            match pair do (v, _) -> v == List.head(xs) end
          None -> false
          end
      )
    end

  end

  -- ================================================================
  -- Msgpack round-trip properties
  -- ================================================================

  describe "Msgpack" do

    test "Null round-trips" do
      match Msgpack.decode(Msgpack.encode(Msgpack.Null)) do
      Ok(v) -> Test.assert_eq(v, Msgpack.Null, "null round-trip")
      Err(e) -> panic("decode error: " ++ e)
      end
    end

    test "Bool round-trips" do
      Check.all(Gen.bool(), fn b ->
        match Msgpack.decode(Msgpack.encode(Msgpack.Bool(b))) do
        Ok(v) -> v == Msgpack.Bool(b)
        Err(_) -> false
        end
      )
    end

    test "Int fixint range round-trips" do
      Check.all(Gen.int(-32, 127), fn n ->
        match Msgpack.decode(Msgpack.encode(Msgpack.Int(n))) do
        Ok(v) -> v == Msgpack.Int(n)
        Err(_) -> false
        end
      )
    end

    test "Int int32 range round-trips" do
      Check.all(Gen.int(-2147483648, 2147483647), fn n ->
        match Msgpack.decode(Msgpack.encode(Msgpack.Int(n))) do
        Ok(v) -> v == Msgpack.Int(n)
        Err(_) -> false
        end
      )
    end

    test "Int int64 range round-trips" do
      Check.all(Gen.int(-4611686018427387903, 4611686018427387903), fn n ->
        match Msgpack.decode(Msgpack.encode(Msgpack.Int(n))) do
        Ok(v) -> v == Msgpack.Int(n)
        Err(_) -> false
        end
      )
    end

    test "Str round-trips (lowercase ASCII)" do
      Check.all(Gen.lowercase_string(), fn s ->
        match Msgpack.decode(Msgpack.encode(Msgpack.Str(s))) do
        Ok(v) -> v == Msgpack.Str(s)
        Err(_) -> false
        end
      )
    end

    test "Bin round-trips" do
      Check.all(Gen.list(Gen.int(0, 255)), fn bs ->
        match Msgpack.decode(Msgpack.encode(Msgpack.Bin(bs))) do
        Ok(v) -> v == Msgpack.Bin(bs)
        Err(_) -> false
        end
      )
    end

    test "Array of ints round-trips" do
      Check.all(Gen.list(Gen.int(-100, 100)), fn ns ->
        let v = Msgpack.Array(List.map(ns, fn n -> Msgpack.Int(n)))
        match Msgpack.decode(Msgpack.encode(v)) do
        Ok(decoded) -> decoded == v
        Err(_)      -> false
        end
      )
    end

    test "Map with string keys and int values round-trips" do
      Check.all(
        Gen.list(Gen.tuple2(Gen.lowercase_string(), Gen.int(-100, 100))),
        fn pairs ->
          let kvs = List.map(pairs, fn p ->
            match p do (k, v) -> (Msgpack.Str(k), Msgpack.Int(v)) end)
          let msg = Msgpack.Map(kvs)
          match Msgpack.decode(Msgpack.encode(msg)) do
          Ok(decoded) -> decoded == msg
          Err(_)      -> false
          end
      )
    end

    test "encode always produces non-empty bytes" do
      Check.all(Gen.int(-1000000, 1000000), fn n ->
        let bs = Msgpack.encode(Msgpack.Int(n))
        List.length(bs) > 0
      )
    end

    test "fixint range encodes in 1 byte" do
      Check.all(Gen.int(-32, 127), fn n ->
        List.length(Msgpack.encode(Msgpack.Int(n))) == 1
      )
    end

    test "decode_all of encoded list recovers all values" do
      Check.all(Gen.list(Gen.int(-50, 50)), fn ns ->
        let vals = List.map(ns, fn n -> Msgpack.Int(n))
        let bs   = List.fold_left(vals, Nil,
                     fn (acc, v) -> List.append(acc, Msgpack.encode(v)))
        match Msgpack.decode_all(bs) do
        Ok(decoded) ->
          List.length(decoded) == List.length(vals) &&
          List.all(List.zip(decoded, vals), fn p -> match p do (a, b) -> a == b end)
        Err(_)      -> false
        end
      )
    end

  end

end
