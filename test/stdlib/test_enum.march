-- Tests for the Enum stdlib module (higher-order list operations)
-- Run with: dune exec march -- test test/stdlib/test_enum.march

mod TestEnum do

describe "Enum" do

  describe "map" do

    test "map double" do
      let xs = Cons(1, Cons(2, Cons(3, Nil)))
      let doubled = Enum.map(xs, fn x -> x * 2)
      assert (head(doubled) == 2)
      assert (head(tail(doubled)) == 4)
      assert (head(tail(tail(doubled))) == 6)
    end

    test "map empty" do
      let result = Enum.map(Nil, fn (x : Int) -> x * 2)
      assert (length(result) == 0)
    end

    test "map to string" do
      let xs = Cons(1, Cons(2, Nil))
      let strs = Enum.map(xs, fn x -> int_to_string(x))
      assert (head(strs) == "1")
    end

  end

  describe "flat_map" do

    test "flat_map basic" do
      let xs = Cons(1, Cons(2, Cons(3, Nil)))
      let result = Enum.flat_map(xs, fn x -> Cons(x, Cons(x * 10, Nil)))
      assert (length(result) == 6)
      assert (head(result) == 1)
    end

    test "flat_map empty" do
      let result = Enum.flat_map(Nil, fn (x : Int) -> Cons(x, Nil))
      assert (length(result) == 0)
    end

  end

  describe "filter" do

    test "filter even" do
      let xs = Cons(1, Cons(2, Cons(3, Cons(4, Nil))))
      let evens = Enum.filter(xs, fn x -> int_mod(x, 2) == 0)
      assert (length(evens) == 2)
      assert (head(evens) == 2)
    end

    test "filter all pass" do
      let xs = Cons(1, Cons(2, Nil))
      let result = Enum.filter(xs, fn _ -> true)
      assert (length(result) == 2)
    end

    test "filter none pass" do
      let xs = Cons(1, Cons(2, Nil))
      let result = Enum.filter(xs, fn _ -> false)
      assert (length(result) == 0)
    end

  end

  describe "fold" do

    test "fold sum" do
      let xs = Cons(1, Cons(2, Cons(3, Cons(4, Nil))))
      let sum = Enum.fold(0, xs, fn acc -> fn x -> acc + x)
      assert (sum == 10)
    end

    test "fold product" do
      let xs = Cons(1, Cons(2, Cons(3, Cons(4, Nil))))
      let prod = Enum.fold(1, xs, fn acc -> fn x -> acc * x)
      assert (prod == 24)
    end

    test "fold empty" do
      let result = Enum.fold(0, Nil, fn acc -> fn (x : Int) -> acc + x)
      assert (result == 0)
    end

  end

  describe "reduce" do

    test "reduce sum" do
      let xs = Cons(1, Cons(2, Cons(3, Nil)))
      | match Enum.reduce(xs, fn a -> fn b -> a + b) do
      | None -> panic("FAIL: reduce sum returned None")
      | Some(v) -> assert (v == 6)
      end
    end

    test "reduce single" do
      | match Enum.reduce(Cons(42, Nil), fn a -> fn b -> a + b) do
      | None -> panic("FAIL: reduce single returned None")
      | Some(v) -> assert (v == 42)
      end
    end

    test "reduce empty returns None" do
      | match Enum.reduce(Nil, fn (a : Int) -> fn b -> a + b) do
      | None -> ()
      | Some(_) -> panic("FAIL: reduce empty should return None")
      end
    end

  end

  describe "count" do

    test "count" do
      let xs = Cons(1, Cons(2, Cons(3, Nil)))
      assert (Enum.count(xs) == 3)
    end

    test "count empty" do
      assert (Enum.count(Nil) == 0)
    end

  end

  describe "any and all" do

    test "any true" do
      let xs = Cons(1, Cons(2, Cons(3, Nil)))
      | assert Enum.any(xs, fn x -> x > 2)
    end

    test "any false" do
      let xs = Cons(1, Cons(2, Cons(3, Nil)))
      | assert not(Enum.any(xs, fn x -> x > 10))
    end

    test "all true" do
      let xs = Cons(1, Cons(2, Cons(3, Nil)))
      | assert Enum.all(xs, fn x -> x > 0)
    end

    test "all false" do
      let xs = Cons(1, Cons(2, Cons(3, Nil)))
      | assert not(Enum.all(xs, fn x -> x > 1))
    end

  end

  describe "find" do

    test "find existing" do
      let xs = Cons(1, Cons(2, Cons(3, Nil)))
      | match Enum.find(xs, fn x -> x > 1) do
      | None -> panic("FAIL: find existing returned None")
      | Some(v) -> assert (v == 2)
      end
    end

    test "find not found" do
      let xs = Cons(1, Cons(2, Nil))
      | match Enum.find(xs, fn x -> x > 10) do
      | None -> ()
      | Some(_) -> panic("FAIL: find not found returned Some")
      end
    end

  end

  describe "zip_with" do

    test "zip_with basic" do
      let xs = Cons(1, Cons(2, Cons(3, Nil)))
      let ys = Cons(10, Cons(20, Cons(30, Nil)))
      let result = Enum.zip_with(xs, ys, fn x -> fn y -> x + y)
      assert (head(result) == 11)
      assert (length(result) == 3)
    end

  end

  describe "sort_by" do

    test "sort_by ascending" do
      let xs = Cons(3, Cons(1, Cons(2, Nil)))
      let sorted = Enum.sort_by(xs, fn a -> fn b -> a < b)
      assert (head(sorted) == 1)
      assert (head(tail(sorted)) == 2)
      assert (head(tail(tail(sorted))) == 3)
    end

    test "sort_by descending" do
      let xs = Cons(1, Cons(3, Cons(2, Nil)))
      let sorted = Enum.sort_by(xs, fn a -> fn b -> a > b)
      assert (head(sorted) == 3)
    end

  end

end

end
