mod TestCSRF do

-- Helper: build a minimal Conn for testing.
-- fd=0, method=m, path="/", path_info=[], query="",
-- req_headers=hdrs, req_body=body,
-- resp_status=0, resp_headers=[], resp_body="",
-- halted=false, assigns=[], upgrade=NoUpgrade
fn make_conn(m, hdrs, body) do
  Conn(0, m, "/", Nil, "", hdrs, body, 0, Nil, "", false, Nil, NoUpgrade)
end

fn conn_with_token(tok) do
  let c = make_conn(Get, Nil, "")
  HttpServer.assign(c, "_csrf_token", tok)
end

-- -------------------------------------------------------------------------

describe "CSRF.generate_token" do
  test "produces a non-empty string" do
    let tok = CSRF.generate_token()
    assert (String.byte_size(tok) > 0)
  end

  test "produces distinct tokens on each call" do
    let t1 = CSRF.generate_token()
    let t2 = CSRF.generate_token()
    -- Tokens should differ (probability of collision is astronomically low)
    assert (t1 != t2)
  end

  test "produces tokens of reasonable length (base64 of 32 bytes = 44 chars)" do
    let tok = CSRF.generate_token()
    -- base64_encode(32 bytes) = 44 characters (with = padding)
    assert (String.byte_size(tok) >= 40)
  end
end

-- -------------------------------------------------------------------------

describe "CSRF.token" do
  test "returns empty string when no token assigned" do
    let conn = make_conn(Get, Nil, "")
    assert (CSRF.token(conn) == "")
  end

  test "returns the stored token from assigns" do
    let conn = conn_with_token("abc123")
    assert (CSRF.token(conn) == "abc123")
  end
end

-- -------------------------------------------------------------------------

describe "CSRF.ensure_token" do
  test "assigns a token when none is present" do
    let conn = make_conn(Get, Nil, "")
    let conn2 = CSRF.ensure_token(conn)
    assert (CSRF.token(conn2) != "")
  end

  test "is idempotent: does not replace an existing token" do
    let conn = conn_with_token("stable-tok")
    let conn2 = CSRF.ensure_token(conn)
    assert (CSRF.token(conn2) == "stable-tok")
  end

  test "assigns a token that is non-empty" do
    let conn = make_conn(Post, Nil, "")
    let conn2 = CSRF.ensure_token(conn)
    let tok = CSRF.token(conn2)
    assert (String.byte_size(tok) > 0)
  end
end

-- -------------------------------------------------------------------------

describe "CSRF.tag" do
  test "returns IOList containing hidden input" do
    let conn = conn_with_token("tok42")
    let html_str = IOList.to_string(CSRF.tag(conn))
    assert (String.contains(html_str, "name=\"_csrf_token\""))
  end

  test "embeds the token value in the hidden input" do
    let conn = conn_with_token("my-secret-tok")
    let html_str = IOList.to_string(CSRF.tag(conn))
    assert (String.contains(html_str, "value=\"my-secret-tok\""))
  end

  test "uses input type hidden" do
    let conn = conn_with_token("x")
    let html_str = IOList.to_string(CSRF.tag(conn))
    assert (String.contains(html_str, "type=\"hidden\""))
  end

  test "escapes token value containing HTML entities" do
    -- Tokens are base64-encoded bytes; they should not contain < or >
    -- but we test the escape path with a crafted assign
    let conn = conn_with_token("<evil>")
    let html_str = IOList.to_string(CSRF.tag(conn))
    assert (String.contains(html_str, "&lt;evil&gt;"))
    assert (!String.contains(html_str, "<evil>"))
  end
end

-- -------------------------------------------------------------------------

describe "CSRF.tag_string" do
  test "returns a String (same content as tag)" do
    let conn = conn_with_token("tok99")
    let s = CSRF.tag_string(conn)
    assert (String.contains(s, "name=\"_csrf_token\""))
    assert (String.contains(s, "value=\"tok99\""))
  end

  test "returns the same content as IOList.to_string(tag(conn))" do
    let conn = conn_with_token("compare-me")
    let via_tag    = IOList.to_string(CSRF.tag(conn))
    let via_string = CSRF.tag_string(conn)
    assert (via_tag == via_string)
  end
end

-- -------------------------------------------------------------------------

describe "CSRF.validate" do
  test "returns false when no session token assigned" do
    let conn = make_conn(Post, Nil, "_csrf_token=tok")
    assert (!CSRF.validate(conn))
  end

  test "returns false when no body token present" do
    let conn = conn_with_token("tok")
    assert (!CSRF.validate(conn))
  end

  test "returns false when tokens differ" do
    let conn0 = make_conn(Post, Nil, "_csrf_token=wrong")
    let conn  = HttpServer.assign(conn0, "_csrf_token", "correct")
    assert (!CSRF.validate(conn))
  end

  test "returns true when tokens match" do
    let conn0 = make_conn(Post, Nil, "_csrf_token=secret42")
    let conn  = HttpServer.assign(conn0, "_csrf_token", "secret42")
    assert (CSRF.validate(conn))
  end

  test "handles body with multiple fields" do
    let body = "name=alice&_csrf_token=tok&age=30"
    let conn0 = make_conn(Post, Nil, body)
    let conn  = HttpServer.assign(conn0, "_csrf_token", "tok")
    assert (CSRF.validate(conn))
  end

  test "returns true when _csrf_skipped is set" do
    -- Even with mismatched tokens, skip overrides
    let conn0 = make_conn(Post, Nil, "_csrf_token=wrong")
    let conn1 = HttpServer.assign(conn0, "_csrf_token", "correct")
    let conn2 = CSRF.skip(conn1)
    assert (CSRF.validate(conn2))
  end
end

-- -------------------------------------------------------------------------

describe "CSRF.protect — safe methods pass through" do
  test "GET is not checked" do
    let conn = make_conn(Get, Nil, "")
    let result = CSRF.protect(conn)
    -- GET is not halted regardless of token state
    assert (!HttpServer.halted(result))
  end

  test "HEAD is not checked" do
    let conn = make_conn(Head, Nil, "")
    let result = CSRF.protect(conn)
    assert (!HttpServer.halted(result))
  end

  test "OPTIONS is not checked" do
    let conn = make_conn(Options, Nil, "")
    let result = CSRF.protect(conn)
    assert (!HttpServer.halted(result))
  end
end

describe "CSRF.protect — mutating methods require valid token" do
  test "POST with matching token passes" do
    let conn0 = make_conn(Post, Nil, "_csrf_token=tok")
    let conn  = HttpServer.assign(conn0, "_csrf_token", "tok")
    let result = CSRF.protect(conn)
    assert (!HttpServer.halted(result))
  end

  test "PUT with matching token passes" do
    let conn0 = make_conn(Put, Nil, "_csrf_token=tok")
    let conn  = HttpServer.assign(conn0, "_csrf_token", "tok")
    let result = CSRF.protect(conn)
    assert (!HttpServer.halted(result))
  end

  test "PATCH with matching token passes" do
    let conn0 = make_conn(Patch, Nil, "_csrf_token=tok")
    let conn  = HttpServer.assign(conn0, "_csrf_token", "tok")
    let result = CSRF.protect(conn)
    assert (!HttpServer.halted(result))
  end

  test "DELETE with matching token passes" do
    let conn0 = make_conn(Delete, Nil, "_csrf_token=tok")
    let conn  = HttpServer.assign(conn0, "_csrf_token", "tok")
    let result = CSRF.protect(conn)
    assert (!HttpServer.halted(result))
  end

  test "POST with wrong token returns 403" do
    let conn0 = make_conn(Post, Nil, "_csrf_token=wrong")
    let conn  = HttpServer.assign(conn0, "_csrf_token", "correct")
    let result = CSRF.protect(conn)
    assert (HttpServer.status(result) == 403)
  end

  test "POST with missing token returns 403" do
    let conn0 = make_conn(Post, Nil, "name=alice")
    let conn  = HttpServer.assign(conn0, "_csrf_token", "tok")
    let result = CSRF.protect(conn)
    assert (HttpServer.status(result) == 403)
  end

  test "POST with no session token returns 403" do
    let conn = make_conn(Post, Nil, "_csrf_token=tok")
    let result = CSRF.protect(conn)
    assert (HttpServer.status(result) == 403)
  end
end

describe "CSRF.protect — JSON content-type is exempt" do
  test "POST with application/json skips CSRF check" do
    let hdrs = Cons(Header("content-type", "application/json"), Nil)
    let conn = make_conn(Post, hdrs, "{\"key\":\"value\"}")
    -- No token in session or body — but JSON is exempt
    let result = CSRF.protect(conn)
    assert (!HttpServer.halted(result))
    assert (HttpServer.status(result) != 403)
  end

  test "PUT with application/json; charset=utf-8 skips CSRF check" do
    let hdrs = Cons(Header("content-type", "application/json; charset=utf-8"), Nil)
    let conn = make_conn(Put, hdrs, "{}")
    let result = CSRF.protect(conn)
    assert (!HttpServer.halted(result))
  end
end

-- -------------------------------------------------------------------------

describe "CSRF.skip" do
  test "marks conn so validate returns true regardless of token" do
    let conn0 = make_conn(Post, Nil, "_csrf_token=anything")
    let conn1 = HttpServer.assign(conn0, "_csrf_token", "different")
    let conn2 = CSRF.skip(conn1)
    assert (CSRF.validate(conn2))
  end

  test "marks conn so protect passes through on POST" do
    let conn0 = make_conn(Post, Nil, "")
    let conn1 = CSRF.skip(conn0)
    let result = CSRF.protect(conn1)
    assert (!HttpServer.halted(result))
    assert (HttpServer.status(result) != 403)
  end
end

-- -------------------------------------------------------------------------

describe "~H sigil CSRF auto-injection" do
  -- These tests verify that the desugar pass injects CSRF.tag_string(conn)
  -- after <form method="post"> in ~H templates.  We supply a conn with a
  -- known token and confirm the token appears in the rendered HTML.

  test "auto-injects hidden field for method=post" do
    let conn = conn_with_token("csrf-tok-post")
    let html = IOList.to_string(~H"<form method=\"post\" action=\"/\"><input type=\"text\" name=\"x\"></form>")
    assert (String.contains(html, "_csrf_token"))
    assert (String.contains(html, "csrf-tok-post"))
  end

  test "auto-injects hidden field for method=put" do
    let conn = conn_with_token("csrf-tok-put")
    let html = IOList.to_string(~H"<form method=\"put\" action=\"/\"><button>Ok</button></form>")
    assert (String.contains(html, "_csrf_token"))
    assert (String.contains(html, "csrf-tok-put"))
  end

  test "auto-injects hidden field for method=patch" do
    let conn = conn_with_token("csrf-tok-patch")
    let html = IOList.to_string(~H"<form method=\"patch\" action=\"/\"><button>Ok</button></form>")
    assert (String.contains(html, "_csrf_token"))
  end

  test "auto-injects hidden field for method=delete" do
    let conn = conn_with_token("csrf-tok-delete")
    let html = IOList.to_string(~H"<form method=\"delete\" action=\"/\"><button>Delete</button></form>")
    assert (String.contains(html, "_csrf_token"))
  end

  test "does not inject for GET form" do
    let conn = conn_with_token("should-not-appear")
    let html = IOList.to_string(~H"<form method=\"get\" action=\"/search\"><input name=\"q\"></form>")
    assert (!String.contains(html, "_csrf_token"))
  end

  test "does not inject when no method attribute" do
    let conn = conn_with_token("should-not-appear")
    let html = IOList.to_string(~H"<form action=\"/\"><input name=\"q\"></form>")
    -- Default method is GET; no injection expected
    assert (!String.contains(html, "_csrf_token"))
  end

  test "static content before and after form tag is preserved" do
    let conn = conn_with_token("tok")
    let html = IOList.to_string(~H"<div><form method=\"post\" action=\"/\"><input name=\"x\"></form></div>")
    assert (String.contains(html, "<div>"))
    assert (String.contains(html, "</div>"))
    assert (String.contains(html, "name=\"x\""))
    assert (String.contains(html, "_csrf_token"))
  end
end

end
