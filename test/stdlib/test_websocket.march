-- test/stdlib/test_websocket.march
-- Tests for the WebSocket stdlib module.
-- Covers frame type constructors and pattern matching.
-- Network/upgrade calls are not exercised here.
-- Run with: dune exec march -- test test/stdlib/test_websocket.march

mod TestWebSocket do

-- Local mirrors of WebSocket private types (matched structurally at runtime).
ptype WsFrame = TextFrame(String) | BinaryFrame(String) | Ping | Pong | Close(Int, String)
ptype WsSocket = WsSocket(Int)
ptype SelectResult = WsData(WsFrame) | ActorMsg | Timeout

describe "WsFrame constructors" do
  test "TextFrame stores content" do
    let f = TextFrame("hello")
    match f do
    | TextFrame(s) -> assert (s == "hello")
    | _            -> assert false
    end
  end

  test "BinaryFrame stores content" do
    let f = BinaryFrame("\x00\x01\x02")
    match f do
    | BinaryFrame(s) -> assert (s == "\x00\x01\x02")
    | _              -> assert false
    end
  end

  test "Ping constructor" do
    let f = Ping
    match f do
    | Ping -> ()
    | _    -> assert false
    end
  end

  test "Pong constructor" do
    let f = Pong
    match f do
    | Pong -> ()
    | _    -> assert false
    end
  end

  test "Close stores code and reason" do
    let f = Close(1000, "normal closure")
    match f do
    | Close(code, reason) -> do
      assert (code == 1000)
      assert (reason == "normal closure")
    end
    | _ -> assert false
    end
  end

  test "empty TextFrame" do
    let f = TextFrame("")
    match f do
    | TextFrame(s) -> assert (s == "")
    | _            -> assert false
    end
  end

  test "Close code variants" do
    | match Close(1000, "normal") do | Close(c, _) -> assert (c == 1000) | _ -> () end
    | match Close(1001, "going away") do | Close(c, _) -> assert (c == 1001) | _ -> () end
    | match Close(1011, "server error") do | Close(c, _) -> assert (c == 1011) | _ -> () end
  end
end

describe "WsSocket constructor" do
  test "WsSocket stores fd" do
    let s = WsSocket(42)
    match s do
    | WsSocket(fd) -> assert (fd == 42)
    end
  end
end

describe "SelectResult constructors" do
  test "WsData wraps a frame" do
    let r = WsData(TextFrame("hi"))
    match r do
    | WsData(f) -> do
      match f do
      | TextFrame(s) -> assert (s == "hi")
      | _            -> assert false
      end
    end
    | _ -> assert false
    end
  end

  test "ActorMsg constructor" do
    let r = ActorMsg
    match r do
    | ActorMsg -> ()
    | _        -> assert false
    end
  end

  test "Timeout constructor" do
    let r = Timeout
    match r do
    | Timeout -> ()
    | _       -> assert false
    end
  end
end

pfn is_text_frame(f) do
  match f do
  | TextFrame(_) -> true
  | _            -> false
  end
end

pfn is_control_frame(f) do
  match f do
  | Ping        -> true
  | Pong        -> true
  | Close(_, _) -> true
  | _           -> false
  end
end

describe "WsFrame predicates" do
  test "TextFrame is text, others are not" do
    assert (is_text_frame(TextFrame("hi")))
    assert (not (is_text_frame(BinaryFrame("hi"))))
    assert (not (is_text_frame(Ping)))
  end

  test "Ping Pong Close are control frames" do
    assert (is_control_frame(Ping))
    assert (is_control_frame(Pong))
    assert (is_control_frame(Close(1000, "")))
    assert (not (is_control_frame(TextFrame("x"))))
  end
end

end
