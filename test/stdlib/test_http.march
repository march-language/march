-- test/stdlib/test_http.march
-- Tests for the Http stdlib module.
-- Covers method helpers, status helpers, request/response constructors,
-- accessors, transforms, URL parsing, and query-string encoding.
-- Run with: dune exec march -- test test/stdlib/test_http.march

mod TestHttp do

pfn make_test_req() do
  Request(Get, SchemeHttp, "example.com", Some(8080), "/foo", Some("q=1"),
          Cons(Header("content-type", "text/plain"), Nil), "body")
end

pfn make_test_resp() do
  Response(Status(200), Cons(Header("content-type", "application/json"), Nil), "{}")
end

describe "Http method helpers" do
  test "Get to string" do
    assert (Http.method_to_string(Get) == "GET")
  end

  test "Post to string" do
    assert (Http.method_to_string(Post) == "POST")
  end

  test "Put to string" do
    assert (Http.method_to_string(Put) == "PUT")
  end

  test "Patch to string" do
    assert (Http.method_to_string(Patch) == "PATCH")
  end

  test "Delete to string" do
    assert (Http.method_to_string(Delete) == "DELETE")
  end

  test "Head to string" do
    assert (Http.method_to_string(Head) == "HEAD")
  end

  test "Options to string" do
    assert (Http.method_to_string(Options) == "OPTIONS")
  end

  test "Trace to string" do
    assert (Http.method_to_string(Trace) == "TRACE")
  end

  test "Connect to string" do
    assert (Http.method_to_string(Connect) == "CONNECT")
  end

  test "Other to string" do
    assert (Http.method_to_string(Other("CUSTOM")) == "CUSTOM")
  end
end

describe "Http status helpers" do
  test "status_ok is 200" do
    assert (Http.status_code(Http.status_ok()) == 200)
  end

  test "status_created is 201" do
    assert (Http.status_code(Http.status_created()) == 201)
  end

  test "status_no_content is 204" do
    assert (Http.status_code(Http.status_no_content()) == 204)
  end

  test "status_moved is 301" do
    assert (Http.status_code(Http.status_moved()) == 301)
  end

  test "status_found is 302" do
    assert (Http.status_code(Http.status_found()) == 302)
  end

  test "status_bad_request is 400" do
    assert (Http.status_code(Http.status_bad_request()) == 400)
  end

  test "status_unauthorized is 401" do
    assert (Http.status_code(Http.status_unauthorized()) == 401)
  end

  test "status_forbidden is 403" do
    assert (Http.status_code(Http.status_forbidden()) == 403)
  end

  test "status_not_found is 404" do
    assert (Http.status_code(Http.status_not_found()) == 404)
  end

  test "status_server_error is 500" do
    assert (Http.status_code(Http.status_server_error()) == 500)
  end

  test "is_informational 100-199" do
    assert (Http.is_informational(Status(100)))
    assert (Http.is_informational(Status(199)))
    assert (not (Http.is_informational(Status(200))))
  end

  test "is_success 200-299" do
    assert (Http.is_success(Status(200)))
    assert (Http.is_success(Status(201)))
    assert (Http.is_success(Status(299)))
    assert (not (Http.is_success(Status(300))))
  end

  test "is_redirect 300-399" do
    assert (Http.is_redirect(Status(301)))
    assert (Http.is_redirect(Status(302)))
    assert (not (Http.is_redirect(Status(200))))
  end

  test "is_client_error 400-499" do
    assert (Http.is_client_error(Status(400)))
    assert (Http.is_client_error(Status(404)))
    assert (not (Http.is_client_error(Status(500))))
  end

  test "is_server_error 500-599" do
    assert (Http.is_server_error(Status(500)))
    assert (Http.is_server_error(Status(503)))
    assert (not (Http.is_server_error(Status(404))))
  end
end

describe "Http request accessors" do
  test "method accessor returns method" do
    let req = make_test_req()
    assert (Http.method_to_string(Http.method(req)) == "GET")
  end

  test "host accessor" do
    let req = make_test_req()
    assert (Http.host(req) == "example.com")
  end

  test "path accessor" do
    let req = make_test_req()
    assert (Http.path(req) == "/foo")
  end

  test "port accessor returns Some port" do
    let req = make_test_req()
    assert (Http.port(req) == Some(8080))
  end

  test "query accessor returns Some query" do
    let req = make_test_req()
    assert (Http.query(req) == Some("q=1"))
  end

  test "body accessor" do
    let req = make_test_req()
    assert (Http.body(req) == "body")
  end
end

describe "Http request transforms" do
  test "set_method changes method" do
    let req = make_test_req()
    let req2 = Http.set_method(req, Post)
    assert (Http.method_to_string(Http.method(req2)) == "POST")
  end

  test "set_host changes host" do
    let req = make_test_req()
    let req3 = Http.set_host(req, "other.com")
    assert (Http.host(req3) == "other.com")
  end

  test "set_path changes path" do
    let req = make_test_req()
    let req4 = Http.set_path(req, "/bar")
    assert (Http.path(req4) == "/bar")
  end

  test "set_port changes port" do
    let req = make_test_req()
    let req5 = Http.set_port(req, 9090)
    assert (Http.port(req5) == Some(9090))
  end

  test "set_body changes body" do
    let req = make_test_req()
    let req6 = Http.set_body(req, "new_body")
    assert (Http.body(req6) == "new_body")
  end

  test "set_header adds header case-insensitively accessible" do
    let req = Request(Get, SchemeHttp, "example.com", None, "/", None, Nil, "")
    let req2 = Http.set_header(req, "X-Token", "abc123")
    assert (Http.get_request_header(req2, "X-Token") == Some("abc123"))
    assert (Http.get_request_header(req2, "x-token") == Some("abc123"))
    assert (not (is_nil(Http.headers(req2))))
  end

  test "set_header strips CR from header value (CRLF injection defence)" do
    let req = Request(Get, SchemeHttp, "example.com", None, "/", None, Nil, "")
    let req2 = Http.set_header(req, "X-Evil", "abc\rX-Injected: yes")
    assert (Http.get_request_header(req2, "X-Evil") == Some("abcX-Injected: yes"))
  end

  test "set_header strips LF from header value" do
    let req = Request(Get, SchemeHttp, "example.com", None, "/", None, Nil, "")
    let req2 = Http.set_header(req, "X-Evil", "abc\nX-Injected: yes")
    assert (Http.get_request_header(req2, "X-Evil") == Some("abcX-Injected: yes"))
  end

  test "set_header strips NUL from header name and value" do
    let req = Request(Get, SchemeHttp, "example.com", None, "/", None, Nil, "")
    let req2 = Http.set_header(req, "X-\x00Name", "v\x00alue")
    assert (Http.get_request_header(req2, "X-Name") == Some("value"))
  end

  test "set_header strips CRLF from header name" do
    let req = Request(Get, SchemeHttp, "example.com", None, "/", None, Nil, "")
    let req2 = Http.set_header(req, "X-\r\nInjected", "ok")
    assert (Http.get_request_header(req2, "X-Injected") == Some("ok"))
  end
end

describe "Http response accessors" do
  test "response_status_code" do
    let resp = make_test_resp()
    assert (Http.response_status_code(resp) == 200)
  end

  test "response_is_success for 200" do
    let resp = make_test_resp()
    assert (Http.response_is_success(resp))
  end

  test "response_is_redirect false for 200" do
    let resp = make_test_resp()
    assert (not (Http.response_is_redirect(resp)))
  end

  test "response_body" do
    let resp = make_test_resp()
    assert (Http.response_body(resp) == "{}")
  end

  test "get_header present lowercase" do
    let resp = make_test_resp()
    assert (Http.get_header(resp, "content-type") == Some("application/json"))
  end

  test "get_header case insensitive" do
    let resp = make_test_resp()
    assert (Http.get_header(resp, "Content-Type") == Some("application/json"))
  end

  test "get_header missing returns None" do
    let resp = make_test_resp()
    assert (Http.get_header(resp, "x-missing") == None)
  end
end

describe "Http URL parsing" do
  test "parse http url" do
    let req = match Http.parse_url("http://example.com/path") do
      Ok(r)  -> r
      Err(_) -> panic("parse http url: expected Ok")
    end
    assert (Http.host(req) == "example.com")
    assert (Http.path(req) == "/path")
    assert (Http.port(req) == None)
  end

  test "parse https url" do
    let req = match Http.parse_url("https://api.example.com/v1") do
      Ok(r)  -> r
      Err(_) -> panic("parse https url: expected Ok")
    end
    assert (Http.host(req) == "api.example.com")
    assert (Http.path(req) == "/v1")
  end

  test "parse url with port" do
    let req = match Http.parse_url("http://localhost:3000/hello") do
      Ok(r)  -> r
      Err(_) -> panic("parse url with port: expected Ok")
    end
    assert (Http.host(req) == "localhost")
    assert (Http.port(req) == Some(3000))
  end

  test "parse url with query string" do
    let req = match Http.parse_url("http://example.com/search?q=march&limit=10") do
      Ok(r)  -> r
      Err(_) -> panic("parse url with query: expected Ok")
    end
    assert (Http.path(req) == "/search")
    assert (Http.query(req) == Some("q=march&limit=10"))
  end

  test "invalid scheme returns Err" do
    match Http.parse_url("ftp://example.com") do
    Err(_) -> ()
    Ok(_)  -> assert false
    end
  end

  test "missing host returns Err" do
    match Http.parse_url("http:///path") do
    Err(_) -> ()
    Ok(_)  -> assert false
    end
  end
end

describe "Http convenience constructors" do
  test "Http.get creates GET request" do
    let req = match Http.get("http://example.com/") do
      Ok(r)  -> r
      Err(_) -> panic("Http.get: expected Ok")
    end
    assert (Http.method_to_string(Http.method(req)) == "GET")
  end

  test "Http.post creates POST with body" do
    let req = match Http.post("http://example.com/", "payload") do
      Ok(r)  -> r
      Err(_) -> panic("Http.post: expected Ok")
    end
    assert (Http.method_to_string(Http.method(req)) == "POST")
    assert (Http.body(req) == "payload")
  end

  test "Http.delete creates DELETE request" do
    let req = match Http.delete("http://example.com/res/1") do
      Ok(r)  -> r
      Err(_) -> panic("Http.delete: expected Ok")
    end
    assert (Http.method_to_string(Http.method(req)) == "DELETE")
  end
end

describe "Http query encoding" do
  test "encode_query empty list" do
    assert (Http.encode_query(Nil) == "")
  end

  test "encode_query one pair" do
    assert (Http.encode_query(Cons(("key", "val"), Nil)) == "key=val")
  end

  test "encode_query two pairs" do
    assert (Http.encode_query(Cons(("a", "1"), Cons(("b", "2"), Nil))) == "a=1&b=2")
  end

  test "set_query empty params clears query" do
    let req = Request(Get, SchemeHttp, "example.com", None, "/", Some("old=1"), Nil, "")
    let req2 = Http.set_query(req, Nil)
    assert (Http.query(req2) == None)
  end

  test "set_query adds params" do
    let req = Request(Get, SchemeHttp, "example.com", None, "/", None, Nil, "")
    let req2 = Http.set_query(req, Cons(("page", "2"), Nil))
    assert (Http.query(req2) == Some("page=2"))
  end
end

end
