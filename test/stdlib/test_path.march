-- test/stdlib/test_path.march
-- Tests for the Path module (pure string operations).
-- Run with: dune exec march -- test test/stdlib/test_path.march

mod TestPath do

describe "Path.join" do
  test "basic join" do
    assert (Path.join("foo", "bar") == "foo/bar")
  end

  test "trailing slash on left" do
    assert (Path.join("foo/", "bar") == "foo/bar")
  end

  test "nested left" do
    assert (Path.join("a/b/c", "d") == "a/b/c/d")
  end

  test "absolute left" do
    assert (Path.join("/usr", "local") == "/usr/local")
  end
end

describe "Path.is_absolute" do
  test "root is absolute" do
    assert (Path.is_absolute("/"))
  end

  test "/usr/local is absolute" do
    assert (Path.is_absolute("/usr/local"))
  end

  test "relative path is not absolute" do
    assert (not (Path.is_absolute("foo/bar")))
  end

  test "empty string is not absolute" do
    assert (not (Path.is_absolute("")))
  end
end

describe "Path.basename" do
  test "file in directory" do
    assert (Path.basename("/foo/bar/baz.txt") == "baz.txt")
  end

  test "no directory component" do
    assert (Path.basename("file.txt") == "file.txt")
  end

  test "dotfile" do
    assert (Path.basename("/home/.bashrc") == ".bashrc")
  end
end

describe "Path.dirname" do
  test "basic dirname" do
    assert (Path.dirname("/foo/bar/baz.txt") == "/foo/bar")
  end

  test "single depth" do
    assert (Path.dirname("/foo") == "/")
  end

  test "relative path" do
    assert (Path.dirname("a/b/c") == "a/b")
  end

  test "no slash returns dot" do
    assert (Path.dirname("file.txt") == ".")
  end
end

describe "Path.extension" do
  test "png extension" do
    assert (Path.extension("photo.png") == "png")
  end

  test "txt extension" do
    assert (Path.extension("readme.txt") == "txt")
  end

  test "no extension returns empty" do
    assert (Path.extension("Makefile") == "")
  end

  test "dotfile has no extension" do
    assert (Path.extension(".bashrc") == "")
  end

  test "double suffix returns last" do
    assert (Path.extension("archive.tar.gz") == "gz")
  end

  test "extension from full path" do
    assert (Path.extension("/usr/local/lib.so") == "so")
  end
end

describe "Path.strip_extension" do
  test "basic strip" do
    assert (Path.strip_extension("photo.png") == "photo")
  end

  test "strip with directory" do
    assert (Path.strip_extension("/usr/photo.png") == "/usr/photo")
  end

  test "no extension unchanged" do
    assert (Path.strip_extension("Makefile") == "Makefile")
  end

  test "dotfile unchanged" do
    assert (Path.strip_extension(".bashrc") == ".bashrc")
  end

  test "double suffix strips last" do
    assert (Path.strip_extension("archive.tar.gz") == "archive.tar")
  end
end

describe "Path.components" do
  test "absolute path components" do
    let comps = Path.components("/usr/local/bin")
    assert (List.length(comps) == 3)
    assert (List.nth(comps, 0) == "usr")
    assert (List.nth(comps, 1) == "local")
    assert (List.nth(comps, 2) == "bin")
  end

  test "relative path components count" do
    let comps = Path.components("a/b")
    assert (List.length(comps) == 2)
  end

  test "root has no components" do
    let comps = Path.components("/")
    assert (List.length(comps) == 0)
  end

  test "double slash deduplicated" do
    let comps = Path.components("a//b")
    assert (List.length(comps) == 2)
  end
end

describe "Path.normalize" do
  test "dot-dot collapses" do
    assert (Path.normalize("a/../b/./c") == "b/c")
  end

  test "absolute excess dot-dot clamped to root" do
    assert (Path.normalize("/a/../../../b") == "/b")
  end

  test "already clean unchanged" do
    assert (Path.normalize("a/b/c") == "a/b/c")
  end

  test "trailing dot removed" do
    assert (Path.normalize("a/b/.") == "a/b")
  end

  test "single dot stays" do
    assert (Path.normalize(".") == ".")
  end

  test "absolute dot-dot in middle" do
    assert (Path.normalize("/usr/local/../share") == "/usr/share")
  end

  test "leading dot-dot relative preserved" do
    assert (Path.normalize("../foo") == "../foo")
  end
end

end
