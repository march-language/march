-- Tests for the Bytes stdlib module
-- Run with: dune exec march -- test test/stdlib/test_bytes.march

mod TestBytes do

describe "Bytes" do

  describe "empty and is_empty" do

    test "empty is empty" do
      let b = Bytes.empty()
      assert Bytes.is_empty(b)
      assert (Bytes.length(b) == 0)
    end

  end

  describe "from_string and to_string" do

    test "from_string roundtrip" do
      let bs = Bytes.from_string("hello")
      assert (Bytes.to_string(bs) == "hello")
    end

    test "from_string length" do
      let bs = Bytes.from_string("hello")
      assert (Bytes.length(bs) == 5)
    end

    test "from_string get bytes" do
      let bs = Bytes.from_string("ABC")
      assert (Bytes.get(bs, 0) == 65)
      assert (Bytes.get(bs, 1) == 66)
      assert (Bytes.get(bs, 2) == 67)
    end

    test "from_string empty" do
      let bs = Bytes.from_string("")
      assert Bytes.is_empty(bs)
    end

  end

  describe "from_list and to_list" do

    test "from_list roundtrip" do
      let xs = Cons(72, Cons(101, Cons(108, Cons(108, Cons(111, Nil)))))
      let b = Bytes.from_list(xs)
      assert (Bytes.to_string(b) == "Hello")
    end

    test "to_list" do
      let b = Bytes.from_string("AB")
      let xs = Bytes.to_list(b)
      assert (List.length(xs) == 2)
      assert (List.nth(xs, 0) == 65)
      assert (List.nth(xs, 1) == 66)
    end

  end

  describe "get and length" do

    test "get individual bytes" do
      let b = Bytes.from_string("hello")
      assert (Bytes.get(b, 0) == 104)
      assert (Bytes.get(b, 1) == 101)
      assert (Bytes.length(b) == 5)
    end

  end

  describe "slice" do

    test "slice from start" do
      let b = Bytes.from_string("hello world")
      let s = Bytes.slice(b, 0, 5)
      assert (Bytes.to_string(s) == "hello")
      assert (Bytes.length(s) == 5)
    end

    test "slice from middle" do
      let b = Bytes.from_string("hello world")
      let s = Bytes.slice(b, 6, 5)
      assert (Bytes.to_string(s) == "world")
    end

    test "slice empty" do
      let b = Bytes.from_string("hello")
      let s = Bytes.slice(b, 0, 0)
      assert Bytes.is_empty(s)
    end

  end

  describe "concat" do

    test "concat two bytes" do
      let b1 = Bytes.from_string("foo")
      let b2 = Bytes.from_string("bar")
      let bc = Bytes.concat(b1, b2)
      assert (Bytes.length(bc) == 6)
      assert (Bytes.to_string(bc) == "foobar")
    end

    test "concat with empty" do
      let b = Bytes.from_string("foo")
      let e = Bytes.empty()
      assert (Bytes.to_string(Bytes.concat(e, b)) == "foo")
      assert (Bytes.to_string(Bytes.concat(b, e)) == "foo")
    end

  end

  describe "hex encoding" do

    test "to_hex" do
      let b = Bytes.from_list(Cons(0, Cons(255, Cons(16, Nil))))
      let h = Bytes.to_hex(b)
      assert (h == "00ff10")
    end

    test "from_hex roundtrip" do
      let b = Bytes.from_string("hello")
      let hex = Bytes.to_hex(b)
      match Bytes.from_hex(hex) do
      | Err(e) -> panic("from_hex failed: " ++ e)
      | Ok(b2) -> assert (Bytes.to_string(b2) == "hello")
      end
    end

    test "from_hex invalid returns Err" do
      match Bytes.from_hex("xyz") do
      | Err(_) -> ()
      | Ok(_) -> panic("invalid hex should return Err")
      end
    end

    test "from_hex odd length returns Err" do
      match Bytes.from_hex("abc") do
      | Err(_) -> ()
      | Ok(_) -> panic("odd-length hex should return Err")
      end
    end

  end

  describe "base64 encoding" do

    test "encode_base64 and decode_base64 roundtrip" do
      let b = Bytes.from_string("hello")
      let encoded = Bytes.encode_base64(b)
      match Bytes.decode_base64(encoded) do
      | Err(e) -> panic("decode_base64 failed: " ++ e)
      | Ok(b2) -> assert (Bytes.to_string(b2) == "hello")
      end
    end

    test "encode_base64 empty" do
      let b = Bytes.empty()
      let encoded = Bytes.encode_base64(b)
      assert (encoded == "")
    end

    test "decode_base64 invalid returns Err" do
      match Bytes.decode_base64("!!!") do
      | Err(_) -> ()
      | Ok(_) -> panic("invalid base64 should return Err")
      end
    end

  end

  describe "encode_utf8 and decode_utf8" do

    test "encode_utf8 roundtrip" do
      let b = Bytes.encode_utf8("hello")
      assert (Bytes.to_string(b) == "hello")
    end

    test "decode_utf8" do
      let b = Bytes.from_string("world")
      match Bytes.decode_utf8(b) do
      | Err(e) -> panic("decode_utf8 failed: " ++ e)
      | Ok(s) -> assert (s == "world")
      end
    end

  end

end

end
