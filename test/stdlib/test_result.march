-- Tests for the Result stdlib module
-- Run with: dune exec march -- test test/stdlib/test_result.march

mod TestResult do

describe "is_ok" do
  test "is_ok returns true for Ok" do
    assert Result.is_ok(Ok(42))
  end

  test "is_ok returns false for Err" do
    assert !Result.is_ok(Err("error"))
  end
end

describe "is_err" do
  test "is_err returns true for Err" do
    assert Result.is_err(Err("oops"))
  end

  test "is_err returns false for Ok" do
    assert !Result.is_err(Ok(1))
  end
end

describe "unwrap" do
  test "unwrap extracts Ok value" do
    assert (Result.unwrap(Ok(7)) == 7)
  end

  test "unwrap of Ok(0) is 0" do
    assert (Result.unwrap(Ok(0)) == 0)
  end
end

describe "expect" do
  test "expect extracts Ok value" do
    assert (Result.expect(Ok(99), "should not panic") == 99)
  end
end

describe "unwrap_err" do
  test "unwrap_err extracts Err value" do
    assert (Result.unwrap_err(Err("boom")) == "boom")
  end
end

describe "unwrap_or" do
  test "unwrap_or returns Ok value" do
    assert (Result.unwrap_or(Ok(5), 0) == 5)
  end

  test "unwrap_or returns default for Err" do
    assert (Result.unwrap_or(Err("bad"), 42) == 42)
  end
end

describe "map" do
  test "map transforms Ok value" do
    assert (Result.unwrap(Result.map(Ok(3), fn x -> x * 2)) == 6)
  end

  test "map leaves Err unchanged" do
    assert Result.is_err(Result.map(Err("e"), fn (x : Int) -> x + 1))
  end
end

describe "map_err" do
  test "map_err leaves Ok unchanged" do
    assert Result.is_ok(Result.map_err(Ok(10), fn (e : String) -> "mapped: " ++ e))
  end

  test "map_err transforms Err value" do
    assert Result.is_err(Result.map_err(Err("old"), fn e -> "new: " ++ e))
  end
end

describe "flat_map" do
  test "flat_map Ok to Ok" do
    assert (Result.unwrap(Result.flat_map(Ok(4), fn x -> Ok(x + 1))) == 5)
  end

  test "flat_map Ok to Err gives Err" do
    assert Result.is_err(Result.flat_map(Ok(1), fn (x : Int) -> Err("fail")))
  end

  test "flat_map Err gives Err" do
    assert Result.is_err(Result.flat_map(Err("e"), fn (x : Int) -> Ok(x)))
  end
end

describe "or_else" do
  test "or_else returns original Ok" do
    assert (Result.unwrap(Result.or_else(Ok(3), fn (e : String) -> Ok(99))) == 3)
  end

  test "or_else calls function for Err" do
    assert (Result.unwrap(Result.or_else(Err("e"), fn _e -> Ok(7))) == 7)
  end
end

describe "collect" do
  test "collect all Ok gives Ok list" do
    let results = Cons(Ok(1), Cons(Ok(2), Cons(Ok(3), Nil)))
    match Result.collect(results) do
    Ok(lst) -> do
      assert (length(lst) == 3)
      assert (head(lst) == 1)
    end
    Err(_) -> assert false
    end
  end

  test "collect empty list gives Ok empty list" do
    match Result.collect(Nil) do
    Ok(lst) -> assert (length(lst) == 0)
    Err(_) -> assert false
    end
  end

  test "collect with Err gives Err" do
    let results = Cons(Ok(1), Cons(Err("oops"), Cons(Ok(3), Nil)))
    assert Result.is_err(Result.collect(results))
  end
end

describe "to_option" do
  test "to_option of Ok gives Some" do
    assert Option.is_some(Result.to_option(Ok(5)))
  end

  test "to_option of Err gives None" do
    assert Option.is_none(Result.to_option(Err("e")))
  end
end

end
