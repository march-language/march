-- Tests for Depot.Query — composable lazy query builder.

mod TestDepotQuery do

-- Helper schema for tests
fn user_schema() do
  Depot.Schema.define("users", {
    fields = {
      id   = "UUID",
      name = "String",
      age  = "Int",
      active = "Bool"
    }
  })
end

-- Build sample rows
fn sample_rows() do
  [
    { id = "1", name = "Alice",   age = 30, active = true },
    { id = "2", name = "Bob",     age = 25, active = false },
    { id = "3", name = "Charlie", age = 35, active = true },
    { id = "4", name = "Diana",   age = 28, active = true },
    { id = "5", name = "Eve",     age = 22, active = false }
  ]
end

test "from creates a query" do
  let q = Depot.Query.from(user_schema())
  let s = Depot.Query.schema(q)
  assert Depot.Schema.table(s) == "users"
end

test "execute with no operations returns all rows" do
  let q = Depot.Query.from(user_schema())
  let rows = sample_rows()
  let results = Depot.Query.execute(q, rows)
  assert List.length(results) == 5
end

test "where_ filters rows" do
  let q = Depot.Query.from(user_schema())
    |> Depot.Query.where_(fn row -> match record_get(row, "active") do
      Some(true) -> true
      _ -> false
    end)
  let results = Depot.Query.execute(q, sample_rows())
  assert List.length(results) == 3
end

test "multiple where_ calls are AND-combined" do
  let q = Depot.Query.from(user_schema())
    |> Depot.Query.where_(fn row -> match record_get(row, "active") do
      Some(true) -> true
      _ -> false
    end)
    |> Depot.Query.where_(fn row -> match record_get(row, "age") do
      Some(a) -> a > 28
      _ -> false
    end)
  let results = Depot.Query.execute(q, sample_rows())
  -- Alice (30, active) and Charlie (35, active)
  assert List.length(results) == 2
end

test "limit restricts result count" do
  let q = Depot.Query.from(user_schema())
    |> Depot.Query.limit(2)
  let results = Depot.Query.execute(q, sample_rows())
  assert List.length(results) == 2
end

test "offset skips rows" do
  let q = Depot.Query.from(user_schema())
    |> Depot.Query.offset(3)
  let results = Depot.Query.execute(q, sample_rows())
  assert List.length(results) == 2
end

test "limit and offset combine" do
  let q = Depot.Query.from(user_schema())
    |> Depot.Query.offset(1)
    |> Depot.Query.limit(2)
  let results = Depot.Query.execute(q, sample_rows())
  assert List.length(results) == 2
end

test "order_asc sorts ascending" do
  let q = Depot.Query.from(user_schema())
    |> Depot.Query.order_asc("age")
  let results = Depot.Query.execute(q, sample_rows())
  let first = List.head(results)
  assert record_get(first, "name") == Some("Eve")
end

test "order_desc sorts descending" do
  let q = Depot.Query.from(user_schema())
    |> Depot.Query.order_desc("age")
  let results = Depot.Query.execute(q, sample_rows())
  let first = List.head(results)
  assert record_get(first, "name") == Some("Charlie")
end

test "select projects rows" do
  let q = Depot.Query.from(user_schema())
    |> Depot.Query.select(fn row -> match record_get(row, "name") do
      Some(n) -> n
      None -> "unknown"
    end)
    |> Depot.Query.limit(1)
  let results = Depot.Query.execute(q, sample_rows())
  let first = List.head(results)
  assert first == "Alice"
end

test "count returns number of matching rows" do
  let q = Depot.Query.from(user_schema())
    |> Depot.Query.where_(fn row -> match record_get(row, "active") do
      Some(true) -> true
      _ -> false
    end)
  let n = Depot.Query.count(q, sample_rows())
  assert n == 3
end

test "exists returns true when results exist" do
  let q = Depot.Query.from(user_schema())
    |> Depot.Query.where_(fn row -> match record_get(row, "active") do
      Some(true) -> true
      _ -> false
    end)
  assert Depot.Query.exists(q, sample_rows()) == true
end

test "exists returns false when no results" do
  let q = Depot.Query.from(user_schema())
    |> Depot.Query.where_(fn row -> match record_get(row, "age") do
      Some(a) -> a > 100
      _ -> false
    end)
  assert Depot.Query.exists(q, sample_rows()) == false
end

test "first returns Some for matching query" do
  let q = Depot.Query.from(user_schema())
    |> Depot.Query.order_asc("age")
  let result = Depot.Query.first(q, sample_rows())
  match result do
    Some(row) -> assert record_get(row, "name") == Some("Eve")
    None -> assert false
  end
end

test "first returns None for empty results" do
  let q = Depot.Query.from(user_schema())
    |> Depot.Query.where_(fn row -> match record_get(row, "age") do
      Some(a) -> a > 100
      _ -> false
    end)
  let result = Depot.Query.first(q, sample_rows())
  assert result == None
end

test "full pipeline: where + order + offset + limit + select" do
  let q = Depot.Query.from(user_schema())
    |> Depot.Query.where_(fn row -> match record_get(row, "active") do
      Some(true) -> true
      _ -> false
    end)
    |> Depot.Query.order_asc("age")
    |> Depot.Query.offset(1)
    |> Depot.Query.limit(1)
    |> Depot.Query.select(fn row -> match record_get(row, "name") do
      Some(n) -> n
      None -> "unknown"
    end)
  let results = Depot.Query.execute(q, sample_rows())
  -- Active sorted by age: Diana(28), Alice(30), Charlie(35)
  -- Offset 1 -> Alice(30), Charlie(35)
  -- Limit 1 -> Alice(30)
  assert List.length(results) == 1
  assert List.head(results) == "Alice"
end

end
