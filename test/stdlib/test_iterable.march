-- Tests for the Iterable stdlib module
-- Run with: dune exec march -- test test/stdlib/test_iterable.march

mod TestIterable do

describe "map" do
  test "map on empty list" do
    let empty : List(Int) = Nil
    assert (Iterable.map(empty, fn x -> x + 1) == Nil)
  end

  test "map identity is identity" do
    assert (Iterable.map([1, 2, 3], fn x -> x) == [1, 2, 3])
  end

  test "map transforms elements" do
    assert (Iterable.map([1, 2, 3], fn x -> x * 2) == [2, 4, 6])
  end

  test "map on singleton" do
    assert (Iterable.map([5], fn x -> x * 3) == [15])
  end

  test "map preserves order" do
    assert (Iterable.map([3, 1, 2], fn x -> x + 10) == [13, 11, 12])
  end

  test "map to different type" do
    assert (Iterable.map([1, 2, 3], fn x -> int_to_string(x)) == ["1", "2", "3"])
  end

  test "map does not change length" do
    assert (Iterable.count(Iterable.map([1, 2, 3, 4, 5], fn x -> x)) == 5)
  end
end

describe "flat_map" do
  test "flat_map on empty list" do
    let empty : List(Int) = Nil
    assert (Iterable.flat_map(empty, fn x -> [x]) == Nil)
  end

  test "flat_map returning empty lists flattens to empty" do
    assert (Iterable.flat_map([1, 2, 3], fn _ -> Nil) == Nil)
  end

  test "flat_map returning single-element lists" do
    assert (Iterable.flat_map([1, 2, 3], fn x -> [x * 2]) == [2, 4, 6])
  end

  test "flat_map returning multiple-element lists" do
    assert (Iterable.flat_map([1, 2], fn x -> [x, x * 10]) == [1, 10, 2, 20])
  end

  test "flat_map on singleton returning multiple elements" do
    assert (Iterable.flat_map([5], fn x -> [x, x + 1, x + 2]) == [5, 6, 7])
  end

  test "flat_map returning mixed empty and non-empty" do
    assert (Iterable.flat_map([1, 2, 3], fn x -> if x == 2 do Nil else [x] end) == [1, 3])
  end
end

describe "filter" do
  test "filter on empty list" do
    let empty : List(Int) = Nil
    assert (Iterable.filter(empty, fn x -> x > 0) == Nil)
  end

  test "filter keeping all elements" do
    assert (Iterable.filter([1, 2, 3], fn x -> x > 0) == [1, 2, 3])
  end

  test "filter keeping no elements" do
    assert (Iterable.filter([1, 2, 3], fn x -> x > 10) == Nil)
  end

  test "filter keeping some elements" do
    assert (Iterable.filter([1, 2, 3, 4, 5], fn x -> x > 3) == [4, 5])
  end

  test "filter preserves relative order" do
    assert (Iterable.filter([5, 1, 4, 2, 3], fn x -> x > 2) == [5, 4, 3])
  end

  test "filter on singleton that matches" do
    assert (Iterable.filter([42], fn x -> x == 42) == [42])
  end

  test "filter on singleton that does not match" do
    assert (Iterable.filter([42], fn x -> x == 0) == Nil)
  end

  test "filter by even" do
    assert (Iterable.filter([1, 2, 3, 4, 5, 6], fn x -> x % 2 == 0) == [2, 4, 6])
  end
end

describe "fold" do
  test "fold on empty list returns zero" do
    let empty : List(Int) = Nil
    assert (Iterable.fold(0, empty, fn (acc, x) -> acc + x) == 0)
  end

  test "fold sum of list" do
    assert (Iterable.fold(0, [1, 2, 3, 4, 5], fn (acc, x) -> acc + x) == 15)
  end

  test "fold singleton" do
    assert (Iterable.fold(0, [42], fn (acc, x) -> acc + x) == 42)
  end

  test "fold is left-associative" do
    -- (((10 - 1) - 2) - 3) = 4
    assert (Iterable.fold(10, [1, 2, 3], fn (acc, x) -> acc - x) == 4)
  end

  test "fold builds string in order" do
    assert (Iterable.fold("", ["a", "b", "c"], fn (acc, x) -> acc ++ x) == "abc")
  end

  test "fold count elements" do
    assert (Iterable.fold(0, [1, 2, 3, 4], fn (acc, x) -> acc + 1) == 4)
  end

  test "fold with non-zero initial value" do
    assert (Iterable.fold(100, [1, 2, 3], fn (acc, x) -> acc + x) == 106)
  end
end

describe "count" do
  test "count of empty list is 0" do
    let empty : List(Int) = Nil
    assert (Iterable.count(empty) == 0)
  end

  test "count of singleton is 1" do
    assert (Iterable.count([42]) == 1)
  end

  test "count of multi-element list" do
    assert (Iterable.count([1, 2, 3, 4, 5]) == 5)
  end

  test "count of string list" do
    assert (Iterable.count(["a", "b", "c"]) == 3)
  end
end

describe "any" do
  test "any on empty list is false" do
    let empty : List(Int) = Nil
    assert !Iterable.any(empty, fn x -> x > 0)
  end

  test "any with always-true predicate" do
    assert Iterable.any([1, 2, 3], fn _ -> true)
  end

  test "any with always-false predicate" do
    assert !Iterable.any([1, 2, 3], fn _ -> false)
  end

  test "any with some matching" do
    assert Iterable.any([1, 2, 3], fn x -> x == 2)
  end

  test "any with none matching" do
    assert !Iterable.any([1, 2, 3], fn x -> x > 10)
  end

  test "any finds first element" do
    assert Iterable.any([5, 1, 2], fn x -> x > 3)
  end

  test "any finds last element" do
    assert Iterable.any([1, 2, 5], fn x -> x > 3)
  end

  test "any on singleton that matches" do
    assert Iterable.any([42], fn x -> x == 42)
  end

  test "any on singleton that does not match" do
    assert !Iterable.any([42], fn x -> x == 0)
  end
end

describe "all" do
  test "all on empty list is true" do
    let empty : List(Int) = Nil
    assert Iterable.all(empty, fn x -> x > 0)
  end

  test "all with always-true predicate" do
    assert Iterable.all([1, 2, 3], fn _ -> true)
  end

  test "all with always-false predicate" do
    assert !Iterable.all([1, 2, 3], fn _ -> false)
  end

  test "all with all matching" do
    assert Iterable.all([1, 2, 3], fn x -> x > 0)
  end

  test "all with none matching" do
    assert !Iterable.all([1, 2, 3], fn x -> x > 10)
  end

  test "all with some matching fails" do
    assert !Iterable.all([1, 2, 10], fn x -> x < 5)
  end

  test "all on singleton that matches" do
    assert Iterable.all([42], fn x -> x == 42)
  end

  test "all on singleton that does not match" do
    assert !Iterable.all([42], fn x -> x == 0)
  end
end

describe "find" do
  test "find on empty list returns None" do
    let empty : List(Int) = Nil
    assert Option.is_none(Iterable.find(empty, fn x -> x > 0))
  end

  test "find with no match returns None" do
    assert Option.is_none(Iterable.find([1, 2, 3], fn x -> x > 10))
  end

  test "find returns first match" do
    let result = Iterable.find([1, 2, 3, 4], fn x -> x > 2)
    assert Option.is_some(result)
    assert (Option.unwrap(result) == 3)
  end

  test "find matches last element" do
    let result = Iterable.find([1, 2, 3], fn x -> x == 3)
    assert Option.is_some(result)
    assert (Option.unwrap(result) == 3)
  end

  test "find matches first element" do
    let result = Iterable.find([5, 1, 2], fn x -> x > 3)
    assert Option.is_some(result)
    assert (Option.unwrap(result) == 5)
  end

  test "find on singleton that matches" do
    let result = Iterable.find([99], fn x -> x > 0)
    assert Option.is_some(result)
    assert (Option.unwrap(result) == 99)
  end

  test "find on singleton that does not match" do
    assert Option.is_none(Iterable.find([99], fn x -> x < 0))
  end
end

describe "take" do
  test "take 0 returns empty" do
    assert (Iterable.take([1, 2, 3], 0) == Nil)
  end

  test "take negative returns empty" do
    assert (Iterable.take([1, 2, 3], -1) == Nil)
  end

  test "take exact length returns all" do
    assert (Iterable.take([1, 2, 3], 3) == [1, 2, 3])
  end

  test "take more than length returns all" do
    assert (Iterable.take([1, 2, 3], 10) == [1, 2, 3])
  end

  test "take from empty list" do
    let empty : List(Int) = Nil
    assert (Iterable.take(empty, 5) == Nil)
  end

  test "take first n elements" do
    assert (Iterable.take([1, 2, 3, 4, 5], 3) == [1, 2, 3])
  end

  test "take 1 returns first element" do
    assert (Iterable.take([10, 20, 30], 1) == [10])
  end

  test "take preserves order" do
    assert (Iterable.take([3, 1, 4, 1, 5], 3) == [3, 1, 4])
  end
end

describe "drop" do
  test "drop 0 returns all" do
    assert (Iterable.drop([1, 2, 3], 0) == [1, 2, 3])
  end

  test "drop negative returns all" do
    assert (Iterable.drop([1, 2, 3], -1) == [1, 2, 3])
  end

  test "drop exact length returns empty" do
    assert (Iterable.drop([1, 2, 3], 3) == Nil)
  end

  test "drop more than length returns empty" do
    assert (Iterable.drop([1, 2, 3], 10) == Nil)
  end

  test "drop from empty list" do
    let empty : List(Int) = Nil
    assert (Iterable.drop(empty, 5) == Nil)
  end

  test "drop first n elements" do
    assert (Iterable.drop([1, 2, 3, 4, 5], 2) == [3, 4, 5])
  end

  test "drop 1 removes first element" do
    assert (Iterable.drop([10, 20, 30], 1) == [20, 30])
  end

  test "drop and take are complementary" do
    let xs = [1, 2, 3, 4, 5]
    assert (Iterable.count(Iterable.take(xs, 3)) + Iterable.count(Iterable.drop(xs, 3)) == 5)
  end
end

describe "zip" do
  test "zip equal-length lists" do
    assert (Iterable.zip([1, 2, 3], ["a", "b", "c"]) == [(1, "a"), (2, "b"), (3, "c")])
  end

  test "zip two empty lists" do
    let e1 : List(Int) = Nil
    let e2 : List(String) = Nil
    assert (Iterable.zip(e1, e2) == Nil)
  end

  test "zip with left empty" do
    let e : List(Int) = Nil
    assert (Iterable.zip(e, ["a", "b"]) == Nil)
  end

  test "zip with right empty" do
    let e : List(String) = Nil
    assert (Iterable.zip([1, 2], e) == Nil)
  end

  test "zip stops at shorter left list" do
    assert (Iterable.zip([1, 2], ["a", "b", "c"]) == [(1, "a"), (2, "b")])
  end

  test "zip stops at shorter right list" do
    assert (Iterable.zip([1, 2, 3], ["a", "b"]) == [(1, "a"), (2, "b")])
  end

  test "zip singletons" do
    assert (Iterable.zip([42], ["hello"]) == [(42, "hello")])
  end

  test "zip result length equals min of input lengths" do
    assert (Iterable.count(Iterable.zip([1, 2, 3], ["a", "b"])) == 2)
  end
end

describe "enumerate" do
  test "enumerate empty list" do
    let empty : List(Int) = Nil
    assert (Iterable.enumerate(empty) == Nil)
  end

  test "enumerate singleton" do
    assert (Iterable.enumerate(["a"]) == [(0, "a")])
  end

  test "enumerate multiple elements" do
    assert (Iterable.enumerate(["a", "b", "c"]) == [(0, "a"), (1, "b"), (2, "c")])
  end

  test "enumerate starts at index 0" do
    assert (Iterable.enumerate([10, 20]) == [(0, 10), (1, 20)])
  end

  test "enumerate preserves element order" do
    assert (Iterable.enumerate([3, 1, 4, 1, 5]) == [(0, 3), (1, 1), (2, 4), (3, 1), (4, 5)])
  end

  test "enumerate result length equals input length" do
    assert (Iterable.count(Iterable.enumerate([1, 2, 3, 4, 5])) == 5)
  end

  test "enumerate indices are sequential" do
    let indexed = Iterable.enumerate([10, 20, 30, 40])
    let indices = Iterable.map(indexed, fn p -> match p do (i, _) -> i end)
    assert (indices == [0, 1, 2, 3])
  end
end

end
