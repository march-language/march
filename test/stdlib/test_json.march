-- Tests for the Json stdlib module
-- Run with: dune exec march -- test test/stdlib/test_json.march

mod TestJson do

describe "Json" do

  describe "parse null" do

    test "parse null" do
      match Json.parse("null") do
      Err(e) -> panic("parse null failed: " ++ e)
      Ok(v) -> match v do Null -> () | _ -> panic("expected Null") end
      end
    end

  end

  describe "parse booleans" do

    test "parse true" do
      match Json.parse("true") do
      Err(e) -> panic("parse true failed: " ++ e)
      Ok(v) -> match v do Bool(b) -> assert b | _ -> panic("expected Bool") end
      end
    end

    test "parse false" do
      match Json.parse("false") do
      Err(e) -> panic("parse false failed: " ++ e)
      Ok(v) -> match v do Bool(b) -> assert not(b) | _ -> panic("expected Bool") end
      end
    end

  end

  describe "parse numbers" do

    test "parse integer" do
      match Json.parse("42") do
      Err(e) -> panic("parse int failed: " ++ e)
      Ok(v) -> do
        match v do
        Number(f) -> assert (f == 42.0)
        _ -> panic("expected Number")
        end
      end
      end
    end

    test "parse negative integer" do
      match Json.parse("-7") do
      Err(e) -> panic("parse neg failed: " ++ e)
      Ok(v) -> do
        match v do
        Number(f) -> assert (f == -7.0)
        _ -> panic("expected Number")
        end
      end
      end
    end

    test "parse zero" do
      match Json.parse("0") do
      Err(e) -> panic("parse zero failed: " ++ e)
      Ok(v) -> do
        match v do
        Number(f) -> assert (f == 0.0)
        _ -> panic("expected Number")
        end
      end
      end
    end

    test "parse float" do
      match Json.parse("3.14") do
      Err(e) -> panic("parse float failed: " ++ e)
      Ok(v) -> do
        match v do
        Number(f) -> assert (f > 3.13 && f < 3.15)
        _ -> panic("expected Number")
        end
      end
      end
    end

  end

  describe "parse strings" do

    test "parse basic string" do
      match Json.parse("\"hello\"") do
      Err(e) -> panic("parse string failed: " ++ e)
      Ok(v) -> do
        match v do
        Str(s) -> assert (s == "hello")
        _ -> panic("expected Str")
        end
      end
      end
    end

    test "parse empty string" do
      match Json.parse("\"\"") do
      Err(e) -> panic("parse empty string failed: " ++ e)
      Ok(v) -> do
        match v do
        Str(s) -> assert (s == "")
        _ -> panic("expected Str")
        end
      end
      end
    end

  end

  describe "parse arrays" do

    test "parse empty array" do
      match Json.parse("[]") do
      Err(e) -> panic("parse empty array failed: " ++ e)
      Ok(v) -> do
        match v do
        Array(xs) -> assert (List.length(xs) == 0)
        _ -> panic("expected Array")
        end
      end
      end
    end

    test "parse int array" do
      match Json.parse("[1, 2, 3]") do
      Err(e) -> panic("parse int array failed: " ++ e)
      Ok(v) -> do
        match v do
        Array(xs) -> assert (List.length(xs) == 3)
        _ -> panic("expected Array")
        end
      end
      end
    end

    test "parse mixed array" do
      match Json.parse("[1, \"two\", true, null]") do
      Err(e) -> panic("parse mixed array failed: " ++ e)
      Ok(v) -> do
        match v do
        Array(xs) -> assert (List.length(xs) == 4)
        _ -> panic("expected Array")
        end
      end
      end
    end

  end

  describe "parse objects" do

    test "parse empty object" do
      match Json.parse("{}") do
      Err(e) -> panic("parse empty object failed: " ++ e)
      Ok(v) -> do
        match v do
        Object(kvs) -> assert (List.length(kvs) == 0)
        _ -> panic("expected Object")
        end
      end
      end
    end

    test "parse and get key" do
      match Json.parse("{\"key\": \"value\"}") do
      Err(e) -> panic("parse object failed: " ++ e)
      Ok(v) -> do
        match Json.get(v, "key") do
        None -> panic("key not found")
        Some(val) ->
          match val do
          Str(s) -> assert (s == "value")
          _ -> panic("expected Str")
          end
        end
      end
      end
    end

    test "missing key returns None" do
      match Json.parse("{\"key\": \"value\"}") do
      Err(e) -> panic("parse failed: " ++ e)
      Ok(v) -> do
        match Json.get(v, "missing") do
        None -> ()
        Some(_) -> panic("missing key should be None")
        end
      end
      end
    end

    test "parse multi-field object" do
      match Json.parse("{\"x\": 1, \"y\": 2, \"z\": 3}") do
      Err(e) -> panic("parse multi-field failed: " ++ e)
      Ok(v) -> do
        match Json.get(v, "x") do
        None -> panic("x missing")
        Some(val) ->
          match val do
          Number(f) -> assert (f == 1.0)
          _ -> panic("x not Number")
          end
        end
        match Json.get(v, "z") do
        None -> panic("z missing")
        Some(val) ->
          match val do
          Number(f) -> assert (f == 3.0)
          _ -> panic("z not Number")
          end
        end
      end
      end
    end

  end

  describe "nested JSON" do

    test "nested object" do
      match Json.parse("{\"person\": {\"name\": \"Alice\", \"age\": 30}}") do
      Err(e) -> panic("parse nested failed: " ++ e)
      Ok(v) -> do
        match Json.get(v, "person") do
        None -> panic("person missing")
        Some(person) ->
          match Json.get(person, "name") do
          None -> panic("name missing")
          Some(name_val) ->
            match name_val do
            Str(s) -> assert (s == "Alice")
            _ -> panic("name not Str")
            end
          end
        end
      end
      end
    end

    test "get_in nested path" do
      match Json.parse("{\"person\": {\"name\": \"Alice\"}}") do
      Err(e) -> panic("parse failed: " ++ e)
      Ok(v) -> do
        match Json.get_in(v, Cons("person", Cons("name", Nil))) do
        None -> panic("nested path missing")
        Some(val) ->
          match val do
          Str(s) -> assert (s == "Alice")
          _ -> panic("expected Str")
          end
        end
      end
      end
    end

  end

  describe "to_string" do

    test "to_string null" do
      assert (Json.to_string(Null) == "null")
    end

    test "to_string booleans" do
      assert (Json.to_string(Bool(true)) == "true")
      assert (Json.to_string(Bool(false)) == "false")
    end

    test "to_string integer number" do
      assert (Json.to_string(Number(42.0)) == "42")
    end

    test "to_string string" do
      assert (Json.to_string(Str("hello")) == "\"hello\"")
    end

    test "to_string array" do
      let arr = Array(Cons(Number(1.0), Cons(Number(2.0), Cons(Number(3.0), Nil))))
      assert (Json.to_string(arr) == "[1,2,3]")
    end

    test "to_string object" do
      let obj = Object(Cons(("key", Str("val")), Nil))
      assert (Json.to_string(obj) == "{\"key\":\"val\"}")
    end

  end

  describe "encode helpers" do

    test "encode_null" do
      assert (Json.to_string(Json.encode_null()) == "null")
    end

    test "encode_bool" do
      assert (Json.to_string(Json.encode_bool(true)) == "true")
    end

    test "encode_int" do
      assert (Json.to_string(Json.encode_int(42)) == "42")
    end

    test "encode_string" do
      assert (Json.to_string(Json.encode_string("hi")) == "\"hi\"")
    end

  end

  describe "roundtrip" do

    test "parse then to_string roundtrip" do
      let original = "{\"x\":1,\"y\":true}"
      match Json.parse(original) do
      Err(e) -> panic("roundtrip parse failed: " ++ e)
      Ok(v) -> do
        let re_encoded = Json.to_string(v)
        match Json.parse(re_encoded) do
        Err(e) -> panic("roundtrip re-parse failed: " ++ e)
        Ok(_) -> ()
        end
      end
      end
    end

  end

  describe "parse errors" do

    test "invalid json returns Err" do
      match Json.parse("{invalid}") do
      Err(_) -> ()
      Ok(_) -> panic("invalid json should return Err")
      end
    end

    test "empty string returns Err" do
      match Json.parse("") do
      Err(_) -> ()
      Ok(_) -> panic("empty json should return Err")
      end
    end

    test "unclosed string returns Err" do
      match Json.parse("{\"unclosed\": \"string") do
      Err(_) -> ()
      Ok(_) -> panic("unclosed string should return Err")
      end
    end

  end

  describe "whitespace handling" do

    test "whitespace around tokens" do
      match Json.parse("  {  \"k\"  :  42  }  ") do
      Err(e) -> panic("whitespace parse failed: " ++ e)
      Ok(v) -> do
        match Json.get(v, "k") do
        None -> panic("key missing")
        Some(val) ->
          match val do
          Number(f) -> assert (f == 42.0)
          _ -> panic("not Number")
          end
        end
      end
      end
    end

  end

end

end
