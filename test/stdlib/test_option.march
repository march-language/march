-- Tests for the Option stdlib module
-- Run with: dune exec march -- test test/stdlib/test_option.march

mod TestOption do

describe "is_some" do
  test "is_some returns true for Some value" do
    assert Option.is_some(Some(1))
  end

  test "is_some returns false for None" do
    assert !Option.is_some(None)
  end

  test "is_some returns true for Some(0)" do
    assert Option.is_some(Some(0))
  end
end

describe "is_none" do
  test "is_none returns true for None" do
    assert Option.is_none(None)
  end

  test "is_none returns false for Some value" do
    assert !Option.is_none(Some(42))
  end
end

describe "unwrap" do
  test "unwrap extracts value from Some" do
    assert (Option.unwrap(Some(42)) == 42)
  end

  test "unwrap of Some(0) is 0" do
    assert (Option.unwrap(Some(0)) == 0)
  end
end

describe "expect" do
  test "expect extracts value from Some" do
    assert (Option.expect(Some(99), "should not panic") == 99)
  end
end

describe "unwrap_or" do
  test "unwrap_or returns value when Some" do
    assert (Option.unwrap_or(Some(5), 0) == 5)
  end

  test "unwrap_or returns default when None" do
    assert (Option.unwrap_or(None, 42) == 42)
  end

  test "unwrap_or returns zero default for None" do
    assert (Option.unwrap_or(None, 0) == 0)
  end
end

describe "unwrap_or_else" do
  test "unwrap_or_else returns value when Some" do
    assert (Option.unwrap_or_else(Some(7), fn _u -> 99) == 7)
  end

  test "unwrap_or_else calls function when None" do
    assert (Option.unwrap_or_else(None, fn _u -> 10) == 10)
  end
end

describe "map" do
  test "map transforms Some value" do
    assert (Option.unwrap(Option.map(Some(3), fn x -> x * 2)) == 6)
  end

  test "map of None is None" do
    assert Option.is_none(Option.map(None, fn (x : Int) -> x * 2))
  end

  test "map can return zero" do
    assert (Option.unwrap(Option.map(Some(5), fn _ -> 0)) == 0)
  end
end

describe "flat_map" do
  test "flat_map Some to Some" do
    assert (Option.unwrap(Option.flat_map(Some(4), fn x -> Some(x + 1))) == 5)
  end

  test "flat_map Some to None gives None" do
    assert Option.is_none(Option.flat_map(Some(1), fn (x : Int) -> None))
  end

  test "flat_map None gives None" do
    assert Option.is_none(Option.flat_map(None, fn (x : Int) -> Some(x)))
  end
end

describe "filter" do
  test "filter keeps value when predicate passes" do
    assert (Option.unwrap(Option.filter(Some(4), fn x -> x > 2)) == 4)
  end

  test "filter gives None when predicate fails" do
    assert Option.is_none(Option.filter(Some(1), fn x -> x > 2))
  end

  test "filter of None is None" do
    assert Option.is_none(Option.filter(None, fn (x : Int) -> true))
  end
end

describe "or_else" do
  test "or_else returns original Some" do
    assert (Option.unwrap(Option.or_else(Some(5), fn _u -> Some(99))) == 5)
  end

  test "or_else calls function for None" do
    assert (Option.unwrap(Option.or_else(None, fn _u -> Some(7))) == 7)
  end
end

describe "zip" do
  test "zip of two Some values gives Some pair" do
    match Option.zip(Some(1), Some(2)) do
    | Some((a, b)) ->
      assert (a == 1)
      assert (b == 2)
    | None -> assert false
    end
  end

  test "zip with first None gives None" do
    assert Option.is_none(Option.zip(None, Some(2)))
  end

  test "zip with second None gives None" do
    assert Option.is_none(Option.zip(Some(1), None))
  end

  test "zip of two Nones gives None" do
    assert Option.is_none(Option.zip(None, None))
  end
end

describe "to_result" do
  test "to_result of Some gives Ok" do
    assert Result.is_ok(Option.to_result(Some(42), "err"))
  end

  test "to_result of None gives Err" do
    assert Result.is_err(Option.to_result(None, "err"))
  end
end

describe "to_list" do
  test "to_list of Some gives single-element list" do
    let lst = Option.to_list(Some(10))
    assert (length(lst) == 1)
    assert (head(lst) == 10)
  end

  test "to_list of None gives empty list" do
    assert (length(Option.to_list(None)) == 0)
  end
end

end
