-- Tests for the Map stdlib module (HAMT-based persistent map)
-- Run with: dune exec march -- test test/stdlib/test_map.march

mod TestMap do

pfn int_cmp(a : Int) : Int -> Bool do
  fn b -> a < b
end

pfn str_cmp(a : String) : String -> Bool do
  fn b -> a < b
end

describe "empty and is_empty" do
  test "empty map is empty" do
    let m = Map.empty()
    assert Map.is_empty(m)
    assert (Map.size(m) == 0)
  end
end

describe "singleton" do
  test "singleton is not empty and has size 1" do
    let m = Map.singleton(1, "one")
    assert !Map.is_empty(m)
    assert (Map.size(m) == 1)
    assert Map.contains_key(m, 1, int_cmp)
  end
end

describe "insert and get" do
  test "inserted keys can be retrieved" do
    let m = Map.empty()
    let m1 = Map.insert(m, 1, "one", int_cmp)
    let m2 = Map.insert(m1, 2, "two", int_cmp)
    let m3 = Map.insert(m2, 3, "three", int_cmp)
    match Map.get(m3, 1, int_cmp) do
    | Some(v) -> assert (v == "one")
    | None -> assert false
    end
    match Map.get(m3, 2, int_cmp) do
    | Some(v) -> assert (v == "two")
    | None -> assert false
    end
    match Map.get(m3, 3, int_cmp) do
    | Some(v) -> assert (v == "three")
    | None -> assert false
    end
  end

  test "get returns None for absent key" do
    let m = Map.singleton(1, "one")
    assert Option.is_none(Map.get(m, 99, int_cmp))
  end

  test "insert overwrites existing key" do
    let m = Map.insert(Map.empty(), 1, "old", int_cmp)
    let m2 = Map.insert(m, 1, "new", int_cmp)
    assert (Map.size(m2) == 1)
    match Map.get(m2, 1, int_cmp) do
    | Some(v) -> assert (v == "new")
    | None -> assert false
    end
  end

  test "insert is persistent" do
    let m0 = Map.empty()
    let m1 = Map.insert(m0, 10, "ten", int_cmp)
    let m2 = Map.insert(m1, 20, "twenty", int_cmp)
    assert (Map.size(m1) == 1)
    assert Option.is_none(Map.get(m1, 20, int_cmp))
  end
end

describe "get_or" do
  test "get_or returns value when key present" do
    let m = Map.singleton(5, "five")
    assert (Map.get_or(m, 5, "default", int_cmp) == "five")
  end

  test "get_or returns default when key absent" do
    let m = Map.empty()
    assert (Map.get_or(m, 99, "default", int_cmp) == "default")
  end
end

describe "contains_key" do
  test "contains_key returns true for present key" do
    let m = Map.singleton(42, "answer")
    assert Map.contains_key(m, 42, int_cmp)
  end

  test "contains_key returns false for absent key" do
    let m = Map.singleton(42, "answer")
    assert !Map.contains_key(m, 0, int_cmp)
  end

  test "contains_key on empty map returns false" do
    assert !Map.contains_key(Map.empty(), 1, int_cmp)
  end
end

describe "remove" do
  test "remove eliminates the key" do
    let m = Map.insert(Map.insert(Map.empty(), 1, "a", int_cmp), 2, "b", int_cmp)
    let m2 = Map.remove(m, 1, int_cmp)
    assert !Map.contains_key(m2, 1, int_cmp)
    assert Map.contains_key(m2, 2, int_cmp)
    assert (Map.size(m2) == 1)
  end

  test "remove of absent key leaves map unchanged" do
    let m = Map.singleton(1, "one")
    let m2 = Map.remove(m, 99, int_cmp)
    assert (Map.size(m2) == 1)
  end

  test "remove of only key gives empty map" do
    let m = Map.singleton(1, "one")
    let m2 = Map.remove(m, 1, int_cmp)
    assert Map.is_empty(m2)
  end
end

describe "size" do
  test "size of 10-entry map is 10" do
    fn insert_n(n) do
      fn go(i, m) do
        if i > n then m else go(i + 1, Map.insert(m, i, i * 10, int_cmp))
      end
      go(1, Map.empty())
    end
    let m = insert_n(10)
    assert (Map.size(m) == 10)
  end
end

describe "fold" do
  test "fold sums all values" do
    let m = Map.insert(Map.insert(Map.insert(Map.empty(), 1, 10, int_cmp), 2, 20, int_cmp), 3, 30, int_cmp)
    let s = Map.fold(0, m, fn acc -> fn _k -> fn v -> acc + v)
    assert (s == 60)
  end

  test "fold counts keys" do
    let m = Map.insert(Map.insert(Map.empty(), 1, "a", int_cmp), 2, "b", int_cmp)
    let c = Map.fold(0, m, fn acc -> fn _k -> fn _v -> acc + 1)
    assert (c == 2)
  end
end

describe "keys, values, entries" do
  test "keys returns all keys" do
    let m = Map.insert(Map.insert(Map.empty(), 1, "a", int_cmp), 2, "b", int_cmp)
    assert (length(Map.keys(m)) == 2)
  end

  test "values returns all values" do
    let m = Map.singleton(1, "hello")
    let vs = Map.values(m)
    assert (length(vs) == 1)
    assert (head(vs) == "hello")
  end

  test "entries returns all key-value pairs" do
    let m = Map.singleton(42, 99)
    let es = Map.entries(m)
    assert (length(es) == 1)
    match head(es) do
    | (k, v) ->
      assert (k == 42)
      assert (v == 99)
    end
  end
end

describe "from_list and to_list" do
  test "from_list builds map from pairs" do
    let pairs = Cons((1, "one"), Cons((2, "two"), Cons((3, "three"), Nil)))
    let m = Map.from_list(pairs, int_cmp)
    assert (Map.size(m) == 3)
    assert Map.contains_key(m, 1, int_cmp)
    assert Map.contains_key(m, 3, int_cmp)
  end

  test "from_list with duplicate keys uses last value" do
    let pairs = Cons((1, "first"), Cons((1, "second"), Nil))
    let m = Map.from_list(pairs, int_cmp)
    assert (Map.size(m) == 1)
    match Map.get(m, 1, int_cmp) do
    | Some(v) -> assert (v == "second")
    | None -> assert false
    end
  end

  test "to_list of singleton has one pair" do
    let m = Map.singleton(7, "seven")
    assert (length(Map.to_list(m)) == 1)
  end
end

describe "map_values" do
  test "map_values transforms all values" do
    let m = Map.insert(Map.insert(Map.empty(), 1, 10, int_cmp), 2, 20, int_cmp)
    let doubled = Map.map_values(m, fn x -> x * 2)
    assert (Map.size(doubled) == 2)
    match Map.get(doubled, 1, int_cmp) do
    | Some(v) -> assert (v == 20)
    | None -> assert false
    end
    match Map.get(doubled, 2, int_cmp) do
    | Some(v) -> assert (v == 40)
    | None -> assert false
    end
  end
end

describe "filter" do
  test "filter keeps entries matching predicate" do
    let m = Map.insert(Map.insert(Map.insert(Map.empty(), 1, 10, int_cmp), 2, 20, int_cmp), 3, 30, int_cmp)
    let big = Map.filter(m, fn _k -> fn v -> v > 15, int_cmp)
    assert (Map.size(big) == 2)
    assert !Map.contains_key(big, 1, int_cmp)
  end
end

describe "merge" do
  test "merge of disjoint maps has all keys" do
    let a = Map.singleton(1, "a1")
    let b = Map.singleton(2, "b2")
    let c = Map.merge(a, b, int_cmp)
    assert (Map.size(c) == 2)
    assert Map.contains_key(c, 1, int_cmp)
    assert Map.contains_key(c, 2, int_cmp)
  end

  test "merge with overlap: b value wins" do
    let a = Map.singleton(1, "from_a")
    let b = Map.singleton(1, "from_b")
    let c = Map.merge(a, b, int_cmp)
    assert (Map.size(c) == 1)
    match Map.get(c, 1, int_cmp) do
    | Some(v) -> assert (v == "from_b")
    | None -> assert false
    end
  end

  test "merge_with combines conflicting values" do
    let a = Map.singleton(1, 10)
    let b = Map.singleton(1, 5)
    let c = Map.merge_with(a, b, fn va -> fn vb -> va + vb, int_cmp)
    assert (Map.size(c) == 1)
    match Map.get(c, 1, int_cmp) do
    | Some(v) -> assert (v == 15)
    | None -> assert false
    end
  end

  test "merge_with on disjoint maps has all keys" do
    let a = Map.singleton(1, 10)
    let b = Map.singleton(2, 20)
    let c = Map.merge_with(a, b, fn va -> fn vb -> va + vb, int_cmp)
    assert (Map.size(c) == 2)
  end
end

describe "string keys" do
  test "map works with string keys" do
    let m = Map.insert(Map.insert(Map.empty(), "hello", 1, str_cmp), "world", 2, str_cmp)
    assert (Map.size(m) == 2)
    match Map.get(m, "hello", str_cmp) do
    | Some(v) -> assert (v == 1)
    | None -> assert false
    end
    match Map.get(m, "world", str_cmp) do
    | Some(v) -> assert (v == 2)
    | None -> assert false
    end
    assert Option.is_none(Map.get(m, "missing", str_cmp))
  end
end

end
