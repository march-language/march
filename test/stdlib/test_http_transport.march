-- test/stdlib/test_http_transport.march
-- Tests for the HttpTransport stdlib module.
-- Only tests the pure/structural parts (error type constructors, etc.).
-- Network I/O functions are not exercised here.
-- Run with: dune exec march -- test test/stdlib/test_http_transport.march

mod TestHttpTransport do

-- Local mirror of HttpTransport.TransportError (private in HttpTransport).
-- Constructors are structurally matched at runtime by name.
ptype TransportError =
  ConnectionRefused(String)
  | ConnTimeout(String)
  | SendError(String)
  | RecvError(String)
  | ConnParseError(String)
  | Closed
  | SchemeNotSupported(String)

pfn show_error(e) do
  match e do
  ConnectionRefused(s) -> "refused:" ++ s
  ConnTimeout(s)       -> "timeout:" ++ s
  SendError(s)         -> "send:" ++ s
  RecvError(s)         -> "recv:" ++ s
  ConnParseError(s)    -> "parse:" ++ s
  Closed               -> "closed"
  end
end

describe "TransportError constructors" do
  test "ConnectionRefused stores message" do
    let e = ConnectionRefused("localhost:8080")
    match e do
    ConnectionRefused(msg) -> assert (msg == "localhost:8080")
    _ -> assert false
    end
  end

  test "ConnTimeout stores message" do
    let e = ConnTimeout("timed out after 30s")
    match e do
    ConnTimeout(msg) -> assert (msg == "timed out after 30s")
    _ -> assert false
    end
  end

  test "SendError stores message" do
    let e = SendError("broken pipe")
    match e do
    SendError(msg) -> assert (msg == "broken pipe")
    _ -> assert false
    end
  end

  test "RecvError stores message" do
    let e = RecvError("connection reset")
    match e do
    RecvError(msg) -> assert (msg == "connection reset")
    _ -> assert false
    end
  end

  test "ConnParseError stores message" do
    let e = ConnParseError("unexpected EOF")
    match e do
    ConnParseError(msg) -> assert (msg == "unexpected EOF")
    _ -> assert false
    end
  end

  test "Closed constructor" do
    let e = Closed
    match e do
    Closed -> ()
    _ -> assert false
    end
  end
end

describe "TransportError pattern matching" do
  test "match ConnectionRefused" do
    assert (show_error(ConnectionRefused("h")) == "refused:h")
  end

  test "match ConnTimeout" do
    assert (show_error(ConnTimeout("t")) == "timeout:t")
  end

  test "match SendError" do
    assert (show_error(SendError("s")) == "send:s")
  end

  test "match RecvError" do
    assert (show_error(RecvError("r")) == "recv:r")
  end

  test "match ConnParseError" do
    assert (show_error(ConnParseError("p")) == "parse:p")
  end

  test "match Closed" do
    assert (show_error(Closed) == "closed")
  end
end

describe "https scheme guard" do
  test "request rejects https request with SchemeNotSupported" do
    let req = Request(Get, SchemeHttps, "example.com", None, "/", None, Nil, "")
    match HttpTransport.request(req) do
    Err(SchemeNotSupported(_)) -> ()
    Err(_) -> assert false
    Ok(_)  -> assert false
    end
  end

  test "simple_get rejects https URL with SchemeNotSupported" do
    match HttpTransport.simple_get("https://example.com/") do
    Err(SchemeNotSupported(_)) -> ()
    Err(_) -> assert false
    Ok(_)  -> assert false
    end
  end

  test "request_on rejects https request with SchemeNotSupported" do
    -- fd=-1 is invalid but we never reach tcp_send because of the early check.
    let req = Request(Get, SchemeHttps, "example.com", None, "/", None, Nil, "")
    match HttpTransport.request_on(-1, req) do
    Err(SchemeNotSupported(_)) -> ()
    Err(_) -> assert false
    Ok(_)  -> assert false
    end
  end

  test "stream_request_on rejects https request with SchemeNotSupported" do
    let req = Request(Get, SchemeHttps, "example.com", None, "/", None, Nil, "")
    match HttpTransport.stream_request_on(-1, req, fn _ -> ()) do
    Err(SchemeNotSupported(_)) -> ()
    Err(_) -> assert false
    Ok(_)  -> assert false
    end
  end

  test "connect rejects https request with SchemeNotSupported" do
    let req = Request(Get, SchemeHttps, "example.com", None, "/", None, Nil, "")
    match HttpTransport.connect(req) do
    Err(SchemeNotSupported(_)) -> ()
    Err(_) -> assert false
    Ok(_)  -> assert false
    end
  end
end

end
