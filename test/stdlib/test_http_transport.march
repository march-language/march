-- Tests for the HttpTransport stdlib module.
-- Only tests the pure/structural parts (error type constructors, etc.).
-- Network I/O functions are not exercised here.

mod TestHttpTransport do

  -- ── TransportError constructors ────────────────────────────────────

  fn test_connection_refused_ctor() do
    let e = ConnectionRefused("localhost:8080")
    match e do
    | ConnectionRefused(msg) ->
      Test.assert_eq_str(msg, "localhost:8080", "ConnectionRefused msg")
    | _ -> Test.fail("wrong ctor")
    end
  end

  fn test_conn_timeout_ctor() do
    let e = ConnTimeout("timed out after 30s")
    match e do
    | ConnTimeout(msg) ->
      Test.assert_eq_str(msg, "timed out after 30s", "ConnTimeout msg")
    | _ -> Test.fail("wrong ctor")
    end
  end

  fn test_send_error_ctor() do
    let e = SendError("broken pipe")
    match e do
    | SendError(msg) ->
      Test.assert_eq_str(msg, "broken pipe", "SendError msg")
    | _ -> Test.fail("wrong ctor")
    end
  end

  fn test_recv_error_ctor() do
    let e = RecvError("connection reset")
    match e do
    | RecvError(msg) ->
      Test.assert_eq_str(msg, "connection reset", "RecvError msg")
    | _ -> Test.fail("wrong ctor")
    end
  end

  fn test_parse_error_ctor() do
    let e = ConnConnParseError("unexpected EOF")
    match e do
    | ConnConnParseError(msg) ->
      Test.assert_eq_str(msg, "unexpected EOF", "ConnConnParseError msg")
    | _ -> Test.fail("wrong ctor")
    end
  end

  fn test_closed_ctor() do
    let e = Closed
    match e do
    | Closed -> ()
    | _ -> Test.fail("wrong ctor")
    end
  end

  -- ── Error type is a variant — match coverage ──────────────────────

  fn describe_error(e) do
    match e do
    | ConnectionRefused(s) -> "refused:" ++ s
    | ConnTimeout(s)       -> "timeout:" ++ s
    | SendError(s)         -> "send:" ++ s
    | RecvError(s)         -> "recv:" ++ s
    | ConnConnParseError(s) -> "parse:" ++ s
    | Closed               -> "closed"
    end
  end

  fn test_error_matching() do
    Test.assert_eq_str(describe_error(ConnectionRefused("h")),    "refused:h",  "match refused")
    Test.assert_eq_str(describe_error(ConnTimeout("t")),          "timeout:t",  "match timeout")
    Test.assert_eq_str(describe_error(SendError("s")),            "send:s",     "match send")
    Test.assert_eq_str(describe_error(RecvError("r")),            "recv:r",     "match recv")
    Test.assert_eq_str(describe_error(ConnConnParseError("p")),   "parse:p",    "match parse")
    Test.assert_eq_str(describe_error(Closed),                    "closed",     "match closed")
  end

  -- ── Entry point ────────────────────────────────────────────────────

  pub fn main() do
    test_connection_refused_ctor()
    test_conn_timeout_ctor()
    test_send_error_ctor()
    test_recv_error_ctor()
    test_parse_error_ctor()
    test_closed_ctor()
    test_error_matching()
  end

end
