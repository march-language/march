-- Tests for the Logger stdlib module.
-- Covers: level constructors, level_to_string, level_from_string,
-- level_rank, level_enabled, format_entry.
-- (Actual I/O log functions are not verified for output content.)

mod TestLogger do

  -- ── Level constructors ─────────────────────────────────────────────

  fn test_level_ctors() do
    match Logger.Debug do | Debug -> () | _ -> Test.fail("Debug") end
    match Logger.Info  do | Info  -> () | _ -> Test.fail("Info")  end
    match Logger.Warn  do | Warn  -> () | _ -> Test.fail("Warn")  end
    match Logger.Error do | Error -> () | _ -> Test.fail("Error") end
  end

  -- ── level_to_string ────────────────────────────────────────────────

  fn test_level_to_string() do
    Test.assert_eq_str(Logger.level_to_string(Logger.Debug), "DEBUG", "Debug string")
    Test.assert_eq_str(Logger.level_to_string(Logger.Info),  "INFO",  "Info string")
    Test.assert_eq_str(Logger.level_to_string(Logger.Warn),  "WARN",  "Warn string")
    Test.assert_eq_str(Logger.level_to_string(Logger.Error), "ERROR", "Error string")
  end

  -- ── level_from_string ──────────────────────────────────────────────

  fn test_level_from_string_exact() do
    let d = Test.assert_some(Logger.level_from_string("debug"), "debug")
    match d do | Debug -> () | _ -> Test.fail("expected Debug") end
    let i = Test.assert_some(Logger.level_from_string("info"), "info")
    match i do | Info -> () | _ -> Test.fail("expected Info") end
    let w = Test.assert_some(Logger.level_from_string("warn"), "warn")
    match w do | Warn -> () | _ -> Test.fail("expected Warn") end
    let e = Test.assert_some(Logger.level_from_string("error"), "error")
    match e do | Error -> () | _ -> Test.fail("expected Error") end
  end

  fn test_level_from_string_uppercase() do
    let d = Test.assert_some(Logger.level_from_string("DEBUG"), "DEBUG")
    match d do | Debug -> () | _ -> Test.fail("expected Debug from DEBUG") end
    let i = Test.assert_some(Logger.level_from_string("INFO"), "INFO")
    match i do | Info -> () | _ -> Test.fail("expected Info from INFO") end
  end

  fn test_level_from_string_mixed_case() do
    let w = Test.assert_some(Logger.level_from_string("Warn"), "Warn mixed")
    match w do | Warn -> () | _ -> Test.fail("expected Warn from Warn") end
  end

  fn test_level_from_string_unknown() do
    Test.assert_none(Logger.level_from_string("trace"),   "trace is unknown")
    Test.assert_none(Logger.level_from_string("verbose"), "verbose is unknown")
    Test.assert_none(Logger.level_from_string(""),        "empty string is unknown")
  end

  -- ── level_rank ─────────────────────────────────────────────────────

  fn test_level_rank_ordering() do
    let d = Logger.level_rank(Logger.Debug)
    let i = Logger.level_rank(Logger.Info)
    let w = Logger.level_rank(Logger.Warn)
    let e = Logger.level_rank(Logger.Error)
    Test.assert_true(d < i, "Debug < Info")
    Test.assert_true(i < w, "Info < Warn")
    Test.assert_true(w < e, "Warn < Error")
  end

  fn test_level_rank_specific_values() do
    Test.assert_eq_int(Logger.level_rank(Logger.Debug), 0, "Debug rank 0")
    Test.assert_eq_int(Logger.level_rank(Logger.Info),  1, "Info rank 1")
    Test.assert_eq_int(Logger.level_rank(Logger.Warn),  2, "Warn rank 2")
    Test.assert_eq_int(Logger.level_rank(Logger.Error), 3, "Error rank 3")
  end

  -- ── level_enabled ──────────────────────────────────────────────────

  fn test_level_enabled_same() do
    Test.assert_true(Logger.level_enabled(Logger.Debug, Logger.Debug), "Debug >= Debug")
    Test.assert_true(Logger.level_enabled(Logger.Info,  Logger.Info),  "Info >= Info")
    Test.assert_true(Logger.level_enabled(Logger.Warn,  Logger.Warn),  "Warn >= Warn")
    Test.assert_true(Logger.level_enabled(Logger.Error, Logger.Error), "Error >= Error")
  end

  fn test_level_enabled_higher() do
    Test.assert_true(Logger.level_enabled(Logger.Info,  Logger.Debug), "Info >= Debug")
    Test.assert_true(Logger.level_enabled(Logger.Warn,  Logger.Debug), "Warn >= Debug")
    Test.assert_true(Logger.level_enabled(Logger.Error, Logger.Debug), "Error >= Debug")
    Test.assert_true(Logger.level_enabled(Logger.Error, Logger.Warn),  "Error >= Warn")
  end

  fn test_level_enabled_lower() do
    Test.assert_false(Logger.level_enabled(Logger.Debug, Logger.Info),  "Debug < Info")
    Test.assert_false(Logger.level_enabled(Logger.Debug, Logger.Error), "Debug < Error")
    Test.assert_false(Logger.level_enabled(Logger.Warn,  Logger.Error), "Warn < Error")
  end

  fn test_min_level_info_filters_debug() do
    let min = Logger.Info
    Test.assert_false(Logger.level_enabled(Logger.Debug, min), "Debug filtered at Info minimum")
    Test.assert_true(Logger.level_enabled(Logger.Info, min),  "Info allowed at Info minimum")
    Test.assert_true(Logger.level_enabled(Logger.Error, min), "Error allowed at Info minimum")
  end

  -- ── format_entry ───────────────────────────────────────────────────

  fn test_format_entry_debug() do
    let s = Logger.format_entry(Logger.Debug, "test message")
    Test.assert_eq_str(s, "[DEBUG] test message", "format_entry Debug")
  end

  fn test_format_entry_error() do
    let s = Logger.format_entry(Logger.Error, "something went wrong")
    Test.assert_eq_str(s, "[ERROR] something went wrong", "format_entry Error")
  end

  fn test_format_entry_empty_message() do
    let s = Logger.format_entry(Logger.Info, "")
    Test.assert_eq_str(s, "[INFO] ", "format_entry empty message")
  end

  -- ── log functions don't panic ──────────────────────────────────────

  fn test_log_functions_run() do
    Logger.log(Logger.Info, "test log call")
    Logger.debug("test debug")
    Logger.info("test info")
    Logger.warn("test warn")
    Logger.error("test error")
    Logger.log_if(Logger.Info, Logger.Debug, "should print")
    Logger.log_if(Logger.Debug, Logger.Error, "should not print")
  end

  -- ── Entry point ────────────────────────────────────────────────────

  pub fn main() do
    test_level_ctors()
    test_level_to_string()
    test_level_from_string_exact()
    test_level_from_string_uppercase()
    test_level_from_string_mixed_case()
    test_level_from_string_unknown()
    test_level_rank_ordering()
    test_level_rank_specific_values()
    test_level_enabled_same()
    test_level_enabled_higher()
    test_level_enabled_lower()
    test_min_level_info_filters_debug()
    test_format_entry_debug()
    test_format_entry_error()
    test_format_entry_empty_message()
    test_log_functions_run()
  end

end
