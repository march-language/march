-- Tests for the Logger stdlib module.
-- Run with: dune exec march -- test test/stdlib/test_logger.march

mod TestLogger do

-- Helper: get a Level from a string, panic if unknown
fn get_level(s) do
  match Logger.level_from_string(s) do
  | None -> panic("unknown level: " ++ s)
  | Some(l) -> l
  end
end

describe "Logger" do

  describe "level_from_string" do

    test "level_from_string exact lowercase" do
      match Logger.level_from_string("debug") do
      | None -> panic("expected Some for debug")
      | Some(l) -> assert (Logger.level_to_string(l) == "DEBUG")
      end
      match Logger.level_from_string("info") do
      | None -> panic("expected Some for info")
      | Some(l) -> assert (Logger.level_to_string(l) == "INFO")
      end
      match Logger.level_from_string("warn") do
      | None -> panic("expected Some for warn")
      | Some(l) -> assert (Logger.level_to_string(l) == "WARN")
      end
      match Logger.level_from_string("error") do
      | None -> panic("expected Some for error")
      | Some(l) -> assert (Logger.level_to_string(l) == "ERROR")
      end
    end

    test "level_from_string uppercase" do
      match Logger.level_from_string("DEBUG") do
      | None -> panic("expected Some for DEBUG")
      | Some(l) -> assert (Logger.level_to_string(l) == "DEBUG")
      end
      match Logger.level_from_string("INFO") do
      | None -> panic("expected Some for INFO")
      | Some(l) -> assert (Logger.level_to_string(l) == "INFO")
      end
    end

    test "level_from_string warning alias" do
      match Logger.level_from_string("warning") do
      | None -> panic("expected Some for warning")
      | Some(l) -> assert (Logger.level_to_string(l) == "WARN")
      end
    end

    test "level_from_string unknown returns None" do
      assert Option.is_none(Logger.level_from_string("trace"))
      assert Option.is_none(Logger.level_from_string("verbose"))
      assert Option.is_none(Logger.level_from_string(""))
    end

  end

  describe "level_to_string" do

    test "level_to_string values" do
      assert (Logger.level_to_string(get_level("debug")) == "DEBUG")
      assert (Logger.level_to_string(get_level("info"))  == "INFO")
      assert (Logger.level_to_string(get_level("warn"))  == "WARN")
      assert (Logger.level_to_string(get_level("error")) == "ERROR")
    end

  end

  describe "level_rank" do

    test "level_rank ordering" do
      let d = Logger.level_rank(get_level("debug"))
      let i = Logger.level_rank(get_level("info"))
      let w = Logger.level_rank(get_level("warn"))
      let e = Logger.level_rank(get_level("error"))
      assert (d < i)
      assert (i < w)
      assert (w < e)
    end

    test "level_rank specific values" do
      assert (Logger.level_rank(get_level("debug")) == 0)
      assert (Logger.level_rank(get_level("info"))  == 1)
      assert (Logger.level_rank(get_level("warn"))  == 2)
      assert (Logger.level_rank(get_level("error")) == 3)
    end

  end

  describe "level_enabled" do

    test "level_enabled same level" do
      let debug_ = get_level("debug")
      let info_  = get_level("info")
      let warn_  = get_level("warn")
      let error_ = get_level("error")
      assert Logger.level_enabled(debug_, debug_)
      assert Logger.level_enabled(info_,  info_)
      assert Logger.level_enabled(warn_,  warn_)
      assert Logger.level_enabled(error_, error_)
    end

    test "level_enabled higher level" do
      let debug_ = get_level("debug")
      let warn_  = get_level("warn")
      let error_ = get_level("error")
      assert Logger.level_enabled(get_level("info"),  debug_)
      assert Logger.level_enabled(warn_,  debug_)
      assert Logger.level_enabled(error_, debug_)
      assert Logger.level_enabled(error_, warn_)
    end

    test "level_enabled lower level" do
      assert not(Logger.level_enabled(get_level("debug"), get_level("info")))
      assert not(Logger.level_enabled(get_level("debug"), get_level("error")))
      assert not(Logger.level_enabled(get_level("warn"),  get_level("error")))
    end

  end

  describe "format_entry" do

    test "format_entry debug" do
      let s = Logger.format_entry(get_level("debug"), "test message")
      assert (s == "[DEBUG] test message")
    end

    test "format_entry error" do
      let s = Logger.format_entry(get_level("error"), "something went wrong")
      assert (s == "[ERROR] something went wrong")
    end

    test "format_entry empty message" do
      let s = Logger.format_entry(get_level("info"), "")
      assert (s == "[INFO] ")
    end

  end

  describe "log functions" do

    test "log functions run without error" do
      Logger.log(get_level("info"), "test log call")
      Logger.debug("test debug")
      Logger.info("test info")
      Logger.warn("test warn")
      Logger.error("test error")
      Logger.log_if(get_level("info"), get_level("debug"), "should print")
      Logger.log_if(get_level("debug"), get_level("error"), "should not print")
    end

  end

end

end
