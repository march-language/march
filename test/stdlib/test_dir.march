-- test/stdlib/test_dir.march
-- Tests for the Dir stdlib module.
-- Uses /tmp for temporary directories; each test uses a unique base path.
-- Run with: dune exec march -- test test/stdlib/test_dir.march

mod TestDir do

describe "Dir.exists" do
  test "returns false for nonexistent path" do
    assert (not (Dir.exists("/tmp/march_td_noexist_00")))
  end

  test "returns true after mkdir" do
    let path = "/tmp/march_td_exists_01"
    let _ = Dir.rm_rf(path)
    let _ = Dir.mkdir(path)
    assert (Dir.exists(path))
    let _ = Dir.rm_rf(path)
  end

  test "returns false for a file path" do
    let path = "/tmp/march_td_file_02"
    let _ = File.write(path, "data")
    assert (not (Dir.exists(path)))
    let _ = File.delete(path)
  end
end

describe "Dir.mkdir" do
  test "creates a directory" do
    let path = "/tmp/march_td_mkdir_03"
    let _ = Dir.rm_rf(path)
    match Dir.mkdir(path) do
    | Err(_) -> assert false
    | Ok(_)  -> ()
    end
    assert (Dir.exists(path))
    let _ = Dir.rm_rf(path)
  end

  test "duplicate mkdir returns Err" do
    let path = "/tmp/march_td_mkdir_dup_04"
    let _ = Dir.rm_rf(path)
    let _ = Dir.mkdir(path)
    match Dir.mkdir(path) do
    | Err(_) -> ()
    | Ok(_)  -> assert false
    end
    let _ = Dir.rm_rf(path)
  end
end

describe "Dir.list" do
  test "empty directory has no entries" do
    let path = "/tmp/march_td_list_05"
    let _ = Dir.rm_rf(path)
    let _ = Dir.mkdir(path)
    let names = match Dir.list(path) do
      | Ok(ns) -> ns
      | Err(_) -> panic("Dir.list failed")
    end
    assert (List.length(names) == 0)
    let _ = Dir.rm_rf(path)
  end

  test "list returns created files" do
    let path = "/tmp/march_td_list_06"
    let _ = Dir.rm_rf(path)
    let _ = Dir.mkdir(path)
    let _ = File.write(path ++ "/a.txt", "A")
    let _ = File.write(path ++ "/b.txt", "B")
    let names = match Dir.list(path) do
      | Ok(ns) -> ns
      | Err(_) -> panic("Dir.list after writes failed")
    end
    assert (List.length(names) == 2)
    let _ = Dir.rm_rf(path)
  end

  test "list on nonexistent returns Err" do
    match Dir.list("/tmp/march_td_list_noexist_07") do
    | Err(_) -> ()
    | Ok(_)  -> assert false
    end
  end
end

describe "Dir.list_full" do
  test "returns full absolute paths" do
    let path = "/tmp/march_td_full_08"
    let _ = Dir.rm_rf(path)
    let _ = Dir.mkdir(path)
    let _ = File.write(path ++ "/a.txt", "A")
    let _ = File.write(path ++ "/b.txt", "B")
    let paths = match Dir.list_full(path) do
      | Ok(ps) -> ps
      | Err(_) -> panic("Dir.list_full failed")
    end
    assert (List.length(paths) == 2)
    | assert (List.all(paths, fn p -> String.starts_with(p, path)))
    let _ = Dir.rm_rf(path)
  end
end

describe "Dir.mkdir_p" do
  test "creates nested directories" do
    let base   = "/tmp/march_td_mkdirp_09"
    let nested = base ++ "/deep/nested/path"
    let _ = Dir.rm_rf(base)
    match Dir.mkdir_p(nested) do
    | Err(_) -> assert false
    | Ok(_)  -> ()
    end
    assert (Dir.exists(nested))
    let _ = Dir.rm_rf(base)
  end
end

describe "Dir.rmdir" do
  test "removes an empty directory" do
    let path = "/tmp/march_td_rmdir_10"
    let _ = Dir.rm_rf(path)
    let _ = Dir.mkdir(path)
    match Dir.rmdir(path) do
    | Err(_) -> assert false
    | Ok(_)  -> ()
    end
    assert (not (Dir.exists(path)))
  end

  test "fails on non-empty directory" do
    let path = "/tmp/march_td_rmdir_ne_11"
    let _ = Dir.rm_rf(path)
    let _ = Dir.mkdir(path)
    let _ = File.write(path ++ "/file.txt", "data")
    match Dir.rmdir(path) do
    | Err(_) -> ()
    | Ok(_)  -> assert false
    end
    let _ = Dir.rm_rf(path)
  end
end

describe "Dir.rm_rf" do
  test "removes directory tree recursively" do
    let path = "/tmp/march_td_rmrf_12"
    let _ = Dir.rm_rf(path)
    let _ = Dir.mkdir(path)
    let _ = File.write(path ++ "/f1.txt", "x")
    let _ = Dir.mkdir(path ++ "/sub")
    let _ = File.write(path ++ "/sub/f2.txt", "y")
    match Dir.rm_rf(path) do
    | Err(_) -> assert false
    | Ok(_)  -> ()
    end
    assert (not (Dir.exists(path)))
  end

  test "rm_rf on nonexistent does not panic" do
    match Dir.rm_rf("/tmp/march_td_rmrf_noexist_13") do
    | Err(_) -> ()
    | Ok(_)  -> ()
    end
  end
end

end
