-- Tests for the Math stdlib module
-- Run with: dune exec march -- test test/stdlib/test_math.march

mod TestMath do

pfn approx_eq(a : Float, b : Float) : Bool do
  let diff = if a > b do a - b else b - a end
  diff < 0.0001
end

describe "constants" do
  test "pi is approximately 3.14159" do
    assert approx_eq(Math.pi(), 3.14159)
  end

  test "e is approximately 2.71828" do
    assert approx_eq(Math.e(), 2.71828)
  end

  test "tau is approximately 6.28318" do
    assert approx_eq(Math.tau(), 6.28318)
  end
end

describe "abs" do
  test "abs of positive float is unchanged" do
    assert approx_eq(Math.abs(3.5), 3.5)
  end

  test "abs of negative float gives positive" do
    assert approx_eq(Math.abs(-3.5), 3.5)
  end

  test "abs of zero is zero" do
    assert approx_eq(Math.abs(0.0), 0.0)
  end
end

describe "min_int and max_int" do
  test "min_int returns smaller of two ints" do
    assert (Math.min_int(3, 5) == 3)
    assert (Math.min_int(5, 3) == 3)
    assert (Math.min_int(-1, 1) == -1)
  end

  test "max_int returns larger of two ints" do
    assert (Math.max_int(3, 5) == 5)
    assert (Math.max_int(5, 3) == 5)
    assert (Math.max_int(-1, 1) == 1)
  end
end

describe "min_float and max_float" do
  test "min_float returns smaller float" do
    assert approx_eq(Math.min_float(1.5, 2.5), 1.5)
  end

  test "max_float returns larger float" do
    assert approx_eq(Math.max_float(1.5, 2.5), 2.5)
  end
end

describe "clamp_int" do
  test "clamp_int returns value when in range" do
    assert (Math.clamp_int(5, 0, 10) == 5)
  end

  test "clamp_int returns low when below range" do
    assert (Math.clamp_int(-5, 0, 10) == 0)
  end

  test "clamp_int returns high when above range" do
    assert (Math.clamp_int(15, 0, 10) == 10)
  end
end

describe "sqrt" do
  test "sqrt of 4 is 2" do
    assert approx_eq(Math.sqrt(4.0), 2.0)
  end

  test "sqrt of 0 is 0" do
    assert approx_eq(Math.sqrt(0.0), 0.0)
  end

  test "sqrt of 2 is approximately 1.41421" do
    assert approx_eq(Math.sqrt(2.0), 1.41421)
  end
end

describe "pow" do
  test "pow 2^10 is 1024" do
    assert approx_eq(Math.pow(2.0, 10.0), 1024.0)
  end

  test "pow x^0 is 1" do
    assert approx_eq(Math.pow(5.0, 0.0), 1.0)
  end

  test "pow 1^n is 1" do
    assert approx_eq(Math.pow(1.0, 100.0), 1.0)
  end
end

describe "floor, ceil, round" do
  test "floor rounds down" do
    assert approx_eq(Math.floor(3.7), 3.0)
    assert approx_eq(Math.floor(-3.7), -4.0)
  end

  test "ceil rounds up" do
    assert approx_eq(Math.ceil(3.2), 4.0)
    assert approx_eq(Math.ceil(-3.2), -3.0)
  end

  test "round rounds to nearest" do
    assert approx_eq(Math.round(3.5), 4.0)
    assert approx_eq(Math.round(3.4), 3.0)
  end
end

describe "logarithms" do
  test "log(e) is 1" do
    assert approx_eq(Math.log(Math.e()), 1.0)
  end

  test "log2(8) is 3" do
    assert approx_eq(Math.log2(8.0), 3.0)
  end

  test "log10(1000) is 3" do
    assert approx_eq(Math.log10(1000.0), 3.0)
  end
end

describe "trigonometry" do
  test "sin(0) is 0" do
    assert approx_eq(Math.sin(0.0), 0.0)
  end

  test "cos(0) is 1" do
    assert approx_eq(Math.cos(0.0), 1.0)
  end

  test "sin(pi) is approximately 0" do
    assert approx_eq(Math.sin(Math.pi()), 0.0)
  end
end

describe "lerp" do
  test "lerp at t=0 returns a" do
    assert approx_eq(Math.lerp(0.0, 10.0, 0.0), 0.0)
  end

  test "lerp at t=1 returns b" do
    assert approx_eq(Math.lerp(0.0, 10.0, 1.0), 10.0)
  end

  test "lerp at t=0.5 returns midpoint" do
    assert approx_eq(Math.lerp(0.0, 10.0, 0.5), 5.0)
  end
end

end
