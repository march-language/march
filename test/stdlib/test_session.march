-- Tests for the Session stdlib module.

mod TestSession do

-- ---------------------------------------------------------------------------
-- Helpers
-- ---------------------------------------------------------------------------

-- Build a minimal Conn.
fn make_conn(hdrs) do
  Conn(0, Get, "/", Nil, "", hdrs, "", 0, Nil, "", false, Nil, NoUpgrade)
end

fn empty_conn() do
  make_conn(Nil)
end

fn conn_with_cookie(cookie_val) do
  make_conn(Cons(Header("cookie", cookie_val), Nil))
end

-- Extract the cookie value from a Set-Cookie header string.
-- e.g. "_session=abc.def; Path=/" -> "abc.def"
fn extract_cookie_val(sc) do
  match String.split_first(sc, "=") do
  None -> ""
  Some((_, rest)) ->
    match String.split_first(rest, ";") do
    None -> rest
    Some((v, _)) -> v
    end
  end
end

-- Get the cookie value from a response conn's Set-Cookie header.
fn resp_cookie_val(conn) do
  match HttpServer.get_resp_header(conn, "set-cookie") do
  None     -> None
  Some(sc) -> Some(extract_cookie_val(sc))
  end
end

-- ---------------------------------------------------------------------------
-- Session.initialized
-- ---------------------------------------------------------------------------

describe "Session.initialized" do
  test "returns false before load" do
    let conn = empty_conn()
    assert (!Session.initialized(conn))
  end

  test "returns true after load :cookie" do
    let conn = Session.load(empty_conn(), :cookie)
    assert (Session.initialized(conn))
  end

  test "returns true after load :vault" do
    let conn = Session.load(empty_conn(), :vault)
    assert (Session.initialized(conn))
  end
end

-- ---------------------------------------------------------------------------
-- Session.load — :cookie backend
-- ---------------------------------------------------------------------------

describe "Session.load :cookie" do
  test "fresh session is empty" do
    let conn = Session.load(empty_conn(), :cookie)
    assert (Session.all(conn) == Nil)
  end

  test "unknown backend falls back to cookie" do
    let conn = Session.load(empty_conn(), :unknown)
    assert (Session.initialized(conn))
    assert (Session.all(conn) == Nil)
  end

  test "tampered cookie starts fresh session" do
    let c = conn_with_cookie("_session=totalgarbage.invalidsig")
    let conn = Session.load(c, :cookie)
    assert (Session.all(conn) == Nil)
  end

  test "missing cookie starts fresh session" do
    let conn = Session.load(empty_conn(), :cookie)
    assert (Session.all(conn) == Nil)
  end
end

-- ---------------------------------------------------------------------------
-- Session.load — :vault backend
-- ---------------------------------------------------------------------------

describe "Session.load :vault" do
  test "fresh session (no cookie) is empty" do
    let conn = Session.load(empty_conn(), :vault)
    assert (Session.all(conn) == Nil)
  end

  test "session ID assigned on first visit" do
    let conn = Session.load(empty_conn(), :vault)
    match HttpServer.get_assign(conn, "_session_id") do
    Some(sid) -> assert (String.byte_size(sid) > 0)
    None      -> assert false
    end
  end

  test "vault round-trip: put, save, reload" do
    let conn1 = Session.load(empty_conn(), :vault)
    let conn2 = conn1 |> Session.put("user", "alice") |> Session.save()
    match resp_cookie_val(conn2) do
    None      -> assert false
    Some(sid) -> do
      let conn3 = conn_with_cookie("_session=" ++ sid)
      let conn4 = Session.load(conn3, :vault)
      assert (Session.get(conn4, "user") == Some("alice"))
    end
    end
  end
end

-- ---------------------------------------------------------------------------
-- Session.get / Session.put / Session.delete / Session.clear
-- ---------------------------------------------------------------------------

describe "Session.get" do
  test "returns None for missing key" do
    let conn = Session.load(empty_conn(), :cookie)
    assert (Session.get(conn, "missing") == None)
  end

  test "returns Some after put" do
    let conn = Session.load(empty_conn(), :cookie) |> Session.put("x", "hello")
    assert (Session.get(conn, "x") == Some("hello"))
  end

  test "last put wins for same key" do
    let conn = Session.load(empty_conn(), :cookie)
              |> Session.put("k", "v1")
              |> Session.put("k", "v2")
    assert (Session.get(conn, "k") == Some("v2"))
  end

  test "independent keys do not interfere" do
    let conn = Session.load(empty_conn(), :cookie)
              |> Session.put("a", "1")
              |> Session.put("b", "2")
    assert (Session.get(conn, "a") == Some("1"))
    assert (Session.get(conn, "b") == Some("2"))
  end
end

describe "Session.delete" do
  test "removing an existing key" do
    let conn = Session.load(empty_conn(), :cookie)
              |> Session.put("gone", "val")
              |> Session.delete("gone")
    assert (Session.get(conn, "gone") == None)
  end

  test "no-op for missing key" do
    let conn = Session.load(empty_conn(), :cookie)
              |> Session.put("x", "1")
              |> Session.delete("missing")
    assert (Session.get(conn, "x") == Some("1"))
  end
end

describe "Session.clear" do
  test "clears all session data" do
    let conn = Session.load(empty_conn(), :cookie)
              |> Session.put("a", "1")
              |> Session.put("b", "2")
              |> Session.clear()
    assert (Session.all(conn) == Nil)
  end

  test "can put values after clear" do
    let conn = Session.load(empty_conn(), :cookie)
              |> Session.put("a", "1")
              |> Session.clear()
              |> Session.put("b", "2")
    assert (Session.get(conn, "a") == None)
    assert (Session.get(conn, "b") == Some("2"))
  end
end

describe "Session.all" do
  test "returns empty list for fresh session" do
    let conn = Session.load(empty_conn(), :cookie)
    assert (Session.all(conn) == Nil)
  end

  test "returns all pairs" do
    let conn = Session.load(empty_conn(), :cookie)
              |> Session.put("a", "1")
              |> Session.put("b", "2")
    assert (List.length(Session.all(conn)) == 2)
  end
end

-- ---------------------------------------------------------------------------
-- Session.save (cookie backend)
-- ---------------------------------------------------------------------------

describe "Session.save cookie" do
  test "adds Set-Cookie response header" do
    let conn = Session.load(empty_conn(), :cookie)
              |> Session.put("user_id", "99")
              |> Session.save()
    match HttpServer.get_resp_header(conn, "set-cookie") do
    Some(_) -> assert true
    None    -> assert false
    end
  end

  test "Set-Cookie starts with cookie name" do
    let conn = Session.load(empty_conn(), :cookie) |> Session.save()
    match HttpServer.get_resp_header(conn, "set-cookie") do
    Some(sc) -> assert (String.starts_with(sc, "_session="))
    None     -> assert false
    end
  end

  test "cookie round-trip preserves values" do
    let conn1 = Session.load(empty_conn(), :cookie)
               |> Session.put("role", "admin")
               |> Session.put("user_id", "7")
               |> Session.save()
    match resp_cookie_val(conn1) do
    None           -> assert false
    Some(cookie_val) -> do
      let conn2 = conn_with_cookie("_session=" ++ cookie_val)
      let conn3 = Session.load(conn2, :cookie)
      assert (Session.get(conn3, "role")    == Some("admin"))
      assert (Session.get(conn3, "user_id") == Some("7"))
    end
    end
  end

  test "tampered cookie after valid save is rejected" do
    let conn1 = Session.load(empty_conn(), :cookie)
               |> Session.put("secret", "yes")
               |> Session.save()
    match resp_cookie_val(conn1) do
    None             -> assert false
    Some(cookie_val) -> do
      -- Append junk to the signed cookie value itself (not the header)
      let conn2 = conn_with_cookie("_session=" ++ cookie_val ++ "TAMPERED")
      let conn3 = Session.load(conn2, :cookie)
      assert (Session.get(conn3, "secret") == None)
    end
    end
  end

  test "empty session produces valid cookie that reloads to empty" do
    let conn1 = Session.load(empty_conn(), :cookie) |> Session.save()
    match resp_cookie_val(conn1) do
    None           -> assert false
    Some(cookie_val) -> do
      let conn2 = conn_with_cookie("_session=" ++ cookie_val)
      let conn3 = Session.load(conn2, :cookie)
      assert (Session.all(conn3) == Nil)
    end
    end
  end
end

-- ---------------------------------------------------------------------------
-- Session.save_with_opts
-- ---------------------------------------------------------------------------

describe "Session.save_with_opts" do
  test "max_age appears in Set-Cookie" do
    let conn = Session.load(empty_conn(), :cookie)
              |> Session.save_with_opts([("max_age", "3600")])
    match HttpServer.get_resp_header(conn, "set-cookie") do
    Some(sc) -> assert (String.contains(sc, "Max-Age=3600"))
    None     -> assert false
    end
  end

  test "secure flag appears when requested" do
    let conn = Session.load(empty_conn(), :cookie)
              |> Session.save_with_opts([("secure", "true")])
    match HttpServer.get_resp_header(conn, "set-cookie") do
    Some(sc) -> assert (String.contains(sc, "Secure"))
    None     -> assert false
    end
  end

  test "default SameSite=Lax is present" do
    let conn = Session.load(empty_conn(), :cookie) |> Session.save()
    match HttpServer.get_resp_header(conn, "set-cookie") do
    Some(sc) -> assert (String.contains(sc, "SameSite=Lax"))
    None     -> assert false
    end
  end

  test "custom SameSite overrides default" do
    let conn = Session.load(empty_conn(), :cookie)
              |> Session.save_with_opts([("same_site", "Strict")])
    match HttpServer.get_resp_header(conn, "set-cookie") do
    Some(sc) -> assert (String.contains(sc, "SameSite=Strict"))
    None     -> assert false
    end
  end

  test "HttpOnly is present by default" do
    let conn = Session.load(empty_conn(), :cookie) |> Session.save()
    match HttpServer.get_resp_header(conn, "set-cookie") do
    Some(sc) -> assert (String.contains(sc, "HttpOnly"))
    None     -> assert false
    end
  end

  test "custom path appears in Set-Cookie" do
    let conn = Session.load(empty_conn(), :cookie)
              |> Session.save_with_opts([("path", "/app")])
    match HttpServer.get_resp_header(conn, "set-cookie") do
    Some(sc) -> assert (String.contains(sc, "Path=/app"))
    None     -> assert false
    end
  end
end

-- ---------------------------------------------------------------------------
-- Flash messages
-- ---------------------------------------------------------------------------

describe "Session.put_flash / Session.get_flash" do
  test "get_flash returns (conn, None) when no flash set" do
    let conn = Session.load(empty_conn(), :cookie)
    match Session.get_flash(conn, "notice") do
    (_, None)    -> assert true
    (_, Some(_)) -> assert false
    end
  end

  test "get_flash returns (conn, Some) after put_flash" do
    let conn = Session.load(empty_conn(), :cookie)
              |> Session.put_flash("notice", "Saved!")
    match Session.get_flash(conn, "notice") do
    (_, Some(msg)) -> assert (msg == "Saved!")
    (_, None)      -> assert false
    end
  end

  test "flash is removed after being read and saved" do
    let conn1 = Session.load(empty_conn(), :cookie)
               |> Session.put_flash("notice", "Hello")
    match Session.get_flash(conn1, "notice") do
    (_, None)        -> assert false
    (conn2, Some(_)) -> do
      let conn3 = Session.save(conn2)
      match resp_cookie_val(conn3) do
      None           -> assert false
      Some(cookie_val) -> do
        let conn4 = conn_with_cookie("_session=" ++ cookie_val)
        let conn5 = Session.load(conn4, :cookie)
        match Session.get_flash(conn5, "notice") do
        (_, None)    -> assert true
        (_, Some(_)) -> assert false
        end
      end
      end
    end
    end
  end

  test "unread flash survives save" do
    let conn1 = Session.load(empty_conn(), :cookie)
               |> Session.put_flash("error", "Oops")
               |> Session.save()
    match resp_cookie_val(conn1) do
    None           -> assert false
    Some(cookie_val) -> do
      let conn2 = conn_with_cookie("_session=" ++ cookie_val)
      let conn3 = Session.load(conn2, :cookie)
      match Session.get_flash(conn3, "error") do
      (_, Some(msg)) -> assert (msg == "Oops")
      (_, None)      -> assert false
      end
    end
    end
  end

  test "multiple flash keys are independent" do
    let conn = Session.load(empty_conn(), :cookie)
              |> Session.put_flash("notice", "OK")
              |> Session.put_flash("error", "Bad")
    match Session.get_flash(conn, "notice") do
    (_, Some(v)) -> assert (v == "OK")
    (_, None)    -> assert false
    end
    match Session.get_flash(conn, "error") do
    (_, Some(v)) -> assert (v == "Bad")
    (_, None)    -> assert false
    end
  end

  test "clear removes flash messages" do
    let conn = Session.load(empty_conn(), :cookie)
              |> Session.put_flash("notice", "Hi")
              |> Session.clear()
    match Session.get_flash(conn, "notice") do
    (_, None)    -> assert true
    (_, Some(_)) -> assert false
    end
  end

  test "flash does not interfere with regular session keys" do
    let conn = Session.load(empty_conn(), :cookie)
              |> Session.put("user_id", "42")
              |> Session.put_flash("notice", "Welcome")
    assert (Session.get(conn, "user_id") == Some("42"))
    match Session.get_flash(conn, "notice") do
    (_, Some(v)) -> assert (v == "Welcome")
    (_, None)    -> assert false
    end
  end

  test "regular key does not interfere with flash" do
    let conn = Session.load(empty_conn(), :cookie)
              |> Session.put_flash("notice", "Hi")
              |> Session.put("x", "1")
    match Session.get_flash(conn, "notice") do
    (_, Some(v)) -> assert (v == "Hi")
    (_, None)    -> assert false
    end
    assert (Session.get(conn, "x") == Some("1"))
  end
end

-- ---------------------------------------------------------------------------
-- CSRF integration
-- ---------------------------------------------------------------------------

describe "CSRF + Session composability" do
  test "CSRF.ensure_token works after Session.load" do
    let conn = Session.load(empty_conn(), :cookie)
              |> CSRF.ensure_token()
    let tok = CSRF.token(conn)
    assert (String.byte_size(tok) > 0)
  end

  test "CSRF token can be persisted in session and reloaded" do
    let conn1 = Session.load(empty_conn(), :cookie)
               |> CSRF.ensure_token()
    let tok1 = CSRF.token(conn1)
    let conn2 = conn1
               |> Session.put("_csrf_token", tok1)
               |> Session.save()
    match resp_cookie_val(conn2) do
    None           -> assert false
    Some(cookie_val) -> do
      let conn3 = conn_with_cookie("_session=" ++ cookie_val)
      let conn4 = Session.load(conn3, :cookie)
      assert (Session.get(conn4, "_csrf_token") == Some(tok1))
    end
    end
  end
end

end -- mod TestSession
