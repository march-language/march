-- Tests for the List stdlib module
-- Run with: dune exec march -- test test/stdlib/test_list.march

mod TestList do

pfn five() : List(Int) do
  Cons(1, Cons(2, Cons(3, Cons(4, Cons(5, Nil)))))
end

pfn three() : List(Int) do
  Cons(10, Cons(20, Cons(30, Nil)))
end

describe "construction" do
  test "empty returns empty list" do
    assert List.is_empty(List.empty())
  end

  test "singleton returns list with one element" do
    let s = List.singleton(42)
    assert (List.length(s) == 1)
    assert (List.head(s) == 42)
  end

  test "repeat n times produces correct length" do
    let r = List.repeat(7, 3)
    assert (List.length(r) == 3)
    assert (List.head(r) == 7)
  end

  test "repeat zero times produces empty list" do
    assert List.is_empty(List.repeat(5, 0))
  end

  test "range produces correct elements" do
    let r = List.range(1, 5)
    assert (List.length(r) == 4)
    assert (List.head(r) == 1)
    assert (List.last(r) == 4)
  end

  test "range with equal start and stop is empty" do
    assert List.is_empty(List.range(5, 5))
  end

  test "range with start greater than stop is empty" do
    assert List.is_empty(List.range(6, 3))
  end

  test "range_step positive step" do
    let r = List.range_step(0, 10, 2)
    assert (List.length(r) == 5)
    assert (List.head(r) == 0)
    assert (List.last(r) == 8)
  end

  test "range_step negative step" do
    let r = List.range_step(5, 0, -1)
    assert (List.length(r) == 5)
    assert (List.head(r) == 5)
  end
end

describe "access" do
  test "head returns first element" do
    assert (List.head(five()) == 1)
  end

  test "head_opt returns Some for non-empty list" do
    assert Option.is_some(List.head_opt(three()))
  end

  test "head_opt returns None for empty list" do
    let empty : List(Int) = Nil
    assert Option.is_none(List.head_opt(empty))
  end

  test "tail returns rest of list" do
    let t = List.tail(Cons(1, Cons(2, Nil)))
    assert (List.head(t) == 2)
  end

  test "tail_opt returns Some for non-empty list" do
    assert Option.is_some(List.tail_opt(three()))
  end

  test "tail_opt returns None for empty list" do
    let empty : List(Int) = Nil
    assert Option.is_none(List.tail_opt(empty))
  end

  test "last returns final element" do
    assert (List.last(five()) == 5)
  end

  test "last of singleton returns the element" do
    assert (List.last(List.singleton(99)) == 99)
  end

  test "nth returns element at index" do
    assert (List.nth(five(), 0) == 1)
    assert (List.nth(five(), 2) == 3)
    assert (List.nth(five(), 4) == 5)
  end

  test "nth_opt returns Some when in bounds" do
    assert Option.is_some(List.nth_opt(five(), 1))
  end

  test "nth_opt returns None when out of bounds" do
    assert Option.is_none(List.nth_opt(five(), 10))
  end
end

describe "measurement" do
  test "length of empty list is zero" do
    let empty : List(Int) = Nil
    assert (List.length(empty) == 0)
  end

  test "length of five-element list is five" do
    assert (List.length(five()) == 5)
  end

  test "is_empty returns true for Nil" do
    let empty : List(Int) = Nil
    assert List.is_empty(empty)
  end

  test "is_empty returns false for non-empty list" do
    assert !List.is_empty(five())
  end
end

describe "transforming" do
  test "reverse flips list order" do
    let r = List.reverse(three())
    assert (List.head(r) == 30)
    assert (List.last(r) == 10)
  end

  test "reverse of empty is empty" do
    let empty : List(Int) = Nil
    assert List.is_empty(List.reverse(empty))
  end

  test "append concatenates two lists" do
    let a = Cons(1, Cons(2, Nil))
    let b = Cons(3, Cons(4, Nil))
    let c = List.append(a, b)
    assert (List.length(c) == 4)
    assert (List.head(c) == 1)
    assert (List.last(c) == 4)
  end

  test "append with empty left gives same list" do
    let empty : List(Int) = Nil
    let r = List.append(empty, three())
    assert (List.length(r) == 3)
  end

  test "append with empty right gives same list" do
    let empty : List(Int) = Nil
    let r = List.append(three(), empty)
    assert (List.length(r) == 3)
  end

  test "map applies function to each element" do
    let doubled = List.map(three(), fn x -> x * 2)
    assert (List.head(doubled) == 20)
    assert (List.last(doubled) == 60)
  end

  test "map over empty list gives empty list" do
    let empty : List(Int) = Nil
    | assert List.is_empty(List.map(empty, fn x -> x + 1))
  end

  test "flat_map expands each element" do
    let xs = Cons(1, Cons(2, Cons(3, Nil)))
    let r = List.flat_map(xs, fn x -> Cons(x, Cons(x * 10, Nil)))
    assert (List.length(r) == 6)
    assert (List.head(r) == 1)
  end

  test "flat_map returning empty gives empty list" do
    let xs = Cons(1, Cons(2, Nil))
    let empty : List(Int) = Nil
    let r = List.flat_map(xs, fn _x -> empty)
    assert List.is_empty(r)
  end

  test "filter keeps elements satisfying predicate" do
    let evens = List.filter(five(), fn x -> x % 2 == 0)
    assert (List.length(evens) == 2)
    assert (List.head(evens) == 2)
    assert (List.last(evens) == 4)
  end

  test "filter on empty list gives empty list" do
    let empty : List(Int) = Nil
    | assert List.is_empty(List.filter(empty, fn x -> x > 0))
  end

  test "filter_map keeps Some values" do
    let xs = Cons(1, Cons(2, Cons(3, Cons(4, Nil))))
    let r = List.filter_map(xs, fn x -> if x % 2 == 0 do Some(x * 10) else None) end
    assert (List.length(r) == 2)
    assert (List.head(r) == 20)
    assert (List.last(r) == 40)
  end

  test "intersperse inserts separator between elements" do
    let r = List.intersperse(three(), 0)
    assert (List.length(r) == 5)
    assert (List.nth(r, 1) == 0)
    assert (List.nth(r, 3) == 0)
  end

  test "intersperse of singleton gives singleton" do
    let r = List.intersperse(List.singleton(5), 0)
    assert (List.length(r) == 1)
  end
end

describe "folding" do
  test "fold_left sums list" do
    let s = List.fold_left(0, five(), fn (acc, x) -> acc + x)
    assert (s == 15)
  end

  test "fold_left builds reversed list" do
    let r = List.fold_left(Nil, three(), fn (acc, x) -> Cons(x, acc))
    assert (List.head(r) == 30)
  end

  test "fold_right sums list" do
    let s = List.fold_right(five(), 0, fn (x, acc) -> x + acc)
    assert (s == 15)
  end

  test "scan_left produces prefix sums" do
    let xs = Cons(1, Cons(2, Cons(3, Nil)))
    let r = List.scan_left(0, xs, fn (acc, x) -> acc + x)
    assert (List.length(r) == 4)
    assert (List.head(r) == 0)
    assert (List.last(r) == 6)
  end
end

describe "searching" do
  test "find returns Some when element exists" do
    | assert Option.is_some(List.find(five(), fn x -> x == 3))
  end

  test "find returns None when element is absent" do
    | assert Option.is_none(List.find(five(), fn x -> x == 99))
  end

  test "find returns correct value" do
    | assert (Option.unwrap(List.find(five(), fn x -> x > 3)) == 4)
  end

  test "find_index returns correct index" do
    | assert (Option.unwrap(List.find_index(five(), fn x -> x == 3)) == 2)
  end

  test "find_index returns None when absent" do
    | assert Option.is_none(List.find_index(five(), fn x -> x > 100))
  end

  test "any returns true when an element satisfies predicate" do
    | assert List.any(five(), fn x -> x > 4)
  end

  test "any returns false when no element satisfies predicate" do
    | assert !List.any(five(), fn x -> x > 10)
  end

  test "any on empty list returns false" do
    let empty : List(Int) = Nil
    | assert !List.any(empty, fn x -> x > 0)
  end

  test "all returns true when all elements satisfy predicate" do
    | assert List.all(five(), fn x -> x > 0)
  end

  test "all returns false when some element fails" do
    | assert !List.all(five(), fn x -> x > 3)
  end

  test "all on empty list returns true vacuously" do
    let empty : List(Int) = Nil
    | assert List.all(empty, fn x -> x > 0)
  end
end

describe "sorting" do
  test "sort_by ascending" do
    let xs = Cons(3, Cons(1, Cons(4, Cons(1, Cons(5, Nil)))))
    let sorted = List.sort_by(xs, fn (a, b) -> a < b)
    assert (List.head(sorted) == 1)
    assert (List.last(sorted) == 5)
  end

  test "sort_by descending" do
    let xs = Cons(3, Cons(1, Cons(4, Nil)))
    let sorted = List.sort_by(xs, fn (a, b) -> a > b)
    assert (List.head(sorted) == 4)
    assert (List.last(sorted) == 1)
  end

  test "sort_by empty list gives empty list" do
    let empty : List(Int) = Nil
    | assert List.is_empty(List.sort_by(empty, fn (a, b) -> a < b))
  end
end

describe "splitting" do
  test "take returns first n elements" do
    let r = List.take(five(), 3)
    assert (List.length(r) == 3)
    assert (List.head(r) == 1)
    assert (List.last(r) == 3)
  end

  test "take more than length returns whole list" do
    let r = List.take(three(), 100)
    assert (List.length(r) == 3)
  end

  test "take zero returns empty list" do
    assert List.is_empty(List.take(five(), 0))
  end

  test "drop removes first n elements" do
    let r = List.drop(five(), 2)
    assert (List.length(r) == 3)
    assert (List.head(r) == 3)
  end

  test "drop more than length returns empty list" do
    assert List.is_empty(List.drop(three(), 10))
  end

  test "drop zero returns same list" do
    assert (List.length(List.drop(three(), 0)) == 3)
  end

  test "take_while takes while predicate holds" do
    let r = List.take_while(five(), fn x -> x < 4)
    assert (List.length(r) == 3)
    assert (List.last(r) == 3)
  end

  test "take_while with always-false predicate gives empty" do
    | assert List.is_empty(List.take_while(five(), fn x -> x > 10))
  end

  test "take_while with always-true predicate gives all" do
    | assert (List.length(List.take_while(five(), fn x -> x > 0)) == 5)
  end

  test "drop_while drops while predicate holds" do
    let r = List.drop_while(five(), fn x -> x < 3)
    assert (List.head(r) == 3)
    assert (List.length(r) == 3)
  end

  test "split_at splits at position" do
    match List.split_at(five(), 3) do
    | (left, right) -> do
      assert (List.length(left) == 3)
      assert (List.length(right) == 2)
      assert (List.last(left) == 3)
      assert (List.head(right) == 4)
    end
    end
  end

  test "partition separates by predicate" do
    | match List.partition(five(), fn x -> x % 2 == 0) do
    | (evens, odds) -> do
      assert (List.length(evens) == 2)
      assert (List.length(odds) == 3)
      assert (List.head(evens) == 2)
      assert (List.head(odds) == 1)
    end
    end
  end

  test "drop_last removes last element" do
    let r = List.drop_last(three())
    assert (List.length(r) == 2)
    assert (List.last(r) == 20)
  end

  test "drop_last of empty is empty" do
    let empty : List(Int) = Nil
    assert List.is_empty(List.drop_last(empty))
  end

  test "chunks splits into groups of given size" do
    let r = List.chunks(five(), 2)
    assert (List.length(r) == 3)
    assert (List.length(List.head(r)) == 2)
    assert (List.length(List.last(r)) == 1)
  end
end

describe "combining" do
  test "zip pairs elements from two lists" do
    let a = Cons(1, Cons(2, Cons(3, Nil)))
    let b = Cons(10, Cons(20, Cons(30, Nil)))
    let r = List.zip(a, b)
    assert (List.length(r) == 3)
    match List.head(r) do
    | (x, y) -> do
      assert (x == 1)
      assert (y == 10)
    end
    end
  end

  test "zip stops at shorter list" do
    let a = Cons(1, Cons(2, Nil))
    let b = Cons(10, Cons(20, Cons(30, Nil)))
    assert (List.length(List.zip(a, b)) == 2)
  end

  test "zip_with applies function to pairs" do
    let a = Cons(1, Cons(2, Cons(3, Nil)))
    let b = Cons(4, Cons(5, Cons(6, Nil)))
    let r = List.zip_with(a, b, fn (x, y) -> x + y)
    assert (List.head(r) == 5)
    assert (List.last(r) == 9)
  end

  test "unzip splits list of pairs" do
    let pairs = Cons((1, 10), Cons((2, 20), Cons((3, 30), Nil)))
    match List.unzip(pairs) do
    | (as_, bs) -> do
      assert (List.head(as_) == 1)
      assert (List.head(bs) == 10)
      assert (List.length(as_) == 3)
    end
    end
  end

  test "enumerate pairs elements with indices" do
    let r = List.enumerate(three())
    match List.head(r) do
    | (i, v) -> do
      assert (i == 0)
      assert (v == 10)
    end
    end
    assert (List.length(r) == 3)
  end
end

describe "reducing" do
  test "sum_int sums list of integers" do
    assert (List.sum_int(five()) == 15)
  end

  test "sum_int of empty list is zero" do
    assert (List.sum_int(Nil) == 0)
  end

  test "product_int multiplies list of integers" do
    assert (List.product_int(Cons(1, Cons(2, Cons(3, Cons(4, Nil))))) == 24)
  end

  test "product_int of empty list is one" do
    assert (List.product_int(Nil) == 1)
  end

  test "minimum_int returns smallest element" do
    assert (List.minimum_int(five()) == 1)
  end

  test "minimum_int of singleton" do
    assert (List.minimum_int(Cons(-5, Nil)) == -5)
  end

  test "maximum_int returns largest element" do
    assert (List.maximum_int(five()) == 5)
  end

  test "maximum_int with negative numbers" do
    let xs = Cons(-3, Cons(-1, Cons(-5, Nil)))
    assert (List.maximum_int(xs) == -1)
  end
end

describe "deduplication" do
  test "dedup removes consecutive duplicates" do
    let xs = Cons(1, Cons(1, Cons(2, Cons(2, Cons(3, Nil)))))
    let r = List.dedup(xs)
    assert (List.length(r) == 3)
    assert (List.head(r) == 1)
  end

  test "dedup with no duplicates keeps all elements" do
    assert (List.length(List.dedup(three())) == 3)
  end

  test "dedup of empty list is empty" do
    let empty : List(Int) = Nil
    assert List.is_empty(List.dedup(empty))
  end
end

end
