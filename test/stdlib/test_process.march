-- Tests for the Process stdlib module.
-- Run with: dune exec march -- test test/stdlib/test_process.march

mod TestProcess do

describe "Process" do

  describe "cwd" do

    test "cwd is non-empty" do
      let dir = Process.cwd()
      assert not(string_is_empty(dir))
    end

    test "cwd has at least one character" do
      let dir = Process.cwd()
      assert (string_byte_length(dir) >= 1)
    end

  end

  describe "env" do

    test "PATH is set" do
      let path = Process.env("PATH")
      assert Option.is_some(path)
    end

    test "PATH is non-empty" do
      let path_opt = Process.env("PATH")
      match path_opt do
      None -> ()
      Some(p) -> assert not(string_is_empty(p))
      end
    end

    test "HOME if set is non-empty" do
      let home = Process.env("HOME")
      match home do
      None    -> ()
      Some(h) -> assert not(string_is_empty(h))
      end
    end

    test "unset variable is None" do
      let val_ = Process.env("__MARCH_TEST_UNSET_VAR_ZXQVWP__")
      assert Option.is_none(val_)
    end

    test "env returns Option" do
      let result = Process.env("PATH")
      match result do
      Some(_) -> ()
      None    -> ()
      end
    end

  end

  describe "argv" do

    test "argv is non-nil" do
      let args = Process.argv()
      assert not(is_nil(args))
    end

    test "argv first element is non-empty string" do
      let args = Process.argv()
      match args do
      Nil        -> panic("argv is empty — expected at least argv[0]")
      Cons(a, _) -> assert not(string_is_empty(a))
      end
    end

  end

end

end
