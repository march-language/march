-- Tests for Depot.Test: test-scoped transaction isolation.

mod TestDepotTest do

pfn user_schema() do
  Depot.Schema.define("depot_test_users", {
    fields = {
      name = "String",
      email = "String"
    }
  })
end

pfn make_gate(name, email) do
  Depot.Gate.cast_record(
    Depot.Schema.blank(user_schema()),
    { name = name, email = email },
    ["name", "email"]
  )
end

pfn unwrap_ok(result) do
  match result do
    Ok(v) -> v
    Err(_) -> panic("expected Ok, got Err")
  end
end

pfn insert_user(name, email) do
  unwrap_ok(Depot.Repo.insert(user_schema(), make_gate(name, email)))
end

pfn clear_users() do
  Depot.Repo.delete_all(user_schema())
end

test "start_sandbox activates sandbox" do
  Depot.Test.start_sandbox()
  assert Depot.Test.active() == true
  Depot.Test.stop_sandbox()
end

test "stop_sandbox deactivates sandbox" do
  Depot.Test.start_sandbox()
  Depot.Test.stop_sandbox()
  assert Depot.Test.active() == false
end

test "checkout and checkin rolls back inserts" do
  Depot.Test.start_sandbox()
  clear_users()
  Depot.Test.checkout(["depot_test_users"])
  insert_user("Alice", "alice@test.com")
  assert Depot.Repo.count(user_schema()) == 1
  Depot.Test.checkin()
  assert Depot.Repo.count(user_schema()) == 0
  Depot.Test.stop_sandbox()
end

test "checkout preserves pre-existing data" do
  Depot.Test.start_sandbox()
  clear_users()
  insert_user("Baseline", "base@test.com")
  assert Depot.Repo.count(user_schema()) == 1
  Depot.Test.checkout(["depot_test_users"])
  insert_user("Extra", "extra@test.com")
  assert Depot.Repo.count(user_schema()) == 2
  Depot.Test.checkin()
  assert Depot.Repo.count(user_schema()) == 1
  clear_users()
  Depot.Test.stop_sandbox()
end

pfn sandboxed_insert_count() do
  let _ = insert_user("Temp", "temp@test.com")
  Depot.Repo.count(user_schema())
end

test "sandboxed function auto-rolls back" do
  Depot.Test.start_sandbox()
  clear_users()
  let result = Depot.Test.sandboxed(["depot_test_users"], sandboxed_insert_count)
  assert result == 1
  assert Depot.Repo.count(user_schema()) == 0
  Depot.Test.stop_sandbox()
end

test "multiple checkout/checkin cycles work" do
  Depot.Test.start_sandbox()
  clear_users()
  Depot.Test.checkout(["depot_test_users"])
  insert_user("One", "one@test.com")
  assert Depot.Repo.count(user_schema()) == 1
  Depot.Test.checkin()
  assert Depot.Repo.count(user_schema()) == 0
  Depot.Test.checkout(["depot_test_users"])
  insert_user("Two", "two@test.com")
  insert_user("Three", "three@test.com")
  assert Depot.Repo.count(user_schema()) == 2
  Depot.Test.checkin()
  assert Depot.Repo.count(user_schema()) == 0
  Depot.Test.stop_sandbox()
end

test "sandbox preserves deletes on rollback" do
  Depot.Test.start_sandbox()
  clear_users()
  insert_user("Keep", "keep@test.com")
  assert Depot.Repo.count(user_schema()) == 1
  Depot.Test.checkout(["depot_test_users"])
  Depot.Repo.delete_all(user_schema())
  assert Depot.Repo.count(user_schema()) == 0
  Depot.Test.checkin()
  assert Depot.Repo.count(user_schema()) == 1
  clear_users()
  Depot.Test.stop_sandbox()
end

end
