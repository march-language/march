-- Tests for the Test stdlib module (assertion helpers).
-- Run with: dune exec march -- test test/stdlib/test_test.march

mod TestTest do

-- ---- Test.assert_eq on primitive types ----

test "assert_eq on ints" do
  Test.assert_eq(1 + 1, 2, "int equal")
end

test "assert_eq on strings" do
  Test.assert_eq("hi" ++ "lo", "hilo", "string equal")
end

test "assert_eq on bools" do
  Test.assert_eq(true, true, "bool equal")
end

-- ---- Test.assert_eq on composite values ----

test "assert_eq on tuples" do
  Test.assert_eq((1, "a"), (1, "a"), "tuple equal")
end

test "assert_eq on lists" do
  Test.assert_eq([1, 2, 3], [1, 2, 3], "list equal")
end

test "assert_eq on Option" do
  Test.assert_eq(Some(42), Some(42), "option equal")
end

test "assert_eq on nested structures" do
  Test.assert_eq(Some((1, [2, 3])), Some((1, [2, 3])), "nested equal")
end

-- ---- Test.assert_ne ----

test "assert_ne on differing ints" do
  Test.assert_ne(1, 2, "ints differ")
end

test "assert_ne on Some vs None" do
  Test.assert_ne(Some(1), None, "some vs none")
end

test "assert_ne on different tuples" do
  Test.assert_ne((1, "a"), (1, "b"), "tuples differ")
end

end
