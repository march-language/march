-- Tests for Depot.Repo: in-memory Vault-backed repository.

mod TestDepotRepo do

-- Helper: define a simple users schema for testing.
pfn user_schema() do
  Depot.Schema.define("test_repo_users", {
    fields = {
      name  = "String",
      email = "String",
      age   = ("Int", { default = 0 }),
      role  = ("String", { default = "user" })
    }
  })
end

-- Helper: unwrap Ok or panic.
pfn unwrap_ok(result) do
  match result do
    Ok(v) -> v
    Err(_) -> panic("expected Ok, got Err")
  end
end

-- Helper: check if result is Err.
pfn is_err(result) do
  match result do
    Ok(_) -> false
    Err(_) -> true
  end
end

-- Helper: unwrap Err gate.
pfn unwrap_err(result) do
  match result do
    Ok(_) -> panic("expected Err, got Ok")
    Err(g) -> g
  end
end

-- Helper: unwrap Some or panic.
pfn unwrap_some(opt) do
  match opt do
    Some(v) -> v
    None -> panic("expected Some, got None")
  end
end

-- Helper: check if option is None.
pfn is_none(opt) do
  match opt do
    Some(_) -> false
    None -> true
  end
end

-- Helper: insert a user and return the record.
pfn insert_user(name, email, age, role) do
  let schema = user_schema()
  let blank = Depot.Schema.blank(schema)
  let params = { name = name, email = email, age = age, role = role }
  let gate = Depot.Gate.cast_record(blank, params, ["name", "email", "age", "role"])
  unwrap_ok(Depot.Repo.insert(schema, gate))
end

-- Helper: clear all test data before each test group.
pfn clear_users() do
  Depot.Repo.delete_all(user_schema())
end

-- =========================================================================
-- insert tests
-- =========================================================================

test "insert returns Ok with a record" do
  clear_users()
  let schema = user_schema()
  let blank = Depot.Schema.blank(schema)
  let params = { name = "Alice", email = "alice@test.com", age = 30, role = "admin" }
  let gate = Depot.Gate.cast_record(blank, params, ["name", "email", "age", "role"])
  let record = unwrap_ok(Depot.Repo.insert(schema, gate))
  assert record.name == "Alice"
  assert record.email == "alice@test.com"
  assert to_string(record.age) == "30"
  assert record.role == "admin"
end

test "insert auto-generates a primary key (id)" do
  clear_users()
  let schema = user_schema()
  let blank = Depot.Schema.blank(schema)
  let params = { name = "Bob", email = "bob@test.com", age = 25, role = "user" }
  let gate = Depot.Gate.cast_record(blank, params, ["name", "email", "age", "role"])
  let record = unwrap_ok(Depot.Repo.insert(schema, gate))
  assert String.byte_size(record.id) > 0
end

test "insert returns Err when gate is invalid" do
  clear_users()
  let schema = user_schema()
  let blank = Depot.Schema.blank(schema)
  let params = { name = "", email = "", age = 0, role = "user" }
  let gate = Depot.Gate.cast_record(blank, params, ["name", "email"])
    |> Depot.Gate.validate_required(["name", "email"])
  let result = Depot.Repo.insert(schema, gate)
  assert is_err(result) == true
  let g = unwrap_err(result)
  assert Depot.Gate.is_valid(g) == false
end

test "insert stores the record in Vault" do
  clear_users()
  let record = insert_user("Charlie", "charlie@test.com", 35, "user")
  let schema = user_schema()
  let fetched = unwrap_some(Depot.Repo.get(schema, record.id))
  assert fetched.name == "Charlie"
end

test "insert multiple records" do
  clear_users()
  insert_user("Alice", "alice@test.com", 30, "admin")
  insert_user("Bob", "bob@test.com", 25, "user")
  insert_user("Charlie", "charlie@test.com", 35, "user")
  assert Depot.Repo.count(user_schema()) == 3
end

-- =========================================================================
-- all tests
-- =========================================================================

test "all returns empty list when no records" do
  clear_users()
  let rows = Depot.Repo.all(user_schema())
  assert List.length(rows) == 0
end

test "all returns all inserted records" do
  clear_users()
  insert_user("Alice", "alice@test.com", 30, "admin")
  insert_user("Bob", "bob@test.com", 25, "user")
  let rows = Depot.Repo.all(user_schema())
  assert List.length(rows) == 2
end

-- =========================================================================
-- get tests
-- =========================================================================

test "get returns Some for existing record" do
  clear_users()
  let record = insert_user("Alice", "alice@test.com", 30, "admin")
  let fetched = unwrap_some(Depot.Repo.get(user_schema(), record.id))
  assert fetched.email == "alice@test.com"
end

test "get returns None for missing id" do
  clear_users()
  assert is_none(Depot.Repo.get(user_schema(), "nonexistent")) == true
end

-- =========================================================================
-- get_bang tests
-- =========================================================================

test "get_bang returns record for existing id" do
  clear_users()
  let record = insert_user("Alice", "alice@test.com", 30, "admin")
  let fetched = Depot.Repo.get_bang(user_schema(), record.id)
  assert fetched.name == "Alice"
end

-- =========================================================================
-- get_by tests
-- =========================================================================

test "get_by finds record matching single field" do
  clear_users()
  insert_user("Alice", "alice@test.com", 30, "admin")
  insert_user("Bob", "bob@test.com", 25, "user")
  let found = unwrap_some(Depot.Repo.get_by(user_schema(), { email = "bob@test.com" }))
  assert found.name == "Bob"
end

test "get_by finds record matching multiple fields" do
  clear_users()
  insert_user("Alice", "alice@test.com", 30, "admin")
  insert_user("Bob", "bob@test.com", 25, "user")
  insert_user("Charlie", "charlie@test.com", 35, "user")
  let found = unwrap_some(Depot.Repo.get_by(user_schema(), { role = "user", name = "Charlie" }))
  assert found.email == "charlie@test.com"
end

test "get_by returns None when no match" do
  clear_users()
  insert_user("Alice", "alice@test.com", 30, "admin")
  assert is_none(Depot.Repo.get_by(user_schema(), { email = "nobody@test.com" })) == true
end

-- =========================================================================
-- one tests
-- =========================================================================

test "one returns Some when exactly one record" do
  clear_users()
  insert_user("Alice", "alice@test.com", 30, "admin")
  let found = unwrap_some(Depot.Repo.one(user_schema()))
  assert found.name == "Alice"
end

test "one returns None when zero records" do
  clear_users()
  assert is_none(Depot.Repo.one(user_schema())) == true
end

test "one returns None when multiple records" do
  clear_users()
  insert_user("Alice", "alice@test.com", 30, "admin")
  insert_user("Bob", "bob@test.com", 25, "user")
  assert is_none(Depot.Repo.one(user_schema())) == true
end

-- =========================================================================
-- count tests
-- =========================================================================

test "count returns 0 when empty" do
  clear_users()
  assert Depot.Repo.count(user_schema()) == 0
end

test "count returns correct number" do
  clear_users()
  insert_user("A", "a@test.com", 1, "user")
  insert_user("B", "b@test.com", 2, "user")
  insert_user("C", "c@test.com", 3, "admin")
  assert Depot.Repo.count(user_schema()) == 3
end

-- =========================================================================
-- exists tests
-- =========================================================================

test "exists returns false when empty" do
  clear_users()
  assert Depot.Repo.exists(user_schema()) == false
end

test "exists returns true when records present" do
  clear_users()
  insert_user("Alice", "alice@test.com", 30, "admin")
  assert Depot.Repo.exists(user_schema()) == true
end

-- =========================================================================
-- delete tests
-- =========================================================================

test "delete removes a record by id" do
  clear_users()
  let record = insert_user("Alice", "alice@test.com", 30, "admin")
  assert Depot.Repo.count(user_schema()) == 1
  Depot.Repo.delete(user_schema(), record.id)
  assert Depot.Repo.count(user_schema()) == 0
end

test "delete is a no-op for missing id" do
  clear_users()
  insert_user("Alice", "alice@test.com", 30, "admin")
  Depot.Repo.delete(user_schema(), "nonexistent")
  assert Depot.Repo.count(user_schema()) == 1
end

-- =========================================================================
-- delete_all tests
-- =========================================================================

test "delete_all removes all records" do
  clear_users()
  insert_user("A", "a@test.com", 1, "user")
  insert_user("B", "b@test.com", 2, "user")
  insert_user("C", "c@test.com", 3, "admin")
  let n = Depot.Repo.delete_all(user_schema())
  assert n == 3
  assert Depot.Repo.count(user_schema()) == 0
end

test "delete_all returns 0 when empty" do
  clear_users()
  let n = Depot.Repo.delete_all(user_schema())
  assert n == 0
end

-- =========================================================================
-- update tests
-- =========================================================================

test "update changes fields on existing record" do
  clear_users()
  let record = insert_user("Alice", "alice@test.com", 30, "user")
  let schema = user_schema()
  let params = { name = "Alicia", email = "alice@test.com", age = 30, role = "admin" }
  let gate = Depot.Gate.cast_record(record, params, ["name", "role"])
  let updated = unwrap_ok(Depot.Repo.update(schema, gate))
  assert updated.name == "Alicia"
  assert updated.role == "admin"
  assert updated.id == record.id
end

test "update persists to Vault" do
  clear_users()
  let record = insert_user("Alice", "alice@test.com", 30, "user")
  let schema = user_schema()
  let params = { name = "Alicia", email = "alice@test.com", age = 30, role = "admin" }
  let gate = Depot.Gate.cast_record(record, params, ["name", "role"])
  Depot.Repo.update(schema, gate)
  let fetched = unwrap_some(Depot.Repo.get(schema, record.id))
  assert fetched.name == "Alicia"
  assert fetched.role == "admin"
end

test "update returns Err when gate is invalid" do
  clear_users()
  let record = insert_user("Alice", "alice@test.com", 30, "user")
  let schema = user_schema()
  let params = { name = "", email = "alice@test.com", age = 30, role = "admin" }
  let gate = Depot.Gate.cast_record(record, params, ["name", "role"])
    |> Depot.Gate.validate_required(["name"])
  let result = Depot.Repo.update(schema, gate)
  assert is_err(result) == true
  let g = unwrap_err(result)
  assert Depot.Gate.is_valid(g) == false
end

end -- mod TestDepotRepo
