-- Tests for the Queue stdlib module
-- Run with: dune exec march -- test test/stdlib/test_queue.march

mod TestQueue do

describe "empty and is_empty" do
  test "empty queue is empty" do
    assert Queue.is_empty(Queue.empty())
  end

  test "non-empty queue is not empty" do
    assert !Queue.is_empty(Queue.push_back(Queue.empty(), 1))
  end
end

describe "size" do
  test "size of empty queue is zero" do
    assert (Queue.size(Queue.empty()) == 0)
  end

  test "size of single-element queue is one" do
    assert (Queue.size(Queue.push_back(Queue.empty(), 42)) == 1)
  end

  test "size after multiple pushes" do
    let q = Queue.push_back(Queue.push_back(Queue.push_back(Queue.empty(), 1), 2), 3)
    assert (Queue.size(q) == 3)
  end
end

describe "push_back and peek_front" do
  test "push_back then peek_front returns first element" do
    let q = Queue.push_back(Queue.push_back(Queue.empty(), 1), 2)
    match Queue.peek_front(q) do
    None -> assert false
    Some(v) -> assert (v == 1)
    end
  end

  test "push_front then peek_front returns new front" do
    let q = Queue.push_front(Queue.push_back(Queue.empty(), 1), 0)
    match Queue.peek_front(q) do
    None -> assert false
    Some(v) -> assert (v == 0)
    end
  end
end

describe "pop_front" do
  test "pop_front returns front element and remainder" do
    let q = Queue.push_back(Queue.push_back(Queue.empty(), 10), 20)
    match Queue.pop_front(q) do
    None -> assert false
    Some((v, rest)) -> do
      assert (v == 10)
      assert (Queue.size(rest) == 1)
    end
    end
  end

  test "pop_front of empty queue returns None" do
    match Queue.pop_front(Queue.empty()) do
    None -> assert true
    Some(_) -> assert false
    end
  end
end

describe "peek_back and pop_back" do
  test "peek_back returns last element" do
    let q = Queue.push_back(Queue.push_back(Queue.empty(), 1), 5)
    match Queue.peek_back(q) do
    None -> assert false
    Some(v) -> assert (v == 5)
    end
  end

  test "peek_back of empty queue returns None" do
    match Queue.peek_back(Queue.empty()) do
    None -> assert true
    Some(_) -> assert false
    end
  end

  test "pop_back returns last element and remainder" do
    let q = Queue.push_back(Queue.push_back(Queue.empty(), 1), 99)
    match Queue.pop_back(q) do
    None -> assert false
    Some((v, rest)) -> do
      assert (v == 99)
      assert (Queue.size(rest) == 1)
    end
    end
  end
end

describe "to_list and from_list" do
  test "to_list returns elements in front-to-back order" do
    let q = Queue.push_back(Queue.push_back(Queue.push_back(Queue.empty(), 1), 2), 3)
    let lst = Queue.to_list(q)
    assert (length(lst) == 3)
    assert (head(lst) == 1)
  end

  test "from_list builds queue from list" do
    let lst = Cons(1, Cons(2, Cons(3, Nil)))
    let q = Queue.from_list(lst)
    assert (Queue.size(q) == 3)
    match Queue.peek_front(q) do
    None -> assert false
    Some(v) -> assert (v == 1)
    end
  end

  test "from_list of empty list gives empty queue" do
    assert Queue.is_empty(Queue.from_list(Nil))
  end
end

end
