-- Tests for the BigInt stdlib module
-- Run with: dune exec march -- test test/stdlib/test_bigint.march

mod TestBigInt do

describe "BigInt" do

  describe "construction" do

    test "zero to_string" do
      assert (BigInt.to_string(BigInt.zero()) == "0")
    end

    test "zero is_zero" do
      assert BigInt.is_zero(BigInt.zero())
    end

    test "one to_string" do
      assert (BigInt.to_string(BigInt.one()) == "1")
    end

    test "one is not zero" do
      assert not(BigInt.is_zero(BigInt.one()))
    end

    test "from_int positive" do
      assert (BigInt.to_string(BigInt.from_int(42)) == "42")
    end

    test "from_int zero is_zero" do
      let n = BigInt.from_int(0)
      assert BigInt.is_zero(n)
    end

    test "from_int zero to_string" do
      assert (BigInt.to_string(BigInt.from_int(0)) == "0")
    end

    test "from_int negative to_string" do
      assert (BigInt.to_string(BigInt.from_int(-5)) == "-5")
    end

    test "from_int negative is_negative" do
      assert BigInt.is_negative(BigInt.from_int(-5))
    end

    test "from_int negative not positive" do
      assert not(BigInt.is_positive(BigInt.from_int(-5)))
    end

    test "from_int large" do
      assert (BigInt.to_string(BigInt.from_int(1000000)) == "1000000")
    end

  end

  describe "arithmetic" do

    test "add basic" do
      let a = BigInt.from_int(10)
      let b = BigInt.from_int(20)
      assert (BigInt.to_string(BigInt.add(a, b)) == "30")
    end

    test "add with zero" do
      let a = BigInt.from_int(42)
      assert (BigInt.to_string(BigInt.add(a, BigInt.zero())) == "42")
    end

    test "add with negative" do
      let a = BigInt.from_int(10)
      let b = BigInt.from_int(-3)
      assert (BigInt.to_string(BigInt.add(a, b)) == "7")
    end

    test "add both negative" do
      let a = BigInt.from_int(-5)
      let b = BigInt.from_int(-3)
      assert (BigInt.to_string(BigInt.add(a, b)) == "-8")
    end

    test "sub basic" do
      let a = BigInt.from_int(20)
      let b = BigInt.from_int(8)
      assert (BigInt.to_string(BigInt.sub(a, b)) == "12")
    end

    test "sub to zero" do
      let a = BigInt.from_int(7)
      let b = BigInt.from_int(7)
      assert (BigInt.to_string(BigInt.sub(a, b)) == "0")
      assert BigInt.is_zero(BigInt.sub(a, b))
    end

    test "negate positive" do
      assert (BigInt.to_string(BigInt.negate(BigInt.from_int(7))) == "-7")
    end

    test "negate negative" do
      assert (BigInt.to_string(BigInt.negate(BigInt.from_int(-7))) == "7")
    end

    test "negate zero" do
      assert (BigInt.to_string(BigInt.negate(BigInt.zero())) == "0")
    end

    test "mul basic" do
      let a = BigInt.from_int(6)
      let b = BigInt.from_int(7)
      assert (BigInt.to_string(BigInt.mul(a, b)) == "42")
    end

    test "mul by zero" do
      assert (BigInt.to_string(BigInt.mul(BigInt.from_int(999), BigInt.zero())) == "0")
    end

    test "mul with negative" do
      let a = BigInt.from_int(3)
      let b = BigInt.from_int(-4)
      assert (BigInt.to_string(BigInt.mul(a, b)) == "-12")
    end

    test "mul both negative" do
      let a = BigInt.from_int(-3)
      let b = BigInt.from_int(-4)
      assert (BigInt.to_string(BigInt.mul(a, b)) == "12")
    end

    test "div basic" do
      let a = BigInt.from_int(20)
      let b = BigInt.from_int(4)
      assert (BigInt.to_string(BigInt.div(a, b)) == "5")
    end

    test "div truncates" do
      let a = BigInt.from_int(7)
      let b = BigInt.from_int(2)
      assert (BigInt.to_string(BigInt.div(a, b)) == "3")
    end

    test "mod basic" do
      let a = BigInt.from_int(10)
      let b = BigInt.from_int(3)
      assert (BigInt.to_string(BigInt.mod_(a, b)) == "1")
    end

    test "mod exact" do
      let a = BigInt.from_int(12)
      let b = BigInt.from_int(4)
      assert (BigInt.to_string(BigInt.mod_(a, b)) == "0")
      assert BigInt.is_zero(BigInt.mod_(a, b))
    end

  end

  describe "absolute value" do

    test "abs positive" do
      assert (BigInt.to_string(BigInt.abs(BigInt.from_int(5))) == "5")
    end

    test "abs negative" do
      assert (BigInt.to_string(BigInt.abs(BigInt.from_int(-5))) == "5")
      assert not(BigInt.is_negative(BigInt.abs(BigInt.from_int(-5))))
    end

    test "abs zero" do
      assert (BigInt.to_string(BigInt.abs(BigInt.zero())) == "0")
    end

  end

  describe "predicates" do

    test "is_positive" do
      assert BigInt.is_positive(BigInt.from_int(1))
      assert BigInt.is_positive(BigInt.from_int(100))
      assert not(BigInt.is_positive(BigInt.zero()))
      assert not(BigInt.is_positive(BigInt.from_int(-1)))
    end

    test "is_negative" do
      assert BigInt.is_negative(BigInt.from_int(-1))
      assert not(BigInt.is_negative(BigInt.zero()))
      assert not(BigInt.is_negative(BigInt.from_int(1)))
    end

    test "is_zero" do
      assert BigInt.is_zero(BigInt.zero())
      assert BigInt.is_zero(BigInt.from_int(0))
      assert not(BigInt.is_zero(BigInt.one()))
    end

  end

end

end
