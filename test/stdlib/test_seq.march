-- Tests for the Seq stdlib module (lazy fold-based sequences).
-- Run with: dune exec march -- test test/stdlib/test_seq.march

mod TestSeq do

-- Step type mirrors Seq.Step so Continue/Halt constructors are in scope.
ptype Step(a) = Continue(a) Halt(a)

describe "from_list and to_list" do

  test "round trip empty list" do
    let s = Seq.from_list([])
    let result = Seq.to_list(s)
    assert (result == [])
  end

  test "round trip single element" do
    let s = Seq.from_list([42])
    let result = Seq.to_list(s)
    assert (result == [42])
  end

  test "round trip preserves order" do
    let s = Seq.from_list([1, 2, 3, 4, 5])
    let result = Seq.to_list(s)
    assert (result == [1, 2, 3, 4, 5])
  end

  test "round trip strings" do
    let s = Seq.from_list(["a", "b", "c"])
    let result = Seq.to_list(s)
    assert (result == ["a", "b", "c"])
  end

end

describe "empty" do

  test "empty to_list is empty" do
    let s = Seq.empty()
    assert (Seq.to_list(s) == [])
  end

  test "empty count is 0" do
    assert (Seq.count(Seq.empty()) == 0)
  end

  test "empty fold returns start" do
    let result = Seq.fold(Seq.empty(), 99, fn (acc, x) -> acc + x)
    assert (result == 99)
  end

end

describe "unfold" do

  test "countdown from 3 to 1" do
    let s = Seq.unfold(3, fn seed -> do
      if seed <= 0 do None
      else Some((seed, seed - 1)) end
    end
    )
    assert (Seq.to_list(s) == [3, 2, 1])
  end

  test "unfold empty when seed produces None immediately" do
    let s = Seq.unfold(0, fn seed -> do
      if seed <= 0 do None
      else Some((seed, seed - 1)) end
    end
    )
    assert (Seq.to_list(s) == [])
  end

  test "unfold single element" do
    let s = Seq.unfold(1, fn seed -> do
      if seed <= 0 do None
      else Some((seed, seed - 1)) end
    end
    )
    assert (Seq.to_list(s) == [1])
  end

  test "unfold range 1 to 5" do
    let s = Seq.unfold(1, fn seed -> do
      if seed > 5 do None
      else Some((seed, seed + 1)) end
    end
    )
    assert (Seq.to_list(s) == [1, 2, 3, 4, 5])
  end

  test "unfold count matches generated elements" do
    let s = Seq.unfold(1, fn seed -> do
      if seed > 10 do None
      else Some((seed, seed + 1)) end
    end
    )
    assert (Seq.count(s) == 10)
  end

end

describe "concat" do

  test "empty + empty" do
    let s = Seq.concat(Seq.empty(), Seq.empty())
    assert (Seq.to_list(s) == [])
  end

  test "empty + nonempty" do
    let s = Seq.concat(Seq.empty(), Seq.from_list([1, 2, 3]))
    assert (Seq.to_list(s) == [1, 2, 3])
  end

  test "nonempty + empty" do
    let s = Seq.concat(Seq.from_list([1, 2, 3]), Seq.empty())
    assert (Seq.to_list(s) == [1, 2, 3])
  end

  test "nonempty + nonempty" do
    let s = Seq.concat(Seq.from_list([1, 2]), Seq.from_list([3, 4]))
    assert (Seq.to_list(s) == [1, 2, 3, 4])
  end

  test "concat preserves element order" do
    let s = Seq.concat(Seq.from_list([1, 2, 3]), Seq.from_list([4, 5, 6]))
    let result = Seq.to_list(s)
    assert (List.nth(result, 0) == 1)
    assert (List.nth(result, 3) == 4)
    assert (List.nth(result, 5) == 6)
  end

  test "concat count" do
    let s = Seq.concat(Seq.from_list([1, 2, 3]), Seq.from_list([4, 5]))
    assert (Seq.count(s) == 5)
  end

end

describe "map" do

  test "map on empty" do
    let s = Seq.map(Seq.empty(), fn (x : Int) -> x * 2)
    assert (Seq.to_list(s) == [])
  end

  test "map doubles" do
    let s = Seq.map(Seq.from_list([1, 2, 3]), fn x -> x * 2)
    assert (Seq.to_list(s) == [2, 4, 6])
  end

  test "map to string" do
    let s = Seq.map(Seq.from_list([1, 2, 3]), fn x -> int_to_string(x))
    assert (Seq.to_list(s) == ["1", "2", "3"])
  end

  test "map identity" do
    let s = Seq.map(Seq.from_list([10, 20, 30]), fn x -> x)
    assert (Seq.to_list(s) == [10, 20, 30])
  end

  test "map preserves count" do
    let s = Seq.map(Seq.from_list([1, 2, 3, 4]), fn x -> x + 100)
    assert (Seq.count(s) == 4)
  end

end

describe "filter" do

  test "filter on empty" do
    let s = Seq.filter(Seq.empty(), fn (x : Int) -> x > 0)
    assert (Seq.to_list(s) == [])
  end

  test "filter evens" do
    let s = Seq.filter(Seq.from_list([1, 2, 3, 4, 5, 6]), fn x -> x % 2 == 0)
    assert (Seq.to_list(s) == [2, 4, 6])
  end

  test "filter all pass" do
    let s = Seq.filter(Seq.from_list([1, 2, 3]), fn _ -> true)
    assert (Seq.to_list(s) == [1, 2, 3])
  end

  test "filter none pass" do
    let s = Seq.filter(Seq.from_list([1, 2, 3]), fn _ -> false)
    assert (Seq.to_list(s) == [])
  end

  test "filter preserves order" do
    let s = Seq.filter(Seq.from_list([5, 1, 4, 2, 3]), fn x -> x > 3)
    assert (Seq.to_list(s) == [5, 4])
  end

end

describe "flat_map" do

  test "flat_map on empty" do
    let s = Seq.flat_map(Seq.empty(), fn (x : Int) -> Seq.from_list([x, x * 2]))
    assert (Seq.to_list(s) == [])
  end

  test "flat_map duplicates each element" do
    let s = Seq.flat_map(Seq.from_list([1, 2, 3]), fn x -> Seq.from_list([x, x]))
    assert (Seq.to_list(s) == [1, 1, 2, 2, 3, 3])
  end

  test "flat_map with always empty inner seqs" do
    let s = Seq.flat_map(Seq.from_list([1, 2, 3]), fn _ -> Seq.empty())
    assert (Seq.to_list(s) == [])
  end

  test "flat_map flattens pairs" do
    let s = Seq.flat_map(Seq.from_list([1, 2]), fn x -> Seq.from_list([x, x + 10]))
    assert (Seq.to_list(s) == [1, 11, 2, 12])
  end

  test "flat_map count" do
    let s = Seq.flat_map(Seq.from_list([1, 2, 3]), fn x -> Seq.from_list([x, x, x]))
    assert (Seq.count(s) == 9)
  end

end

describe "take" do

  test "take 0" do
    let s = Seq.take(Seq.from_list([1, 2, 3]), 0)
    assert (Seq.to_list(s) == [])
  end

  test "take fewer than length" do
    let s = Seq.take(Seq.from_list([1, 2, 3, 4, 5]), 3)
    assert (Seq.to_list(s) == [1, 2, 3])
  end

  test "take exactly length" do
    let s = Seq.take(Seq.from_list([1, 2, 3]), 3)
    assert (Seq.to_list(s) == [1, 2, 3])
  end

  test "take more than length" do
    let s = Seq.take(Seq.from_list([1, 2, 3]), 10)
    assert (Seq.to_list(s) == [1, 2, 3])
  end

  test "take from empty" do
    let s = Seq.take(Seq.empty(), 5)
    assert (Seq.to_list(s) == [])
  end

  test "take 1 gives first element" do
    let s = Seq.take(Seq.from_list([7, 8, 9]), 1)
    assert (Seq.to_list(s) == [7])
  end

end

describe "drop" do

  test "drop 0" do
    let s = Seq.drop(Seq.from_list([1, 2, 3]), 0)
    assert (Seq.to_list(s) == [1, 2, 3])
  end

  test "drop some" do
    let s = Seq.drop(Seq.from_list([1, 2, 3, 4, 5]), 2)
    assert (Seq.to_list(s) == [3, 4, 5])
  end

  test "drop exactly length" do
    let s = Seq.drop(Seq.from_list([1, 2, 3]), 3)
    assert (Seq.to_list(s) == [])
  end

  test "drop more than length" do
    let s = Seq.drop(Seq.from_list([1, 2, 3]), 10)
    assert (Seq.to_list(s) == [])
  end

  test "drop from empty" do
    let s = Seq.drop(Seq.empty(), 5)
    assert (Seq.to_list(s) == [])
  end

  test "drop 1 removes first" do
    let s = Seq.drop(Seq.from_list([10, 20, 30]), 1)
    assert (Seq.to_list(s) == [20, 30])
  end

end

describe "zip" do

  test "zip equal length" do
    let s = Seq.zip(Seq.from_list([1, 2, 3]), Seq.from_list([4, 5, 6]))
    let result = Seq.to_list(s)
    assert (List.length(result) == 3)
    match List.nth(result, 0) do (a, b) -> assert (a == 1) assert (b == 4) end
    match List.nth(result, 1) do (a, b) -> assert (a == 2) assert (b == 5) end
    match List.nth(result, 2) do (a, b) -> assert (a == 3) assert (b == 6) end
  end

  test "zip s1 shorter stops at s1" do
    let s = Seq.zip(Seq.from_list([1, 2]), Seq.from_list([4, 5, 6]))
    let result = Seq.to_list(s)
    assert (List.length(result) == 2)
  end

  test "zip s1 longer stops at s2" do
    let s = Seq.zip(Seq.from_list([1, 2, 3]), Seq.from_list([4, 5]))
    let result = Seq.to_list(s)
    assert (List.length(result) == 2)
  end

  test "zip with empty s1" do
    let s = Seq.zip(Seq.empty(), Seq.from_list([1, 2, 3]))
    assert (Seq.to_list(s) == [])
  end

  test "zip with empty s2" do
    let s = Seq.zip(Seq.from_list([1, 2, 3]), Seq.empty())
    assert (Seq.to_list(s) == [])
  end

  test "zip both empty" do
    let s = Seq.zip(Seq.empty(), Seq.empty())
    assert (Seq.to_list(s) == [])
  end

  test "zip first elements match" do
    let s = Seq.zip(Seq.from_list([10, 20]), Seq.from_list([100, 200]))
    let result = Seq.to_list(s)
    match List.nth(result, 0) do (a, b) -> assert (a == 10) assert (b == 100) end
  end

end

describe "batch" do

  test "batch exact division" do
    let s = Seq.batch(Seq.from_list([1, 2, 3, 4]), 2)
    let result = Seq.to_list(s)
    assert (List.length(result) == 2)
    assert (List.nth(result, 0) == [1, 2])
    assert (List.nth(result, 1) == [3, 4])
  end

  test "batch with remainder" do
    let s = Seq.batch(Seq.from_list([1, 2, 3, 4, 5]), 2)
    let result = Seq.to_list(s)
    assert (List.length(result) == 3)
    assert (List.nth(result, 0) == [1, 2])
    assert (List.nth(result, 1) == [3, 4])
    assert (List.nth(result, 2) == [5])
  end

  test "batch size larger than sequence" do
    let s = Seq.batch(Seq.from_list([1, 2, 3]), 10)
    let result = Seq.to_list(s)
    assert (List.length(result) == 1)
    assert (List.nth(result, 0) == [1, 2, 3])
  end

  test "batch empty sequence" do
    let s = Seq.batch(Seq.empty(), 3)
    assert (Seq.to_list(s) == [])
  end

  test "batch size 1 gives singleton lists" do
    let s = Seq.batch(Seq.from_list([1, 2, 3]), 1)
    let result = Seq.to_list(s)
    assert (List.length(result) == 3)
    assert (List.nth(result, 0) == [1])
    assert (List.nth(result, 1) == [2])
    assert (List.nth(result, 2) == [3])
  end

  test "batch three-way exact" do
    let s = Seq.batch(Seq.from_list([1, 2, 3, 4, 5, 6]), 3)
    let result = Seq.to_list(s)
    assert (List.length(result) == 2)
    assert (List.nth(result, 0) == [1, 2, 3])
    assert (List.nth(result, 1) == [4, 5, 6])
  end

end

describe "fold" do

  test "fold sum on empty returns start" do
    let result = Seq.fold(Seq.empty(), 0, fn (acc, x) -> acc + x)
    assert (result == 0)
  end

  test "fold sum" do
    let result = Seq.fold(Seq.from_list([1, 2, 3, 4]), 0, fn (acc, x) -> acc + x)
    assert (result == 10)
  end

  test "fold product" do
    let result = Seq.fold(Seq.from_list([1, 2, 3, 4]), 1, fn (acc, x) -> acc * x)
    assert (result == 24)
  end

  test "fold builds list in reverse" do
    let result = Seq.fold(Seq.from_list([1, 2, 3]), [], fn (acc, x) -> Cons(x, acc))
    assert (result == [3, 2, 1])
  end

  test "fold string concat" do
    let result = Seq.fold(Seq.from_list(["a", "b", "c"]), "", fn (acc, x) -> acc ++ x)
    assert (result == "abc")
  end

  test "fold counts elements" do
    let result = Seq.fold(Seq.from_list([10, 20, 30]), 0, fn (acc, ig) -> acc + 1)
    assert (result == 3)
  end

end

describe "fold_while" do

  test "fold_while sum always continuing" do
    let result = Seq.fold_while(Seq.from_list([1, 2, 3, 4]), 0, fn (acc, x) -> Continue(acc + x))
    assert (result == 10)
  end

  test "fold_while halts when threshold reached" do
    -- Sum until adding next element would exceed 5; halt returns acc (before adding)
    let result = Seq.fold_while(Seq.from_list([1, 2, 3, 4, 5]), 0, fn (acc, x) -> do
      if acc + x > 5 do Halt(acc)
      else Continue(acc + x) end
    end
    )
    assert (result == 3)
  end

  test "fold_while halts on first element" do
    let result = Seq.fold_while(Seq.from_list([10, 20, 30]), 0, fn (acc, x) ->
      Halt(acc + x)
    )
    assert (result == 10)
  end

  test "fold_while on empty returns start" do
    let result = Seq.fold_while(Seq.empty(), 42, fn (acc, x) -> Continue(acc + x))
    assert (result == 42)
  end

  test "fold_while halt captures accumulated value" do
    -- halt at x==3: sum is 1+2+3=6
    let result = Seq.fold_while(Seq.from_list([1, 2, 3, 4, 5]), 0, fn (acc, x) -> do
      if x == 3 do Halt(acc + x)
      else Continue(acc + x) end
    end
    )
    assert (result == 6)
  end

  test "fold_while never halts equals fold" do
    let s = Seq.from_list([1, 2, 3, 4, 5])
    let via_fold = Seq.fold(s, 0, fn (acc, x) -> acc + x)
    let via_fold_while = Seq.fold_while(s, 0, fn (acc, x) -> Continue(acc + x))
    assert (via_fold == via_fold_while)
  end

end

describe "each" do

  -- each uses :ok as the fold accumulator, so the callback must return Atom.
  test "each on empty runs without error" do
    let ig = Seq.each(Seq.empty(), fn (x : Int) -> :ok)
    assert true
  end

  test "each on nonempty runs without error" do
    let ig = Seq.each(Seq.from_list([1, 2, 3]), fn (x : Int) -> :ok)
    assert true
  end

end

describe "count" do

  test "count empty" do
    assert (Seq.count(Seq.empty()) == 0)
  end

  test "count single" do
    assert (Seq.count(Seq.from_list([42])) == 1)
  end

  test "count multiple" do
    assert (Seq.count(Seq.from_list([1, 2, 3, 4, 5])) == 5)
  end

  test "count after filter" do
    let s = Seq.filter(Seq.from_list([1, 2, 3, 4, 5, 6]), fn x -> x % 2 == 0)
    assert (Seq.count(s) == 3)
  end

  test "count after map unchanged" do
    let s = Seq.map(Seq.from_list([1, 2, 3, 4]), fn x -> x * 100)
    assert (Seq.count(s) == 4)
  end

end

describe "find" do

  test "find on empty returns None" do
    match Seq.find(Seq.empty(), fn (x : Int) -> x > 0) do
    None -> ()
    Some(_) -> panic("expected None")
    end
  end

  test "find first match" do
    match Seq.find(Seq.from_list([1, 2, 3, 4]), fn x -> x > 2) do
    None -> panic("expected Some")
    Some(v) -> assert (v == 3)
    end
  end

  test "find no match returns None" do
    match Seq.find(Seq.from_list([1, 2, 3]), fn x -> x > 10) do
    None -> ()
    Some(_) -> panic("expected None")
    end
  end

  test "find first element" do
    match Seq.find(Seq.from_list([5, 3, 1]), fn x -> x > 0) do
    None -> panic("expected Some")
    Some(v) -> assert (v == 5)
    end
  end

  test "find single match" do
    match Seq.find(Seq.from_list([1, 2, 3, 4, 5]), fn x -> x == 3) do
    None -> panic("expected Some")
    Some(v) -> assert (v == 3)
    end
  end

end

describe "any" do

  test "any on empty is false" do
    assert !Seq.any(Seq.empty(), fn (x : Int) -> x > 0)
  end

  test "any with always-true pred" do
    assert Seq.any(Seq.from_list([1, 2, 3]), fn _ -> true)
  end

  test "any with always-false pred" do
    assert !Seq.any(Seq.from_list([1, 2, 3]), fn _ -> false)
  end

  test "any true when last element matches" do
    assert Seq.any(Seq.from_list([1, 2, 3, 4, 5]), fn x -> x == 5)
  end

  test "any false when nothing matches" do
    assert !Seq.any(Seq.from_list([1, 2, 3]), fn x -> x > 10)
  end

  test "any true when first element matches" do
    assert Seq.any(Seq.from_list([10, 1, 2]), fn x -> x > 9)
  end

end

describe "all" do

  test "all on empty is true" do
    assert Seq.all(Seq.empty(), fn (x : Int) -> x > 0)
  end

  test "all with always-true pred" do
    assert Seq.all(Seq.from_list([1, 2, 3]), fn _ -> true)
  end

  test "all with always-false pred" do
    assert !Seq.all(Seq.from_list([1, 2, 3]), fn _ -> false)
  end

  test "all true when all match" do
    assert Seq.all(Seq.from_list([2, 4, 6]), fn x -> x % 2 == 0)
  end

  test "all false when one does not match" do
    assert !Seq.all(Seq.from_list([2, 3, 4]), fn x -> x % 2 == 0)
  end

  test "all false when last does not match" do
    assert !Seq.all(Seq.from_list([2, 4, 5]), fn x -> x % 2 == 0)
  end

end

describe "chaining" do

  test "map then filter then to_list" do
    let doubled = Seq.map(Seq.from_list([1, 2, 3, 4, 5]), fn x -> x * 2)
    let filtered = Seq.filter(doubled, fn x -> x > 4)
    let result = Seq.to_list(filtered)
    assert (result == [6, 8, 10])
  end

  test "concat then map" do
    let s1 = Seq.from_list([1, 2])
    let s2 = Seq.from_list([3, 4])
    let combined = Seq.concat(s1, s2)
    let result = Seq.to_list(Seq.map(combined, fn x -> x * 10))
    assert (result == [10, 20, 30, 40])
  end

  -- NOTE: Seq uses church-encoded folds that visit ALL elements even with take.
  -- Infinite unfold + take would loop forever. Use bounded unfold instead.
  test "unfold bounded then take then count" do
    let first20 = Seq.unfold(1, fn s -> if s > 20 do None else Some((s, s + 1))) end
    let taken = Seq.take(first20, 10)
    assert (Seq.count(taken) == 10)
  end

  test "unfold bounded then take then fold" do
    let first20 = Seq.unfold(1, fn s -> if s > 20 do None else Some((s, s + 1))) end
    let first5 = Seq.take(first20, 5)
    let sum = Seq.fold(first5, 0, fn (acc, x) -> acc + x)
    assert (sum == 15)
  end

  test "flat_map then filter" do
    let expanded = Seq.flat_map(Seq.from_list([1, 2, 3]), fn x -> Seq.from_list([x, x * 2]))
    let result = Seq.to_list(Seq.filter(expanded, fn x -> x > 3))
    assert (result == [4, 6])
  end

  test "drop then take" do
    let s = Seq.from_list([1, 2, 3, 4, 5, 6, 7, 8])
    let dropped = Seq.drop(s, 2)
    let taken = Seq.take(dropped, 3)
    let result = Seq.to_list(taken)
    assert (result == [3, 4, 5])
  end

  test "batch after map" do
    let mapped = Seq.map(Seq.from_list([1, 2, 3, 4]), fn x -> x * 2)
    let batched = Seq.batch(mapped, 2)
    let result = Seq.to_list(batched)
    assert (List.length(result) == 2)
    assert (List.nth(result, 0) == [2, 4])
    assert (List.nth(result, 1) == [6, 8])
  end

end

end
