-- test/stdlib/test_bastion_idempotency.march
-- Tests for BastionIdempotency middleware.

mod TestBastionIdempotency do

-- ── Conn helpers ──────────────────────────────────────────────────────────────

pfn make_conn(m, hdrs, body) do
  Conn(0, m, "/", Nil, "", hdrs, body, 0, Nil, "", false, Nil, NoUpgrade)
end

-- Build a conn that carries an Idempotency-Key request header.
pfn conn_with_ikey(method, key) do
  let hdrs = Cons(Header("idempotency-key", key), Nil)
  make_conn(method, hdrs, "")
end

-- Build a conn without any Idempotency-Key header.
pfn conn_no_ikey(method) do
  make_conn(method, Nil, "")
end

-- Simple echo handler: returns 200 with body "hello".
pfn echo_handler(conn) do
  HttpServer.send_resp(conn, 200, "hello")
end

-- Handler that returns a 500.
pfn error_handler(conn) do
  HttpServer.send_resp(conn, 500, "oops")
end

-- Unique vault table name per test group to avoid cross-test pollution.
pfn fresh_table() do
  let nonce = base64_encode(random_bytes(6))
  "idem_test_" ++ nonce
end

-- ── get_key ───────────────────────────────────────────────────────────────────

describe "BastionIdempotency.get_key" do
  test "returns None when no Idempotency-Key header" do
    let conn = conn_no_ikey(Post)
    assert (BastionIdempotency.get_key(conn) == None)
  end

  test "returns Some(key) when header is present" do
    let conn = conn_with_ikey(Post, "my-key-123")
    assert (BastionIdempotency.get_key(conn) == Some("my-key-123"))
  end

  test "header lookup is case-insensitive" do
    -- Header stored as "Idempotency-Key" but looked up lowercased.
    let hdrs = Cons(Header("Idempotency-Key", "KEY-CAPS"), Nil)
    let conn = make_conn(Post, hdrs, "")
    assert (BastionIdempotency.get_key(conn) == Some("KEY-CAPS"))
  end
end

-- ── lookup ────────────────────────────────────────────────────────────────────

describe "BastionIdempotency.lookup" do
  test "returns None for an unknown key" do
    let tbl = fresh_table()
    let result = BastionIdempotency.lookup(tbl, "unknown-key", "")
    assert (result == None)
  end

  test "returns None for an unknown scoped key" do
    let tbl = fresh_table()
    let result = BastionIdempotency.lookup(tbl, "k", "scope1")
    assert (result == None)
  end
end

-- ── mark_in_progress / lookup ─────────────────────────────────────────────────

describe "BastionIdempotency.mark_in_progress" do
  test "lookup returns Some(InProgress) after mark_in_progress" do
    let tbl = fresh_table()
    BastionIdempotency.mark_in_progress(tbl, "key-ip", "")
    let result = BastionIdempotency.lookup(tbl, "key-ip", "")
    match result do
    Some(InProgress(_)) -> assert true
    _                   -> assert false
    end
  end

  test "mark_in_progress with scope uses scoped key" do
    let tbl = fresh_table()
    BastionIdempotency.mark_in_progress(tbl, "key-scoped", "users")
    -- without scope should be absent
    let r_no_scope = BastionIdempotency.lookup(tbl, "key-scoped", "")
    assert (r_no_scope == None)
    -- with scope should be present
    let r_scoped = BastionIdempotency.lookup(tbl, "key-scoped", "users")
    match r_scoped do
    Some(InProgress(_)) -> assert true
    _                   -> assert false
    end
  end
end

-- ── complete_entry / lookup ───────────────────────────────────────────────────

describe "BastionIdempotency.complete_entry" do
  test "lookup returns Some(Completed) after complete_entry" do
    let tbl = fresh_table()
    BastionIdempotency.complete_entry(tbl, "key-done", "", 200, Nil, "body-text")
    let result = BastionIdempotency.lookup(tbl, "key-done", "")
    match result do
    Some(Completed(status, _, body, _)) -> do
      assert (status == 200)
      assert (body == "body-text")
    end
    _ -> assert false
    end
  end

  test "complete_entry stores the status code" do
    let tbl = fresh_table()
    BastionIdempotency.complete_entry(tbl, "key-201", "", 201, Nil, "created")
    let result = BastionIdempotency.lookup(tbl, "key-201", "")
    match result do
    Some(Completed(status, _, _, _)) -> assert (status == 201)
    _                                -> assert false
    end
  end

  test "complete_entry overwrites InProgress" do
    let tbl = fresh_table()
    BastionIdempotency.mark_in_progress(tbl, "key-overwrite", "")
    BastionIdempotency.complete_entry(tbl, "key-overwrite", "", 200, Nil, "done")
    let result = BastionIdempotency.lookup(tbl, "key-overwrite", "")
    match result do
    Some(Completed(_, _, _, _)) -> assert true
    _                           -> assert false
    end
  end
end

-- ── invalidate ────────────────────────────────────────────────────────────────

describe "BastionIdempotency.invalidate" do
  test "invalidate removes a cached entry" do
    let tbl = fresh_table()
    BastionIdempotency.complete_entry(tbl, "inv-key", "", 200, Nil, "ok")
    BastionIdempotency.invalidate(tbl, "inv-key", "")
    let result = BastionIdempotency.lookup(tbl, "inv-key", "")
    assert (result == None)
  end

  test "invalidate is a no-op for a non-existent key" do
    let tbl = fresh_table()
    -- Must not raise
    BastionIdempotency.invalidate(tbl, "missing-key", "")
    assert true
  end

  test "invalidate only removes the matching key" do
    let tbl = fresh_table()
    BastionIdempotency.complete_entry(tbl, "k1", "", 200, Nil, "one")
    BastionIdempotency.complete_entry(tbl, "k2", "", 200, Nil, "two")
    BastionIdempotency.invalidate(tbl, "k1", "")
    assert (BastionIdempotency.lookup(tbl, "k1", "") == None)
    match BastionIdempotency.lookup(tbl, "k2", "") do
    Some(Completed(_, _, _, _)) -> assert true
    _                           -> assert false
    end
  end
end

-- ── protect: no idempotency key ───────────────────────────────────────────────

describe "BastionIdempotency.protect — no idempotency key" do
  test "calls handler directly when no key header present" do
    let tbl  = fresh_table()
    let opts = Cons(("vault_table", tbl), Nil)
    let conn = conn_no_ikey(Post)
    let result = BastionIdempotency.protect(conn, fn c -> echo_handler(c), opts)
    assert (HttpServer.status(result) == 200)
    assert (HttpServer.resp_body(result) == "hello")
  end
end

-- ── protect: first request ────────────────────────────────────────────────────

describe "BastionIdempotency.protect — first request with key" do
  test "first call executes the handler and returns its response" do
    let tbl  = fresh_table()
    let opts = Cons(("vault_table", tbl), Nil)
    let conn = conn_with_ikey(Post, "first-req-key")
    let result = BastionIdempotency.protect(conn, fn c -> echo_handler(c), opts)
    assert (HttpServer.status(result) == 200)
    assert (HttpServer.resp_body(result) == "hello")
  end

  test "first call stores the result in cache" do
    let tbl  = fresh_table()
    let opts = Cons(("vault_table", tbl), Nil)
    let conn = conn_with_ikey(Post, "store-key")
    BastionIdempotency.protect(conn, fn c -> echo_handler(c), opts)
    let cached = BastionIdempotency.lookup(tbl, "store-key", "")
    match cached do
    Some(Completed(200, _, "hello", _)) -> assert true
    _                                   -> assert false
    end
  end

  test "first call adds x-idempotent-replayed: false header" do
    let tbl  = fresh_table()
    let opts = Cons(("vault_table", tbl), Nil)
    let conn = conn_with_ikey(Post, "first-hdr-key")
    let result = BastionIdempotency.protect(conn, fn c -> echo_handler(c), opts)
    let replayed = HttpServer.get_resp_header(result, "x-idempotent-replayed")
    assert (replayed == Some("false"))
  end
end

-- ── protect: second request (cache hit) ──────────────────────────────────────

describe "BastionIdempotency.protect — second request replays cache" do
  test "second call with same key replays cached response" do
    let tbl  = fresh_table()
    let opts = Cons(("vault_table", tbl), Nil)
    let key  = "replay-key"
    let conn1 = conn_with_ikey(Post, key)
    BastionIdempotency.protect(conn1, fn c -> echo_handler(c), opts)
    -- Second call
    let conn2   = conn_with_ikey(Post, key)
    let result2 = BastionIdempotency.protect(conn2, fn c -> echo_handler(c), opts)
    assert (HttpServer.status(result2) == 200)
    assert (HttpServer.resp_body(result2) == "hello")
  end

  test "second call adds x-idempotent-replayed: true header" do
    let tbl  = fresh_table()
    let opts = Cons(("vault_table", tbl), Nil)
    let key  = "replay-hdr-key"
    let conn1 = conn_with_ikey(Post, key)
    BastionIdempotency.protect(conn1, fn c -> echo_handler(c), opts)
    let conn2   = conn_with_ikey(Post, key)
    let result2 = BastionIdempotency.protect(conn2, fn c -> echo_handler(c), opts)
    let replayed = HttpServer.get_resp_header(result2, "x-idempotent-replayed")
    assert (replayed == Some("true"))
  end
end

-- ── protect: 5xx not cached ───────────────────────────────────────────────────

describe "BastionIdempotency.protect — 5xx responses not cached" do
  test "5xx handler response is not stored in cache" do
    let tbl  = fresh_table()
    let opts = Cons(("vault_table", tbl), Nil)
    let conn = conn_with_ikey(Post, "error-key")
    BastionIdempotency.protect(conn, fn c -> error_handler(c), opts)
    -- Cache should be empty (InProgress dropped)
    let cached = BastionIdempotency.lookup(tbl, "error-key", "")
    assert (cached == None)
  end

  test "5xx response is returned to caller unchanged (minus idempotency-key header)" do
    let tbl  = fresh_table()
    let opts = Cons(("vault_table", tbl), Nil)
    let conn = conn_with_ikey(Post, "err-resp-key")
    let result = BastionIdempotency.protect(conn, fn c -> error_handler(c), opts)
    assert (HttpServer.status(result) == 500)
  end

  test "second call after 5xx re-runs the handler (cache miss)" do
    let tbl  = fresh_table()
    let opts = Cons(("vault_table", tbl), Nil)
    let key  = "retry-after-error"
    -- First call: error, not cached
    let conn1 = conn_with_ikey(Post, key)
    BastionIdempotency.protect(conn1, fn c -> error_handler(c), opts)
    -- Second call: should run handler again (no InProgress / Completed in cache)
    let conn2   = conn_with_ikey(Post, key)
    let result2 = BastionIdempotency.protect(conn2, fn c -> echo_handler(c), opts)
    assert (HttpServer.status(result2) == 200)
  end
end

-- ── protect: InProgress (simulated concurrent) ───────────────────────────────

describe "BastionIdempotency.protect — InProgress returns 409" do
  test "request while InProgress sentinel is set returns 409" do
    let tbl = fresh_table()
    let key = "concurrent-key"
    -- Manually inject InProgress (simulating a concurrent in-flight request)
    BastionIdempotency.mark_in_progress(tbl, key, "")
    let opts   = Cons(("vault_table", tbl), Nil)
    let conn   = conn_with_ikey(Post, key)
    let result = BastionIdempotency.protect(conn, fn c -> echo_handler(c), opts)
    assert (HttpServer.status(result) == 409)
  end
end

-- ── protect: scope option ─────────────────────────────────────────────────────

describe "BastionIdempotency.protect — scope option" do
  test "keys under different scopes are independent" do
    let tbl  = fresh_table()
    let key  = "scope-key"
    let opts1 = Cons(("vault_table", tbl), Cons(("scope", "payments"), Nil))
    let opts2 = Cons(("vault_table", tbl), Cons(("scope", "orders"), Nil))
    let conn1 = conn_with_ikey(Post, key)
    let conn2 = conn_with_ikey(Post, key)
    BastionIdempotency.protect(conn1, fn c -> echo_handler(c), opts1)
    -- Second conn with DIFFERENT scope should run handler, not replay
    let result2 = BastionIdempotency.protect(conn2, fn c -> echo_handler(c), opts2)
    -- x-idempotent-replayed should be "false" (first call for this scope)
    let replayed = HttpServer.get_resp_header(result2, "x-idempotent-replayed")
    assert (replayed == Some("false"))
  end
end

end
