-- Tests for the Decimal stdlib module
-- Run with: dune exec march -- test test/stdlib/test_decimal.march

mod TestDecimal do

describe "Decimal" do

  describe "construction" do

    test "from_int basic" do
      let d = Decimal.from_int(42)
      assert (Decimal.to_string(d) == "42")
      assert (Decimal.scale(d) == 0)
      assert (Decimal.coefficient(d) == 42)
    end

    test "from_int_scaled" do
      let d = Decimal.from_int_scaled(123, 2)
      assert (Decimal.to_string(d) == "1.23")
      assert (Decimal.scale(d) == 2)
      assert (Decimal.coefficient(d) == 123)
    end

    test "from_string integer" do
      let d = Decimal.from_string("100")
      assert (Decimal.to_string(d) == "100")
    end

    test "from_string decimal" do
      let d = Decimal.from_string("1.23")
      assert (Decimal.to_string(d) == "1.23")
    end

    test "from_string negative" do
      let d = Decimal.from_string("-0.5")
      assert (Decimal.to_string(d) == "-0.5")
    end

  end

  describe "arithmetic" do

    test "add same scale" do
      let a = Decimal.from_int_scaled(123, 2)
      let b = Decimal.from_int_scaled(456, 2)
      let r = Decimal.add(a, b)
      assert (Decimal.to_string(r) == "5.79")
    end

    test "add different scale" do
      let a = Decimal.from_int_scaled(100, 2)
      let b = Decimal.from_int(1)
      let r = Decimal.add(a, b)
      assert (Decimal.to_string(r) == "2.00")
    end

    test "sub basic" do
      let a = Decimal.from_int_scaled(500, 2)
      let b = Decimal.from_int_scaled(200, 2)
      let r = Decimal.sub(a, b)
      assert (Decimal.to_string(r) == "3.00")
    end

    test "mul basic" do
      let a = Decimal.from_int_scaled(200, 2)
      let b = Decimal.from_int_scaled(300, 2)
      let r = Decimal.mul(a, b)
      assert (Decimal.to_string(r) == "6.0000")
    end

    test "mul integers" do
      let a = Decimal.from_int(3)
      let b = Decimal.from_int(4)
      let r = Decimal.mul(a, b)
      assert (Decimal.to_string(r) == "12")
    end

    test "div basic" do
      let a = Decimal.from_int(10)
      let b = Decimal.from_int(4)
      let r = Decimal.div(a, b, 2)
      assert (Decimal.to_string(r) == "2.50")
    end

  end

  describe "rounding" do

    test "round down" do
      let d = Decimal.from_int_scaled(1234, 3)
      let r = Decimal.round(d, 2)
      assert (Decimal.to_string(r) == "1.23")
    end

    test "round up half-up" do
      let d = Decimal.from_int_scaled(1235, 3)
      let r = Decimal.round(d, 2)
      assert (Decimal.to_string(r) == "1.24")
    end

    test "round no-op when scale <= places" do
      let d = Decimal.from_int_scaled(100, 2)
      let r = Decimal.round(d, 3)
      assert (Decimal.to_string(r) == "1.00")
    end

  end

  describe "predicates" do

    test "is_zero true" do
      assert Decimal.is_zero(Decimal.from_int(0))
      assert Decimal.is_zero(Decimal.from_int_scaled(0, 2))
    end

    test "is_zero false" do
      assert not(Decimal.is_zero(Decimal.from_int(1)))
    end

    test "abs positive" do
      let d = Decimal.from_int_scaled(500, 2)
      assert (Decimal.to_string(Decimal.abs(d)) == "5.00")
    end

    test "abs negative" do
      let d = Decimal.from_int_scaled(-500, 2)
      assert (Decimal.to_string(Decimal.abs(d)) == "5.00")
    end

  end

  describe "accessors" do

    test "scale" do
      assert (Decimal.scale(Decimal.from_int_scaled(100, 2)) == 2)
      assert (Decimal.scale(Decimal.from_int(5)) == 0)
    end

    test "coefficient" do
      assert (Decimal.coefficient(Decimal.from_int_scaled(123, 2)) == 123)
      assert (Decimal.coefficient(Decimal.from_int(7)) == 7)
    end

  end

end

end
