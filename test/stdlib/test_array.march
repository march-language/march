-- Tests for the Array stdlib module (persistent vector)
-- Run with: dune exec march -- test test/stdlib/test_array.march

mod TestArray do

fn make_vec(n : Int) do
  fn go(i : Int, v) do
    if i > n then v else go(i + 1, Array.push(v, i))
  end
  go(1, Array.empty())
end

describe "empty" do
  test "empty vector is empty" do
    let v = Array.empty()
    assert Array.is_empty(v)
    assert (Array.length(v) == 0)
  end
end

describe "length" do
  test "length of five-element vector is five" do
    assert (Array.length(make_vec(5)) == 5)
  end

  test "length of empty vector is zero" do
    assert (Array.length(Array.empty()) == 0)
  end
end

describe "is_empty" do
  test "is_empty returns true for empty vector" do
    assert Array.is_empty(Array.empty())
  end

  test "is_empty returns false for non-empty vector" do
    assert !Array.is_empty(Array.push(Array.empty(), 1))
  end
end

describe "push and get" do
  test "pushed elements are retrievable by index" do
    let v = Array.push(Array.push(Array.push(Array.empty(), 10), 20), 30)
    assert (Array.get(v, 0) == 10)
    assert (Array.get(v, 1) == 20)
    assert (Array.get(v, 2) == 30)
    assert (Array.length(v) == 3)
  end

  test "push many elements crossing trie boundary" do
    let v = make_vec(33)
    assert (Array.length(v) == 33)
    assert (Array.get(v, 0) == 1)
    assert (Array.get(v, 31) == 32)
    assert (Array.get(v, 32) == 33)
  end

  test "push 64 elements crossing two boundaries" do
    let v = make_vec(64)
    assert (Array.length(v) == 64)
    assert (Array.get(v, 0) == 1)
    assert (Array.get(v, 63) == 64)
  end
end

describe "set" do
  test "set updates element at index" do
    let v = make_vec(5)
    let v2 = Array.set(v, 2, 99)
    assert (Array.get(v2, 2) == 99)
    assert (Array.get(v2, 1) == 2)
    assert (Array.get(v2, 3) == 4)
    assert (Array.get(v, 2) == 3)
  end

  test "set at first index" do
    let v = Array.push(Array.push(Array.empty(), 1), 2)
    let v2 = Array.set(v, 0, 100)
    assert (Array.get(v2, 0) == 100)
  end
end

describe "pop" do
  test "pop removes and returns last element" do
    let v = make_vec(5)
    match Array.pop(v) do
    | (v2, last) ->
      assert (last == 5)
      assert (Array.length(v2) == 4)
      assert (Array.get(v2, 0) == 1)
    end
  end

  test "pop from single-element vector gives empty vector" do
    let v = Array.push(Array.empty(), 42)
    match Array.pop(v) do
    | (v2, last) ->
      assert (last == 42)
      assert Array.is_empty(v2)
    end
  end

  test "pop across trie boundary" do
    let v = make_vec(33)
    match Array.pop(v) do
    | (v2, last) ->
      assert (last == 33)
      assert (Array.length(v2) == 32)
    end
  end
end

describe "map" do
  test "map applies function to each element" do
    let v = make_vec(5)
    let doubled = Array.map(v, fn x -> x * 2)
    assert (Array.get(doubled, 0) == 2)
    assert (Array.get(doubled, 4) == 10)
    assert (Array.length(doubled) == 5)
  end

  test "map over empty vector gives empty vector" do
    assert Array.is_empty(Array.map(Array.empty(), fn (x : Int) -> x + 1))
  end
end

describe "fold_left" do
  test "fold_left sums all elements" do
    let s = Array.fold_left(0, make_vec(5), fn (acc, x) -> acc + x)
    assert (s == 15)
  end

  test "fold_left over empty vector gives initial accumulator" do
    let s = Array.fold_left(0, Array.empty(), fn (acc, x) -> acc + x)
    assert (s == 0)
  end

  test "fold_left counts elements" do
    let c = Array.fold_left(0, make_vec(10), fn (acc, _x) -> acc + 1)
    assert (c == 10)
  end
end

describe "to_list and from_list" do
  test "to_list produces elements in order" do
    let v = make_vec(3)
    let lst = Array.to_list(v)
    assert (length(lst) == 3)
    assert (head(lst) == 1)
    assert (List.last(lst) == 3)
  end

  test "to_list of empty vector is Nil" do
    assert is_nil(Array.to_list(Array.empty()))
  end

  test "from_list builds vector from list" do
    let lst = Cons(10, Cons(20, Cons(30, Nil)))
    let v = Array.from_list(lst)
    assert (Array.length(v) == 3)
    assert (Array.get(v, 0) == 10)
    assert (Array.get(v, 2) == 30)
  end

  test "from_list of empty list gives empty vector" do
    let empty : List(Int) = Nil
    assert Array.is_empty(Array.from_list(empty))
  end

  test "from_list then to_list is identity" do
    let lst = Cons(5, Cons(4, Cons(3, Cons(2, Cons(1, Nil)))))
    let v = Array.from_list(lst)
    let lst2 = Array.to_list(v)
    assert (length(lst2) == 5)
    assert (head(lst2) == 5)
    assert (List.last(lst2) == 1)
  end
end

end
