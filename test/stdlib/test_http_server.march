-- Tests for the HttpServer stdlib module.
-- Covers Conn construction, accessors, transforms, pipeline execution,
-- and server config. No actual TCP binding.

mod TestHttpServer do

  -- ── Conn construction helpers ──────────────────────────────────────

  -- Build a minimal Conn for testing (fd=0, no upgrade)
  fn make_conn(meth, path_, qs, req_hdrs, req_body) do
    let path_parts = filter(string_split(path_, "/"), fn s -> not(string_is_empty(s)))
    Conn(0, meth, path_, path_parts, qs, req_hdrs, req_body, 0, Nil, "", false, Nil, NoUpgrade)
  end

  fn make_get(path_) do
    make_conn(Get, path_, "", Cons(Header("host", "localhost"), Nil), "")
  end

  fn make_post(path_, body) do
    make_conn(Post, path_, "", Cons(Header("content-type", "text/plain"), Nil), body)
  end

  -- ── Conn accessors ─────────────────────────────────────────────────

  fn test_method_accessor() do
    let conn = make_get("/users")
    Test.assert_eq_str(Http.method_to_string(HttpServer.method(conn)), "GET", "method GET")
    let conn2 = make_post("/submit", "data")
    Test.assert_eq_str(Http.method_to_string(HttpServer.method(conn2)), "POST", "method POST")
  end

  fn test_path_accessor() do
    let conn = make_get("/api/v1/users")
    Test.assert_eq_str(HttpServer.path(conn), "/api/v1/users", "path accessor")
  end

  fn test_path_info_accessor() do
    let conn = make_get("/api/v1/users")
    let info = HttpServer.path_info(conn)
    Test.assert_false(is_nil(info), "path_info not empty")
    Test.assert_eq_str(head(info), "api", "first segment")
  end

  fn test_query_string_accessor() do
    let conn = make_conn(Get, "/search", "q=hello&limit=5", Nil, "")
    Test.assert_eq_str(HttpServer.query_string(conn), "q=hello&limit=5", "query_string")
  end

  fn test_req_body_accessor() do
    let conn = make_post("/submit", "my payload")
    Test.assert_eq_str(HttpServer.req_body(conn), "my payload", "req_body")
  end

  fn test_status_accessor_default() do
    let conn = make_get("/")
    Test.assert_eq_int(HttpServer.status(conn), 0, "status 0 by default")
  end

  fn test_halted_accessor_default() do
    let conn = make_get("/")
    Test.assert_false(HttpServer.halted(conn), "not halted by default")
  end

  -- ── Request header lookup ──────────────────────────────────────────

  fn test_get_req_header() do
    let conn = make_get("/")
    let val_ = Test.assert_some(HttpServer.get_req_header(conn, "host"), "host header present")
    Test.assert_eq_str(val_, "localhost", "host value")
    -- case-insensitive
    let val2 = Test.assert_some(HttpServer.get_req_header(conn, "HOST"), "HOST uppercase")
    Test.assert_eq_str(val2, "localhost", "HOST uppercase value")
    Test.assert_none(HttpServer.get_req_header(conn, "x-missing"), "missing header None")
  end

  -- ── Conn transforms ────────────────────────────────────────────────

  fn test_put_resp_header() do
    let conn = make_get("/")
    let conn2 = HttpServer.put_resp_header(conn, "X-Custom", "hello")
    let hdrs = HttpServer.resp_headers(conn2)
    Test.assert_false(is_nil(hdrs), "resp headers non-empty")
    -- verify value via resp_headers list
    match head(hdrs) do
    | Header(n, v) ->
      Test.assert_eq_str(string_to_lowercase(n), "x-custom", "resp header name")
      Test.assert_eq_str(v, "hello", "resp header value")
    end
  end

  fn test_assign() do
    let conn = make_get("/")
    let conn2 = HttpServer.assign(conn, "user_id", "42")
    let v = Test.assert_some(HttpServer.get_assign(conn2, "user_id"), "user_id assign")
    Test.assert_eq_str(v, "42", "assign value")
    Test.assert_none(HttpServer.get_assign(conn2, "missing"), "missing assign None")
  end

  fn test_send_resp() do
    let conn = make_get("/")
    let conn2 = HttpServer.send_resp(conn, 200, "hello world")
    Test.assert_eq_int(HttpServer.status(conn2), 200, "send_resp status")
    Test.assert_eq_str(HttpServer.resp_body(conn2), "hello world", "send_resp body")
    Test.assert_true(HttpServer.halted(conn2), "halted after send_resp")
  end

  fn test_halt() do
    let conn = make_get("/")
    let conn2 = HttpServer.halt(conn)
    Test.assert_true(HttpServer.halted(conn2), "halted after halt()")
  end

  -- ── Convenience response builders ─────────────────────────────────

  fn test_text_response() do
    let conn = make_get("/")
    let conn2 = HttpServer.text(conn, 200, "plain text")
    Test.assert_eq_int(HttpServer.status(conn2), 200, "text status")
    Test.assert_eq_str(HttpServer.resp_body(conn2), "plain text", "text body")
    Test.assert_true(HttpServer.halted(conn2), "text halted")
    let ct = Test.assert_some(HttpServer.get_req_header(
      Conn(HttpServer.fd(conn2), HttpServer.method(conn2), HttpServer.path(conn2),
           HttpServer.path_info(conn2), HttpServer.query_string(conn2),
           HttpServer.resp_headers(conn2), HttpServer.resp_body(conn2),
           HttpServer.status(conn2), HttpServer.resp_headers(conn2),
           HttpServer.resp_body(conn2), HttpServer.halted(conn2),
           HttpServer.assigns(conn2), NoUpgrade), "content-type"),
      "content-type in resp headers")
    Test.assert_true(string_starts_with(ct, "text/plain"), "text content-type")
  end

  fn test_json_response() do
    let conn = make_get("/")
    let conn2 = HttpServer.json(conn, 201, "{\"ok\":true}")
    Test.assert_eq_int(HttpServer.status(conn2), 201, "json status")
    Test.assert_eq_str(HttpServer.resp_body(conn2), "{\"ok\":true}", "json body")
  end

  fn test_redirect_response() do
    let conn = make_get("/old")
    let conn2 = HttpServer.redirect(conn, "/new")
    Test.assert_eq_int(HttpServer.status(conn2), 302, "redirect status")
    Test.assert_true(HttpServer.halted(conn2), "redirect halted")
  end

  -- ── Pipeline execution ─────────────────────────────────────────────

  fn test_run_pipeline_empty() do
    let conn = make_get("/")
    let conn2 = HttpServer.run_pipeline(conn, Nil)
    -- unchanged
    Test.assert_eq_str(HttpServer.path(conn2), "/", "empty pipeline unchanged")
    Test.assert_false(HttpServer.halted(conn2), "not halted")
  end

  fn test_run_pipeline_single_plug() do
    let conn = make_get("/")
    let add_header_plug = fn c -> HttpServer.put_resp_header(c, "X-Plug", "ran")
    let conn2 = HttpServer.run_pipeline(conn, Cons(add_header_plug, Nil))
    let hdrs = HttpServer.resp_headers(conn2)
    Test.assert_false(is_nil(hdrs), "plug added header")
  end

  fn test_run_pipeline_stops_when_halted() do
    let conn = make_get("/")
    -- First plug halts, second plug would add a header
    let halt_plug = fn c -> HttpServer.halt(c)
    let add_header_plug = fn c -> HttpServer.put_resp_header(c, "X-After-Halt", "should not run")
    let conn2 = HttpServer.run_pipeline(conn, Cons(halt_plug, Cons(add_header_plug, Nil)))
    Test.assert_true(HttpServer.halted(conn2), "halted after halt plug")
    -- The second plug should NOT have run
    Test.assert_none(
      HttpServer.get_req_header(
        Conn(0, Get, "/", Nil, "", HttpServer.resp_headers(conn2), "", 0, Nil, "", false, Nil, NoUpgrade),
        "x-after-halt"),
      "second plug did not run")
  end

  fn test_run_pipeline_multiple_plugs() do
    let conn = make_get("/")
    let plug1 = fn c -> HttpServer.assign(c, "step", "1")
    let plug2 = fn c -> HttpServer.assign(c, "done", "yes")
    let conn2 = HttpServer.run_pipeline(conn, Cons(plug1, Cons(plug2, Nil)))
    let s = Test.assert_some(HttpServer.get_assign(conn2, "step"), "step assign")
    Test.assert_eq_str(s, "1", "step=1")
    let d = Test.assert_some(HttpServer.get_assign(conn2, "done"), "done assign")
    Test.assert_eq_str(d, "yes", "done=yes")
  end

  -- ── Server config ──────────────────────────────────────────────────

  fn test_server_new() do
    -- Just verify it doesn't panic
    let srv = HttpServer.new(4000)
    ()
  end

  -- ── Entry point ────────────────────────────────────────────────────

  pub fn main() do
    test_method_accessor()
    test_path_accessor()
    test_path_info_accessor()
    test_query_string_accessor()
    test_req_body_accessor()
    test_status_accessor_default()
    test_halted_accessor_default()
    test_get_req_header()
    test_put_resp_header()
    test_assign()
    test_send_resp()
    test_halt()
    test_text_response()
    test_json_response()
    test_redirect_response()
    test_run_pipeline_empty()
    test_run_pipeline_single_plug()
    test_run_pipeline_stops_when_halted()
    test_run_pipeline_multiple_plugs()
    test_server_new()
  end

end
