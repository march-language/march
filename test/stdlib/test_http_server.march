-- test/stdlib/test_http_server.march
-- Tests for the HttpServer stdlib module.
-- Covers Conn construction, accessors, transforms, pipeline execution,
-- and server config. No actual TCP binding.
-- Run with: dune exec march -- test test/stdlib/test_http_server.march

mod TestHttpServer do

-- Local mirrors of HttpServer private types (matched structurally at runtime).
type Upgrade = NoUpgrade | WebSocketUpgrade(a)
type Conn = Conn(
  Int, Method, String, List(String), String,
  List(Header), String, Int, List(Header), String,
  Bool, List((String, String)), Upgrade
)

fn make_conn(meth, path_, qs, req_hdrs, req_body) do
  let path_parts = List.filter(string_split(path_, "/"), fn s -> not(string_is_empty(s)))
  Conn(0, meth, path_, path_parts, qs, req_hdrs, req_body, 0, Nil, "", false, Nil, NoUpgrade)
end

fn make_get(path_) do
  make_conn(Get, path_, "", Cons(Header("host", "localhost"), Nil), "")
end

fn make_post(path_, body) do
  make_conn(Post, path_, "", Cons(Header("content-type", "text/plain"), Nil), body)
end

describe "HttpServer Conn accessors" do
  test "method accessor Get" do
    let conn = make_get("/users")
    assert (Http.method_to_string(HttpServer.method(conn)) == "GET")
  end

  test "method accessor Post" do
    let conn = make_post("/submit", "data")
    assert (Http.method_to_string(HttpServer.method(conn)) == "POST")
  end

  test "path accessor" do
    let conn = make_get("/api/v1/users")
    assert (HttpServer.path(conn) == "/api/v1/users")
  end

  test "path_info splits path segments" do
    let conn = make_get("/api/v1/users")
    let info = HttpServer.path_info(conn)
    assert (not (is_nil(info)))
    assert (head(info) == "api")
  end

  test "query_string accessor" do
    let conn = make_conn(Get, "/search", "q=hello&limit=5", Nil, "")
    assert (HttpServer.query_string(conn) == "q=hello&limit=5")
  end

  test "req_body accessor" do
    let conn = make_post("/submit", "my payload")
    assert (HttpServer.req_body(conn) == "my payload")
  end

  test "status is 0 by default" do
    let conn = make_get("/")
    assert (HttpServer.status(conn) == 0)
  end

  test "halted is false by default" do
    let conn = make_get("/")
    assert (not (HttpServer.halted(conn)))
  end
end

describe "HttpServer request header lookup" do
  test "get_req_header finds host" do
    let conn = make_get("/")
    assert (HttpServer.get_req_header(conn, "host") == Some("localhost"))
  end

  test "get_req_header is case insensitive" do
    let conn = make_get("/")
    assert (HttpServer.get_req_header(conn, "HOST") == Some("localhost"))
  end

  test "get_req_header returns None for missing header" do
    let conn = make_get("/")
    assert (HttpServer.get_req_header(conn, "x-missing") == None)
  end
end

describe "HttpServer Conn transforms" do
  test "put_resp_header adds header to resp_headers" do
    let conn = make_get("/")
    let conn2 = HttpServer.put_resp_header(conn, "X-Custom", "hello")
    let hdrs = HttpServer.resp_headers(conn2)
    assert (not (is_nil(hdrs)))
    match head(hdrs) do
    | Header(n, v) ->
      assert (string_to_lowercase(n) == "x-custom")
      assert (v == "hello")
    end
  end

  test "assign stores and retrieves value" do
    let conn = make_get("/")
    let conn2 = HttpServer.assign(conn, "user_id", "42")
    assert (HttpServer.get_assign(conn2, "user_id") == Some("42"))
    assert (HttpServer.get_assign(conn2, "missing") == None)
  end

  test "send_resp sets status body and halts" do
    let conn = make_get("/")
    let conn2 = HttpServer.send_resp(conn, 200, "hello world")
    assert (HttpServer.status(conn2) == 200)
    assert (HttpServer.resp_body(conn2) == "hello world")
    assert (HttpServer.halted(conn2))
  end

  test "halt marks conn as halted" do
    let conn = make_get("/")
    let conn2 = HttpServer.halt(conn)
    assert (HttpServer.halted(conn2))
  end
end

describe "HttpServer convenience response builders" do
  test "text sets status body and halts" do
    let conn = make_get("/")
    let conn2 = HttpServer.text(conn, 200, "plain text")
    assert (HttpServer.status(conn2) == 200)
    assert (HttpServer.resp_body(conn2) == "plain text")
    assert (HttpServer.halted(conn2))
  end

  test "text sets content-type header" do
    let conn = make_get("/")
    let conn2 = HttpServer.text(conn, 200, "plain text")
    let hdrs = HttpServer.resp_headers(conn2)
    assert (not (is_nil(hdrs)))
    match head(hdrs) do
    | Header(n, _) -> assert (string_to_lowercase(n) == "content-type")
    end
  end

  test "json sets status and body" do
    let conn = make_get("/")
    let conn2 = HttpServer.json(conn, 201, "{\"ok\":true}")
    assert (HttpServer.status(conn2) == 201)
    assert (HttpServer.resp_body(conn2) == "{\"ok\":true}")
  end

  test "redirect sets status 302 and halts" do
    let conn = make_get("/old")
    let conn2 = HttpServer.redirect(conn, "/new")
    assert (HttpServer.status(conn2) == 302)
    assert (HttpServer.halted(conn2))
  end
end

describe "HttpServer pipeline execution" do
  test "empty pipeline leaves conn unchanged" do
    let conn = make_get("/")
    let conn2 = HttpServer.run_pipeline(conn, Nil)
    assert (HttpServer.path(conn2) == "/")
    assert (not (HttpServer.halted(conn2)))
  end

  test "single plug is applied" do
    let conn = make_get("/")
    let add_header = fn c -> HttpServer.put_resp_header(c, "X-Plug", "ran")
    let conn2 = HttpServer.run_pipeline(conn, Cons(add_header, Nil))
    assert (not (is_nil(HttpServer.resp_headers(conn2))))
  end

  test "pipeline stops when halted" do
    let conn = make_get("/")
    let halt_plug       = fn c -> HttpServer.halt(c)
    let add_after_halt  = fn c -> HttpServer.put_resp_header(c, "X-After-Halt", "bad")
    let conn2 = HttpServer.run_pipeline(conn, Cons(halt_plug, Cons(add_after_halt, Nil)))
    assert (HttpServer.halted(conn2))
    let hdrs = HttpServer.resp_headers(conn2)
    let has_bad = List.any(hdrs, fn h ->
      match h do | Header(n, _) -> string_to_lowercase(n) == "x-after-halt" end)
    assert (not(has_bad))
  end

  test "multiple plugs all run when not halted" do
    let conn = make_get("/")
    let plug1 = fn c -> HttpServer.assign(c, "step", "1")
    let plug2 = fn c -> HttpServer.assign(c, "done", "yes")
    let conn2 = HttpServer.run_pipeline(conn, Cons(plug1, Cons(plug2, Nil)))
    assert (HttpServer.get_assign(conn2, "step") == Some("1"))
    assert (HttpServer.get_assign(conn2, "done") == Some("yes"))
  end
end

describe "HttpServer server config" do
  test "new creates a server without panicking" do
    let _srv = HttpServer.new(4000)
    ()
  end
end

end
