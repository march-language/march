-- Tests for the String stdlib module
-- Run with: dune exec march -- test test/stdlib/test_string.march

mod TestString do

describe "byte_size" do
  test "byte_size of empty string is zero" do
    assert (String.byte_size("") == 0)
  end

  test "byte_size of ascii string" do
    assert (String.byte_size("hello") == 5)
  end
end

describe "contains" do
  test "contains returns true when substring present" do
    assert String.contains("hello world", "world")
  end

  test "contains returns false when substring absent" do
    assert !String.contains("hello world", "xyz")
  end

  test "contains empty substring always true" do
    assert String.contains("abc", "")
  end
end

describe "starts_with" do
  test "starts_with returns true for matching prefix" do
    assert String.starts_with("hello world", "hello")
  end

  test "starts_with returns false for non-prefix" do
    assert !String.starts_with("hello world", "world")
  end

  test "starts_with empty prefix always true" do
    assert String.starts_with("hello", "")
  end
end

describe "ends_with" do
  test "ends_with returns true for matching suffix" do
    assert String.ends_with("hello world", "world")
  end

  test "ends_with returns false for non-suffix" do
    assert !String.ends_with("hello world", "hello")
  end
end

describe "concat" do
  test "concat joins two strings" do
    assert (String.concat("hello", " world") == "hello world")
  end

  test "concat with empty left" do
    assert (String.concat("", "hello") == "hello")
  end

  test "concat with empty right" do
    assert (String.concat("hello", "") == "hello")
  end
end

describe "replace" do
  test "replace substitutes first occurrence" do
    assert (String.replace("hello hello", "hello", "hi") == "hi hello")
  end

  test "replace_all substitutes all occurrences" do
    assert (String.replace_all("hello hello", "hello", "hi") == "hi hi")
  end

  test "replace with no match returns original" do
    assert (String.replace("hello", "xyz", "hi") == "hello")
  end
end

describe "split" do
  test "split on separator produces correct parts" do
    let parts = String.split("a,b,c", ",")
    assert (length(parts) == 3)
    assert (head(parts) == "a")
  end

  test "split with no match returns single-element list" do
    assert (length(String.split("hello", ",")) == 1)
  end
end

describe "join" do
  test "join concatenates with separator" do
    let parts = Cons("a", Cons("b", Cons("c", Nil)))
    assert (String.join(parts, ",") == "a,b,c")
  end

  test "join of empty list gives empty string" do
    assert (String.join(Nil, ",") == "")
  end
end

describe "trim" do
  test "trim removes leading and trailing whitespace" do
    assert (String.trim("  hello  ") == "hello")
  end

  test "trim_start removes only leading whitespace" do
    assert (String.trim_start("  hello  ") == "hello  ")
  end

  test "trim_end removes only trailing whitespace" do
    assert (String.trim_end("  hello  ") == "  hello")
  end
end

describe "case conversion" do
  test "to_uppercase converts to upper case" do
    assert (String.to_uppercase("hello") == "HELLO")
  end

  test "to_lowercase converts to lower case" do
    assert (String.to_lowercase("HELLO") == "hello")
  end
end

describe "repeat" do
  test "repeat n times concatenates string n times" do
    assert (String.repeat("ab", 3) == "ababab")
  end

  test "repeat zero times gives empty string" do
    assert (String.repeat("ab", 0) == "")
  end
end

describe "reverse" do
  test "reverse reverses ascii string" do
    assert (String.reverse("hello") == "olleh")
  end

  test "reverse of empty string is empty" do
    assert (String.reverse("") == "")
  end
end

describe "padding" do
  test "pad_left pads with fill character on left" do
    assert (String.pad_left("42", 5, "0") == "00042")
  end

  test "pad_right pads with fill character on right" do
    assert (String.pad_right("hi", 5, " ") == "hi   ")
  end

  test "pad_left does nothing when already long enough" do
    assert (String.pad_left("hello", 3, "0") == "hello")
  end
end

describe "is_empty" do
  test "is_empty returns true for empty string" do
    assert String.is_empty("")
  end

  test "is_empty returns false for non-empty string" do
    assert !String.is_empty("a")
  end
end

describe "to_int and to_float" do
  test "to_int parses valid integer string" do
    match String.to_int("42") do
    Err(_) -> assert false
    Ok(n) -> assert (n == 42)
    end
  end

  test "to_int returns Err for invalid string" do
    match String.to_int("abc") do
    Err(_) -> assert true
    Ok(_) -> assert false
    end
  end

  test "to_int parses negative integer" do
    match String.to_int("-7") do
    Err(_) -> assert false
    Ok(n) -> assert (n == -7)
    end
  end
end

describe "from_int and from_float" do
  test "from_int converts integer to string" do
    assert (String.from_int(42) == "42")
  end

  test "from_int converts negative integer" do
    assert (String.from_int(-7) == "-7")
  end
end

describe "index_of" do
  test "index_of returns byte offset when found" do
    match String.index_of("hello world", "world") do
    None -> assert false
    Some(i) -> assert (i == 6)
    end
  end

  test "index_of returns None when not found" do
    match String.index_of("hello", "xyz") do
    None -> assert true
    Some(_) -> assert false
    end
  end
end

end
