-- test/stdlib/test_bastion_telemetry.march
-- Tests for the BastionTelemetry stdlib module.
-- Run with: dune exec march -- test test/stdlib/test_bastion_telemetry.march

mod TestBastionTelemetry do

-- ── Local type definitions ─────────────────────────────────────────────────
-- Mirror the Conn/Upgrade types from HttpServer so register_before/after_send
-- tests can build a minimal Conn without pulling in the HTTP server.

ptype Upgrade = NoUpgrade | WebSocketUpgrade(a)

ptype Conn = Conn(
  Int,          -- fd
  String,       -- method
  String,       -- path
  List(String), -- path_parts
  String,       -- query_string
  List(String), -- req_headers (simplified)
  String,       -- req_body
  Int,          -- status
  List(String), -- resp_headers (simplified)
  String,       -- resp_body
  Bool,         -- halted
  List((String, String)), -- assigns
  Upgrade       -- upgrade
)

pfn make_conn() do
  Conn(0, "GET", "/", Nil, "", Nil, "", 0, Nil, "", false, Nil, NoUpgrade)
end

-- ── TelemetryEvent constructors and accessors ──────────────────────────────

describe "BastionTelemetry TelemetryEvent" do
  test "constructor builds an event with correct fields" do
    let ev = BastionTelemetry.TelemetryEvent(
      ["web", "request"],
      [("duration", 10)],
      [("route", "/users")]
    )
    assert (BastionTelemetry.event_name(ev) == ["web", "request"])
  end

  test "event_measurements returns measurement list" do
    let ev = BastionTelemetry.TelemetryEvent(
      ["test"],
      [("latency", 5), ("rows", 3)],
      Nil
    )
    assert (BastionTelemetry.event_measurements(ev) == [("latency", 5), ("rows", 3)])
  end

  test "event_metadata returns metadata list" do
    let ev = BastionTelemetry.TelemetryEvent(
      ["test"],
      Nil,
      [("status", "ok"), ("route", "/")]
    )
    assert (BastionTelemetry.event_metadata(ev) == [("status", "ok"), ("route", "/")])
  end
end

-- ── execute and recent_events ──────────────────────────────────────────────

describe "BastionTelemetry execute / recent_events" do
  test "execute stores an event retrievable by recent_events" do
    BastionTelemetry.execute(["tel_test", "stored"], [("v", 1)], [("k", "a")])
    let evs = BastionTelemetry.recent_events(10)
    let found = List.any(evs, fn ev ->
      BastionTelemetry.event_name(ev) == ["tel_test", "stored"]
    )
    assert found
  end

  test "recent_events limit is respected" do
    BastionTelemetry.execute(["tel_limit", "e1"], Nil, Nil)
    BastionTelemetry.execute(["tel_limit", "e2"], Nil, Nil)
    BastionTelemetry.execute(["tel_limit", "e3"], Nil, Nil)
    let evs = BastionTelemetry.recent_events(1)
    assert (List.length(evs) == 1)
  end

  test "recent_events returns newest event first" do
    BastionTelemetry.execute(["tel_order", "first"], Nil, Nil)
    BastionTelemetry.execute(["tel_order", "second"], Nil, Nil)
    let evs = BastionTelemetry.recent_events(5)
    -- The most recently executed event is at the front.
    let found_second = List.any(evs, fn ev ->
      BastionTelemetry.event_name(ev) == ["tel_order", "second"]
    )
    assert found_second
  end

  test "execute stores measurements and metadata" do
    BastionTelemetry.execute(
      ["tel_fields", "check"],
      [("ms", 99)],
      [("path", "/api")]
    )
    let evs = BastionTelemetry.recent_events(20)
    let found = List.any(evs, fn ev -> do
      let meas = BastionTelemetry.event_measurements(ev)
      let meta = BastionTelemetry.event_metadata(ev)
      BastionTelemetry.event_name(ev) == ["tel_fields", "check"]
      && meas == [("ms", 99)]
      && meta == [("path", "/api")]
    end)
    assert found
  end
end

-- ── attach / detach / handler_count ───────────────────────────────────────

describe "BastionTelemetry attach / detach / handler_count" do
  test "attach increases handler_count by 1" do
    let before = BastionTelemetry.handler_count()
    BastionTelemetry.attach("tc_handler_a", [["web"]], fn _ev -> ())
    let after = BastionTelemetry.handler_count()
    assert (after == before + 1)
  end

  test "detach decreases handler_count by 1" do
    BastionTelemetry.attach("tc_handler_b", Nil, fn _ev -> ())
    let before = BastionTelemetry.handler_count()
    BastionTelemetry.detach("tc_handler_b")
    let after = BastionTelemetry.handler_count()
    assert (after == before - 1)
  end

  test "attaching the same handler_id twice does not double-count" do
    BastionTelemetry.attach("tc_dedup", [["x"]], fn _ev -> ())
    let c1 = BastionTelemetry.handler_count()
    BastionTelemetry.attach("tc_dedup", [["y"]], fn _ev -> ())
    let c2 = BastionTelemetry.handler_count()
    assert (c2 == c1)
  end

  test "detaching non-existent handler does not crash" do
    let before = BastionTelemetry.handler_count()
    BastionTelemetry.detach("tc_nonexistent_xyz")
    let after = BastionTelemetry.handler_count()
    assert (after == before)
  end

  test "handler_count is zero when no handlers attached (fresh table check)" do
    -- Just ensure the function is callable and returns a non-negative Int.
    let count = BastionTelemetry.handler_count()
    assert (count >= 0)
  end
end

-- ── subscribed_events ─────────────────────────────────────────────────────

describe "BastionTelemetry subscribed_events" do
  test "returns the event filter list for an attached handler" do
    let filters = [["bastion", "endpoint"]]
    BastionTelemetry.attach("tc_sub_check", filters, fn _ev -> ())
    let result = BastionTelemetry.subscribed_events("tc_sub_check")
    assert (result == Some(filters))
  end

  test "returns None for an unregistered handler" do
    let result = BastionTelemetry.subscribed_events("tc_sub_unknown_xyz")
    assert (result == None)
  end
end

-- ── ring buffer cap ────────────────────────────────────────────────────────

describe "BastionTelemetry event ring buffer cap" do
  test "recent_events with limit 0 returns empty list" do
    BastionTelemetry.execute(["tel_cap", "e"], Nil, Nil)
    let evs = BastionTelemetry.recent_events(0)
    assert (List.length(evs) == 0)
  end

  test "recent_events with large limit does not error" do
    let evs = BastionTelemetry.recent_events(9999)
    -- Should return a list (not panic), even if smaller than 9999 entries.
    assert (List.length(evs) >= 0)
  end
end

-- ── Aggregator ────────────────────────────────────────────────────────────

describe "BastionTelemetry.Aggregator" do
  test "start initialises counters without error" do
    BastionTelemetry.Aggregator.start()
    let (total, errs) = BastionTelemetry.Aggregator.counters()
    assert (total >= 0)
    assert (errs >= 0)
  end

  test "record increments total counter" do
    BastionTelemetry.Aggregator.start()
    let (before, _) = BastionTelemetry.Aggregator.counters()
    let ev = BastionTelemetry.TelemetryEvent(["agg", "test"], [("n", 1)], Nil)
    BastionTelemetry.Aggregator.record(ev)
    let (after, _) = BastionTelemetry.Aggregator.counters()
    assert (after == before + 1)
  end

  test "record increments error_count for error events" do
    BastionTelemetry.Aggregator.start()
    let (_, errs_before) = BastionTelemetry.Aggregator.counters()
    let ev = BastionTelemetry.TelemetryEvent(
      ["agg", "error"],
      Nil,
      [("error", "true")]
    )
    BastionTelemetry.Aggregator.record(ev)
    let (_, errs_after) = BastionTelemetry.Aggregator.counters()
    assert (errs_after == errs_before + 1)
  end

  test "recent_requests returns only endpoint events" do
    BastionTelemetry.Aggregator.start()
    let ep_ev = BastionTelemetry.TelemetryEvent(
      ["bastion", "endpoint", "stop"],
      [("duration", 5)],
      Nil
    )
    let other_ev = BastionTelemetry.TelemetryEvent(
      ["custom", "metric"],
      Nil,
      Nil
    )
    BastionTelemetry.Aggregator.record(ep_ev)
    BastionTelemetry.Aggregator.record(other_ev)
    let reqs = BastionTelemetry.Aggregator.recent_requests(50)
    let all_endpoint = List.all(reqs, fn ev ->
      match BastionTelemetry.event_name(ev) do
      Cons("bastion", Cons("endpoint", _)) -> true
      _ -> false
      end
    )
    assert all_endpoint
  end

  test "counters returns tuple of (total, error_count)" do
    BastionTelemetry.Aggregator.start()
    let result = BastionTelemetry.Aggregator.counters()
    match result do
    (t, e) -> assert (t >= 0 && e >= 0)
    end
  end
end

end -- mod TestBastionTelemetry
