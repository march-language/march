-- Tests for the Regex stdlib module.
-- Run with: dune exec march -- test test/stdlib/test_regex.march
-- Uses pure March regex engine (standard syntax: * + ? directly, not \+ \?).

mod TestRegex do

describe "Regex" do

  describe "matches" do

    test "matches literal" do
      assert Regex.matches("hello", "hello world")
      assert Regex.matches("world", "hello world")
      assert not(Regex.matches("xyz", "hello world"))
      assert Regex.matches("", "anything")
    end

    test "dot matches any character" do
      assert Regex.matches("h.llo", "hello")
      assert Regex.matches("h.llo", "hxllo")
    end

    test "star quantifier" do
      assert Regex.matches("ab*c", "ac")
      assert Regex.matches("ab*c", "abc")
      assert Regex.matches("ab*c", "abbbbc")
    end

    test "plus quantifier" do
      assert Regex.matches("ab+c", "abc")
      assert Regex.matches("ab+c", "abbbbc")
      assert not(Regex.matches("ab+c", "ac"))
    end

    test "optional quantifier" do
      assert Regex.matches("colou?r", "colour")
      assert Regex.matches("colou?r", "color")
    end

    test "anchors" do
      assert Regex.matches("^hello", "hello world")
      assert not(Regex.matches("^world", "hello world"))
      assert Regex.matches("world$", "hello world")
      assert not(Regex.matches("hello$", "hello world"))
    end

    test "character classes" do
      assert Regex.matches("[0-9]", "abc3def")
      assert not(Regex.matches("[0-9]", "abcdef"))
      assert Regex.matches("[a-z]", "Hello World")
      assert Regex.matches("[^a-z]", "HELLO")
    end

  end

  describe "find" do

    test "find single digit" do
      match Regex.find("[0-9]", "price: 42 dollars") do
      None -> panic("find digit not found")
      Some(m) -> assert (m == "4")
      end
    end

    test "find literal" do
      match Regex.find("world", "hello world") do
      None -> panic("find literal not found")
      Some(m) -> assert (m == "world")
      end
    end

    test "find no match returns None" do
      match Regex.find("xyz", "hello world") do
      None -> ()
      Some(_) -> panic("find no match should be None")
      end
    end

  end

  describe "find_all" do

    test "find_all digits" do
      let digits = Regex.find_all("[0-9]", "a1b2c3")
      assert (List.length(digits) == 3)
    end

    test "find_all repeated pattern" do
      let words = Regex.find_all("ab", "ababab")
      assert (List.length(words) == 3)
    end

    test "find_all no match returns empty" do
      let empty_result = Regex.find_all("xyz", "hello world")
      assert (List.length(empty_result) == 0)
    end

  end

  describe "replace" do

    test "replace basic" do
      assert (Regex.replace("world", "March", "hello world") == "hello March")
    end

    test "replace first only" do
      assert (Regex.replace("o", "0", "foo bar boo") == "f0o bar boo")
    end

    test "replace no match" do
      assert (Regex.replace("xyz", "!", "hello") == "hello")
    end

  end

  describe "replace_all" do

    test "replace_all digits" do
      assert (Regex.replace_all("[0-9]", "#", "a1b2c3") == "a#b#c#")
    end

    test "replace_all all occurrences" do
      assert (Regex.replace_all("o", "0", "foo bar boo") == "f00 bar b00")
    end

    test "replace_all no match" do
      assert (Regex.replace_all("xyz", "!", "hello") == "hello")
    end

  end

  describe "split" do

    test "split comma" do
      let parts = Regex.split(",", "a,b,c,d")
      assert (List.length(parts) == 4)
      assert (List.nth(parts, 0) == "a")
      assert (List.nth(parts, 3) == "d")
    end

    test "split whitespace" do
      let ws_parts = Regex.split(" +", "hello   world foo")
      assert (List.length(ws_parts) == 3)
    end

  end

end

end
