-- test/stdlib/test_regex.march
-- Comprehensive tests for the Regex module.
-- Uses OCaml Str syntax (basic regex, not PCRE).

mod TestRegex do

fn main() do
  -- ---- Regex.match_ ----
  assert_true("match_ literal", Regex.match_("hello", "hello world"))
  assert_true("match_ anywhere in string", Regex.match_("world", "hello world"))
  assert_true("no match", not Regex.match_("xyz", "hello world"))
  assert_true("match_ empty pattern", Regex.match_("", "anything"))

  -- Dot matches any character
  assert_true("dot matches", Regex.match_("h.llo", "hello"))
  assert_true("dot matches 2", Regex.match_("h.llo", "hxllo"))

  -- Star (0 or more)
  assert_true("star 0 times", Regex.match_("ab*c", "ac"))
  assert_true("star 1 time", Regex.match_("ab*c", "abc"))
  assert_true("star many", Regex.match_("ab*c", "abbbbc"))

  -- Plus (1 or more) - Str uses \+
  assert_true("plus 1", Regex.match_("ab\\+c", "abc"))
  assert_true("plus many", Regex.match_("ab\\+c", "abbbbc"))
  assert_true("plus 0 fails", not Regex.match_("ab\\+c", "ac"))

  -- Question mark (0 or 1) - Str uses \?
  assert_true("optional present", Regex.match_("colou\\?r", "colour"))
  assert_true("optional absent", Regex.match_("colou\\?r", "color"))

  -- Anchors
  assert_true("anchor start match", Regex.match_("^hello", "hello world"))
  assert_true("anchor start no match", not Regex.match_("^world", "hello world"))
  assert_true("anchor end match", Regex.match_("world$", "hello world"))
  assert_true("anchor end no match", not Regex.match_("hello$", "hello world"))

  -- Character classes
  assert_true("char class digit", Regex.match_("[0-9]", "abc3def"))
  assert_true("char class no digit", not Regex.match_("[0-9]", "abcdef"))
  assert_true("char class letters", Regex.match_("[a-z]", "Hello World"))
  assert_true("negated char class", Regex.match_("[^a-z]", "HELLO"))

  -- ---- Regex.find ----
  match Regex.find("[0-9]+", "price: 42 dollars") do
  | None -> panic("find digit not found")
  | Some(m) -> assert_eq("find digit", m, "4")  -- Str matches single char for +
  end

  match Regex.find("world", "hello world") do
  | None -> panic("find literal not found")
  | Some(m) -> assert_eq("find literal", m, "world")
  end

  match Regex.find("xyz", "hello world") do
  | None -> :ok
  | Some(_) -> panic("find no match should be None")
  end

  -- ---- Regex.find_all ----
  let digits = Regex.find_all("[0-9]", "a1b2c3")
  assert_eq("find_all digit count", List.length(digits), 3)

  let words = Regex.find_all("ab", "ababab")
  assert_eq("find_all repeated", List.length(words), 3)

  let empty_result = Regex.find_all("xyz", "hello world")
  assert_eq("find_all no match empty", List.length(empty_result), 0)

  -- ---- Regex.replace ----
  assert_eq("replace basic", Regex.replace("world", "March", "hello world"), "hello March")
  assert_eq("replace first only", Regex.replace("o", "0", "foo bar boo"), "f0o bar b0o")
  assert_eq("replace digits", Regex.replace("[0-9]", "#", "a1b2c3"), "a#b#c#")
  assert_eq("replace no match", Regex.replace("xyz", "!", "hello"), "hello")

  -- ---- Regex.split ----
  let parts = Regex.split(",", "a,b,c,d")
  assert_eq("split comma count", List.length(parts), 4)
  assert_eq("split[0]", List.nth(parts, 0), "a")
  assert_eq("split[3]", List.nth(parts, 3), "d")

  let ws_parts = Regex.split("[ \t]+", "hello   world\tfoo")
  assert_eq("split whitespace count", List.length(ws_parts), 3)

  -- ---- Regex.is_valid ----
  assert_true("is_valid simple", Regex.is_valid("hello"))
  assert_true("is_valid complex", Regex.is_valid("[a-z]+"))
  assert_true("is_valid anchors", Regex.is_valid("^start.*end$"))

  -- ---- Regex.matches_full ----
  assert_true("matches_full exact", Regex.matches_full("[0-9]+", "12345"))
  assert_true("matches_full no partial", not Regex.matches_full("[0-9]+", "123abc"))
  assert_true("matches_full empty", Regex.matches_full("", ""))

  -- ---- Regex.count ----
  assert_eq("count digits", Regex.count("[0-9]", "a1b2c3d4"), 4)
  assert_eq("count none", Regex.count("[0-9]", "abcdef"), 0)

  println("All Regex tests passed!")
end

end
