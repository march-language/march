-- Tests for the DateTime stdlib module
-- Run with: dune exec march -- test test/stdlib/test_datetime.march

mod TestDateTime do

describe "DateTime" do

  describe "from_timestamp and to_timestamp" do

    test "epoch is timestamp 0" do
      let epoch = DateTime.from_timestamp(0)
      match epoch do
      DateTime(Date(y, m, d), Time(h, mn, s)) -> do
        assert (y == 1970)
        assert (m == 1)
        assert (d == 1)
        assert (h == 0)
        assert (mn == 0)
        assert (s == 0)
      end
      end
    end

    test "to_timestamp roundtrip" do
      let dt = DateTime.from_timestamp(86400)
      let ts = DateTime.to_timestamp(dt)
      assert (ts == 86400)
    end

    test "one day is 86400 seconds" do
      let dt = DateTime.from_timestamp(86400)
      match dt do
      DateTime(Date(y, m, d), Time(h, mn, s)) -> do
        assert (y == 1970)
        assert (m == 1)
        assert (d == 2)
        assert (h == 0)
        assert (mn == 0)
        assert (s == 0)
      end
      end
    end

    test "one hour" do
      let dt = DateTime.from_timestamp(3600)
      match dt do
      DateTime(Date(_, _, _), Time(h, mn, s)) -> do
        assert (h == 1)
        assert (mn == 0)
        assert (s == 0)
      end
      end
    end

  end

  describe "add_seconds" do

    test "add 60 seconds" do
      let base = DateTime.from_timestamp(0)
      let plus60 = DateTime.add_seconds(base, 60)
      match plus60 do
      DateTime(Date(_, _, _), Time(_, mn, s)) -> do
        assert (mn == 1)
        assert (s == 0)
      end
      end
    end

    test "add one day in seconds" do
      let base = DateTime.from_timestamp(0)
      let plus_day = DateTime.add_seconds(base, 86400)
      match plus_day do
      DateTime(Date(_, _, d), Time(_, _, _)) ->
        assert (d == 2)
      end
    end

    test "subtract 60 seconds" do
      let base = DateTime.from_timestamp(60)
      let minus60 = DateTime.add_seconds(base, -60)
      match minus60 do
      DateTime(Date(_, _, _), Time(_, mn, s)) -> do
        assert (mn == 0)
        assert (s == 0)
      end
      end
    end

  end

  describe "add_days" do

    test "add 1 day" do
      let base = DateTime.from_timestamp(0)
      let next = DateTime.add_days(base, 1)
      match next do
      DateTime(Date(_, _, d), Time(_, _, _)) ->
        assert (d == 2)
      end
    end

    test "add days crossing month boundary" do
      -- Jan 1 1970 + 31 days = Feb 1 1970
      let jan1 = DateTime.from_timestamp(0)
      let feb1 = DateTime.add_days(jan1, 31)
      match feb1 do
      DateTime(Date(_, m, d), Time(_, _, _)) -> do
        assert (d == 1)
        assert (m == 2)
      end
      end
    end

    test "add days crossing year boundary" do
      -- Jan 1 1970 + 365 days = Jan 1 1971
      let jan1 = DateTime.from_timestamp(0)
      let next_year = DateTime.add_days(jan1, 365)
      match next_year do
      DateTime(Date(y, m, d), Time(_, _, _)) -> do
        assert (y == 1971)
        assert (m == 1)
        assert (d == 1)
      end
      end
    end

  end

  describe "diff_seconds" do

    test "diff_seconds one minute" do
      let t1 = DateTime.from_timestamp(60)
      let t2 = DateTime.from_timestamp(0)
      assert (DateTime.diff_seconds(t1, t2) == 60)
      assert (DateTime.diff_seconds(t2, t1) == -60)
    end

    test "diff_seconds same is 0" do
      let t = DateTime.from_timestamp(12345)
      assert (DateTime.diff_seconds(t, t) == 0)
    end

  end

  describe "compare" do

    test "compare ordering" do
      let a = DateTime.from_timestamp(0)
      let b = DateTime.from_timestamp(86400)
      assert (DateTime.compare(a, b) < 0)
      assert (DateTime.compare(b, a) > 0)
      assert (DateTime.compare(a, a) == 0)
    end

  end

  describe "day_of_week" do

    test "known weekday Thursday Jan 1 1970" do
      let epoch = DateTime.from_timestamp(0)
      -- Jan 1, 1970 was a Thursday = 4
      assert (DateTime.day_of_week(epoch) == 4)
    end

    test "day_of_week Friday Jan 2 1970" do
      let next = DateTime.from_timestamp(86400)
      -- Jan 2, 1970 was a Friday = 5
      assert (DateTime.day_of_week(next) == 5)
    end

  end

  describe "format" do

    test "format date" do
      -- 2001-09-09T01:46:40 UTC is Unix timestamp 1000000000
      let dt = DateTime.from_timestamp(1000000000)
      let s = DateTime.format(dt, "%Y-%m-%d")
      assert (s == "2001-09-09")
    end

    test "format time" do
      -- 3661 seconds = 1h 1m 1s
      let dt = DateTime.from_timestamp(3661)
      let s = DateTime.format(dt, "%H:%M:%S")
      assert (s == "01:01:01")
    end

    test "format full datetime" do
      let dt = DateTime.from_timestamp(0)
      let s = DateTime.format(dt, "%Y-%m-%d %H:%M:%S")
      assert (s == "1970-01-01 00:00:00")
    end

  end

  describe "parse" do

    test "parse date only" do
      match DateTime.parse("2024-03-15") do
      Err(e) -> panic("parse date failed: " ++ e)
      Ok(dt) -> do
        match dt do
        DateTime(Date(y, m, d), Time(_, _, _)) ->
          assert (y == 2024)
          assert (m == 3)
          assert (d == 15)
        end
      end
      end
    end

    test "parse datetime" do
      match DateTime.parse("2024-03-15 10:30:45") do
      Err(e) -> panic("parse datetime failed: " ++ e)
      Ok(dt) -> do
        match dt do
        DateTime(Date(y, m, d), Time(h, mn, s)) ->
          assert (y == 2024)
          assert (m == 3)
          assert (d == 15)
          assert (h == 10)
          assert (mn == 30)
          assert (s == 45)
        end
      end
      end
    end

    test "parse invalid returns Err" do
      match DateTime.parse("not-a-date") do
      Err(_) -> ()
      Ok(_) -> panic("invalid date should return Err")
      end
    end

    test "parse short string returns Err" do
      match DateTime.parse("2024") do
      Err(_) -> ()
      Ok(_) -> panic("short string should return Err")
      end
    end

  end

  describe "now" do

    test "now returns valid timestamp" do
      let ts = DateTime.now()
      -- Should be after 2020-01-01 (1577836800)
      assert (ts > 1577836800)
    end

    test "now as DateTime has valid fields" do
      let dt = DateTime.from_timestamp(DateTime.now())
      match dt do
      DateTime(Date(y, m, d), Time(h, mn, s)) -> do
        assert (y >= 2024)
        assert (m >= 1 && m <= 12)
        assert (d >= 1 && d <= 31)
        assert (h >= 0 && h <= 23)
        assert (mn >= 0 && mn <= 59)
        assert (s >= 0 && s <= 59)
      end
      end
    end

  end

end

end
