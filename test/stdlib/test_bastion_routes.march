-- test/stdlib/test_bastion_routes.march
-- Tests for the BastionRoutes stdlib module.
-- Run with: dune exec march -- test test/stdlib/test_bastion_routes.march

mod TestBastionRoutes do

-- ── register / all ────────────────────────────────────────────────────────────

describe "BastionRoutes register / all" do
  test "registered route appears in all()" do
    BastionRoutes.register("tr_home", "get", "/", 0)
    let routes = BastionRoutes.all()
    let found = List.any(routes, fn r ->
      match r do
      (name, _, _, _) -> name == "tr_home"
      end
    )
    assert found
  end

  test "registered route stores method and pattern" do
    BastionRoutes.register("tr_users", "get", "/users", 0)
    let routes = BastionRoutes.all()
    let found = List.any(routes, fn r ->
      match r do
      (name, method, pattern, _) -> name == "tr_users" && method == "get" && pattern == "/users"
      end
    )
    assert found
  end

  test "registering same name twice updates entry" do
    BastionRoutes.register("tr_update", "get", "/old", 0)
    BastionRoutes.register("tr_update", "post", "/new", 0)
    let tbl = Vault.whereis("bastion_routes")
    assert (tbl != None)
  end
end

-- ── static_path ───────────────────────────────────────────────────────────────

describe "BastionRoutes static_path" do
  test "static path returns the base path" do
    BastionRoutes.register("tr_about", "get", "/about", 0)
    let p = BastionRoutes.static_path("tr_about")
    assert (p == "/about")
  end

  test "root path returns /" do
    BastionRoutes.register("tr_root", "get", "/", 0)
    let p = BastionRoutes.static_path("tr_root")
    assert (p == "/")
  end

  test "unknown route returns error string" do
    let p = BastionRoutes.static_path("tr_nonexistent_xyz")
    assert (String.starts_with(p, "unknown route:"))
  end
end

-- ── path1 ─────────────────────────────────────────────────────────────────────

describe "BastionRoutes path1" do
  test "path1 fills single dynamic segment" do
    BastionRoutes.register("tr_user", "get", "/users/:id", 1)
    let p = BastionRoutes.path1("tr_user", "42")
    assert (p == "/users/42")
  end

  test "path1 with different segment value" do
    BastionRoutes.register("tr_article", "get", "/articles/:slug", 1)
    let p = BastionRoutes.path1("tr_article", "hello-world")
    assert (p == "/articles/hello-world")
  end
end

-- ── path2 ─────────────────────────────────────────────────────────────────────

describe "BastionRoutes path2" do
  test "path2 fills two dynamic segments" do
    BastionRoutes.register("tr_comment", "get", "/posts/:post_id/comments/:id", 2)
    let p = BastionRoutes.path2("tr_comment", "10", "99")
    assert (p == "/posts/10/comments/99")
  end
end

-- ── path with query params ─────────────────────────────────────────────────────

describe "BastionRoutes path with query params" do
  test "path with single query param appends ?key=value" do
    BastionRoutes.register("tr_search", "get", "/search", 0)
    let p = BastionRoutes.path("tr_search", Nil, Cons(("q", "hello"), Nil))
    assert (p == "/search?q=hello")
  end

  test "path with multiple query params" do
    BastionRoutes.register("tr_list", "get", "/items", 0)
    let p = BastionRoutes.path("tr_list", Nil, Cons(("page", "2"), Cons(("per", "10"), Nil)))
    assert (String.contains(p, "page=2"))
    assert (String.contains(p, "per=10"))
  end

  test "path with no query params has no question mark" do
    BastionRoutes.register("tr_nq", "get", "/no-query", 0)
    let p = BastionRoutes.path("tr_nq", Nil, Nil)
    assert (not (String.contains(p, "?")))
  end

  test "unknown route returns error string" do
    let p = BastionRoutes.path("tr_nonexistent_abc", Nil, Nil)
    assert (String.starts_with(p, "unknown route:"))
  end
end

-- ── query encoding ────────────────────────────────────────────────────────────

describe "BastionRoutes query encoding" do
  test "spaces in query values are encoded as %20" do
    BastionRoutes.register("tr_enc", "get", "/search", 0)
    let p = BastionRoutes.path("tr_enc", Nil, Cons(("q", "a b"), Nil))
    assert (String.contains(p, "a%20b"))
  end

  test "ampersand in query value is encoded as %26" do
    BastionRoutes.register("tr_enc2", "get", "/search", 0)
    let p = BastionRoutes.path("tr_enc2", Nil, Cons(("q", "a&b"), Nil))
    assert (String.contains(p, "a%26b"))
  end

  test "equals sign in query value is encoded as %3D" do
    BastionRoutes.register("tr_enc3", "get", "/search", 0)
    let p = BastionRoutes.path("tr_enc3", Nil, Cons(("q", "a=b"), Nil))
    assert (String.contains(p, "a%3Db"))
  end
end

end -- mod TestBastionRoutes
