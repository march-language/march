-- Tests for the Flow stdlib module.
-- Run with: dune exec march -- test test/stdlib/test_flow.march

mod TestFlow do

describe "Flow" do

  describe "from_list and collect" do

    test "collect empty list" do
      let s = Flow.from_list(Nil)
      let result = Flow.collect(s)
      assert (List.length(result) == 0)
    end

    test "collect preserves elements" do
      let s = Flow.from_list(Cons(1, Cons(2, Cons(3, Nil))))
      let result = Flow.collect(s)
      assert (List.length(result) == 3)
      assert (List.nth(result, 0) == 1)
      assert (List.nth(result, 1) == 2)
      assert (List.nth(result, 2) == 3)
    end

    test "collect strings" do
      let s = Flow.from_list(Cons("a", Cons("b", Nil)))
      let result = Flow.collect(s)
      assert (List.length(result) == 2)
      assert (List.nth(result, 0) == "a")
    end

  end

  describe "map" do

    test "map doubles ints" do
      let s = Flow.from_list(Cons(1, Cons(2, Cons(3, Nil))))
      let result = Flow.collect(Flow.map(s, fn x -> x * 2))
      assert (List.length(result) == 3)
      assert (List.nth(result, 0) == 2)
      assert (List.nth(result, 1) == 4)
      assert (List.nth(result, 2) == 6)
    end

    test "map to string" do
      let s = Flow.from_list(Cons(1, Cons(2, Nil)))
      let result = Flow.collect(Flow.map(s, fn x -> int_to_string(x)))
      assert (List.nth(result, 0) == "1")
      assert (List.nth(result, 1) == "2")
    end

    test "map empty list" do
      let s = Flow.from_list(Nil)
      let result = Flow.collect(Flow.map(s, fn x -> x * 2))
      assert (List.length(result) == 0)
    end

  end

  describe "filter" do

    test "filter even numbers" do
      let xs = Cons(1, Cons(2, Cons(3, Cons(4, Cons(5, Nil)))))
      let s = Flow.from_list(xs)
      let result = Flow.collect(Flow.filter(s, fn x -> x % 2 == 0))
      assert (List.length(result) == 2)
      assert (List.nth(result, 0) == 2)
      assert (List.nth(result, 1) == 4)
    end

    test "filter all pass" do
      let s = Flow.from_list(Cons(1, Cons(2, Cons(3, Nil))))
      let result = Flow.collect(Flow.filter(s, fn _ -> true))
      assert (List.length(result) == 3)
    end

    test "filter none pass" do
      let s = Flow.from_list(Cons(1, Cons(2, Cons(3, Nil))))
      let result = Flow.collect(Flow.filter(s, fn _ -> false))
      assert (List.length(result) == 0)
    end

  end

  describe "take and drop" do

    test "take first two" do
      let s = Flow.from_list(Cons(1, Cons(2, Cons(3, Cons(4, Nil)))))
      let result = Flow.collect(Flow.take(s, 2))
      assert (List.length(result) == 2)
      assert (List.nth(result, 0) == 1)
      assert (List.nth(result, 1) == 2)
    end

    test "take more than length" do
      let s = Flow.from_list(Cons(1, Cons(2, Nil)))
      let result = Flow.collect(Flow.take(s, 10))
      assert (List.length(result) == 2)
    end

    test "take zero" do
      let s = Flow.from_list(Cons(1, Cons(2, Cons(3, Nil))))
      let result = Flow.collect(Flow.take(s, 0))
      assert (List.length(result) == 0)
    end

    test "drop first two" do
      let s = Flow.from_list(Cons(1, Cons(2, Cons(3, Cons(4, Nil)))))
      let result = Flow.collect(Flow.drop(s, 2))
      assert (List.length(result) == 2)
      assert (List.nth(result, 0) == 3)
      assert (List.nth(result, 1) == 4)
    end

    test "drop more than length" do
      let s = Flow.from_list(Cons(1, Cons(2, Nil)))
      let result = Flow.collect(Flow.drop(s, 10))
      assert (List.length(result) == 0)
    end

  end

  describe "count" do

    test "count empty" do
      assert (Flow.count(Flow.from_list(Nil)) == 0)
    end

    test "count elements" do
      let s = Flow.from_list(Cons(1, Cons(2, Cons(3, Nil))))
      assert (Flow.count(s) == 3)
    end

    test "count after filter" do
      let s = Flow.from_list(Cons(1, Cons(2, Cons(3, Cons(4, Nil)))))
      assert (Flow.count(Flow.filter(s, fn x -> x > 2)) == 2)
    end

  end

  describe "find" do

    test "find first match" do
      let s = Flow.from_list(Cons(1, Cons(2, Cons(3, Nil))))
      match Flow.find(s, fn x -> x > 1) do
      | None -> panic("expected Some")
      | Some(v) -> assert (v == 2)
      end
    end

    test "find no match returns None" do
      let s = Flow.from_list(Cons(1, Cons(2, Cons(3, Nil))))
      match Flow.find(s, fn x -> x > 10) do
      | None -> ()
      | Some(_) -> panic("expected None")
      end
    end

  end

  describe "any and all" do

    test "any true" do
      let s = Flow.from_list(Cons(1, Cons(2, Cons(3, Nil))))
      assert Flow.any(s, fn x -> x > 2)
    end

    test "any false" do
      let s = Flow.from_list(Cons(1, Cons(2, Cons(3, Nil))))
      assert not(Flow.any(s, fn x -> x > 10))
    end

    test "all true" do
      let s = Flow.from_list(Cons(2, Cons(4, Cons(6, Nil))))
      assert Flow.all(s, fn x -> x % 2 == 0)
    end

    test "all false" do
      let s = Flow.from_list(Cons(1, Cons(2, Cons(3, Nil))))
      assert not(Flow.all(s, fn x -> x % 2 == 0))
    end

  end

  describe "range" do

    test "range 0 to 5" do
      let s = Flow.range(0, 5)
      let result = Flow.collect(s)
      assert (List.length(result) == 5)
      assert (List.nth(result, 0) == 0)
      assert (List.nth(result, 4) == 4)
    end

    test "range empty when start >= stop" do
      let s = Flow.range(5, 5)
      assert (Flow.count(s) == 0)
    end

    test "range map and filter" do
      let s = Flow.range(1, 11)
      let evens = Flow.filter(s, fn x -> x % 2 == 0)
      let result = Flow.collect(evens)
      assert (List.length(result) == 5)
    end

  end

  describe "run and each" do

    test "run returns unit (count still works after)" do
      let s = Flow.from_list(Cons(1, Cons(2, Cons(3, Nil))))
      assert (Flow.count(s) == 3)
    end

  end

  describe "map then filter" do

    test "map doubles then filter gt 4" do
      let xs = Cons(1, Cons(2, Cons(3, Cons(4, Cons(5, Nil)))))
      let s = Flow.from_list(xs)
      let doubled = Flow.map(s, fn x -> x * 2)
      let filtered = Flow.filter(doubled, fn x -> x > 4)
      let result = Flow.collect(filtered)
      assert (List.length(result) == 3)
      assert (List.nth(result, 0) == 6)
    end

  end

end

end
