-- test/stdlib/test_bastion_hot_deploy.march
-- Tests for the BastionHotDeploy stdlib module.
-- Run with: dune exec march -- test test/stdlib/test_bastion_hot_deploy.march

mod TestBastionHotDeploy do

-- ── Helpers ────────────────────────────────────────────────────────────────

-- Reset the state machine to Serving between test groups so tests are
-- independent.  We simply call mark_serving() before each group.

pfn reset_state() do
  BastionHotDeploy.mark_serving()
  -- Also zero the in-flight counter by over-decrementing (idempotent at 0).
  BastionHotDeploy.decrement_in_flight()
  BastionHotDeploy.decrement_in_flight()
  BastionHotDeploy.decrement_in_flight()
end

-- ── default_config ─────────────────────────────────────────────────────────

describe "BastionHotDeploy default_config" do
  test "timeout_ms is 30000" do
    let cfg = BastionHotDeploy.default_config()
    assert (BastionHotDeploy.config_timeout_ms(cfg) == 30000)
  end

  test "channel_close_timeout_ms is 5000" do
    let cfg = BastionHotDeploy.default_config()
    assert (BastionHotDeploy.config_channel_close_timeout_ms(cfg) == 5000)
  end

  test "drain_status_code is 503" do
    let cfg = BastionHotDeploy.default_config()
    assert (BastionHotDeploy.config_drain_status_code(cfg) == 503)
  end

  test "close_connections is true" do
    let cfg = BastionHotDeploy.default_config()
    assert (BastionHotDeploy.config_close_connections(cfg) == true)
  end
end

-- ── get_status default ─────────────────────────────────────────────────────

describe "BastionHotDeploy get_status" do
  test "returns Serving when no transition has occurred" do
    reset_state()
    let status = BastionHotDeploy.get_status()
    assert (status == BastionHotDeploy.Serving)
  end
end

-- ── start_drain ────────────────────────────────────────────────────────────

describe "BastionHotDeploy start_drain" do
  test "transitions status to Draining" do
    reset_state()
    BastionHotDeploy.start_drain()
    assert (BastionHotDeploy.get_status() == BastionHotDeploy.Draining)
  end

  test "is_draining returns true after start_drain" do
    reset_state()
    BastionHotDeploy.start_drain()
    assert (BastionHotDeploy.is_draining() == true)
  end
end

-- ── mark_serving ───────────────────────────────────────────────────────────

describe "BastionHotDeploy mark_serving" do
  test "transitions status back to Serving after Draining" do
    reset_state()
    BastionHotDeploy.start_drain()
    BastionHotDeploy.mark_serving()
    assert (BastionHotDeploy.get_status() == BastionHotDeploy.Serving)
  end

  test "is_draining returns false after mark_serving" do
    reset_state()
    BastionHotDeploy.start_drain()
    BastionHotDeploy.mark_serving()
    assert (BastionHotDeploy.is_draining() == false)
  end
end

-- ── mark_starting ──────────────────────────────────────────────────────────

describe "BastionHotDeploy mark_starting" do
  test "transitions status to Starting" do
    reset_state()
    BastionHotDeploy.mark_starting()
    assert (BastionHotDeploy.get_status() == BastionHotDeploy.Starting)
  end

  test "is_draining returns false when Starting" do
    reset_state()
    BastionHotDeploy.mark_starting()
    assert (BastionHotDeploy.is_draining() == false)
  end
end

-- ── stop_drain ─────────────────────────────────────────────────────────────

describe "BastionHotDeploy stop_drain" do
  test "transitions status to Stopped" do
    reset_state()
    BastionHotDeploy.start_drain()
    BastionHotDeploy.stop_drain()
    assert (BastionHotDeploy.get_status() == BastionHotDeploy.Stopped)
  end
end

-- ── in_flight counter ─────────────────────────────────────────────────────

describe "BastionHotDeploy in_flight counter" do
  test "in_flight_count starts at 0 after reset" do
    reset_state()
    -- ensure at floor
    BastionHotDeploy.decrement_in_flight()
    assert (BastionHotDeploy.in_flight_count() == 0)
  end

  test "increment_in_flight increases count by 1" do
    reset_state()
    let before = BastionHotDeploy.in_flight_count()
    BastionHotDeploy.increment_in_flight()
    assert (BastionHotDeploy.in_flight_count() == before + 1)
    -- cleanup
    BastionHotDeploy.decrement_in_flight()
  end

  test "decrement_in_flight decreases count by 1" do
    reset_state()
    BastionHotDeploy.increment_in_flight()
    BastionHotDeploy.increment_in_flight()
    let before = BastionHotDeploy.in_flight_count()
    BastionHotDeploy.decrement_in_flight()
    assert (BastionHotDeploy.in_flight_count() == before - 1)
    -- cleanup
    BastionHotDeploy.decrement_in_flight()
  end

  test "decrement_in_flight is floored at 0" do
    reset_state()
    -- Ensure counter is 0, then decrement — must stay at 0.
    BastionHotDeploy.decrement_in_flight()
    BastionHotDeploy.decrement_in_flight()
    assert (BastionHotDeploy.in_flight_count() == 0)
  end

  test "multiple increments and decrements track correctly" do
    reset_state()
    BastionHotDeploy.increment_in_flight()
    BastionHotDeploy.increment_in_flight()
    BastionHotDeploy.increment_in_flight()
    BastionHotDeploy.decrement_in_flight()
    assert (BastionHotDeploy.in_flight_count() == 2)
    -- cleanup
    BastionHotDeploy.decrement_in_flight()
    BastionHotDeploy.decrement_in_flight()
  end
end

-- ── should_drain_request ───────────────────────────────────────────────────

describe "BastionHotDeploy should_drain_request" do
  test "returns false when Serving" do
    reset_state()
    let cfg = BastionHotDeploy.default_config()
    assert (BastionHotDeploy.should_drain_request(cfg) == false)
  end

  test "returns true when Draining" do
    reset_state()
    BastionHotDeploy.start_drain()
    let cfg = BastionHotDeploy.default_config()
    assert (BastionHotDeploy.should_drain_request(cfg) == true)
    reset_state()
  end

  test "returns true when Stopped" do
    reset_state()
    BastionHotDeploy.stop_drain()
    let cfg = BastionHotDeploy.default_config()
    assert (BastionHotDeploy.should_drain_request(cfg) == true)
    reset_state()
  end

  test "returns false when Starting" do
    reset_state()
    BastionHotDeploy.mark_starting()
    let cfg = BastionHotDeploy.default_config()
    assert (BastionHotDeploy.should_drain_request(cfg) == false)
    reset_state()
  end
end

-- ── health_status ──────────────────────────────────────────────────────────

describe "BastionHotDeploy health_status" do
  test "returns (200, ok body) when Serving" do
    reset_state()
    let cfg = BastionHotDeploy.default_config()
    let (code, body) = BastionHotDeploy.health_status(cfg)
    assert (code == 200)
    assert (String.contains(body, "ok"))
  end

  test "returns (503, draining body) when Draining" do
    reset_state()
    BastionHotDeploy.start_drain()
    let cfg = BastionHotDeploy.default_config()
    let (code, body) = BastionHotDeploy.health_status(cfg)
    assert (code == 503)
    assert (String.contains(body, "draining"))
    reset_state()
  end

  test "returns (503, starting body) when Starting" do
    reset_state()
    BastionHotDeploy.mark_starting()
    let cfg = BastionHotDeploy.default_config()
    let (code, body) = BastionHotDeploy.health_status(cfg)
    assert (code == 503)
    assert (String.contains(body, "starting"))
    reset_state()
  end

  test "returns (503, stopped body) when Stopped" do
    reset_state()
    BastionHotDeploy.stop_drain()
    let cfg = BastionHotDeploy.default_config()
    let (code, body) = BastionHotDeploy.health_status(cfg)
    assert (code == 503)
    assert (String.contains(body, "stopped"))
    reset_state()
  end
end

-- ── drain_response ─────────────────────────────────────────────────────────

describe "BastionHotDeploy drain_response" do
  test "returns configured status code" do
    let cfg = BastionHotDeploy.default_config()
    let (code, _) = BastionHotDeploy.drain_response(cfg)
    assert (code == 503)
  end

  test "response body mentions draining" do
    let cfg = BastionHotDeploy.default_config()
    let (_, body) = BastionHotDeploy.drain_response(cfg)
    assert (String.contains(body, "draining"))
  end
end

-- ── is_draining ────────────────────────────────────────────────────────────

describe "BastionHotDeploy is_draining" do
  test "returns false when Serving" do
    reset_state()
    assert (BastionHotDeploy.is_draining() == false)
  end

  test "returns true when Draining" do
    reset_state()
    BastionHotDeploy.start_drain()
    assert (BastionHotDeploy.is_draining() == true)
    reset_state()
  end
end

end -- mod TestBastionHotDeploy
