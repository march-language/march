-- examples/http_hello.march
mod HttpHello do

  fn router(conn) do
    match (HttpServer.method(conn), HttpServer.path_info(conn)) do
    (:get, Nil) -> conn |> HttpServer.text(200, "Hello from compiled March!")
    _ -> conn |> HttpServer.text(404, "Not Found")
    end
  end

  fn main() do
    HttpServer.new(8080)
    |> HttpServer.plug(router)
    |> HttpServer.listen()
  end

end
