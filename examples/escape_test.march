-- Escape analysis smoke test.
-- Run with: march --dump-tir examples/escape_test.march
-- Look for stack_alloc vs alloc in each function.

mod EscapeTest do

type Pair = MkPair(Int, Int)
type Box  = Box(Int)
type Wrap = Wrap(Box)

-- ── Case 1: STACK-PROMOTED ───────────────────────────────────────────────
-- p is allocated locally and only used as a match scrutinee.
-- Expected TIR: stack_alloc MkPair(...)
fn sum_pair(x : Int, y : Int) : Int do
  let p = MkPair(x, y)
  match p with
  | MkPair(a, b) -> a + b
  end
end

-- ── Case 2: NOT PROMOTED — returned to caller ────────────────────────────
-- The allocation is in tail-atom position → escapes.
-- Expected TIR: alloc MkPair(...)
fn make_pair(x : Int, y : Int) : Pair do
  MkPair(x, y)
end

-- ── Case 3: NOT PROMOTED — stored into another heap alloc ────────────────
-- b is stored as an arg to Wrap(b) → escapes.
-- Expected TIR: alloc Box(...),  alloc Wrap(...)
fn nest(x : Int) : Wrap do
  let b = Box(x)
  Wrap(b)
end

-- ── Case 4: STACK-PROMOTED — dead binding ────────────────────────────────
-- Perceus inserts EDecRC(b) for the unused binding; escape sees b only in
-- EDecRC (non-escaping) → promotes to stack_alloc, strips the EDecRC.
-- Expected TIR: stack_alloc Box(...), no dec_rc
fn discard(x : Int) : Int do
  let b = Box(x)
  42
end

fn main() : Unit do
  let s = sum_pair(3, 4)
  println(int_to_string(s))
end

end
