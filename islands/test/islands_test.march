mod IslandsTest do

describe "Islands.hydrate_attr" do
  test "Eager serializes to 'eager'" do
    assert (Islands.hydrate_attr(Eager) == "eager")
  end

  test "Lazy serializes to 'lazy'" do
    assert (Islands.hydrate_attr(Lazy) == "lazy")
  end

  test "OnIdle serializes to 'idle'" do
    assert (Islands.hydrate_attr(OnIdle) == "idle")
  end

  test "OnInteraction serializes to 'interaction'" do
    assert (Islands.hydrate_attr(OnInteraction) == "interaction")
  end
end

describe "Islands.wrap" do
  test "produces data-march-island attribute" do
    let html = Islands.wrap("Counter", Eager, "{\"count\":0}", "<span>0</span>")
    assert (String.contains(html, "data-march-island=\"Counter\""))
  end

  test "produces data-march-hydrate attribute" do
    let html = Islands.wrap("Counter", OnInteraction, "{}", "<div></div>")
    assert (String.contains(html, "data-march-hydrate=\"interaction\""))
  end

  test "includes state JSON in data-march-state attribute" do
    let html = Islands.wrap("Counter", Eager, "{\"count\":42}", "<span>42</span>")
    assert (String.contains(html, "data-march-state="))
    assert (String.contains(html, "42"))
  end

  test "wraps inner HTML inside the div" do
    let html = Islands.wrap("Counter", Eager, "{}", "<button>Click me</button>")
    assert (String.contains(html, "<button>Click me</button>"))
  end

  test "opens and closes the wrapper div" do
    let html = Islands.wrap("Foo", Eager, "{}", "content")
    assert (String.starts_with(html, "<div"))
    assert (String.ends_with(html, "</div>"))
  end

  test "escapes single quotes in state JSON" do
    let html = Islands.wrap("X", Eager, "{'key':'val'}", "")
    assert (String.contains(html, "&#39;"))
  end

  test "lazy hydration attribute is correct" do
    let html = Islands.wrap("Ticker", Lazy, "{}", "")
    assert (String.contains(html, "data-march-hydrate=\"lazy\""))
  end

  test "idle hydration attribute is correct" do
    let html = Islands.wrap("Bg", OnIdle, "{}", "")
    assert (String.contains(html, "data-march-hydrate=\"idle\""))
  end
end

describe "Islands.wrap_eager" do
  test "produces eager hydration" do
    let html = Islands.wrap_eager("Foo", "{}", "<p>hi</p>")
    assert (String.contains(html, "data-march-hydrate=\"eager\""))
  end

  test "passes through inner HTML" do
    let html = Islands.wrap_eager("Foo", "{}", "<p>hello</p>")
    assert (String.contains(html, "<p>hello</p>"))
  end
end

describe "Islands.client_only" do
  test "contains correct island name" do
    let html = Islands.client_only("Spinner", Lazy, "{}")
    assert (String.contains(html, "data-march-island=\"Spinner\""))
  end

  test "contains correct hydration strategy" do
    let html = Islands.client_only("Spinner", Lazy, "{}")
    assert (String.contains(html, "data-march-hydrate=\"lazy\""))
  end

  test "does not include extra HTML content" do
    let html = Islands.client_only("Empty", Eager, "{}")
    assert (String.contains(html, "></div>"))
  end
end

describe "Islands.bootstrap_script" do
  test "generates a script tag" do
    let tag = Islands.bootstrap_script("/_march")
    assert (String.contains(tag, "<script"))
    assert (String.contains(tag, "</script>"))
  end

  test "sets type=module" do
    let tag = Islands.bootstrap_script("/_march")
    assert (String.contains(tag, "type=\"module\""))
  end

  test "src points to march-islands.js under base_url" do
    let tag = Islands.bootstrap_script("/_march")
    assert (String.contains(tag, "src=\"/_march/march-islands.js\""))
  end

  test "uses the provided base_url" do
    let tag = Islands.bootstrap_script("/static/islands")
    assert (String.contains(tag, "/static/islands/march-islands.js"))
  end
end

describe "Islands.preload_hint" do
  test "generates a link element" do
    let hint = Islands.preload_hint("/_march", "Counter")
    assert (String.contains(hint, "<link"))
  end

  test "uses rel=modulepreload" do
    let hint = Islands.preload_hint("/_march", "Counter")
    assert (String.contains(hint, "rel=\"modulepreload\""))
  end

  test "href includes the WASM filename" do
    let hint = Islands.preload_hint("/_march", "Counter")
    assert (String.contains(hint, "href=\"/_march/Counter.wasm\""))
  end
end

describe "Islands.Registry" do
  test "empty_registry has no descriptors" do
    let r = Islands.empty_registry()
    assert (Islands.registry_descriptors(r) == Nil)
  end

  test "register adds a descriptor" do
    let d = Descriptor("Counter", Eager, "")
    let r = Islands.register(Islands.empty_registry(), d)
    assert (List.length(Islands.registry_descriptors(r)) == 1)
  end

  test "can register multiple islands" do
    let r = Islands.empty_registry()
           |> Islands.register(Descriptor("A", Eager, ""))
           |> Islands.register(Descriptor("B", Lazy, ""))
    assert (List.length(Islands.registry_descriptors(r)) == 2)
  end

  test "find_island returns Some for a registered island" do
    let d = Descriptor("Counter", Eager, "")
    let r = Islands.register(Islands.empty_registry(), d)
    let found = Islands.find_island(r, "Counter")
    assert (found != None)
  end

  test "find_island returns None for an unknown name" do
    let r = Islands.empty_registry()
    assert (Islands.find_island(r, "Missing") == None)
  end

  test "descriptor_name returns the island name" do
    let d = Descriptor("Clock", Lazy, "/assets/Clock.wasm")
    assert (Islands.descriptor_name(d) == "Clock")
  end

  test "descriptor_wasm_path returns the wasm path" do
    let d = Descriptor("Clock", Lazy, "/assets/Clock.wasm")
    assert (Islands.descriptor_wasm_path(d) == "/assets/Clock.wasm")
  end

  test "descriptor_hydrate returns the hydration strategy" do
    let d = Descriptor("Clock", OnIdle, "")
    assert (Islands.hydrate_attr(Islands.descriptor_hydrate(d)) == "idle")
  end
end

describe "Islands.registry_preload_hints" do
  test "generates hints for all registered islands" do
    let r = Islands.empty_registry()
           |> Islands.register(Descriptor("Counter", Eager, ""))
           |> Islands.register(Descriptor("Clock", Lazy, ""))
    let hints = Islands.registry_preload_hints(r, "/_march")
    assert (String.contains(hints, "Counter.wasm"))
    assert (String.contains(hints, "Clock.wasm"))
  end

  test "empty registry produces empty string" do
    let r = Islands.empty_registry()
    let hints = Islands.registry_preload_hints(r, "/_march")
    assert (hints == "")
  end
end

end -- mod IslandsTest
