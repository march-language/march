-- Naive recursive Fibonacci benchmark.
-- Benchmarks Game: "fibonacci" problem (naive exponential recursion).
-- Usage: march --compile bench/fib.march -o bench/fib && bench/fib 40

mod Fib do

pfn fib(n : Int) : Int do
  if n < 2 do n
  else fib(n - 1) + fib(n - 2) end
end

pfn main() : Unit do
  println(int_to_string(fib(40)))
end

end
