-- forge notebook serve — live notebook server with WebSocket-based cell execution.
--
-- Serves a browser UI at GET / and a WebSocket endpoint at GET /ws.
-- Protocol (JSON over WebSocket):
--   Client → Server:
--     {"type":"run","cells":[...],"index":N}     run cells 0..N, return output for cell N
--     {"type":"load"}                             send current notebook content
--     {"type":"save","content":"..."}             save notebook file
--     {"type":"start_server","index":N}           spawn server cell N as background process
--     {"type":"stop_server","index":N}            kill server cell N's background process
--     {"type":"read_server","index":N}            poll server cell N's log output
--   Server → Client:
--     {"type":"output","index":N,"stdout":"...","error":null}
--     {"type":"notebook","cells":[...],"source":"..."}
--     {"type":"saved"}
--     {"type":"error","message":"..."}
--     {"type":"server_started","index":N,"pid":"..."}
--     {"type":"server_stopped","index":N}
--     {"type":"server_output","index":N,"content":"...","running":true/false}
--     {"type":"server_error","index":N,"message":"..."}

mod ForgeNotebookServer do

-- ── String helpers ────────────────────────────────────────────────────────────

pfn bs(s) do String.byte_size(s) end
pfn sw(s, p) do String.starts_with(s, p) end
pfn trim(s) do String.trim(s) end
pfn html_escape(s) do
  let s = String.replace_all(s, "&", "&amp;")
  let s = String.replace_all(s, "<", "&lt;")
  let s = String.replace_all(s, ">", "&gt;")
  let s = String.replace_all(s, "\"", "&quot;")
  s
end
pfn json_escape(s) do
  let s = String.replace_all(s, "\\", "\\\\")
  let s = String.replace_all(s, "\"", "\\\"")
  let s = String.replace_all(s, "\n", "\\n")
  let s = String.replace_all(s, "\r", "\\r")
  let s = String.replace_all(s, "\t", "\\t")
  s
end

-- ── Cell types ────────────────────────────────────────────────────────────────

-- Code   = regular code cell (run in sequence, produces output)
-- Server = long-running background process cell (HttpServer, etc.)
type Cell = Markdown(String) | Code(String) | ServerCell(String)

-- parse_cells: parse the .mnb markdown format into a list of cells.
-- Supports three fence kinds:
--   ```march        → Code cell
--   ```march:server → Server cell
--   (plain text)    → Markdown cell
pfn parse_cells(content) do
  let lines = String.split(content, "\n")
  -- mode: "none" | "code" | "server"
  fn go(lines, cells, buf, mode) do
    match lines do
      Nil ->
        let text = String.join(List.reverse(buf), "\n")
        if mode == "code" do
          List.reverse(Cons(Code(text), cells))
        else
          if mode == "server" do
            List.reverse(Cons(ServerCell(text), cells))
          else
            let trimmed = trim(text)
            if String.is_empty(trimmed) do
              List.reverse(cells)
            else
              List.reverse(Cons(Markdown(trimmed), cells))
            end
          end
        end
      Cons(line, rest) ->
        let stripped = trim(line)
        if mode == "code" do
          if stripped == "```" do
            let code = String.join(List.reverse(buf), "\n")
            go(rest, Cons(Code(code), cells), Nil, "none")
          else
            go(rest, cells, Cons(line, buf), "code")
          end
        else
          if mode == "server" do
            if stripped == "```" do
              let code = String.join(List.reverse(buf), "\n")
              go(rest, Cons(ServerCell(code), cells), Nil, "none")
            else
              go(rest, cells, Cons(line, buf), "server")
            end
          else
            if stripped == "```march" do
              let text = trim(String.join(List.reverse(buf), "\n"))
              let new_cells =
                if String.is_empty(text) do cells
                else Cons(Markdown(text), cells)
                end
              go(rest, new_cells, Nil, "code")
            else
              if stripped == "```march:server" do
                let text = trim(String.join(List.reverse(buf), "\n"))
                let new_cells =
                  if String.is_empty(text) do cells
                  else Cons(Markdown(text), cells)
                  end
                go(rest, new_cells, Nil, "server")
              else
                go(rest, cells, Cons(line, buf), "none")
              end
            end
          end
        end
    end
  end
  go(lines, Nil, Nil, "none")
end

-- ── Cell lookup ───────────────────────────────────────────────────────────────

pfn nth_cell(cells, idx) do
  match cells do
    Nil -> None
    Cons(cell, rest) ->
      if idx == 0 do Some(cell)
      else nth_cell(rest, idx - 1)
      end
  end
end

-- ── Runner (sentinel approach) ────────────────────────────────────────────────

pfn cell_start_marker(n) do "__MNB_START_" ++ String.from_int(n) ++ "__" end
pfn cell_end_marker(n)   do "__MNB_END_"   ++ String.from_int(n) ++ "__" end

-- Generate a runner for cells 0..run_through_idx (Code cells only; Server cells skipped).
--
-- Each Code cell becomes a module-level helper function so that:
--   1. Named function declarations inside cells work normally (lexically scoped).
--   2. The cell's return value can be captured and auto-printed.
--
-- Auto-print rule: if the cell's last expression evaluates to a non-unit value
-- (i.e. to_string result != "()"), it is printed automatically — just like a REPL.
--
-- Cells are inlined sequentially into main() so that `let` bindings defined
-- in earlier cells are visible in later ones — exactly like a REPL session.
--
-- Each cell's source is split into "preamble" (let-binding lines) and a
-- "final expression" (the last non-let line).  The preamble lines become
-- top-level lets in main(); the final expression is captured for auto-print.
-- If all lines are let-bindings (no final expression), we emit "()" as the
-- captured value so the auto-print is suppressed.
pfn generate_runner(cells, run_through_idx) do
  -- Strip trailing newline, split into lines.
  fn cell_lines(src) do
    let src = if String.ends_with(src, "\n") do
      String.slice(src, 0, bs(src) - 1)
    else src
    end
    String.split(src, "\n")
  end

  -- Count substring occurrences: count_in("a(b(c", "(") = 2
  fn count_in(s, sub) do List.length(String.split(s, sub)) - 1 end

  -- Number of bracket/block openers in a line (forward direction).
  --   openers = count of `(` and `[` + 1 if line ends with ` do` (opens a block)
  fn line_openers(line) do
    let t = trim(line)
    let b = count_in(line, "(") + count_in(line, "[")
    let d = if String.ends_with(t, " do") || t == "do" do 1 else 0 end
    b + d
  end

  -- Number of bracket/block closers in a line (forward direction).
  --   closers = count of `)` and `]` + 1 if trimmed line is exactly "end"
  fn line_closers(line) do
    let t = trim(line)
    let b = count_in(line, ")") + count_in(line, "]")
    let e = if t == "end" do 1 else 0 end
    b + e
  end

  -- Split lines into (preamble_lines, last_stmt_lines).
  -- last_stmt_lines is the COMPLETE last top-level statement, even if multi-line
  -- (e.g. DataFrame.from_columns([...]), if/match/do blocks).
  -- Works by scanning backward with bracket+block depth tracking:
  --   depth = "how many more openers do we still need to find?"
  --   opener seen going backward → depth decreases
  --   closer seen going backward → depth increases
  --   stop when depth reaches 0 (we found the start of the statement)
  fn split_last(lines) do
    -- Drop trailing blank lines from a reversed list.
    fn drop_blank(ls) do
      match ls do
        Nil -> Nil
        Cons(l, rest) ->
          if String.is_empty(trim(l)) do drop_blank(rest)
          else ls
          end
      end
    end

    -- Scan rev_lines backward, collecting into stmt_rev until depth balances.
    -- Because we prepend each line while scanning backward, stmt_rev accumulates
    -- in FORWARD source order (head = earliest line). Do NOT reverse on return.
    fn find_start(rev_lines, depth, stmt_rev) do
      match rev_lines do
        Nil -> (Nil, stmt_rev)
        Cons(line, rest) ->
          let new_depth = depth - line_openers(line) + line_closers(line)
          if new_depth <= 0 do
            -- Found the opener. Cons it onto stmt_rev; it is now at the head,
            -- which is correct since it's the earliest (first) line.
            (List.reverse(rest), Cons(line, stmt_rev))
          else
            find_start(rest, new_depth, Cons(line, stmt_rev))
          end
      end
    end

    let rev = drop_blank(List.reverse(lines))
    match rev do
      Nil -> (lines, Nil)
      Cons(last_line, rev_rest) ->
        let opens  = line_openers(last_line)
        let closes = line_closers(last_line)
        -- A continuation line has closers and no openers of its own
        -- (e.g. `])`, `))`, standalone `end`)
        let is_cont = opens == 0 && closes > 0
        if is_cont do
          -- Multi-line statement: scan backward until we find the opener(s).
          find_start(rev_rest, closes, Cons(last_line, Nil))
        else
          -- Single-line statement (the common case).
          (List.reverse(rev_rest), Cons(last_line, Nil))
        end
    end
  end

  -- If the first line of a statement is "let NAME = EXPR" (simple ident,
  -- optional type annotation), return Some(NAME) so we can use NAME as the
  -- auto-print result.
  -- Returns None for patterns (let (a,b) = ...) or if not a let line.
  fn let_bound_name(line) do
    let t = trim(line)
    if String.starts_with(t, "let ") do
      -- After "let ": extract identifier before optional ":" or "="
      let after = trim(String.slice(t, 4, bs(t) - 4))
      -- Strip type annotation: take part before first ":"
      let ident_raw = match String.split_first(after, ":") do
        None -> match String.split_first(after, "=") do
          None -> after
          Some((b, _)) -> trim(b)
        end
        Some((b, _)) -> trim(b)
      end
      let ident = trim(ident_raw)
      -- Reject patterns: must not contain ( ) ,  or spaces
      let has_paren = match String.split_first(ident, "(") do Some(_) -> true | None -> false end
      let has_comma = match String.split_first(ident, ",") do Some(_) -> true | None -> false end
      let has_space = match String.split_first(ident, " ") do Some(_) -> true | None -> false end
      if String.is_empty(ident) || has_paren || has_comma || has_space do None
      else Some(ident)
      end
    else
      None
    end
  end

  -- Emit one cell inline into main() so bindings accumulate across cells.
  --
  -- split_last returns (preamble_lines, last_stmt_lines) where last_stmt_lines
  -- is the complete last top-level statement (one or many lines).
  -- We look at the FIRST line of last_stmt to classify it:
  --
  --   plain expression  →  let __rN__ = <whole stmt>
  --   let NAME = EXPR   →  emit stmt verbatim; let __rN__ = NAME   (auto-print)
  --   let PAT = EXPR    →  emit stmt verbatim; let __rN__ = ()     (suppressed)
  fn make_cell_inline(src, n) do
    let ns   = String.from_int(n)
    let rvar = "__r" ++ ns ++ "__"
    let svar = "__s" ++ ns ++ "__"
    let lines = cell_lines(src)
    match split_last(lines) do
      (preamble, last_stmt) ->
        let pre_str = if List.is_empty(preamble) do ""
          else String.join(List.map(preamble, fn l -> "  " ++ l), "\n") ++ "\n"
          end
        -- First line of the last statement drives classification.
        let first_line = match last_stmt do Cons(l, _) -> l | Nil -> "" end
        -- Emit the full statement (all lines), indented.
        let stmt_str = String.join(List.map(last_stmt, fn l -> "  " ++ l), "\n") ++ "\n"
        -- Determine how to capture the result.
        let (binding_str, result_expr) =
          if List.is_empty(last_stmt) do
            ("", "()")
          else
            match let_bound_name(first_line) do
              Some(name) ->
                -- "let name = <multi-line expr>" — emit whole stmt, capture name
                (stmt_str, name)
              None ->
                if String.starts_with(trim(first_line), "let ") do
                  -- Pattern binding (let (a,b) = ...) — emit, suppress result
                  (stmt_str, "()")
                else
                  -- Plain expression — possibly multi-line; join as single expr
                  ("", String.join(last_stmt, "\n"))
                end
            end
          end
        "  println(\"" ++ cell_start_marker(n) ++ "\")\n" ++
        pre_str ++
        binding_str ++
        "  let " ++ rvar ++ " = " ++ result_expr ++ "\n" ++
        "  let " ++ svar ++ " = to_string(" ++ rvar ++ ")\n" ++
        "  if " ++ svar ++ " != \"()\" do println(" ++ svar ++ ") else () end\n" ++
        "  println(\"" ++ cell_end_marker(n) ++ "\")\n"
    end
  end

  -- True if the first non-blank line of src starts with `mod ` (a module cell).
  -- Module cells are embedded as nested mods inside NotebookRunner so their
  -- functions are accessible via Qualified.name syntax from later cells.
  fn is_mod_cell(src) do
    fn first_nonblank(ls) do
      match ls do
        Nil -> ""
        Cons(l, rest) ->
          if String.is_empty(trim(l)) do first_nonblank(rest)
          else trim(l)
          end
      end
    end
    String.starts_with(first_nonblank(cell_lines(src)), "mod ")
  end

  -- For a module cell: returns (nested_mod_code, main_marker_code).
  -- The mod block is embedded inside NotebookRunner (nested mods are valid
  -- March — mod_decl is part of decl_list_r which is used recursively).
  -- Only the empty START/END markers go in main() so extract_cell_output works.
  fn make_mod_cell(src, n) do
    let ns   = String.from_int(n)
    let rvar = "__r" ++ ns ++ "__"
    let svar = "__s" ++ ns ++ "__"
    let mod_code  = String.join(cell_lines(src), "\n") ++ "\n\n"
    let main_code =
      "  println(\"" ++ cell_start_marker(n) ++ "\")\n" ++
      "  let " ++ rvar ++ " = ()\n" ++
      "  let " ++ svar ++ " = to_string(" ++ rvar ++ ")\n" ++
      "  println(\"" ++ cell_end_marker(n) ++ "\")\n"
    let pair = (mod_code, main_code)
    pair
  end

  -- go returns (nested_mod_chunks, main_body_chunks), both in reverse.
  fn go(cells, mod_rev, body_rev, code_n, total_n) do
    if total_n > run_through_idx do
      (List.reverse(mod_rev), List.reverse(body_rev))
    else
      match cells do
        Nil -> (List.reverse(mod_rev), List.reverse(body_rev))
        Cons(Markdown(_), rest)   -> go(rest, mod_rev, body_rev, code_n, total_n + 1)
        Cons(ServerCell(_), rest) -> go(rest, mod_rev, body_rev, code_n, total_n + 1)
        Cons(Code(src), rest) ->
          if is_mod_cell(src) do
            let (mod_code, main_code) = make_mod_cell(src, code_n)
            go(rest,
              Cons(mod_code, mod_rev),
              Cons(main_code, body_rev),
              code_n + 1,
              total_n + 1)
          else
            go(rest,
              mod_rev,
              Cons(make_cell_inline(src, code_n), body_rev),
              code_n + 1,
              total_n + 1)
          end
      end
    end
  end

  let (mod_chunks, body_chunks) = go(cells, Nil, Nil, 0, 0)
  let mod_str  = String.join(mod_chunks, "")
  let body     = String.join(body_chunks, "")
  let body     = if String.is_empty(body) do "  ()\n" else body end
  "mod NotebookRunner do\n\n" ++ mod_str ++ "fn main() do\n" ++ body ++ "end\n\nend\n"
end

-- Generate a standalone runner for a server cell (wraps source in mod+main)
pfn generate_server_runner(src) do
  let src = if String.ends_with(src, "\n") do
    String.slice(src, 0, bs(src) - 1)
  else src
  end
  let indented = String.join(
    List.map(String.split(src, "\n"), fn l -> "  " ++ l),
    "\n"
  ) ++ "\n"
  "mod ServerCell do\nfn main() do\n" ++ indented ++ "end\nend\n"
end

pfn extract_cell_output(stdout, code_n) do
  let start_marker = cell_start_marker(code_n)
  let end_marker   = cell_end_marker(code_n)
  match String.split_first(stdout, start_marker) do
    None -> ""
    Some((_, after_start)) ->
      let after_start =
        if sw(after_start, "\n") do
          String.slice(after_start, 1, bs(after_start) - 1)
        else after_start
        end
      match String.split_first(after_start, end_marker) do
        None -> trim(after_start)
        Some((between, _)) ->
          let s = between
          if String.ends_with(s, "\n") do
            String.slice(s, 0, bs(s) - 1)
          else s
          end
      end
  end
end

-- Run cells 0..run_through_idx, return (stdout_for_target_code_cell, error_opt)
pfn run_cells_to(cells, run_through_idx, march_bin) do
  -- Count which code cell index corresponds to run_through_idx.
  -- Server cells are skipped (they don't count as code cells).
  fn find_code_idx(cells, target_total, code_n, total_n) do
    match cells do
      Nil -> code_n - 1
      Cons(Markdown(_), rest) ->
        if total_n == target_total do code_n - 1
        else find_code_idx(rest, target_total, code_n, total_n + 1)
        end
      Cons(ServerCell(_), rest) ->
        if total_n == target_total do code_n - 1
        else find_code_idx(rest, target_total, code_n, total_n + 1)
        end
      Cons(Code(_), rest) ->
        if total_n == target_total do code_n
        else find_code_idx(rest, target_total, code_n + 1, total_n + 1)
        end
    end
  end
  let target_code_idx = find_code_idx(cells, run_through_idx, 0, 0)
  let src = generate_runner(cells, run_through_idx)
  let tmp = "/tmp/__forge_nb_server_runner__.march"
  match File.write(tmp, src) do
    Err(msg) -> ("", Some("failed to write temp: " ++ msg))
    Ok(_) ->
      match Process.run(march_bin, [tmp]) do
        Err(msg) -> ("", Some("march invocation failed: " ++ msg))
        Ok(result) ->
          let code = Process.exit_code(result)
          let out  = Process.stdout(result)
          let err  = Process.stderr(result)
          if code != 0 do
            let msg = if String.is_empty(trim(err)) do
              "march exited with code " ++ String.from_int(code)
            else trim(err)
            end
            ("", Some(msg))
          else
            (extract_cell_output(out, target_code_idx), None)
          end
      end
  end
end

-- ── Server cell process management ───────────────────────────────────────────

pfn server_tmp_path(idx) do "/tmp/__forge_nb_srv_" ++ String.from_int(idx) ++ "__.march" end
pfn server_log_path(idx) do "/tmp/__forge_nb_srv_" ++ String.from_int(idx) ++ "__.log" end
pfn server_ns()          do "__forge_nb_servers__" end

-- Spawn a server cell as a background OS process (via shell `&`).
-- Stores the PID string in the Vault namespace. Returns Ok(pid) or Err(msg).
pfn start_server_proc(src, idx, march_bin) do
  let tmp = server_tmp_path(idx)
  let log = server_log_path(idx)
  let runner = generate_server_runner(src)
  match File.write(tmp, runner) do
    Err(msg) -> Err("failed to write server temp: " ++ msg)
    Ok(_) ->
      -- Clear old log
      let _ = File.write(log, "")
      -- Start background: sh -c "march /tmp/... > /tmp/...log 2>&1 & echo $!"
      let shell_cmd = march_bin ++ " " ++ tmp ++ " > " ++ log ++ " 2>&1 & echo $!"
      match Process.run("sh", ["-c", shell_cmd]) do
        Err(msg) -> Err("spawn failed: " ++ msg)
        Ok(result) ->
          if Process.exit_code(result) != 0 do
            Err("sh failed: " ++ trim(Process.stderr(result)))
          else
            let pid = trim(Process.stdout(result))
            let _ = Vault.ns_set(server_ns(), String.from_int(idx), pid)
            Ok(pid)
          end
      end
  end
end

-- Kill a running server cell background process by index.
pfn stop_server_proc(idx) do
  match Vault.ns_get(server_ns(), String.from_int(idx)) do
    None -> ()
    Some(pid) ->
      let _ = Process.run("sh", ["-c", "kill -TERM " ++ pid ++ " 2>/dev/null || true"])
      let _ = Vault.ns_drop(server_ns(), String.from_int(idx))
      ()
  end
end

-- Read the current contents of the server log file.
pfn read_server_log(idx) do
  match File.read(server_log_path(idx)) do
    Ok(content) -> content
    Err(_) -> ""
  end
end

-- Check if the server process for index idx is still alive (uses kill -0).
pfn server_is_running(idx) do
  match Vault.ns_get(server_ns(), String.from_int(idx)) do
    None -> false
    Some(pid) ->
      match Process.run("sh", ["-c", "kill -0 " ++ pid ++ " 2>/dev/null && echo alive || echo dead"]) do
        Err(_) -> false
        Ok(result) -> trim(Process.stdout(result)) == "alive"
      end
  end
end

-- ── JSON helpers ──────────────────────────────────────────────────────────────

pfn json_str(s) do "\"" ++ json_escape(s) ++ "\"" end

pfn json_opt_str(opt) do
  match opt do
    None    -> "null"
    Some(s) -> json_str(s)
  end
end

pfn output_msg(idx, stdout_text, error_opt) do
  "{\"type\":\"output\",\"index\":" ++ String.from_int(idx) ++
  ",\"stdout\":" ++ json_str(stdout_text) ++
  ",\"error\":" ++ json_opt_str(error_opt) ++ "}"
end

pfn cells_to_json(cells) do
  fn cell_obj(cell) do
    match cell do
      Markdown(s) -> "{\"kind\":\"markdown\",\"source\":" ++ json_str(s) ++ "}"
      Code(s)     -> "{\"kind\":\"code\",\"source\":" ++ json_str(s) ++ "}"
      ServerCell(s)   -> "{\"kind\":\"server\",\"source\":" ++ json_str(s) ++ "}"
    end
  end
  "[" ++ String.join(List.map(cells, cell_obj), ",") ++ "]"
end

pfn notebook_msg(content, cells) do
  "{\"type\":\"notebook\",\"source\":" ++ json_str(content) ++
  ",\"cells\":" ++ cells_to_json(cells) ++ "}"
end

-- ── JSON parsing helpers ──────────────────────────────────────────────────────

pfn json_get_str(jv, key) do
  match Json.get(jv, key) do
    None -> None
    Some(v) ->
      let s = Json.to_string(v)
      if bs(s) >= 2 && String.slice(s, 0, 1) == "\"" do
        let inner = String.slice(s, 1, bs(s) - 2)
        let inner = String.replace_all(inner, "\\n", "\n")
        let inner = String.replace_all(inner, "\\t", "\t")
        let inner = String.replace_all(inner, "\\r", "\r")
        let inner = String.replace_all(inner, "\\\"", "\"")
        let inner = String.replace_all(inner, "\\\\", "\\")
        Some(inner)
      else None
      end
  end
end

pfn json_get_int(jv, key) do
  match Json.get(jv, key) do
    None -> None
    Some(v) ->
      let s = Json.to_string(v)
      match String.to_int(s) do
        Ok(n)  -> Some(n)
        Err(_) ->
          match String.split_first(s, ".") do
            Some((int_part, _)) -> match String.to_int(int_part) do
              Ok(n)  -> Some(n)
              Err(_) -> None
            end
            None -> None
          end
      end
  end
end



-- ── WebSocket message handler ─────────────────────────────────────────────────

pfn err_frame(msg) do
  TextFrame("{\"type\":\"error\",\"message\":" ++ json_str(msg) ++ "}")
end

pfn handle_ws_msg(msg, nb_path, march_bin, socket) do
  match Json.parse(msg) do
    Err(_) ->
      WebSocket.send_frame(socket, err_frame("invalid JSON"))
    Ok(jv) ->
      match json_get_str(jv, "type") do
        None ->
          WebSocket.send_frame(socket, err_frame("missing type field"))

        Some("load") ->
          match File.read(nb_path) do
            Err(e) ->
              WebSocket.send_frame(socket, err_frame(to_string(e)))
            Ok(content) ->
              let cells = parse_cells(content)
              WebSocket.send_frame(socket, TextFrame(
                notebook_msg(content, cells)
              ))
          end

        Some("save") ->
          match json_get_str(jv, "content") do
            None ->
              WebSocket.send_frame(socket, err_frame("missing content"))
            Some(content) ->
              match File.write(nb_path, content) do
                Err(e) ->
                  WebSocket.send_frame(socket, err_frame(to_string(e)))
                Ok(_) ->
                  WebSocket.send_frame(socket, TextFrame("{\"type\":\"saved\"}"))
              end
          end

        Some("run") ->
          let idx_opt = json_get_int(jv, "index")
          match idx_opt do
            None ->
              WebSocket.send_frame(socket, err_frame("missing index"))
            Some(idx) ->
              match File.read(nb_path) do
                Err(e) ->
                  WebSocket.send_frame(socket, err_frame(to_string(e)))
                Ok(content) ->
                  let cells = parse_cells(content)
                  WebSocket.send_frame(socket, TextFrame(
                    "{\"type\":\"running\",\"index\":" ++ String.from_int(idx) ++ "}"
                  ))
                  let (out, err_opt) = run_cells_to(cells, idx, march_bin)
                  WebSocket.send_frame(socket, TextFrame(
                    output_msg(idx, out, err_opt)
                  ))
              end
          end

        Some("start_server") ->
          match json_get_int(jv, "index") do
            None ->
              WebSocket.send_frame(socket, err_frame("missing index"))
            Some(idx) ->
              match File.read(nb_path) do
                Err(e) ->
                  WebSocket.send_frame(socket, err_frame(to_string(e)))
                Ok(content) ->
                  let cells = parse_cells(content)
                  match nth_cell(cells, idx) do
                    None ->
                      WebSocket.send_frame(socket, err_frame("cell not found"))
                    Some(ServerCell(src)) ->
                      match start_server_proc(src, idx, march_bin) do
                        Err(msg) ->
                          WebSocket.send_frame(socket, TextFrame(
                            "{\"type\":\"server_error\",\"index\":" ++ String.from_int(idx) ++
                            ",\"message\":" ++ json_str(msg) ++ "}"
                          ))
                        Ok(pid) ->
                          WebSocket.send_frame(socket, TextFrame(
                            "{\"type\":\"server_started\",\"index\":" ++ String.from_int(idx) ++
                            ",\"pid\":" ++ json_str(pid) ++ "}"
                          ))
                      end
                    Some(_) ->
                      WebSocket.send_frame(socket, err_frame("cell is not a server cell"))
                  end
              end
          end

        Some("stop_server") ->
          match json_get_int(jv, "index") do
            None ->
              WebSocket.send_frame(socket, err_frame("missing index"))
            Some(idx) ->
              stop_server_proc(idx)
              let _ = File.write(server_log_path(idx), "")
              WebSocket.send_frame(socket, TextFrame(
                "{\"type\":\"server_stopped\",\"index\":" ++ String.from_int(idx) ++ "}"
              ))
          end

        Some("read_server") ->
          match json_get_int(jv, "index") do
            None ->
              WebSocket.send_frame(socket, err_frame("missing index"))
            Some(idx) ->
              let content = read_server_log(idx)
              let running = server_is_running(idx)
              -- If process died, clean up vault entry
              let _ = if running do ()
                else Vault.ns_drop(server_ns(), String.from_int(idx))
                end
              WebSocket.send_frame(socket, TextFrame(
                "{\"type\":\"server_output\",\"index\":" ++ String.from_int(idx) ++
                ",\"content\":" ++ json_str(content) ++
                ",\"running\":" ++ (if running do "true" else "false" end) ++ "}"
              ))
          end

        Some(other) ->
          WebSocket.send_frame(socket, err_frame("unknown type: " ++ json_escape(other)))
      end
  end
end

pfn ws_loop(socket, nb_path, march_bin) do
  match WebSocket.recv(socket) do
    TextFrame(msg) ->
      handle_ws_msg(msg, nb_path, march_bin, socket)
      ws_loop(socket, nb_path, march_bin)
    Ping ->
      WebSocket.send_frame(socket, Pong)
      ws_loop(socket, nb_path, march_bin)
    Pong ->
      ws_loop(socket, nb_path, march_bin)
    Close(code, reason) ->
      WebSocket.close(socket, code, reason)
    _ ->
      ws_loop(socket, nb_path, march_bin)
  end
end

-- ── UI HTML ───────────────────────────────────────────────────────────────────

pfn ui_html(nb_path, port) do
  """<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>March Notebook — """ ++ html_escape(nb_path) ++ """</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;background:#18181b;color:#e4e4e7;height:100vh;display:flex;flex-direction:column}
#toolbar{background:#27272a;border-bottom:1px solid #3f3f46;padding:8px 24px;display:flex;align-items:center;gap:10px;flex-shrink:0}
#toolbar h1{font-size:13px;font-weight:500;color:#d4d4d8;margin-right:auto;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;letter-spacing:.01em}
.btn{padding:5px 13px;border-radius:6px;border:none;cursor:pointer;font-size:12px;font-weight:500;transition:background .12s,opacity .12s}
.btn-primary{background:#7c3aed;color:#fff}
.btn-primary:hover{background:#6d28d9}
.btn-secondary{background:transparent;color:#a1a1aa;border:1px solid #3f3f46}
.btn-secondary:hover{background:#3f3f46;color:#e4e4e7}
.btn-server{background:transparent;color:#4ade80;border:1px solid #166534}
.btn-server:hover{background:#14532d}
.btn:disabled{opacity:.35;cursor:default}
#status{font-size:11px;color:#71717a;padding:3px 10px;border:1px solid #3f3f46;border-radius:4px;min-width:80px;text-align:center;font-family:'JetBrains Mono',monospace}
#status.ok{color:#34d399;border-color:#065f46}
#status.err{color:#f87171;border-color:#7f1d1d}
#status.running{color:#fbbf24;border-color:#78350f}
#notebook{flex:1;overflow-y:auto;padding:40px 0 80px;display:flex;flex-direction:column;align-items:center;gap:0}
.cell{width:100%;max-width:880px;margin:0 auto}

/* ── Markdown cells ─────────────────────────────── */
.cell-md-wrap{border-left:3px solid #3f3f46;margin:2px 0;transition:border-color .15s}
.cell-md-wrap:hover,.cell-md-wrap:focus-within{border-left-color:#7c3aed}
.cell-md-header{display:flex;align-items:center;padding:2px 6px 2px 12px;gap:4px;opacity:0;transition:opacity .15s}
.cell-md-wrap:hover .cell-md-header,.cell-md-wrap:focus-within .cell-md-header{opacity:1}
.cell-md-label{font-size:10px;font-family:'JetBrains Mono',monospace;color:#52525b;flex:1;text-transform:uppercase;letter-spacing:.06em}
.cell-md-actions{display:flex;gap:3px}
.cell-md{padding:6px 16px 10px}
.cell-md h1{font-size:28px;margin:18px 0 10px;font-weight:700;color:#f4f4f5;line-height:1.25}
.cell-md h2{font-size:21px;margin:16px 0 7px;font-weight:600;color:#e4e4e7}
.cell-md h3{font-size:16px;margin:12px 0 5px;font-weight:600;color:#c4b5fd}
.cell-md p{margin:7px 0;color:#a1a1aa;line-height:1.7}
.cell-md ul,.cell-md ol{margin:7px 0 7px 24px;color:#a1a1aa}
.cell-md li{margin:3px 0;line-height:1.65}
.cell-md code{font-family:'JetBrains Mono','Fira Code',monospace;font-size:12px;background:#27272a;padding:2px 6px;border-radius:4px;color:#c4b5fd}
.cell-md hr{border:none;border-top:1px solid #3f3f46;margin:16px 0}
.cell-md em{font-style:italic;color:#a1a1aa}
.cell-md strong{font-weight:600;color:#e4e4e7}
.cell-md-editor{border-top:1px solid #3f3f46;margin-top:4px}
.cell-md-editor textarea{display:block;width:100%;background:transparent;color:#d4d4d8;border:none;resize:none;outline:none;padding:10px 16px;font-family:inherit;font-size:13px;line-height:1.7;overflow:hidden}

/* ── Code cells ─────────────────────────────────── */
.cell-code{background:#1c1c1f;border:1px solid #3f3f46;border-left:3px solid #7c3aed;border-radius:8px;overflow:hidden;transition:border-color .15s;margin:6px 0}
.cell-code:focus-within{border-color:#7c3aed;box-shadow:0 0 0 2px #7c3aed18}
.cell-code.running{border-left-color:#fbbf24;border-color:#78350f}
.cell-code.has-error{border-left-color:#ef4444;border-color:#7f1d1d}

/* ── Server cells ────────────────────────────────── */
.cell-server-wrap{background:#111714;border:1px solid #166534;border-left:3px solid #22c55e;border-radius:8px;overflow:hidden;transition:border-color .15s;margin:6px 0}
.cell-server-wrap:focus-within{border-color:#16a34a;box-shadow:0 0 0 2px #22c55e18}
.cell-server-wrap.server-running{border-left-color:#4ade80}
.cell-server-wrap.has-error{border-left-color:#ef4444;border-color:#7f1d1d}

/* ── Cell header ─────────────────────────────────── */
.cell-header{display:flex;align-items:center;gap:8px;padding:4px 10px 4px 12px;background:#1f1f22;border-bottom:1px solid #2e2e33}
.cell-server-wrap .cell-header{background:#0d1f12;border-bottom-color:#1a4d2a}
.cell-label{font-size:10px;font-family:'JetBrains Mono',monospace;color:#52525b;flex:1;text-transform:uppercase;letter-spacing:.06em}
.cell-label.running{color:#fbbf24}
.cell-label.server-label{color:#22c55e}
.cell-label.server-label.running{color:#4ade80}

/* ── Action buttons ──────────────────────────────── */
.run-btn{padding:2px 10px;font-size:11px;border-radius:4px;border:none;background:#7c3aed;color:#fff;cursor:pointer;font-weight:500}
.run-btn:hover{background:#6d28d9}
.run-btn:disabled{opacity:.35;cursor:default}
.start-btn{padding:2px 10px;font-size:11px;border-radius:4px;border:none;background:#16a34a;color:#fff;cursor:pointer;font-weight:500}
.start-btn:hover{background:#15803d}
.stop-btn{padding:2px 10px;font-size:11px;border-radius:4px;border:none;background:#dc2626;color:#fff;cursor:pointer;font-weight:500}
.stop-btn:hover{background:#b91c1c}
.add-btns{display:flex;gap:4px}
.add-btn{padding:2px 8px;font-size:11px;border-radius:4px;border:1px solid #3f3f46;background:transparent;color:#71717a;cursor:pointer;transition:color .1s,border-color .1s}
.add-btn:hover{border-color:#7c3aed;color:#a78bfa}

/* ── Source textarea ─────────────────────────────── */
textarea.cell-src{display:block;width:100%;background:#1c1c1f;color:#e4e4e7;font-family:'JetBrains Mono','Fira Code',monospace;font-size:13.5px;line-height:1.65;padding:14px 18px;border:none;resize:none;outline:none;tab-size:2;overflow:hidden}
.cell-server-wrap textarea.cell-src{background:#111714;color:#bbf7d0}

/* ── Output areas ────────────────────────────────── */
.cell-out{border-top:1px solid #2e2e33;padding:10px 18px;font-family:'JetBrains Mono',monospace;font-size:13px;white-space:pre-wrap;word-break:break-word;color:#a1a1aa;background:#141417}
.cell-out-html{border-top:1px solid #2e2e33;padding:10px 18px;background:#141417;overflow-x:auto}
.cell-out-html table{border-collapse:collapse;font-size:13px;color:#d4d4d8;width:100%;font-family:-apple-system,sans-serif}
.cell-out-html th{background:#27272a;padding:6px 14px;text-align:left;border-bottom:1px solid #3f3f46;color:#a78bfa;font-weight:600;font-size:12px;letter-spacing:.04em;text-transform:uppercase}
.cell-out-html td{padding:6px 14px;border-bottom:1px solid #27272a;color:#a1a1aa;font-size:13px}
.cell-out-html tr:hover td{background:#1f1f22}
.cell-out-html svg{max-width:100%;height:auto}
.cell-server-out{border-top:1px solid #1a4d2a;padding:10px 18px;font-family:'JetBrains Mono',monospace;font-size:13px;white-space:pre-wrap;word-break:break-word;color:#86efac;background:#0a150d;max-height:300px;overflow-y:auto}
.cell-err{border-top:1px solid #7f1d1d;padding:10px 18px;font-family:'JetBrains Mono',monospace;font-size:13px;color:#fca5a5;white-space:pre-wrap;background:#140a0a}
.pid-badge{font-size:10px;color:#4ade80;font-family:'JetBrains Mono',monospace;padding:1px 6px;border:1px solid #166534;border-radius:3px;margin-left:4px}

/* ── Insert-cell bar ─────────────────────────────── */
.add-cell-bar{display:flex;justify-content:center;gap:8px;padding:5px 0;opacity:0;transition:opacity .15s}
.cell-wrap:hover .add-cell-bar,.add-cell-bar:focus-within{opacity:1}
.add-cell-bar button{padding:2px 12px;font-size:11px;border-radius:10px;border:1px solid #3f3f46;background:transparent;color:#71717a;cursor:pointer;transition:color .1s,border-color .1s}
.add-cell-bar button:hover{border-color:#7c3aed;color:#a78bfa}
#drop-hint{text-align:center;color:#52525b;padding:60px;font-size:14px}

/* ── Phase 1: stale dimming, collapse, copy, badges ─ */
[data-dirty] .cell-out,[data-dirty] .cell-out-html{opacity:0.4;transition:opacity .2s}
.stale-badge{font-size:10px;color:#a16207;background:#451a03;border:1px solid #78350f;border-radius:3px;padding:1px 5px;margin-left:4px;font-family:'JetBrains Mono',monospace}
.slow-badge{font-size:10px;color:#6366f1;background:#1e1b4b;border:1px solid #3730a3;border-radius:3px;padding:1px 5px;margin-left:4px;font-family:'JetBrains Mono',monospace;cursor:default}
.cell-out-wrap{position:relative}
.copy-btn{position:absolute;top:6px;right:8px;padding:2px 8px;font-size:11px;border-radius:4px;border:1px solid #3f3f46;background:#27272a;color:#a1a1aa;cursor:pointer;opacity:0;transition:opacity .15s}
.cell-out-wrap:hover .copy-btn{opacity:1}
.src-collapsed textarea{display:none!important}
.src-collapsed .src-preview{display:block}
.src-preview{font-family:'JetBrains Mono',monospace;font-size:13px;color:#71717a;padding:8px 18px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;cursor:pointer}
.src-preview:hover{color:#a78bfa}
.out-collapsed .cell-out,.out-collapsed .cell-out-html,.out-collapsed .cell-err,.out-collapsed .cell-server-out{display:none!important}
</style>
</head>
<body>
<div id="toolbar">
  <h1 id="nb-title">""" ++ html_escape(nb_path) ++ """</h1>
  <button class="btn btn-secondary" id="btn-add-md">+ Markdown</button>
  <button class="btn btn-secondary" id="btn-add-code">+ Code</button>
  <button class="btn btn-server" id="btn-add-server">+ Server</button>
  <button class="btn btn-primary" id="btn-run-all">▶ Run All</button>
  <button class="btn btn-secondary" id="btn-clear-all">Clear All</button>
  <button class="btn btn-secondary" id="btn-save">Save</button>
  <div id="status">connecting</div>
</div>
<div id="notebook"></div>

<script>
const NB_PATH = """ ++ json_str(nb_path) ++ """;
const WS_URL  = "ws://localhost:""" ++ String.from_int(port) ++ """/ws";

let cells = [];   // [{kind, source, output, error, running, server_log, pid}]
let ws = null;
let pendingRun = null;
const serverPolls = {};

// ── WebSocket ────────────────────────────────────────────────────────────────

function connect() {
  setStatus("connecting", "");
  ws = new WebSocket(WS_URL);
  ws.onopen = () => {
    setStatus("ok", "connected");
    ws.send(JSON.stringify({type:"load"}));
  };
  ws.onclose = () => {
    setStatus("err", "disconnected");
    setTimeout(connect, 2000);
  };
  ws.onerror = () => {};
  ws.onmessage = (e) => handleMsg(JSON.parse(e.data));
}

function send(obj) { if (ws && ws.readyState===1) ws.send(JSON.stringify(obj)); }

// Re-size all textareas once custom fonts finish loading
if (document.fonts && document.fonts.ready) {
  document.fonts.ready.then(resizeAllTextareas);
}

// ── Message handling ─────────────────────────────────────────────────────────

function handleMsg(msg) {
  if (msg.type === "notebook") {
    cells = msg.cells.map(c => ({...c, output:"", error:null, running:false, server_log:"", pid:null, _elapsed_ms:null}));
    render();
    setStatus("ok", "loaded");
  } else if (msg.type === "running") {
    const idx = msg.index;
    if (cells[idx]) { cells[idx].running = true; cells[idx]._start_ms = Date.now(); updateCell(idx); }
    setStatus("running", "running…");
  } else if (msg.type === "output") {
    const idx = msg.index;
    if (cells[idx]) {
      cells[idx].running = false;
      cells[idx].output  = msg.stdout || "";
      cells[idx].error   = msg.error || null;
      cells[idx]._elapsed_ms = cells[idx]._start_ms ? Date.now() - cells[idx]._start_ms : null;
      if (!msg.error) cells[idx]._dirty = false;
      updateCell(idx);
    }
    if (pendingRun !== null) {
      const next = nextCodeCell(pendingRun + 1);
      if (next !== -1) {
        pendingRun = next;
        runCell(next);
      } else {
        pendingRun = null;
        setStatus("ok", "done");
      }
    } else {
      setStatus("ok", "done");
    }
  } else if (msg.type === "saved") {
    setStatus("ok", "saved");
    setTimeout(() => setStatus("ok", "connected"), 1500);
  } else if (msg.type === "server_started") {
    const idx = msg.index;
    if (cells[idx]) {
      cells[idx].running = true;
      cells[idx].pid = msg.pid;
      cells[idx].server_log = "";
      cells[idx].error = null;
      updateCell(idx);
      startServerPoll(idx);
    }
    setStatus("ok", "server started");
  } else if (msg.type === "server_stopped") {
    const idx = msg.index;
    if (cells[idx]) {
      cells[idx].running = false;
      cells[idx].pid = null;
      stopServerPoll(idx);
      updateCell(idx);
    }
    setStatus("ok", "server stopped");
  } else if (msg.type === "server_output") {
    const idx = msg.index;
    if (cells[idx]) {
      cells[idx].server_log = msg.content;
      if (!msg.running) {
        cells[idx].running = false;
        cells[idx].pid = null;
        stopServerPoll(idx);
      }
      updateCell(idx);
    }
  } else if (msg.type === "server_error") {
    const idx = msg.index;
    if (cells[idx]) {
      cells[idx].running = false;
      cells[idx].error = msg.message;
      stopServerPoll(idx);
      updateCell(idx);
    }
    setStatus("err", msg.message);
  } else if (msg.type === "error") {
    setStatus("err", msg.message);
    if (pendingRun !== null) { pendingRun = null; }
  }
}

// ── Server process management ────────────────────────────────────────────────

function startServerPoll(idx) {
  stopServerPoll(idx);
  // Poll immediately, then every 2s
  send({type:"read_server", index:idx});
  serverPolls[idx] = setInterval(() => {
    send({type:"read_server", index:idx});
  }, 2000);
}

function stopServerPoll(idx) {
  if (serverPolls[idx]) {
    clearInterval(serverPolls[idx]);
    delete serverPolls[idx];
  }
}

function startServer(idx) {
  if (cells[idx] && cells[idx].kind === "server") {
    send({type:"save", content: nbSource()});
    send({type:"start_server", index:idx});
    setStatus("running", "starting…");
  }
}

function stopServer(idx) {
  send({type:"stop_server", index:idx});
  stopServerPoll(idx);
  if (cells[idx]) {
    cells[idx].running = false;
    cells[idx].pid = null;
    updateCell(idx);
  }
  setStatus("ok", "stopping…");
}

// ── Cell operations ──────────────────────────────────────────────────────────

function nbSource() {
  return cells.map(c => {
    if (c.kind === "markdown") return c.source;
    if (c.kind === "server")   return "```march:server\n" + c.source + "\n```";
    return "```march\n" + c.source + "\n```";
  }).join("\n\n");
}

function runCell(idx) {
  if (cells[idx] && cells[idx].kind === "code") {
    send({type:"save", content: nbSource()});
    send({type:"run", index:idx});
  }
}

function firstCodeCell() {
  for (let i=0;i<cells.length;i++) if(cells[i].kind==="code") return i;
  return -1;
}

function nextCodeCell(from) {
  for (let i=from;i<cells.length;i++) if(cells[i].kind==="code") return i;
  return -1;
}

function runAll() {
  const first = firstCodeCell();
  if (first === -1) return;
  cells.forEach(c => { c.output=""; c.error=null; c.running=false; c._dirty=false; });
  render();
  pendingRun = first;
  runCell(first);
  setStatus("running", "running…");
}

function clearCell(idx) {
  if (!cells[idx]) return;
  cells[idx].output = "";
  cells[idx].error = null;
  cells[idx]._elapsed_ms = null;
  updateCell(idx);
}

function clearAll() {
  cells.forEach((c, i) => { c.output=""; c.error=null; c._elapsed_ms=null; });
  render();
}

function toggleSrcCollapse(idx) {
  if (!cells[idx]) return;
  cells[idx]._src_collapsed = !cells[idx]._src_collapsed;
  updateCell(idx);
}

function toggleOutCollapse(idx) {
  if (!cells[idx]) return;
  cells[idx]._out_collapsed = !cells[idx]._out_collapsed;
  updateCell(idx);
}

function copyOutput(idx) {
  if (!cells[idx]) return;
  const text = cells[idx].output || cells[idx].error || "";
  navigator.clipboard.writeText(text).then(() => {
    const btn = document.querySelector(`[data-idx="\${idx}"] .copy-btn`);
    if (btn) { btn.textContent = "Copied ✓"; setTimeout(() => { btn.textContent = "Copy"; }, 1500); }
  });
}

// ── Long-running static analysis ─────────────────────────────────────────────

const SLOW_PATTERNS = [
  /\bHttp\./,/\bHttpClient\./,/\bHttpTransport\./,
  /\bTask\.async\b/,/\bTask\.await\b/,/\btask_spawn\b/,
  /\bProcess\.run\b/,/\bProcess\.spawn\b/,
  /\bSocket\./,/\bChannelSocket\./,/\bTls\./,
  /\bSystem\.sleep\b/,
  /\bFile\.read\b/,/\bFile\.write\b/,
];

function isPotentiallyLongRunning(src) {
  if (SLOW_PATTERNS.some(p => p.test(src))) return true;
  const m = src.match(/\bfn\s+(\w+)\s*\(/);
  if (m && new RegExp('\\b' + m[1] + '\\s*\\(').test(src.slice(src.indexOf(m[0]) + m[0].length))) return true;
  return false;
}

function saveNotebook() {
  send({type:"save", content: nbSource()});
}

function addCell(kind, afterIdx) {
  const newCell = {kind, source:"", output:"", error:null, running:false, server_log:"", pid:null};
  cells.splice(afterIdx+1, 0, newCell);
  render();
  const ta = document.querySelector(`[data-idx="\${afterIdx+1}"] textarea`);
  if (ta) ta.focus();
}

function deleteCell(idx) {
  if (cells.length <= 1) return;
  if (cells[idx] && cells[idx].running) stopServer(idx);
  cells.splice(idx, 1);
  render();
}

function moveCell(idx, dir) {
  const to = idx + dir;
  if (to < 0 || to >= cells.length) return;
  [cells[idx], cells[to]] = [cells[to], cells[idx]];
  render();
}

// ── Markdown renderer (minimal) ──────────────────────────────────────────────

function renderMd(src) {
  let html = "";
  const lines = src.split("\n");
  let inUl = false, inP = false;
  for (const line of lines) {
    const t = line.trim();
    if (!t) {
      if (inUl) { html += "</ul>"; inUl = false; }
      if (inP)  { html += "</p>";  inP  = false; }
      continue;
    }
    if (t === "---" || t === "***") {
      if (inUl) { html += "</ul>"; inUl = false; }
      if (inP)  { html += "</p>";  inP  = false; }
      html += "<hr>"; continue;
    }
    const hm = t.match(/^(#{1,3})\s+(.+)/);
    if (hm) {
      if (inUl) { html += "</ul>"; inUl = false; }
      if (inP)  { html += "</p>";  inP  = false; }
      const lvl = hm[1].length;
      html += `<h\${lvl}>\${inline(hm[2])}</h\${lvl}>`;
      continue;
    }
    if (t.startsWith("- ") || t.startsWith("* ")) {
      if (inP)  { html += "</p>";  inP  = false; }
      if (!inUl){ html += "<ul>";  inUl = true;  }
      html += `<li>\${inline(t.slice(2))}</li>`;
      continue;
    }
    if (inUl) { html += "</ul>"; inUl = false; }
    if (!inP) { html += "<p>"; inP = true; } else { html += " "; }
    html += inline(t);
  }
  if (inUl) html += "</ul>";
  if (inP)  html += "</p>";
  return html;
}

function inline(s) {
  s = s.replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;");
  s = s.replace(/`([^`]+)`/g, "<code>$1</code>");
  s = s.replace(/\*\*([^*]+)\*\*/g, "<strong>$1</strong>");
  s = s.replace(/\*([^*]+)\*/g, "<em>$1</em>");
  return s;
}

// ── Render ───────────────────────────────────────────────────────────────────

function esc(s) {
  return String(s).replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;");
}

function render() {
  const nb = document.getElementById("notebook");
  nb.innerHTML = "";
  cells.forEach((cell, idx) => {
    const wrap = document.createElement("div");
    wrap.className = "cell-wrap cell";
    wrap.dataset.idx = idx;

    if (cell.kind === "markdown") {
      wrap.innerHTML = markdownCell(idx, cell);
      attachMarkdownEvents(wrap, idx);
    } else if (cell.kind === "server") {
      wrap.innerHTML = serverCell(idx, cell);
      autoResize(wrap.querySelector("textarea"));
      attachEditorEvents(wrap, idx);
    } else {
      wrap.innerHTML = codeCell(idx, cell);
      autoResize(wrap.querySelector("textarea"));
      attachEditorEvents(wrap, idx);
    }

    // between-cell add bar
    const bar = document.createElement("div");
    bar.className = "add-cell-bar";
    bar.innerHTML = `<button onclick="addCell('markdown',\${idx})">+ md</button><button onclick="addCell('code',\${idx})">+ code</button><button onclick="addCell('server',\${idx})">+ srv</button>`;
    wrap.appendChild(bar);

    nb.appendChild(wrap);
  });

  // end add bar
  const endBar = document.createElement("div");
  endBar.style.cssText = "display:flex;justify-content:center;gap:8px;padding:12px 0";
  endBar.innerHTML = `<button class="add-btn" onclick="addCell('markdown',\${cells.length-1})">+ Markdown</button><button class="add-btn" onclick="addCell('code',\${cells.length-1})">+ Code</button><button class="add-btn" onclick="addCell('server',\${cells.length-1})">+ Server</button>`;
  nb.appendChild(endBar);
  // Defer a second resize pass so custom fonts (JetBrains Mono) are laid out
  requestAnimationFrame(resizeAllTextareas);
}

function markdownCell(idx, cell) {
  const editing = !!cell._editing;
  const editorHtml = editing
    ? `<div class="cell-md-editor"><textarea data-cell="\${idx}" spellcheck="false">\${esc(cell.source)}</textarea></div>`
    : "";
  return `<div class="cell-md-wrap">
    <div class="cell-md-header">
      <span class="cell-md-label">markdown</span>
      <div class="cell-md-actions">
        <button class="add-btn" onclick="moveCell(\${idx},-1)" title="Move up">↑</button>
        <button class="add-btn" onclick="moveCell(\${idx},1)" title="Move down">↓</button>
        <button class="add-btn" onclick="event.stopPropagation();toggleMdEdit(\${idx})" title="\${editing?'Done':'Edit'}">\${editing?'✓':'✎'}</button>
        <button class="add-btn" onclick="deleteCell(\${idx})" title="Delete">✕</button>
      </div>
    </div>
    <div class="cell-md" onclick="if(!event.target.closest('button'))toggleMdEdit(\${idx})">\${renderMd(cell.source)||'<span style="color:#4b5563;font-style:italic">Click to edit…</span>'}</div>
    \${editorHtml}
  </div>`;
}

function toggleMdEdit(idx) {
  if (!cells[idx]) return;
  cells[idx]._editing = !cells[idx]._editing;
  updateCell(idx);
  if (cells[idx]._editing) {
    const wrap = document.querySelector(`[data-idx="\${idx}"]`);
    const ta = wrap && wrap.querySelector("textarea");
    if (ta) { ta.focus(); autoResize(ta); }
  }
}

function attachMarkdownEvents(wrap, idx) {
  const ta = wrap.querySelector(".cell-md-editor textarea");
  if (!ta) return;
  ta.addEventListener("input", () => {
    cells[idx].source = ta.value;
    // live-update the preview while editing
    const preview = wrap.querySelector(".cell-md");
    if (preview) preview.innerHTML = renderMd(ta.value) || '<span style="color:#4b5563;font-style:italic">Click to edit…</span>';
    autoResize(ta);
  });
  ta.addEventListener("keydown", (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === "Enter") {
      e.preventDefault();
      toggleMdEdit(idx);
    }
    if (e.key === "Escape") { e.preventDefault(); toggleMdEdit(idx); }
  });
  autoResize(ta);
}

function renderOutput(text) {
  const t = text.trimStart();
  if (t.startsWith('<svg') || t.startsWith('<table') || t.startsWith('<!DOCTYPE') || t.startsWith('<html')) {
    return `<div class="cell-out-html">\${text}</div>`;
  }
  return `<div class="cell-out">\${esc(text)}</div>`;
}

function codeCell(idx, cell) {
  const cls = cell.running ? " running" : cell.error ? " has-error" : "";
  const timing = (!cell.running && cell._elapsed_ms != null) ? ` · \${cell._elapsed_ms < 1000 ? cell._elapsed_ms+"ms" : (cell._elapsed_ms/1000).toFixed(1)+"s"}` : "";
  const lbl = cell.running ? "running…" : `In [\${idx+1}]\${timing}`;
  const lblCls = cell.running ? " running" : "";
  const staleBadge = cell._dirty ? `<span class="stale-badge" title="Output may be stale">↻ stale</span>` : "";
  const slowBadge = (!cell.running && isPotentiallyLongRunning(cell.source)) ? `<span class="slow-badge" title="May take a while — use ⬛ to cancel">⏱</span>` : "";
  const srcCollapsed = !!cell._src_collapsed;
  const outCollapsed = !!cell._out_collapsed;
  const srcToggle = `<button class="add-btn" onclick="toggleSrcCollapse(\${idx})" title="\${srcCollapsed?'Expand source':'Collapse source'}">\${srcCollapsed?'⌄':'⌃'}</button>`;
  const outToggle = `<button class="add-btn" onclick="toggleOutCollapse(\${idx})" title="\${outCollapsed?'Expand output':'Collapse output'}">\${outCollapsed?'▸':'▾'}</button>`;
  const srcPreview = srcCollapsed ? `<div class="src-preview" onclick="toggleSrcCollapse(\${idx})">\${esc(cell.source.split('\\n')[0])}</div>` : "";
  const hasOut = !!(cell.output || cell.error);
  const copyBtn = hasOut ? `<button class="copy-btn" onclick="copyOutput(\${idx})">Copy</button>` : "";
  const outHtml = cell.error
    ? `<div class="cell-out-wrap">\${copyBtn}<div class="cell-err">\${esc(cell.error)}</div></div>`
    : cell.output
      ? `<div class="cell-out-wrap">\${copyBtn}\${renderOutput(cell.output)}</div>`
      : "";
  const dirtyAttr = cell._dirty ? ' data-dirty="1"' : "";
  const srcCls = srcCollapsed ? " src-collapsed" : "";
  const outCls = outCollapsed ? " out-collapsed" : "";
  return `<div class="cell-code\${cls}\${srcCls}\${outCls}"\${dirtyAttr}>
    <div class="cell-header">
      <span class="cell-label\${lblCls}">\${lbl}</span>\${staleBadge}\${slowBadge}
      <div class="add-btns">
        \${srcToggle}\${outToggle}
        <button class="add-btn" onclick="moveCell(\${idx},-1)" title="Move up">↑</button>
        <button class="add-btn" onclick="moveCell(\${idx},1)" title="Move down">↓</button>
        <button class="add-btn" onclick="clearCell(\${idx})" title="Clear output">○</button>
        <button class="add-btn" onclick="deleteCell(\${idx})" title="Delete">✕</button>
      </div>
      <button class="run-btn" onclick="runCell(\${idx})" \${cell.running?"disabled":""}>▶ Run</button>
    </div>
    <textarea class="cell-src" data-cell="\${idx}" spellcheck="false">\${esc(cell.source)}</textarea>
    \${srcPreview}
    \${outHtml}
  </div>`;
}

function serverCell(idx, cell) {
  const running = !!cell.running;
  const lbl = running ? "server · running" : "server";
  const lblCls = running ? " server-label running" : " server-label";
  const pidBadge = cell.pid ? `<span class="pid-badge">pid \${esc(cell.pid)}</span>` : "";
  const actionBtn = running
    ? `<button class="stop-btn" onclick="stopServer(\${idx})">■ Stop</button>`
    : `<button class="start-btn" onclick="startServer(\${idx})">▶ Start</button>`;
  const outHtml = cell.server_log
    ? `<div class="cell-server-out" id="srv-out-\${idx}">\${esc(cell.server_log)}</div>`
    : "";
  const errHtml = cell.error
    ? `<div class="cell-err">\${esc(cell.error)}</div>`
    : "";
  return `<div class="cell-server-wrap\${running ? " server-running" : cell.error ? " has-error" : ""}">
    <div class="cell-header">
      <span class="cell-label\${lblCls}">\${lbl}</span>
      \${pidBadge}
      <div class="add-btns">
        <button class="add-btn" onclick="moveCell(\${idx},-1)" title="Move up">↑</button>
        <button class="add-btn" onclick="moveCell(\${idx},1)" title="Move down">↓</button>
        <button class="add-btn" onclick="deleteCell(\${idx})" title="Delete">✕</button>
      </div>
      \${actionBtn}
    </div>
    <textarea class="cell-src" data-cell="\${idx}" spellcheck="false">\${esc(cell.source)}</textarea>
    \${outHtml}\${errHtml}
  </div>`;
}

function updateCell(idx) {
  const wrap = document.querySelector(`[data-idx="\${idx}"]`);
  if (!wrap) return;
  const cell = cells[idx];
  // Capture current textarea value before overwriting innerHTML
  const srcArea = wrap.querySelector("textarea[data-cell]");
  if (srcArea) cell.source = srcArea.value;
  if (cell.kind === "markdown") {
    wrap.innerHTML = markdownCell(idx, cell);
    attachMarkdownEvents(wrap, idx);
  } else if (cell.kind === "server") {
    wrap.innerHTML = serverCell(idx, cell);
    autoResize(wrap.querySelector("textarea"));
    attachEditorEvents(wrap, idx);
    const out = document.getElementById(`srv-out-\${idx}`);
    if (out) out.scrollTop = out.scrollHeight;
  } else if (cell.kind === "code") {
    wrap.innerHTML = codeCell(idx, cell);
    autoResize(wrap.querySelector("textarea"));
    attachEditorEvents(wrap, idx);
  }
  // re-attach the add bar
  const bar = document.createElement("div");
  bar.className = "add-cell-bar";
  bar.innerHTML = `<button onclick="addCell('markdown',\${idx})">+ md</button><button onclick="addCell('code',\${idx})">+ code</button><button onclick="addCell('server',\${idx})">+ srv</button>`;
  wrap.appendChild(bar);
}

function attachEditorEvents(wrap, idx) {
  const ta = wrap.querySelector("textarea");
  if (!ta) return;
  ta.addEventListener("input", () => {
    cells[idx].source = ta.value;
    autoResize(ta);
    // Mark this cell and all later code cells as dirty (output may be stale)
    if (cells[idx].kind === "code") {
      for (let i = idx; i < cells.length; i++) {
        if (cells[i].kind === "code") cells[i]._dirty = true;
      }
      // Reflect dirty state in DOM without full re-render
      const cellDiv = wrap.querySelector(".cell-code");
      if (cellDiv) cellDiv.setAttribute("data-dirty", "1");
    }
  });
  ta.addEventListener("keydown", (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === "Enter") {
      e.preventDefault();
      if (cells[idx].kind === "code") runCell(idx);
      else if (cells[idx].kind === "server") startServer(idx);
      else { cells[idx]._editing = false; render(); }
    }
    // Shift+Enter: run cell and move focus to next (Jupyter muscle memory)
    if (e.shiftKey && !e.metaKey && !e.ctrlKey && e.key === "Enter") {
      e.preventDefault();
      if (cells[idx].kind === "code") runCell(idx);
      const nextIdx = idx + 1;
      if (nextIdx < cells.length) {
        setTimeout(() => {
          const nextWrap = document.querySelector(`[data-idx="\${nextIdx}"]`);
          const nextTa = nextWrap && nextWrap.querySelector("textarea");
          if (nextTa) nextTa.focus();
        }, 30);
      } else {
        addCell("code", idx);
      }
    }
    if (e.key === "Tab") {
      e.preventDefault();
      const s = ta.selectionStart, end = ta.selectionEnd;
      ta.value = ta.value.slice(0,s) + "  " + ta.value.slice(end);
      ta.selectionStart = ta.selectionEnd = s + 2;
    }
  });
}

function autoResize(ta) {
  if (!ta) return;
  ta.style.height = "1px";
  ta.style.height = Math.max(48, ta.scrollHeight) + "px";
}

function resizeAllTextareas() {
  document.querySelectorAll("textarea").forEach(autoResize);
}

function setStatus(cls, text) {
  const el = document.getElementById("status");
  el.className = cls;
  el.textContent = text;
}

// ── Toolbar buttons ──────────────────────────────────────────────────────────

document.getElementById("btn-run-all").onclick    = runAll;
document.getElementById("btn-clear-all").onclick  = clearAll;
document.getElementById("btn-save").onclick       = saveNotebook;
document.getElementById("btn-add-code").onclick   = () => addCell("code",   cells.length-1);
document.getElementById("btn-add-md").onclick     = () => addCell("markdown", cells.length-1);
document.getElementById("btn-add-server").onclick = () => addCell("server", cells.length-1);

// ── Keyboard shortcuts ───────────────────────────────────────────────────────

document.addEventListener("keydown", (e) => {
  if ((e.metaKey||e.ctrlKey) && e.shiftKey && e.key==="Enter") { e.preventDefault(); runAll(); }
  if ((e.metaKey||e.ctrlKey) && e.key==="s") { e.preventDefault(); saveNotebook(); }
});

connect();
</script>
</body>
</html>"""
end

-- ── HTTP router ───────────────────────────────────────────────────────────────

pfn router(nb_path, display_title, port, march_bin, conn) do
  match (HttpServer.method(conn), HttpServer.path_info(conn)) do
    (:get, Nil) ->
      conn |> HttpServer.html(200, ui_html(display_title, port))

    (:get, Cons("ws", Nil)) ->
      WebSocket.upgrade(conn, fn socket ->
        ws_loop(socket, nb_path, march_bin)
      )

    _ ->
      conn |> HttpServer.text(404, "Not Found")
  end
end

-- ── Main entry point ──────────────────────────────────────────────────────────

fn main() do
  let nb_path = match System.env("FORGE_NB_INPUT") do
    Some(p) -> p
    None    ->
      IO.warn("forge notebook serve: FORGE_NB_INPUT not set")
      Process.exit(1)
      ""
  end

  let port = match System.env("FORGE_NB_PORT") do
    Some(p) ->
      match String.to_int(p) do
        Ok(n)  -> n
        Err(_) -> 4040
      end
    None -> 4040
  end

  let march_bin = match System.env("FORGE_NB_MARCH") do
    Some(b) -> b
    None    -> "march"
  end

  -- FORGE_NB_TITLE overrides the display title (used for untitled temp notebooks)
  let display_title = match System.env("FORGE_NB_TITLE") do
    Some(t) -> t
    None    -> nb_path
  end

  IO.puts("forge notebook: serving " ++ nb_path ++ " on http://localhost:" ++ String.from_int(port))
  IO.puts("forge notebook: press Ctrl-C to stop")

  let server = HttpServer.new(port)
  let server = HttpServer.plug(server, fn req_conn ->
    router(nb_path, display_title, port, march_bin, req_conn)
  )
  HttpServer.listen(server)
end

end
