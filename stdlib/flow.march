-- Flow module: backpressure-aware pipeline abstraction.
--
-- A Flow pipeline is a chain of stages: producers → transformers → consumers.
-- Demand flows backward (consumers pull from producers), which prevents fast
-- producers from overwhelming slow consumers (backpressure).
--
-- DESIGN: In the interpreter, Flow is implemented as a functional pipeline
-- over lazy Seq(a) values (fold-based, church-encoded).  The `Stage(a)` type
-- wraps a `Seq(a)`, and all transformations delegate to the Seq module.
--
-- In the compiled runtime, each Stage would be backed by an actor.  The
-- consumer sends a Demand(n) message upstream; each stage forwards demand
-- to its source and buffers at most n items before sending them downstream.
-- This is the GenStage/Flow model from Elixir, adapted for March actors.
--
-- with_concurrency/2 is a no-op in the interpreter but signals that the
-- stage may execute with n concurrent workers in the compiled runtime.
--
-- See stdlib/docs/flow.md for design rationale, usage examples, and a
-- comparison with Elixir's GenStage.
--
-- Quick start:
--
--   Flow.from_list([1, 2, 3, 4, 5])
--     |> Flow.map(fn x -> x * 2)
--     |> Flow.filter(fn x -> x > 4)
--     |> Flow.collect
--   -- [6, 8, 10]

mod Flow do

-- A Stage wraps a Seq(a).
-- In the compiled runtime this would be an actor Pid; here it holds the
-- lazy fold function directly.
pub type Stage(a) = Stage(Seq(a))

-- ---- Producers ----

doc "Create a stage from a list of items."
pub fn from_list(xs) do
  Stage(Seq.from_list(xs))
end

doc "Create a stage from an existing Seq."
pub fn from_seq(seq) do
  Stage(seq)
end

doc """
Create a stage by unfolding a seed value.
next : seed -> Option((item, new_seed))
Produces items until next returns None.

Example — integers from 0 to 4:
    Flow.unfold(0, fn s -> if s >= 5 then None else Some((s, s + 1)))
"""
pub fn unfold(seed, next) do
  Stage(Seq.unfold(seed, next))
end

doc "Create a stage over the integer range [start, stop)."
pub fn range(start, stop) do
  Stage(Seq.unfold(start, fn i ->
    if i >= stop then None
    else Some((i, i + 1))))
end

-- ---- Transformers ----

doc "Apply f to every item."
pub fn map(stage, f) do
  match stage do
  | Stage(seq) -> Stage(Seq.map(seq, f))
  end
end

doc "Keep only items where pred returns true."
pub fn filter(stage, pred) do
  match stage do
  | Stage(seq) -> Stage(Seq.filter(seq, pred))
  end
end

doc "Apply f to each item (f returns a list) and flatten the results."
pub fn flat_map(stage, f) do
  match stage do
  | Stage(seq) ->
    Stage(Seq.flat_map(seq, fn x ->
      match f(x) do
      | Stage(inner) -> inner
      end))
  end
end

doc "Keep at most n items."
pub fn take(stage, n) do
  match stage do
  | Stage(seq) -> Stage(Seq.take(seq, n))
  end
end

doc "Skip the first n items."
pub fn drop(stage, n) do
  match stage do
  | Stage(seq) -> Stage(Seq.drop(seq, n))
  end
end

doc "Group items into lists of at most n elements."
pub fn batch(stage, n) do
  match stage do
  | Stage(seq) -> Stage(Seq.batch(seq, n))
  end
end

doc """
Parallelism hint: in the compiled runtime, spawn n worker actors for this stage.
No-op in the interpreter (single-threaded execution).

    Flow.from_list(urls)
      |> Flow.map(fn url -> Http.get(url))
      |> Flow.with_concurrency(8)
      |> Flow.collect
"""
pub fn with_concurrency(stage, n) do stage end

-- ---- Consumers (run the pipeline eagerly) ----

doc "Collect all items into a List."
pub fn collect(stage) do
  match stage do
  | Stage(seq) -> Seq.to_list(seq)
  end
end

doc "Run the pipeline for side effects; discard all items."
pub fn run(stage) do
  match stage do
  | Stage(seq) -> Seq.each(seq, fn _ -> ())
  end
end

doc "Reduce all items to a single value using f(accumulator, item) -> accumulator."
pub fn reduce(stage, start, f) do
  match stage do
  | Stage(seq) -> Seq.fold(seq, start, f)
  end
end

doc "Consume with f(acc, item) -> acc (alias for reduce)."
pub fn into(stage, start, f) do
  reduce(stage, start, f)
end

doc "Run f on each item for its side effects."
pub fn each(stage, f) do
  match stage do
  | Stage(seq) -> Seq.each(seq, f)
  end
end

doc "Count the total number of items produced."
pub fn count(stage) do
  match stage do
  | Stage(seq) -> Seq.count(seq)
  end
end

doc "Return the first item satisfying pred, or None."
pub fn find(stage, pred) do
  match stage do
  | Stage(seq) -> Seq.find(seq, pred)
  end
end

doc "True if any item satisfies pred."
pub fn any(stage, pred) do
  match stage do
  | Stage(seq) -> Seq.any(seq, pred)
  end
end

doc "True if all items satisfy pred."
pub fn all(stage, pred) do
  match stage do
  | Stage(seq) -> Seq.all(seq, pred)
  end
end

end
