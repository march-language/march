-- BastionDev module: developer-experience helpers for Bastion web apps.
--
-- Provides live-reload injection, request timing middleware, a Phoenix
-- Live Dashboard-inspired dev dashboard, and a rich error overlay page.
-- All features are for development only.
--
-- ## Middleware
--
--   BastionDev.request_timer(conn)   — stamps :bastion_start into assigns
--   BastionDev.finish_timer(conn)    — stamps :bastion_elapsed into assigns
--   BastionDev.server_timing(conn)   — emits a Server-Timing response header
--   BastionDev.conn_inspector(conn)  — logs the full conn state via Logger
--
-- ## Live reload
--
--   BastionDev.live_reload_script()       — returns the SSE JS snippet
--   BastionDev.inject_live_reload(conn)   — injects the script before </body>
--   BastionDev.live_reload_handler(conn)  — plug: serves /_bastion/live_reload
--
-- ## Dev dashboard (/_bastion)
--
--   BastionDev.new_stats()                     — empty DevStats
--   BastionDev.record_request(stats, entry)    — push a request entry (cap 50)
--   BastionDev.record_error(stats, entry)      — push an error entry (cap 20)
--   BastionDev.register_route(stats, entry)    — add a route to the registry
--   BastionDev.add_vault_stat(stats, vs)       — add a vault table snapshot
--   BastionDev.inc_ws(stats) / dec_ws(stats)   — track WS connections
--   BastionDev.dashboard_html(stats)           — render the /_bastion page
--   BastionDev.dashboard_handler(conn, stats)  — plug: serves /_bastion
--
-- ## Error overlay
--
--   BastionDev.error_overlay_html(error_msg, stack_trace, conn)
--   BastionDev.error_overlay(conn, error_msg, stack_trace)

mod BastionDev do

-- ── RequestEntry ───────────────────────────────────────────────────────────

-- A single HTTP request log entry.
-- Fields: method string, path, HTTP status code, duration_ms.
type RequestEntry = RequestEntry(
  String,  -- method  (e.g. "GET")
  String,  -- path    (e.g. "/users/42")
  Int,     -- status  (e.g. 200)
  Int      -- duration_ms
)

doc "Create a RequestEntry."
fn make_entry(method_str, path_str, status_code, duration_ms) do
  RequestEntry(method_str, path_str, status_code, duration_ms)
end

fn entry_method(e) do
  match e do
  RequestEntry(m, _, _, _) -> m
  end
end

fn entry_path(e) do
  match e do
  RequestEntry(_, p, _, _) -> p
  end
end

fn entry_status(e) do
  match e do
  RequestEntry(_, _, s, _) -> s
  end
end

fn entry_duration(e) do
  match e do
  RequestEntry(_, _, _, d) -> d
  end
end

-- ── ErrorEntry ─────────────────────────────────────────────────────────────

-- A single error log entry.
type ErrorEntry = ErrorEntry(
  String,  -- error message (exception type + text)
  String,  -- stack trace
  String   -- request path at time of error
)

doc "Create an ErrorEntry."
fn make_error_entry(msg, trace, path_str) do
  ErrorEntry(msg, trace, path_str)
end

fn error_entry_msg(e) do
  match e do
  ErrorEntry(m, _, _) -> m
  end
end

fn error_entry_trace(e) do
  match e do
  ErrorEntry(_, t, _) -> t
  end
end

fn error_entry_path(e) do
  match e do
  ErrorEntry(_, _, p) -> p
  end
end

-- ── RouteEntry ─────────────────────────────────────────────────────────────

-- A registered route in the dev dashboard route table.
type RouteEntry = RouteEntry(
  String,  -- HTTP method  (e.g. "GET", "*" for all)
  String,  -- path pattern  (e.g. "/users/:id")
  String   -- handler description (e.g. "UserController.show")
)

doc "Create a RouteEntry."
fn make_route(method_str, pattern, handler_name) do
  RouteEntry(method_str, pattern, handler_name)
end

fn route_method(r) do
  match r do
  RouteEntry(m, _, _) -> m
  end
end

fn route_pattern(r) do
  match r do
  RouteEntry(_, p, _) -> p
  end
end

fn route_handler(r) do
  match r do
  RouteEntry(_, _, h) -> h
  end
end

-- ── VaultStat ──────────────────────────────────────────────────────────────

-- A snapshot of a Vault table's stats: name and entry count.
type VaultStat = VaultStat(
  String,  -- table name
  Int      -- entry count at snapshot time
)

doc "Create a VaultStat."
fn make_vault_stat(name, count) do
  VaultStat(name, count)
end

doc "Snapshot a live vault table by name. Returns None if not found."
fn snapshot_vault(name) do
  match Vault.whereis(name) do
  None    -> None
  Some(t) -> Some(VaultStat(name, Vault.size(t)))
  end
end

fn vault_stat_name(vs) do
  match vs do
  VaultStat(n, _) -> n
  end
end

fn vault_stat_count(vs) do
  match vs do
  VaultStat(_, c) -> c
  end
end

-- ── DevStats ───────────────────────────────────────────────────────────────

-- Full dev-server state for the /_bastion dashboard.
-- Fields: total_requests, error_count, recent (50), ws_connections,
-- vault_stats, errors (20), routes.
type DevStats = DevStats(
  Int,               -- total_requests
  Int,               -- error_count
  List(RequestEntry),-- recent
  Int,               -- ws_connections
  List(VaultStat),   -- vault_stats
  List(ErrorEntry),  -- errors
  List(RouteEntry)   -- routes
)

doc "Create an empty DevStats."
fn new_stats() do
  DevStats(0, 0, Nil, 0, Nil, Nil, Nil)
end

fn stats_total(s) do
  match s do
  DevStats(t, _, _, _, _, _, _) -> t
  end
end

fn stats_errors(s) do
  match s do
  DevStats(_, e, _, _, _, _, _) -> e
  end
end

fn stats_recent(s) do
  match s do
  DevStats(_, _, r, _, _, _, _) -> r
  end
end

fn stats_ws(s) do
  match s do
  DevStats(_, _, _, w, _, _, _) -> w
  end
end

fn stats_vault(s) do
  match s do
  DevStats(_, _, _, _, v, _, _) -> v
  end
end

fn stats_error_log(s) do
  match s do
  DevStats(_, _, _, _, _, el, _) -> el
  end
end

fn stats_routes(s) do
  match s do
  DevStats(_, _, _, _, _, _, r) -> r
  end
end

-- Keep only the first n items from a list.
pfn take(xs, n) do
  if n <= 0 do Nil
  else
    match xs do
    Nil -> Nil
    Cons(h, t) -> Cons(h, take(t, n - 1))
    end
  end
end

doc "Record a new RequestEntry; keeps newest 50, increments counters."
fn record_request(stats, entry) do
  match stats do
  DevStats(total, errs, recent, ws, vs, el, routes) ->
    do
      let new_total  = total + 1
      let new_errs   = if entry_status(entry) >= 500 do errs + 1 else errs end
      let new_recent = take(Cons(entry, recent), 50)
      DevStats(new_total, new_errs, new_recent, ws, vs, el, routes)
    end
  end
end

doc "Record a new ErrorEntry; keeps newest 20."
fn record_error(stats, entry) do
  match stats do
  DevStats(total, errs, recent, ws, vs, el, routes) ->
    do
      let new_el = take(Cons(entry, el), 20)
      DevStats(total, errs, recent, ws, vs, new_el, routes)
    end
  end
end

doc "Register a route in the dashboard registry."
fn register_route(stats, entry) do
  match stats do
  DevStats(total, errs, recent, ws, vs, el, routes) ->
    DevStats(total, errs, recent, ws, vs, el, Cons(entry, routes))
  end
end

doc "Replace the vault snapshots list."
fn set_vault_stats(stats, vault_list) do
  match stats do
  DevStats(total, errs, recent, ws, _, el, routes) ->
    DevStats(total, errs, recent, ws, vault_list, el, routes)
  end
end

doc "Append a single vault snapshot."
fn add_vault_stat(stats, vs) do
  match stats do
  DevStats(total, errs, recent, ws, vault_list, el, routes) ->
    DevStats(total, errs, recent, ws, Cons(vs, vault_list), el, routes)
  end
end

doc "Increment the active WebSocket connection count."
fn inc_ws(stats) do
  match stats do
  DevStats(t, e, r, w, vs, el, routes) -> DevStats(t, e, r, w + 1, vs, el, routes)
  end
end

doc "Decrement the active WebSocket connection count (floor 0)."
fn dec_ws(stats) do
  match stats do
  DevStats(t, e, r, w, vs, el, routes) ->
    do
      let new_w = if w > 0 do w - 1 else 0 end
      DevStats(t, e, r, new_w, vs, el, routes)
    end
  end
end

-- ── Middleware ─────────────────────────────────────────────────────────────

doc """
Stamp a request-start marker into conn assigns.

Stores "0" under "bastion_start" as a placeholder.  In a production runtime
the C layer replaces this with an actual monotonic timestamp.
"""
fn request_timer(conn) do
  HttpServer.assign(conn, "bastion_start", "0")
end

doc """
Stamp the computed elapsed duration into conn assigns.

Stores "0" under "bastion_elapsed" (no real clock in the pure interpreter).
The runtime overrides "bastion_start" with the actual epoch ms before calling.
"""
fn finish_timer(conn) do
  HttpServer.assign(conn, "bastion_elapsed", "0")
end

doc """
Add a `Server-Timing` response header summarising the request duration.

Reads "bastion_elapsed" from assigns.  Format: `Server-Timing: total;dur=N`.
"""
fn server_timing(conn) do
  let ms = match HttpServer.get_assign(conn, "bastion_elapsed") do
    Some(v) -> v
    None    -> "0"
  end
  HttpServer.put_resp_header(conn, "Server-Timing", "total;dur=" ++ ms)
end

doc """
Log the full conn state (method, path, status, halted) using Logger.info.

    BastionDev.conn_inspector(conn)
    -- [INFO] [conn_inspector] GET /users/42 status=0 halted=false
"""
fn conn_inspector(conn) do
  let m_str    = Http.method_to_string(HttpServer.method(conn))
  let path_str = HttpServer.path(conn)
  let stat_str = int_to_string(HttpServer.status(conn))
  let halt_str = if HttpServer.halted(conn) do "true" else "false" end
  let msg = "[conn_inspector] " ++ m_str ++ " " ++ path_str ++ " status=" ++ stat_str ++ " halted=" ++ halt_str
  Logger.info(msg)
  conn
end

-- ── Live reload ────────────────────────────────────────────────────────────

doc """
Return the JavaScript SSE live-reload snippet as a String.

The script connects to `/_bastion/live_reload` via EventSource and calls
`window.location.reload()` when a `reload` event arrives.  Inject it before
`</body>` in HTML responses during development.
"""
fn live_reload_script() do
  "<script>(function(){" ++
  "var es=new EventSource('/_bastion/live_reload');" ++
  "es.addEventListener('reload',function(){window.location.reload();});" ++
  "es.onerror=function(){setTimeout(function(){" ++
  "es=new EventSource('/_bastion/live_reload');},2000);};" ++
  "})();</script>"
end

-- Check whether a content-type header value is HTML.
pfn is_html_ct(v) do
  string_starts_with(string_to_lowercase(v), "text/html")
end

-- True when the conn's response has an HTML content-type header.
pfn is_html_response(conn) do
  let hdrs = HttpServer.resp_headers(conn)
  fn check(hs) do
    match hs do
    Nil -> false
    Cons(Header(n, v), rest) ->
      if string_to_lowercase(n) == "content-type" do is_html_ct(v)
      else check(rest) end
    end
  end
  check(hdrs)
end

-- Insert `snippet` before the last `</body>` in `html`, or append it.
pfn insert_before_body(html, snippet) do
  let needle     = "</body>"
  let needle_len = string_byte_length(needle)
  let html_len   = string_byte_length(html)
  fn find_last(pos, last_found) do
    if pos + needle_len > html_len do last_found
    else
      let slice = string_slice(html, pos, needle_len)
      let found = string_to_lowercase(slice) == string_to_lowercase(needle)
      if found do find_last(pos + 1, pos)
      else          find_last(pos + 1, last_found) end
    end
  end
  let idx = find_last(0, -1)
  if idx == -1 do html ++ snippet
  else
    let before = string_slice(html, 0, idx)
    let after  = string_slice(html, idx, html_len - idx)
    before ++ snippet ++ after
  end
end

doc """
Inject the live-reload SSE script before `</body>` in HTML responses.

Only modifies halted, HTML-typed responses.  All others pass through unchanged.
"""
fn inject_live_reload(conn) do
  if not(HttpServer.halted(conn)) do conn
  else if not(is_html_response(conn)) do conn
  else
    let body     = HttpServer.resp_body(conn)
    let new_body = insert_before_body(body, live_reload_script())
    let status   = HttpServer.status(conn)
    HttpServer.send_resp(conn, status, new_body)
  end end
end

doc """
Plug handler for the `/_bastion/live_reload` SSE endpoint.

Sets the correct SSE headers and halts.  The runtime keeps the connection
open and pushes `reload` events when source files change.
"""
fn live_reload_handler(conn) do
  if HttpServer.path(conn) == "/_bastion/live_reload" do
    conn
    |> HttpServer.put_resp_header("content-type", "text/event-stream")
    |> HttpServer.put_resp_header("cache-control", "no-cache")
    |> HttpServer.put_resp_header("connection", "keep-alive")
    |> HttpServer.send_resp(200, "")
  else conn end
end

-- ── HTML helpers ──────────────────────────────────────────────────────────

-- Escape HTML entities for safe embedding.
pfn h(s) do
  s
  |> String.replace_all("&", "&amp;")
  |> String.replace_all("<", "&lt;")
  |> String.replace_all(">", "&gt;")
  |> String.replace_all("\"", "&quot;")
end

-- Render an HTML table row <tr><td>k</td><td>v</td></tr>
pfn kv_row(k, v) do
  "<tr><td class=\"k\">" ++ h(k) ++ "</td><td>" ++ h(v) ++ "</td></tr>"
end

-- Render a list of (String, String) pairs as table rows.
pfn render_pairs(pairs) do
  fn go(ps, acc) do
    match ps do
    Nil -> acc
    Cons((k, v), rest) -> go(rest, acc ++ kv_row(k, v))
    end
  end
  go(pairs, "")
end

-- Render a Header list as table rows.
pfn render_headers(hdrs) do
  fn go(hs, acc) do
    match hs do
    Nil -> acc
    Cons(Header(n, v), rest) -> go(rest, acc ++ kv_row(n, v))
    end
  end
  go(hdrs, "")
end

-- CSS class for a status code (2xx=ok, 3xx=redirect, 4xx=warn, 5xx=error).
pfn status_class(code) do
  if code >= 500 do "s5"
  else if code >= 400 do "s4"
  else if code >= 300 do "s3"
  else "s2" end end end
end

-- ── Error overlay ──────────────────────────────────────────────────────────

doc """
Render a rich dev error overlay as a standalone HTML page.

Includes: exception message, full stack trace, request details (method, path,
query string, status at crash), request headers, and conn assigns.
"""
fn error_overlay_html(error_msg, stack_trace, conn) do
  let m_str  = Http.method_to_string(HttpServer.method(conn))
  let p_str  = HttpServer.path(conn)
  let qs_str = HttpServer.query_string(conn)
  let s_str  = int_to_string(HttpServer.status(conn))
  let req_hdrs_rows = render_headers(HttpServer.req_headers(conn))
  let assigns_rows  = render_pairs(HttpServer.assigns(conn))
  "<!DOCTYPE html><html><head><meta charset=\"utf-8\">" ++
  "<title>Bastion Error — " ++ h(p_str) ++ "</title>" ++
  "<style>" ++
  "*{box-sizing:border-box;margin:0;padding:0}" ++
  "body{font-family:'Fira Code',monospace,sans-serif;background:#0f111a;color:#cdd3de;min-height:100vh}" ++
  ".header{background:#1a0a0a;border-bottom:2px solid #ff5555;padding:1.2rem 2rem;display:flex;align-items:center;gap:1rem}" ++
  ".badge{background:#ff5555;color:#fff;padding:.2rem .6rem;border-radius:4px;font-size:.8rem;font-weight:700}" ++
  ".err-title{color:#ff8080;font-size:1.1rem;font-weight:700}" ++
  ".body{padding:2rem;max-width:1100px}" ++
  "h2{color:#82aaff;font-size:.85rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;margin:1.5rem 0 .5rem}" ++
  "pre{background:#070912;border:1px solid #222;border-radius:6px;padding:1.2rem;overflow-x:auto;white-space:pre-wrap;font-size:.85rem;line-height:1.6}" ++
  "table{width:100%;border-collapse:collapse;font-size:.85rem}" ++
  "td{padding:.35rem .6rem;border-bottom:1px solid #1a1e2e;vertical-align:top}" ++
  "td.k{color:#a9b1d6;width:200px;white-space:nowrap}" ++
  ".copy-btn{float:right;background:#1e2030;border:1px solid #333;color:#9aa5ce;padding:.2rem .7rem;border-radius:4px;cursor:pointer;font-size:.75rem}" ++
  "</style></head><body>" ++
  "<div class=\"header\"><span class=\"badge\">500</span><span class=\"err-title\">" ++ h(error_msg) ++ "</span></div>" ++
  "<div class=\"body\">" ++
  "<h2>Stack Trace</h2>" ++
  "<button class=\"copy-btn\" onclick=\"navigator.clipboard.writeText(document.querySelector('pre').innerText)\">Copy</button>" ++
  "<pre>" ++ h(stack_trace) ++ "</pre>" ++
  "<h2>Request</h2>" ++
  "<table>" ++
  kv_row("Method", m_str) ++
  kv_row("Path", p_str) ++
  kv_row("Query String", qs_str) ++
  kv_row("Status at crash", s_str) ++
  "</table>" ++
  "<h2>Request Headers</h2><table>" ++ req_hdrs_rows ++ "</table>" ++
  "<h2>Assigns</h2><table>" ++ assigns_rows ++ "</table>" ++
  "</div></body></html>"
end

doc """
Send a 500 response with the dev error overlay HTML.

    BastionDev.error_overlay(conn, "KeyError: not found", trace)
"""
fn error_overlay(conn, error_msg, stack_trace) do
  conn
  |> HttpServer.put_resp_header("content-type", "text/html; charset=utf-8")
  |> HttpServer.send_resp(500, error_overlay_html(error_msg, stack_trace, conn))
end

-- ── Dashboard HTML ────────────────────────────────────────────────────────

-- Render one RequestEntry as a table row.
pfn render_req_row(entry) do
  let m = entry_method(entry)
  let p = entry_path(entry)
  let s = entry_status(entry)
  let d = entry_duration(entry)
  let sc = status_class(s)
  "<tr><td class=\"m\">" ++ h(m) ++ "</td>" ++
  "<td class=\"p\">" ++ h(p) ++ "</td>" ++
  "<td class=\"s " ++ sc ++ "\">" ++ int_to_string(s) ++ "</td>" ++
  "<td class=\"d\">" ++ int_to_string(d) ++ "ms</td></tr>"
end

-- Render the recent request log.
pfn render_request_log(entries) do
  fn go(es, acc) do
    match es do
    Nil -> acc
    Cons(e, rest) -> go(rest, acc ++ render_req_row(e))
    end
  end
  let rows = go(entries, "")
  if string_is_empty(rows) do
    "<p class=\"empty\">No requests yet.</p>"
  else
    "<table class=\"req-table\">" ++
    "<thead><tr><th>Method</th><th>Path</th><th>Status</th><th>Duration</th></tr></thead>" ++
    "<tbody>" ++ rows ++ "</tbody></table>"
  end
end

-- Render the error log.
pfn render_error_log(entries) do
  fn go(es, acc) do
    match es do
    Nil -> acc
    Cons(e, rest) ->
      do
        let row = "<div class=\"err-row\">" ++
                  "<div class=\"err-msg\">" ++ h(error_entry_msg(e)) ++ "</div>" ++
                  "<div class=\"err-path\">" ++ h(error_entry_path(e)) ++ "</div>" ++
                  "<details><summary>Trace</summary><pre>" ++ h(error_entry_trace(e)) ++ "</pre></details>" ++
                  "</div>"
        go(rest, acc ++ row)
      end
    end
  end
  let rows = go(entries, "")
  if string_is_empty(rows) do
    "<p class=\"empty\">No errors recorded.</p>"
  else rows end
end

-- Render the route registry.
pfn render_routes(routes) do
  fn go(rs, acc) do
    match rs do
    Nil -> acc
    Cons(r, rest) ->
      do
        let row = "<tr><td class=\"m\">" ++ h(route_method(r)) ++ "</td>" ++
                  "<td class=\"p\">" ++ h(route_pattern(r)) ++ "</td>" ++
                  "<td>" ++ h(route_handler(r)) ++ "</td></tr>"
        go(rest, acc ++ row)
      end
    end
  end
  let rows = go(routes, "")
  if string_is_empty(rows) do
    "<p class=\"empty\">No routes registered.</p>"
  else
    "<table class=\"req-table\">" ++
    "<thead><tr><th>Method</th><th>Pattern</th><th>Handler</th></tr></thead>" ++
    "<tbody>" ++ rows ++ "</tbody></table>"
  end
end

-- Render the vault stats.
pfn render_vault(vault_list) do
  fn go(vs, acc) do
    match vs do
    Nil -> acc
    Cons(v, rest) ->
      do
        let row = "<tr><td>" ++ h(vault_stat_name(v)) ++ "</td>" ++
                  "<td>" ++ int_to_string(vault_stat_count(v)) ++ " entries</td></tr>"
        go(rest, acc ++ row)
      end
    end
  end
  let rows = go(vault_list, "")
  if string_is_empty(rows) do
    "<p class=\"empty\">No vault tables tracked.</p>"
  else
    "<table class=\"req-table\">" ++
    "<thead><tr><th>Table</th><th>Size</th></tr></thead>" ++
    "<tbody>" ++ rows ++ "</tbody></table>"
  end
end

-- Render a stat card for the top metrics bar.
pfn stat_card(label, value, extra_class) do
  "<div class=\"card " ++ extra_class ++ "\">" ++
  "<div class=\"card-label\">" ++ h(label) ++ "</div>" ++
  "<div class=\"card-value\">" ++ h(value) ++ "</div>" ++
  "</div>"
end

-- Compute avg duration from a recent entry list (returns "0" if empty).
pfn avg_duration(entries) do
  fn sum_and_count(es, s, c) do
    match es do
    Nil -> (s, c)
    Cons(e, rest) -> sum_and_count(rest, s + entry_duration(e), c + 1)
    end
  end
  let (s, c) = sum_and_count(entries, 0, 0)
  if c == 0 do "0"
  else int_to_string(s / c) end
end

doc """
Render the Bastion dev dashboard as a standalone HTML page.

The page (inspired by Phoenix LiveDashboard) shows:
- Metric cards: total requests, errors, avg response time, WS connections
- Recent request log with colour-coded status badges
- Error log with expandable stack traces
- Vault table stats (name, entry count)
- Registered route table

    let html = BastionDev.dashboard_html(stats)
"""
fn dashboard_html(stats) do
  let total_str = int_to_string(stats_total(stats))
  let errs_str  = int_to_string(stats_errors(stats))
  let ws_str    = int_to_string(stats_ws(stats))
  let avg_str   = avg_duration(stats_recent(stats)) ++ "ms"
  let req_html  = render_request_log(stats_recent(stats))
  let err_html  = render_error_log(stats_error_log(stats))
  let vault_html = render_vault(stats_vault(stats))
  let routes_html = render_routes(stats_routes(stats))
  "<!DOCTYPE html><html><head><meta charset=\"utf-8\">" ++
  "<title>Bastion Dev Dashboard</title>" ++
  "<meta http-equiv=\"refresh\" content=\"5\">" ++
  "<style>" ++
  "*{box-sizing:border-box;margin:0;padding:0}" ++
  "body{font-family:'Fira Code',monospace,sans-serif;background:#0f111a;color:#cdd3de;min-height:100vh}" ++
  ".topbar{background:#1e2030;border-bottom:1px solid #2a2d3e;padding:.8rem 2rem;display:flex;align-items:center;gap:1rem}" ++
  ".topbar-title{color:#82aaff;font-weight:700;font-size:1rem}" ++
  ".env-badge{background:#1a3a2a;color:#9ece6a;border:1px solid #2a5a3a;padding:.15rem .5rem;border-radius:4px;font-size:.75rem}" ++
  ".live-dot{width:8px;height:8px;background:#9ece6a;border-radius:50%;animation:pulse 2s infinite;margin-left:auto}" ++
  "@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}" ++
  ".cards{display:flex;gap:1rem;padding:1.5rem 2rem;flex-wrap:wrap}" ++
  ".card{background:#1e2030;border:1px solid #2a2d3e;border-radius:8px;padding:1rem 1.5rem;min-width:160px}" ++
  ".card-label{color:#7982a9;font-size:.75rem;text-transform:uppercase;letter-spacing:.08em;margin-bottom:.3rem}" ++
  ".card-value{font-size:1.6rem;font-weight:700;color:#c0caf5}" ++
  ".card.error .card-value{color:#f7768e}" ++
  ".card.ws .card-value{color:#7dcfff}" ++
  ".card.avg .card-value{color:#9ece6a}" ++
  ".section{padding:0 2rem 1.5rem}" ++
  "h2{color:#82aaff;font-size:.8rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;margin-bottom:.8rem;padding:.5rem 0;border-bottom:1px solid #1e2030}" ++
  ".req-table{width:100%;border-collapse:collapse;font-size:.83rem}" ++
  ".req-table th{text-align:left;color:#7982a9;padding:.4rem .6rem;border-bottom:1px solid #2a2d3e;font-weight:600;font-size:.75rem;text-transform:uppercase}" ++
  ".req-table td{padding:.35rem .6rem;border-bottom:1px solid #1a1e2e}" ++
  ".req-table td.m{color:#bb9af7;font-weight:600;width:60px}" ++
  ".req-table td.p{color:#cdd3de}" ++
  ".req-table td.d{color:#7982a9;text-align:right;width:80px}" ++
  ".s2{color:#9ece6a}.s3{color:#e0af68}.s4{color:#f7768e}.s5{color:#f7768e;font-weight:700}" ++
  ".req-table td.s{width:60px;text-align:center}" ++
  ".err-row{background:#1a0e0e;border:1px solid #2a1515;border-radius:6px;margin-bottom:.6rem;padding:.8rem 1rem}" ++
  ".err-msg{color:#f7768e;font-size:.85rem;font-weight:600;margin-bottom:.3rem}" ++
  ".err-path{color:#7982a9;font-size:.8rem;margin-bottom:.5rem}" ++
  "details summary{color:#9aa5ce;font-size:.8rem;cursor:pointer;user-select:none}" ++
  "details pre{background:#070912;padding:.8rem;border-radius:4px;margin-top:.4rem;font-size:.78rem;overflow-x:auto;white-space:pre-wrap}" ++
  ".empty{color:#545c7e;font-size:.85rem;font-style:italic;padding:.5rem 0}" ++
  ".k{color:#a9b1d6;width:200px;white-space:nowrap}" ++
  "</style></head><body>" ++
  "<div class=\"topbar\">" ++
  "<span class=\"topbar-title\">⬡ Bastion Dev</span>" ++
  "<span class=\"env-badge\">dev</span>" ++
  "<span class=\"live-dot\"></span>" ++
  "</div>" ++
  "<div class=\"cards\">" ++
  stat_card("Requests", total_str, "") ++
  stat_card("Errors", errs_str, "error") ++
  stat_card("Avg Response", avg_str, "avg") ++
  stat_card("WebSockets", ws_str, "ws") ++
  "</div>" ++
  "<div class=\"section\"><h2>Recent Requests</h2>" ++ req_html ++ "</div>" ++
  "<div class=\"section\"><h2>Error Log</h2>" ++ err_html ++ "</div>" ++
  "<div class=\"section\"><h2>Vault Tables</h2>" ++ vault_html ++ "</div>" ++
  "<div class=\"section\"><h2>Routes</h2>" ++ routes_html ++ "</div>" ++
  "</body></html>"
end

doc """
Plug handler for the `/_bastion` dashboard route.

Intercepts `GET /_bastion`, renders the dashboard using `stats`.  All other
paths fall through unchanged.

    conn |> BastionDev.dashboard_handler(stats)
"""
fn dashboard_handler(conn, stats) do
  if HttpServer.path(conn) == "/_bastion" do
    conn
    |> HttpServer.put_resp_header("content-type", "text/html; charset=utf-8")
    |> HttpServer.send_resp(200, dashboard_html(stats))
  else conn end
end

end
