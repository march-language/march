-- Depot.Test: test-scoped transaction isolation for Depot.
--
-- Wraps Depot.Repo operations in a sandbox that snapshots Vault tables
-- before each test and restores them after, providing clean rollback
-- without a real database.
--
-- Usage:
--
--   Depot.Test.start_sandbox()
--
--   -- Before each test:
--   Depot.Test.checkout(["users", "posts"])
--
--   -- ... run test, insert/update/delete via Depot.Repo ...
--
--   -- After each test:
--   Depot.Test.checkin()
--
--   Depot.Test.stop_sandbox()
--
-- Or use the convenience wrapper:
--
--   Depot.Test.sandboxed(["users"], fn () ->
--     Depot.Repo.insert(schema, gate)
--     -- assertions ...
--   )

mod Depot.Test do

-- ---------------------------------------------------------------------------
-- Private helpers
-- ---------------------------------------------------------------------------

-- Get or create the sandbox state Vault table.
pfn sandbox_vault() do
  match Vault.whereis("__depot_test_sandbox__") do
    Some(t) -> t
    None ->
      let t = Vault.new("__depot_test_sandbox__")
      Vault.set(t, "active", false)
      Vault.set(t, "snapshots", Nil)
      t
  end
end

pfn is_active() do
  let t = sandbox_vault()
  match Vault.get(t, "active") do
    Some(true) -> true
    _ -> false
  end
end

-- Snapshot a single Vault table: returns list of (key, value) pairs.
pfn snapshot_one(tbl, k) do
  match Vault.get(tbl, k) do
    Some(v) -> (k, v)
    None -> (k, None)
  end
end

pfn snapshot_table(table_name) do
  match Vault.whereis(table_name) do
    None -> Nil
    Some(tbl) ->
      let ks = Vault.keys(tbl)
      List.map(ks, fn k -> snapshot_one(tbl, k))
  end
end

-- Drop all keys from a Vault table.
pfn drop_keys(tbl, ks) do
  match ks do
    Nil -> ()
    Cons(k, rest) ->
      Vault.drop(tbl, k)
      drop_keys(tbl, rest)
  end
end

-- Restore a Vault table from a snapshot.
pfn restore_entries(tbl, snapshot) do
  match snapshot do
    Nil -> ()
    Cons((k, v), rest) ->
      Vault.set(tbl, k, v)
      restore_entries(tbl, rest)
  end
end

pfn restore_table(table_name, snapshot) do
  match Vault.whereis(table_name) do
    None -> do
      match snapshot do
        Nil -> ()
        _ ->
          let tbl = Vault.new(table_name)
          restore_entries(tbl, snapshot)
      end
    end
    Some(tbl) -> do
      let ks = Vault.keys(tbl)
      drop_keys(tbl, ks)
      restore_entries(tbl, snapshot)
    end
  end
end

-- Apply rollback to each (table_name, snapshot) pair.
pfn rollback_all(snaps) do
  match snaps do
    Nil -> ()
    Cons((tbl_name, snap), rest) ->
      restore_table(tbl_name, snap)
      rollback_all(rest)
  end
end

-- ---------------------------------------------------------------------------
-- Public API
-- ---------------------------------------------------------------------------

doc """
Start the test sandbox. Call once at the beginning of a test suite.
Enables checkout/checkin lifecycle for test isolation.

    Depot.Test.start_sandbox()
"""
fn start_sandbox() do
  let t = sandbox_vault()
  Vault.set(t, "active", true)
  Vault.set(t, "snapshots", Nil)
  ()
end

doc """
Checkpoint (snapshot) the current state of the given schema tables.
Call before each test to save state for later rollback.

tables is a list of table name strings matching your schemas.

    Depot.Test.checkout(["users", "posts"])
"""
fn checkout(tables) do
  let t = sandbox_vault()
  if is_active() do
    let snaps = List.map(tables, fn tbl_name -> (tbl_name, snapshot_table(tbl_name)))
    Vault.set(t, "snapshots", snaps)
    ()
  else
    panic("Depot.Test.checkout called but sandbox is not active. Call start_sandbox() first.")
  end
end

doc """
Roll back all sandboxed tables to their checkout snapshot.
Call after each test to undo any writes.

    Depot.Test.checkin()
"""
fn checkin() do
  let t = sandbox_vault()
  if is_active() do
    let snaps = match Vault.get(t, "snapshots") do
      Some(s) -> s
      None -> Nil
    end
    rollback_all(snaps)
    Vault.set(t, "snapshots", Nil)
    ()
  else
    panic("Depot.Test.checkin called but sandbox is not active. Call start_sandbox() first.")
  end
end

doc """
Stop the sandbox. Call at the end of a test suite.

    Depot.Test.stop_sandbox()
"""
fn stop_sandbox() do
  let t = sandbox_vault()
  Vault.set(t, "active", false)
  Vault.set(t, "snapshots", Nil)
  ()
end

doc """
Run a function inside a sandbox transaction.
Automatically checkpoints the given tables, runs the function,
then rolls back regardless of success or failure.

    Depot.Test.sandboxed(["users"], fn () ->
      Depot.Repo.insert(schema, gate)
      -- ... test assertions ...
    )
"""
fn sandboxed(tables, func) do
  checkout(tables)
  let result = func()
  checkin()
  result
end

doc """
Check if the sandbox is currently active.

    Depot.Test.active()
"""
fn active() do
  is_active()
end

end
