-- BastionTestSandbox: isolated request sandboxes for controller tests.
--
-- Each sandbox gets a unique namespace so concurrent tests never share
-- Vault data or PubSub subscriptions.  The sandbox lifecycle is:
--
--   let env = BastionTestSandbox.checkout("my_app")
--   let conn = BastionTestSandbox.build_conn(env, Get, "/users")
--   -- … run your pipeline …
--   BastionTestSandbox.release(env)
--
-- Vault isolation is achieved by prefixing every key with the sandbox nonce.
-- PubSub isolation is achieved by using a unique pubsub_name per sandbox.
--
-- The SandboxEnv record:
--   SandboxEnv(app_name, nonce, vault_table, pubsub_name)
--
--   app_name     — the name passed to checkout
--   nonce        — unique random ID for this sandbox instance
--   vault_table  — a Vault table scoped to the nonce
--   pubsub_name  — unique PubSub instance name for this sandbox

mod BastionTestSandbox do

-- ── Types ───────────────────────────────────────────────────────────────────

type SandboxEnv = SandboxEnv(
  String,  -- app_name
  String,  -- nonce (unique ID)
  String,  -- vault_table_name
  String   -- pubsub_name
)

-- ── Accessors ───────────────────────────────────────────────────────────────

fn env_app_name(env) do
  match env do SandboxEnv(a, _, _, _) -> a end
end

fn env_nonce(env) do
  match env do SandboxEnv(_, n, _, _) -> n end
end

fn env_vault_table_name(env) do
  match env do SandboxEnv(_, _, v, _) -> v end
end

fn env_pubsub_name(env) do
  match env do SandboxEnv(_, _, _, p) -> p end
end

-- ── Helpers ─────────────────────────────────────────────────────────────────

pfn gen_nonce() do
  -- Use random_bytes if available; fall back to a counter via Vault.
  -- We use a dedicated Vault table to maintain a monotonic counter.
  let counter_table = match Vault.whereis("__sandbox_counter__") do
    Some(t) -> t
    None    -> Vault.new("__sandbox_counter__")
  end
  let n = Vault.get_or(counter_table, "n", 0)
  Vault.set(counter_table, "n", n + 1)
  "sbx_" ++ int_to_string(n)
end

-- ── Lifecycle ───────────────────────────────────────────────────────────────

doc """
Create a new isolated sandbox environment for `app_name`.
Allocates a unique Vault namespace and PubSub instance.
Returns a `SandboxEnv`.
"""
fn checkout(app_name) do
  let nonce       = gen_nonce()
  let table_name  = app_name ++ "_sandbox_" ++ nonce
  let ps_name     = app_name ++ "_ps_" ++ nonce
  let _t          = Vault.new(table_name)
  SandboxEnv(app_name, nonce, table_name, ps_name)
end

doc """
Release (clean up) a sandbox environment.
Drops all keys from the sandbox Vault table.
Returns :ok.
"""
fn release(env) do
  let table_name = env_vault_table_name(env)
  match Vault.whereis(table_name) do
  None    -> :ok
  Some(t) -> do
    let keys = Vault.keys(t)
    drop_all(t, keys)
    :ok
  end
  end
end

pfn drop_all(t, keys) do
  match keys do
  Nil -> ()
  Cons(k, rest) -> do
    Vault.drop(t, k)
    drop_all(t, rest)
  end
  end
end

-- ── Vault namespace helpers ──────────────────────────────────────────────────

doc """
Build a namespaced key for use in the sandbox's Vault table.

    BastionTestSandbox.sandbox_vault_key(env, "sessions", "user:42")
    -- returns "sessions:user:42"  (scoped to the sandbox table)
"""
fn sandbox_vault_key(_env, table, key) do
  table ++ ":" ++ key
end

doc """
Get a value from the sandbox's Vault table using a namespaced key.
Returns None if not set.
"""
fn vault_get(env, table, key) do
  let table_name = env_vault_table_name(env)
  match Vault.whereis(table_name) do
  None    -> None
  Some(t) -> do
    let full_key = sandbox_vault_key(env, table, key)
    Vault.get(t, full_key)
  end
  end
end

doc "Set a value in the sandbox's Vault table using a namespaced key."
fn vault_set(env, table, key, value) do
  let table_name = env_vault_table_name(env)
  let t = match Vault.whereis(table_name) do
    Some(existing) -> existing
    None           -> Vault.new(table_name)
    end
  let full_key = sandbox_vault_key(env, table, key)
  Vault.set(t, full_key, value)
end

-- ── Conn construction ────────────────────────────────────────────────────────

doc """
Build a test `Conn` for the given `method` and `path`.
The conn includes an assign "_sandbox_nonce" with the sandbox ID so
middleware can detect test mode.
"""
fn build_conn(env, method_, path_) do
  let parts = List.filter(String.split(path_, "/"), fn s -> not(String.byte_size(s) == 0))
  let base  = Conn(0, method_, path_, parts, "", Nil, "", 0, Nil, "", false, Nil, NoUpgrade)
  HttpServer.assign(base, "_sandbox_nonce", env_nonce(env))
end

doc """
Build a test Conn with explicit query string and request headers.
"""
fn build_conn_full(env, method_, path_, qs, req_hdrs, req_body) do
  let parts = List.filter(String.split(path_, "/"), fn s -> not(String.byte_size(s) == 0))
  let base  = Conn(0, method_, path_, parts, qs, req_hdrs, req_body, 0, Nil, "", false, Nil, NoUpgrade)
  HttpServer.assign(base, "_sandbox_nonce", env_nonce(env))
end

doc "Return the unique nonce (ID) for this sandbox environment."
fn get_nonce(env) do env_nonce(env) end

-- ── Registry ─────────────────────────────────────────────────────────────────

pfn get_registry() do
  match Vault.whereis("sandbox_registry") do
  Some(t) -> t
  None    -> Vault.new("sandbox_registry")
  end
end

doc """
Check whether the sandbox environment is still active (not yet released).
Returns true if the sandbox ID is present in the global registry.
"""
fn is_active(env) do
  let reg = get_registry()
  Vault.has(reg, env_nonce(env))
end

doc """
Return the count of currently active (unreleased) sandboxes.
"""
fn active_count() do
  let reg = get_registry()
  Vault.size(reg)
end

-- Override checkout/release to also maintain the registry.
-- We provide register/unregister as private helpers used by the
-- public checkout and release below which wrap the core lifecycle.

pfn register(env) do
  let reg = get_registry()
  Vault.set(reg, env_nonce(env), "active")
end

pfn unregister(env) do
  let reg = get_registry()
  Vault.drop(reg, env_nonce(env))
end

doc """
Create a new isolated sandbox environment for `app_name`, registering it
in the global sandbox registry so `is_active` and `active_count` work.
"""
fn checkout_tracked(app_name) do
  let env = checkout(app_name)
  register(env)
  env
end

doc """
Release a tracked sandbox: drops the registry entry and clears Vault data.
"""
fn release_tracked(env) do
  unregister(env)
  release(env)
end

end
