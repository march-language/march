(executable
 (name main)
 (public_name march)
 (package march)
 (libraries march_lexer march_parser march_ast march_desugar march_typecheck march_codegen march_effects march_errors march_eval march_coverage march_tir march_repl march_debug march_jit march_cas march_format march_resolver march_dump unix))

(rule
 (alias warm-cache)
 (deps main.exe (source_tree ../stdlib))
 (action (no-infer (system "./main.exe warm-cache"))))

(rule
 (alias all)
 (deps (alias warm-cache))
 (action (progn)))
